{"segment_id": "shijing__guofeng-tangfeng-011__001__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-tangfeng-011", "source_id": "guofeng-tangfeng-011__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 1, "canonical_ref": "詩經·國風·唐風·011.1", "text_original": "葛生蒙楚，蘞蔓于野。予美亡此，誰與獨處。", "text_normalized": "葛生蒙楚，蘞蔓于野。予美亡此，誰與獨處。", "notes": "葛生 Chinese stanza 1."}
{"segment_id": "shijing__guofeng-tangfeng-011__002__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-tangfeng-011", "source_id": "guofeng-tangfeng-011__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 2, "canonical_ref": "詩經·國風·唐風·011.2", "text_original": "葛生蒙棘，蘞蔓于域。予美亡此，誰與獨息。", "text_normalized": "葛生蒙棘，蘞蔓于域。予美亡此，誰與獨息。", "notes": "葛生 Chinese stanza 2."}
{"segment_id": "shijing__guofeng-tangfeng-011__003__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-tangfeng-011", "source_id": "guofeng-tangfeng-011__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 3, "canonical_ref": "詩經·國風·唐風·011.3", "text_original": "角枕粲兮，錦衾爛兮。予美亡此，誰與獨旦。", "text_normalized": "角枕粲兮，錦衾爛兮。予美亡此，誰與獨旦。", "notes": "葛生 Chinese stanza 3."}
{"segment_id": "shijing__guofeng-tangfeng-011__004__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-tangfeng-011", "source_id": "guofeng-tangfeng-011__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 4, "canonical_ref": "詩經·國風·唐風·011.4", "text_original": "夏之日，冬之夜。百歲之後，歸于其居。", "text_normalized": "夏之日，冬之夜。百歲之後，歸于其居。", "notes": "葛生 Chinese stanza 4."}
{"segment_id": "shijing__guofeng-tangfeng-011__005__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-tangfeng-011", "source_id": "guofeng-tangfeng-011__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 5, "canonical_ref": "詩經·國風·唐風·011.5", "text_original": "冬之夜，夏之日。百歲之後，歸于其室。", "text_normalized": "冬之夜，夏之日。百歲之後，歸于其室。", "notes": "葛生 Chinese stanza 5."}
