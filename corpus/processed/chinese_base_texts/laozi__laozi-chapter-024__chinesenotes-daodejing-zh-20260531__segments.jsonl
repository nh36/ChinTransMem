{"segment_id": "laozi-chapter-024__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-024", "source_id": "laozi-chapter-024__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 24.1", "sort_key": "024.001", "text_original": "企者不立，", "text_normalized": "企者不立，", "notes": ""}
{"segment_id": "laozi-chapter-024__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-024", "source_id": "laozi-chapter-024__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 24.2", "sort_key": "024.002", "text_original": "跨者不行，自見者不明，自是者不彰，自伐者無功，自矜者不長。", "text_normalized": "跨者不行，自見者不明，自是者不彰，自伐者無功，自矜者不長。", "notes": ""}
{"segment_id": "laozi-chapter-024__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-024", "source_id": "laozi-chapter-024__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 24.3", "sort_key": "024.003", "text_original": "其在道也，曰餘食贅行。", "text_normalized": "其在道也，曰餘食贅行。", "notes": ""}
{"segment_id": "laozi-chapter-024__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-024", "source_id": "laozi-chapter-024__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 24.4", "sort_key": "024.004", "text_original": "物或惡之，故有道者不處。", "text_normalized": "物或惡之，故有道者不處。", "notes": ""}
