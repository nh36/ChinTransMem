{"segment_id": "laozi-chapter-024__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-024", "source_id": "laozi-chapter-024__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 24.1", "sort_key": "024.001", "text_original": "企者不立，", "text_normalized": "企者不立，", "notes": ""}
{"segment_id": "laozi-chapter-024__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-024", "source_id": "laozi-chapter-024__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 24.2", "sort_key": "024.002", "text_original": "跨者不行，", "text_normalized": "跨者不行，", "notes": ""}
{"segment_id": "laozi-chapter-024__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-024", "source_id": "laozi-chapter-024__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 24.3", "sort_key": "024.003", "text_original": "自見者不明，", "text_normalized": "自見者不明，", "notes": ""}
{"segment_id": "laozi-chapter-024__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-024", "source_id": "laozi-chapter-024__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 24.4", "sort_key": "024.004", "text_original": "自是者不彰，", "text_normalized": "自是者不彰，", "notes": ""}
{"segment_id": "laozi-chapter-024__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-024", "source_id": "laozi-chapter-024__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 24.5", "sort_key": "024.005", "text_original": "自伐者無功，", "text_normalized": "自伐者無功，", "notes": ""}
{"segment_id": "laozi-chapter-024__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-024", "source_id": "laozi-chapter-024__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 24.6", "sort_key": "024.006", "text_original": "自矜者不長。", "text_normalized": "自矜者不長。", "notes": ""}
{"segment_id": "laozi-chapter-024__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-024", "source_id": "laozi-chapter-024__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 24.7", "sort_key": "024.007", "text_original": "其在道也，", "text_normalized": "其在道也，", "notes": ""}
{"segment_id": "laozi-chapter-024__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-024", "source_id": "laozi-chapter-024__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 24.8", "sort_key": "024.008", "text_original": "曰餘食贅行。", "text_normalized": "曰餘食贅行。", "notes": ""}
{"segment_id": "laozi-chapter-024__chinesenotes-daodejing-zh-20260531__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-024", "source_id": "laozi-chapter-024__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 24.9", "sort_key": "024.009", "text_original": "物或惡之，", "text_normalized": "物或惡之，", "notes": ""}
{"segment_id": "laozi-chapter-024__chinesenotes-daodejing-zh-20260531__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-024", "source_id": "laozi-chapter-024__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 24.10", "sort_key": "024.010", "text_original": "故有道者不處。", "text_normalized": "故有道者不處。", "notes": ""}
