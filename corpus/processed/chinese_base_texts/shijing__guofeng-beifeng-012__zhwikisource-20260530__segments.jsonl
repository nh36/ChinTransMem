{"segment_id": "shijing__guofeng-beifeng-012__001__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-beifeng-012", "source_id": "guofeng-beifeng-012__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 1, "canonical_ref": "詩經·國風·邶風·012.1", "text_original": "旄丘之葛兮，何誕之節兮，叔兮伯兮，何多日也。", "text_normalized": "旄丘之葛兮，何誕之節兮，叔兮伯兮，何多日也。", "notes": "旄丘 Chinese stanza 1."}
{"segment_id": "shijing__guofeng-beifeng-012__002__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-beifeng-012", "source_id": "guofeng-beifeng-012__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 2, "canonical_ref": "詩經·國風·邶風·012.2", "text_original": "何其處也，必有與也，何其久也，必有以也。", "text_normalized": "何其處也，必有與也，何其久也，必有以也。", "notes": "旄丘 Chinese stanza 2."}
{"segment_id": "shijing__guofeng-beifeng-012__003__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-beifeng-012", "source_id": "guofeng-beifeng-012__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 3, "canonical_ref": "詩經·國風·邶風·012.3", "text_original": "狐裘蒙戎，匪車不東，叔兮伯兮，靡所與同。", "text_normalized": "狐裘蒙戎，匪車不東，叔兮伯兮，靡所與同。", "notes": "旄丘 Chinese stanza 3."}
{"segment_id": "shijing__guofeng-beifeng-012__004__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-beifeng-012", "source_id": "guofeng-beifeng-012__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 4, "canonical_ref": "詩經·國風·邶風·012.4", "text_original": "瑣兮尾兮，流離之子，叔兮伯兮，褎如充耳。", "text_normalized": "瑣兮尾兮，流離之子，叔兮伯兮，褎如充耳。", "notes": "旄丘 Chinese stanza 4."}
