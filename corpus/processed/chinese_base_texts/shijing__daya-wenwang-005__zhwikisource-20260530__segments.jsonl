{"segment_id": "shijing__daya-wenwang-005__001__zhwikisource-20260530", "work_id": "shijing", "section_id": "daya-wenwang-005", "source_id": "daya-wenwang-005__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 1, "canonical_ref": "詩經·大雅·文王之什·005.1", "text_original": "瞻彼旱麓，榛楛濟濟。豈弟君子，干祿豈弟。", "text_normalized": "瞻彼旱麓，榛楛濟濟。豈弟君子，干祿豈弟。", "notes": "旱麓 Chinese stanza 1."}
{"segment_id": "shijing__daya-wenwang-005__002__zhwikisource-20260530", "work_id": "shijing", "section_id": "daya-wenwang-005", "source_id": "daya-wenwang-005__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 2, "canonical_ref": "詩經·大雅·文王之什·005.2", "text_original": "瑟彼玉瓚，黃流在中。豈弟君子，福祿攸降。", "text_normalized": "瑟彼玉瓚，黃流在中。豈弟君子，福祿攸降。", "notes": "旱麓 Chinese stanza 2."}
{"segment_id": "shijing__daya-wenwang-005__003__zhwikisource-20260530", "work_id": "shijing", "section_id": "daya-wenwang-005", "source_id": "daya-wenwang-005__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 3, "canonical_ref": "詩經·大雅·文王之什·005.3", "text_original": "鳶飛戾天，魚躍于淵。豈弟君子，遐不作人。", "text_normalized": "鳶飛戾天，魚躍于淵。豈弟君子，遐不作人。", "notes": "旱麓 Chinese stanza 3."}
{"segment_id": "shijing__daya-wenwang-005__004__zhwikisource-20260530", "work_id": "shijing", "section_id": "daya-wenwang-005", "source_id": "daya-wenwang-005__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 4, "canonical_ref": "詩經·大雅·文王之什·005.4", "text_original": "清酒既載，騂牡既備。以享以祀，以介景福。", "text_normalized": "清酒既載，騂牡既備。以享以祀，以介景福。", "notes": "旱麓 Chinese stanza 4."}
{"segment_id": "shijing__daya-wenwang-005__005__zhwikisource-20260530", "work_id": "shijing", "section_id": "daya-wenwang-005", "source_id": "daya-wenwang-005__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 5, "canonical_ref": "詩經·大雅·文王之什·005.5", "text_original": "瑟彼柞棫，民所燎矣。豈弟君子，神所勞矣。", "text_normalized": "瑟彼柞棫，民所燎矣。豈弟君子，神所勞矣。", "notes": "旱麓 Chinese stanza 5."}
{"segment_id": "shijing__daya-wenwang-005__006__zhwikisource-20260530", "work_id": "shijing", "section_id": "daya-wenwang-005", "source_id": "daya-wenwang-005__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 6, "canonical_ref": "詩經·大雅·文王之什·005.6", "text_original": "莫莫葛藟，施于條枚。豈弟君子，求福不回。", "text_normalized": "莫莫葛藟，施于條枚。豈弟君子，求福不回。", "notes": "旱麓 Chinese stanza 6."}
