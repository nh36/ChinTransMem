{"segment_id": "laozi-chapter-061__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-061", "source_id": "laozi-chapter-061__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 61.1", "sort_key": "061.001", "text_original": "大國者下流，", "text_normalized": "大國者下流，", "notes": ""}
{"segment_id": "laozi-chapter-061__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-061", "source_id": "laozi-chapter-061__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 61.2", "sort_key": "061.002", "text_original": "天下之交。", "text_normalized": "天下之交。", "notes": ""}
{"segment_id": "laozi-chapter-061__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-061", "source_id": "laozi-chapter-061__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 61.3", "sort_key": "061.003", "text_original": "天下之牝，", "text_normalized": "天下之牝，", "notes": ""}
{"segment_id": "laozi-chapter-061__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-061", "source_id": "laozi-chapter-061__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 61.4", "sort_key": "061.004", "text_original": "牝常以靜勝牡，", "text_normalized": "牝常以靜勝牡，", "notes": ""}
{"segment_id": "laozi-chapter-061__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-061", "source_id": "laozi-chapter-061__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 61.5", "sort_key": "061.005", "text_original": "以靜為下。", "text_normalized": "以靜為下。", "notes": ""}
{"segment_id": "laozi-chapter-061__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-061", "source_id": "laozi-chapter-061__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 61.6", "sort_key": "061.006", "text_original": "則取小國；", "text_normalized": "則取小國；", "notes": ""}
{"segment_id": "laozi-chapter-061__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-061", "source_id": "laozi-chapter-061__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 61.7", "sort_key": "061.007", "text_original": "小國以下大國，", "text_normalized": "小國以下大國，", "notes": ""}
{"segment_id": "laozi-chapter-061__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-061", "source_id": "laozi-chapter-061__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 61.8", "sort_key": "061.008", "text_original": "則取大國。", "text_normalized": "則取大國。", "notes": ""}
{"segment_id": "laozi-chapter-061__chinesenotes-daodejing-zh-20260531__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-061", "source_id": "laozi-chapter-061__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 61.9", "sort_key": "061.009", "text_original": "故或下以取，", "text_normalized": "故或下以取，", "notes": ""}
{"segment_id": "laozi-chapter-061__chinesenotes-daodejing-zh-20260531__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-061", "source_id": "laozi-chapter-061__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 61.10", "sort_key": "061.010", "text_original": "或下而取。", "text_normalized": "或下而取。", "notes": ""}
{"segment_id": "laozi-chapter-061__chinesenotes-daodejing-zh-20260531__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-061", "source_id": "laozi-chapter-061__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 61.11", "sort_key": "061.011", "text_original": "大國不過欲兼畜人，", "text_normalized": "大國不過欲兼畜人，", "notes": ""}
{"segment_id": "laozi-chapter-061__chinesenotes-daodejing-zh-20260531__seg-012", "work_id": "laozi", "section_id": "laozi-chapter-061", "source_id": "laozi-chapter-061__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 12, "canonical_ref": "老子 61.12", "sort_key": "061.012", "text_original": "小國不過欲入事人。", "text_normalized": "小國不過欲入事人。", "notes": ""}
{"segment_id": "laozi-chapter-061__chinesenotes-daodejing-zh-20260531__seg-013", "work_id": "laozi", "section_id": "laozi-chapter-061", "source_id": "laozi-chapter-061__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 13, "canonical_ref": "老子 61.13", "sort_key": "061.013", "text_original": "夫兩者各得其所欲，", "text_normalized": "夫兩者各得其所欲，", "notes": ""}
{"segment_id": "laozi-chapter-061__chinesenotes-daodejing-zh-20260531__seg-014", "work_id": "laozi", "section_id": "laozi-chapter-061", "source_id": "laozi-chapter-061__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 14, "canonical_ref": "老子 61.14", "sort_key": "061.014", "text_original": "大者宜為下。", "text_normalized": "大者宜為下。", "notes": ""}
