{"segment_id": "laozi-chapter-080__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-080", "source_id": "laozi-chapter-080__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 80.2", "sort_key": "080.002", "text_original": "使有什伯之器而不用，", "text_normalized": "使有什伯之器而不用，", "notes": ""}
{"segment_id": "laozi-chapter-080__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-080", "source_id": "laozi-chapter-080__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 80.3", "sort_key": "080.003", "text_original": "使民重死而不遠徙。", "text_normalized": "使民重死而不遠徙。", "notes": ""}
{"segment_id": "laozi-chapter-080__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-080", "source_id": "laozi-chapter-080__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 80.4", "sort_key": "080.004", "text_original": "雖有舟輿，", "text_normalized": "雖有舟輿，", "notes": ""}
{"segment_id": "laozi-chapter-080__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-080", "source_id": "laozi-chapter-080__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 80.5", "sort_key": "080.005", "text_original": "無所乘之；", "text_normalized": "無所乘之；", "notes": ""}
{"segment_id": "laozi-chapter-080__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-080", "source_id": "laozi-chapter-080__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 80.6", "sort_key": "080.006", "text_original": "雖有甲兵，", "text_normalized": "雖有甲兵，", "notes": ""}
{"segment_id": "laozi-chapter-080__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-080", "source_id": "laozi-chapter-080__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 80.7", "sort_key": "080.007", "text_original": "無所陳之。", "text_normalized": "無所陳之。", "notes": ""}
{"segment_id": "laozi-chapter-080__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-080", "source_id": "laozi-chapter-080__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 80.8", "sort_key": "080.008", "text_original": "使人復結繩而用之，", "text_normalized": "使人復結繩而用之，", "notes": ""}
{"segment_id": "laozi-chapter-080__chinesenotes-daodejing-zh-20260531__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-080", "source_id": "laozi-chapter-080__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 80.9", "sort_key": "080.009", "text_original": "甘其食，", "text_normalized": "甘其食，", "notes": ""}
{"segment_id": "laozi-chapter-080__chinesenotes-daodejing-zh-20260531__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-080", "source_id": "laozi-chapter-080__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 80.10", "sort_key": "080.010", "text_original": "美其服，", "text_normalized": "美其服，", "notes": ""}
{"segment_id": "laozi-chapter-080__chinesenotes-daodejing-zh-20260531__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-080", "source_id": "laozi-chapter-080__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 80.11", "sort_key": "080.011", "text_original": "安其居，", "text_normalized": "安其居，", "notes": ""}
{"segment_id": "laozi-chapter-080__chinesenotes-daodejing-zh-20260531__seg-012", "work_id": "laozi", "section_id": "laozi-chapter-080", "source_id": "laozi-chapter-080__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 12, "canonical_ref": "老子 80.12", "sort_key": "080.012", "text_original": "樂其俗。", "text_normalized": "樂其俗。", "notes": ""}
{"segment_id": "laozi-chapter-080__chinesenotes-daodejing-zh-20260531__seg-013", "work_id": "laozi", "section_id": "laozi-chapter-080", "source_id": "laozi-chapter-080__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 13, "canonical_ref": "老子 80.13", "sort_key": "080.013", "text_original": "鄰國相望，", "text_normalized": "鄰國相望，", "notes": ""}
{"segment_id": "laozi-chapter-080__chinesenotes-daodejing-zh-20260531__seg-014", "work_id": "laozi", "section_id": "laozi-chapter-080", "source_id": "laozi-chapter-080__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 14, "canonical_ref": "老子 80.14", "sort_key": "080.014", "text_original": "雞犬之聲相聞，", "text_normalized": "雞犬之聲相聞，", "notes": ""}
{"segment_id": "laozi-chapter-080__chinesenotes-daodejing-zh-20260531__seg-015", "work_id": "laozi", "section_id": "laozi-chapter-080", "source_id": "laozi-chapter-080__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 15, "canonical_ref": "老子 80.15", "sort_key": "080.015", "text_original": "民至老死，", "text_normalized": "民至老死，", "notes": ""}
