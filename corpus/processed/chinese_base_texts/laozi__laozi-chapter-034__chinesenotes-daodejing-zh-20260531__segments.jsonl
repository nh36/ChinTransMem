{"segment_id": "laozi-chapter-034__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-034", "source_id": "laozi-chapter-034__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 34.1", "sort_key": "034.001", "text_original": "大道氾兮，", "text_normalized": "大道氾兮，", "notes": ""}
{"segment_id": "laozi-chapter-034__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-034", "source_id": "laozi-chapter-034__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 34.2", "sort_key": "034.002", "text_original": "其可左右。", "text_normalized": "其可左右。", "notes": ""}
{"segment_id": "laozi-chapter-034__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-034", "source_id": "laozi-chapter-034__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 34.3", "sort_key": "034.003", "text_original": "萬物恃之而生而不辭，", "text_normalized": "萬物恃之而生而不辭，", "notes": ""}
{"segment_id": "laozi-chapter-034__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-034", "source_id": "laozi-chapter-034__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 34.4", "sort_key": "034.004", "text_original": "功成不名有。", "text_normalized": "功成不名有。", "notes": ""}
{"segment_id": "laozi-chapter-034__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-034", "source_id": "laozi-chapter-034__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 34.5", "sort_key": "034.005", "text_original": "衣養萬物而不為主，", "text_normalized": "衣養萬物而不為主，", "notes": ""}
{"segment_id": "laozi-chapter-034__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-034", "source_id": "laozi-chapter-034__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 34.6", "sort_key": "034.006", "text_original": "常無欲，", "text_normalized": "常無欲，", "notes": ""}
{"segment_id": "laozi-chapter-034__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-034", "source_id": "laozi-chapter-034__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 34.7", "sort_key": "034.007", "text_original": "可名於小；", "text_normalized": "可名於小；", "notes": ""}
{"segment_id": "laozi-chapter-034__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-034", "source_id": "laozi-chapter-034__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 34.8", "sort_key": "034.008", "text_original": "萬物歸焉而不為主，", "text_normalized": "萬物歸焉而不為主，", "notes": ""}
{"segment_id": "laozi-chapter-034__chinesenotes-daodejing-zh-20260531__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-034", "source_id": "laozi-chapter-034__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 34.9", "sort_key": "034.009", "text_original": "可名為大。", "text_normalized": "可名為大。", "notes": ""}
{"segment_id": "laozi-chapter-034__chinesenotes-daodejing-zh-20260531__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-034", "source_id": "laozi-chapter-034__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 34.10", "sort_key": "034.010", "text_original": "以其終不自為大，", "text_normalized": "以其終不自為大，", "notes": ""}
{"segment_id": "laozi-chapter-034__chinesenotes-daodejing-zh-20260531__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-034", "source_id": "laozi-chapter-034__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 34.11", "sort_key": "034.011", "text_original": "故能成其大。", "text_normalized": "故能成其大。", "notes": ""}
