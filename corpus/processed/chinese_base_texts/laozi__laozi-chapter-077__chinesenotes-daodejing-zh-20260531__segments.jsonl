{"segment_id": "laozi-chapter-077__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-077", "source_id": "laozi-chapter-077__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 77.1", "sort_key": "077.001", "text_original": "天之道，", "text_normalized": "天之道，", "notes": ""}
{"segment_id": "laozi-chapter-077__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-077", "source_id": "laozi-chapter-077__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 77.2", "sort_key": "077.002", "text_original": "其猶張弓與？", "text_normalized": "其猶張弓與？", "notes": ""}
{"segment_id": "laozi-chapter-077__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-077", "source_id": "laozi-chapter-077__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 77.3", "sort_key": "077.003", "text_original": "高者抑之，", "text_normalized": "高者抑之，", "notes": ""}
{"segment_id": "laozi-chapter-077__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-077", "source_id": "laozi-chapter-077__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 77.4", "sort_key": "077.004", "text_original": "下者舉之；", "text_normalized": "下者舉之；", "notes": ""}
{"segment_id": "laozi-chapter-077__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-077", "source_id": "laozi-chapter-077__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 77.5", "sort_key": "077.005", "text_original": "有餘者損之，", "text_normalized": "有餘者損之，", "notes": ""}
{"segment_id": "laozi-chapter-077__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-077", "source_id": "laozi-chapter-077__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 77.6", "sort_key": "077.006", "text_original": "不足者補之。", "text_normalized": "不足者補之。", "notes": ""}
{"segment_id": "laozi-chapter-077__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-077", "source_id": "laozi-chapter-077__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 77.7", "sort_key": "077.007", "text_original": "天之道，", "text_normalized": "天之道，", "notes": ""}
{"segment_id": "laozi-chapter-077__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-077", "source_id": "laozi-chapter-077__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 77.8", "sort_key": "077.008", "text_original": "損有餘而補不足。", "text_normalized": "損有餘而補不足。", "notes": ""}
{"segment_id": "laozi-chapter-077__chinesenotes-daodejing-zh-20260531__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-077", "source_id": "laozi-chapter-077__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 77.9", "sort_key": "077.009", "text_original": "人之道則不然，", "text_normalized": "人之道則不然，", "notes": ""}
{"segment_id": "laozi-chapter-077__chinesenotes-daodejing-zh-20260531__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-077", "source_id": "laozi-chapter-077__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 77.10", "sort_key": "077.010", "text_original": "損不足以奉有餘。", "text_normalized": "損不足以奉有餘。", "notes": ""}
{"segment_id": "laozi-chapter-077__chinesenotes-daodejing-zh-20260531__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-077", "source_id": "laozi-chapter-077__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 77.11", "sort_key": "077.011", "text_original": "孰能有餘以奉天下？", "text_normalized": "孰能有餘以奉天下？", "notes": ""}
{"segment_id": "laozi-chapter-077__chinesenotes-daodejing-zh-20260531__seg-012", "work_id": "laozi", "section_id": "laozi-chapter-077", "source_id": "laozi-chapter-077__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 12, "canonical_ref": "老子 77.12", "sort_key": "077.012", "text_original": "唯有道者。", "text_normalized": "唯有道者。", "notes": ""}
{"segment_id": "laozi-chapter-077__chinesenotes-daodejing-zh-20260531__seg-013", "work_id": "laozi", "section_id": "laozi-chapter-077", "source_id": "laozi-chapter-077__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 13, "canonical_ref": "老子 77.13", "sort_key": "077.013", "text_original": "是以聖人為而不恃，", "text_normalized": "是以聖人為而不恃，", "notes": ""}
{"segment_id": "laozi-chapter-077__chinesenotes-daodejing-zh-20260531__seg-014", "work_id": "laozi", "section_id": "laozi-chapter-077", "source_id": "laozi-chapter-077__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 14, "canonical_ref": "老子 77.14", "sort_key": "077.014", "text_original": "功成而不處，", "text_normalized": "功成而不處，", "notes": ""}
{"segment_id": "laozi-chapter-077__chinesenotes-daodejing-zh-20260531__seg-015", "work_id": "laozi", "section_id": "laozi-chapter-077", "source_id": "laozi-chapter-077__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 15, "canonical_ref": "老子 77.15", "sort_key": "077.015", "text_original": "其不欲見賢。", "text_normalized": "其不欲見賢。", "notes": ""}
