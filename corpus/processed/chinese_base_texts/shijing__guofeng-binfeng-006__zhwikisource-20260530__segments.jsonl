{"segment_id": "shijing__guofeng-binfeng-006__001__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-binfeng-006", "source_id": "guofeng-binfeng-006__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 1, "canonical_ref": "詩經·國風·豳風·006.1", "text_original": "九罭之魚，鱒魴。我覯之子，袞衣繡裳。", "text_normalized": "九罭之魚，鱒魴。我覯之子，袞衣繡裳。", "notes": "九罭 Chinese stanza 1."}
{"segment_id": "shijing__guofeng-binfeng-006__002__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-binfeng-006", "source_id": "guofeng-binfeng-006__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 2, "canonical_ref": "詩經·國風·豳風·006.2", "text_original": "鴻飛遵渚，公歸無所。於女信處。", "text_normalized": "鴻飛遵渚，公歸無所。於女信處。", "notes": "九罭 Chinese stanza 2."}
{"segment_id": "shijing__guofeng-binfeng-006__003__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-binfeng-006", "source_id": "guofeng-binfeng-006__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 3, "canonical_ref": "詩經·國風·豳風·006.3", "text_original": "鴻飛遵陸，公歸不復。於女信宿。", "text_normalized": "鴻飛遵陸，公歸不復。於女信宿。", "notes": "九罭 Chinese stanza 3."}
{"segment_id": "shijing__guofeng-binfeng-006__004__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-binfeng-006", "source_id": "guofeng-binfeng-006__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 4, "canonical_ref": "詩經·國風·豳風·006.4", "text_original": "是以有袞衣兮，無以我公歸兮，無使我心悲兮。", "text_normalized": "是以有袞衣兮，無以我公歸兮，無使我心悲兮。", "notes": "九罭 Chinese stanza 4."}
