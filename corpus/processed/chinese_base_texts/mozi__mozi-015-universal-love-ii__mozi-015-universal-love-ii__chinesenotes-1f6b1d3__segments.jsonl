{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0001", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 1, "text_original": "子墨子言曰：", "text_normalized": "子墨子言曰：", "canonical_ref": "15.1", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0002", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 2, "text_original": "仁人之所以爲事者，必興天下之利，除去天下之害，以此爲事者也。", "text_normalized": "仁人之所以爲事者，必興天下之利，除去天下之害，以此爲事者也。", "canonical_ref": "15.2", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0003", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 3, "text_original": "然則天下之利何也？", "text_normalized": "然則天下之利何也？", "canonical_ref": "15.3", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0004", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 4, "text_original": "天下之害何也？", "text_normalized": "天下之害何也？", "canonical_ref": "15.4", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0005", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 5, "text_original": "子墨子言曰：", "text_normalized": "子墨子言曰：", "canonical_ref": "15.5", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0006", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 6, "text_original": "今若國之與國之相攻，家之與家之相篡，人之與人之相賊，君臣不惠忠，父子不慈孝，兄弟不和調，此則天下之害也。", "text_normalized": "今若國之與國之相攻，家之與家之相篡，人之與人之相賊，君臣不惠忠，父子不慈孝，兄弟不和調，此則天下之害也。", "canonical_ref": "15.6", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0007", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 7, "text_original": "然則察此害亦何用生哉？", "text_normalized": "然則察此害亦何用生哉？", "canonical_ref": "15.7", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0008", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 8, "text_original": "以不相愛生邪？", "text_normalized": "以不相愛生邪？", "canonical_ref": "15.8", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0009", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 9, "text_original": "子墨子言：", "text_normalized": "子墨子言：", "canonical_ref": "15.9", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0010", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 10, "text_original": "以不相愛生。", "text_normalized": "以不相愛生。", "canonical_ref": "15.10", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0011", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 11, "text_original": "今諸侯獨知愛其國，不愛人之國，是以不憚舉其國，以攻人之國。", "text_normalized": "今諸侯獨知愛其國，不愛人之國，是以不憚舉其國，以攻人之國。", "canonical_ref": "15.11", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0012", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 12, "text_original": "今家主獨知愛其家，而不愛人之家，是以不憚舉其家，以篡人之家，今人獨知愛其身，不愛人之身，是以不憚舉其身，以賊人之身。", "text_normalized": "今家主獨知愛其家，而不愛人之家，是以不憚舉其家，以篡人之家，今人獨知愛其身，不愛人之身，是以不憚舉其身，以賊人之身。", "canonical_ref": "15.12", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0013", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 13, "text_original": "是故諸侯不相愛，則必野戰。", "text_normalized": "是故諸侯不相愛，則必野戰。", "canonical_ref": "15.13", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0014", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 14, "text_original": "家主不相愛，則必相篡。", "text_normalized": "家主不相愛，則必相篡。", "canonical_ref": "15.14", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0015", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 15, "text_original": "人與人不相愛，則必相賊。", "text_normalized": "人與人不相愛，則必相賊。", "canonical_ref": "15.15", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0016", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 16, "text_original": "君臣不相愛，則不惠忠。", "text_normalized": "君臣不相愛，則不惠忠。", "canonical_ref": "15.16", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0017", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 17, "text_original": "父子不相愛，則不慈孝。", "text_normalized": "父子不相愛，則不慈孝。", "canonical_ref": "15.17", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0018", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 18, "text_original": "兄弟不相愛，則不和調。", "text_normalized": "兄弟不相愛，則不和調。", "canonical_ref": "15.18", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0019", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 19, "text_original": "天下之人皆不相愛，強必執弱，富必侮貧，貴必敖賤，詐必欺愚。", "text_normalized": "天下之人皆不相愛，強必執弱，富必侮貧，貴必敖賤，詐必欺愚。", "canonical_ref": "15.19", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0020", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 20, "text_original": "凡天下禍篡怨恨，其所以起者，以不相愛生也。", "text_normalized": "凡天下禍篡怨恨，其所以起者，以不相愛生也。", "canonical_ref": "15.20", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0021", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 21, "text_original": "是以仁者非之。", "text_normalized": "是以仁者非之。", "canonical_ref": "15.21", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0022", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 22, "text_original": "旣以非之，何以易之？", "text_normalized": "旣以非之，何以易之？", "canonical_ref": "15.22", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0023", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 23, "text_original": "子墨子言曰：", "text_normalized": "子墨子言曰：", "canonical_ref": "15.23", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0024", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 24, "text_original": "以兼相愛、交相利之法易之。", "text_normalized": "以兼相愛、交相利之法易之。", "canonical_ref": "15.24", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0025", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 25, "text_original": "然則兼相愛、交相利之法將奈何哉？", "text_normalized": "然則兼相愛、交相利之法將奈何哉？", "canonical_ref": "15.25", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0026", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 26, "text_original": "子墨子言：", "text_normalized": "子墨子言：", "canonical_ref": "15.26", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0027", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 27, "text_original": "視人之國，若視其國。", "text_normalized": "視人之國，若視其國。", "canonical_ref": "15.27", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0028", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 28, "text_original": "視人之家，若視其家。", "text_normalized": "視人之家，若視其家。", "canonical_ref": "15.28", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0029", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 29, "text_original": "視人之身，若視其身。", "text_normalized": "視人之身，若視其身。", "canonical_ref": "15.29", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0030", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 30, "text_original": "是故諸侯相愛，則不野戰。", "text_normalized": "是故諸侯相愛，則不野戰。", "canonical_ref": "15.30", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0031", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 31, "text_original": "家主相愛，則不相篡。", "text_normalized": "家主相愛，則不相篡。", "canonical_ref": "15.31", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0032", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 32, "text_original": "人與人相愛，則不相賊。", "text_normalized": "人與人相愛，則不相賊。", "canonical_ref": "15.32", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0033", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 33, "text_original": "君臣相愛，則惠忠。", "text_normalized": "君臣相愛，則惠忠。", "canonical_ref": "15.33", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0034", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 34, "text_original": "父子相愛，則慈孝。", "text_normalized": "父子相愛，則慈孝。", "canonical_ref": "15.34", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0035", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 35, "text_original": "兄弟相愛，則和調。", "text_normalized": "兄弟相愛，則和調。", "canonical_ref": "15.35", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0036", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 36, "text_original": "天下之人皆相愛，強不執弱，衆不劫寡，富不侮貧，貴不敖賤，詐不欺愚。", "text_normalized": "天下之人皆相愛，強不執弱，衆不劫寡，富不侮貧，貴不敖賤，詐不欺愚。", "canonical_ref": "15.36", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0037", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 37, "text_original": "凡天下禍篡怨恨，可使毋起者，以相愛生也。", "text_normalized": "凡天下禍篡怨恨，可使毋起者，以相愛生也。", "canonical_ref": "15.37", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0038", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 38, "text_original": "是以仁者譽之。", "text_normalized": "是以仁者譽之。", "canonical_ref": "15.38", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0039", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 39, "text_original": "然而今天下之士君子曰：", "text_normalized": "然而今天下之士君子曰：", "canonical_ref": "15.39", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0040", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 40, "text_original": "然！", "text_normalized": "然！", "canonical_ref": "15.40", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0041", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 41, "text_original": "乃若兼則善矣。", "text_normalized": "乃若兼則善矣。", "canonical_ref": "15.41", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0042", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 42, "text_original": "雖然，天下之難物於故也。", "text_normalized": "雖然，天下之難物於故也。", "canonical_ref": "15.42", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0043", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 43, "text_original": "子墨子言曰：", "text_normalized": "子墨子言曰：", "canonical_ref": "15.43", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0044", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 44, "text_original": "天下之士君子，特不識其利、辯其故也。", "text_normalized": "天下之士君子，特不識其利、辯其故也。", "canonical_ref": "15.44", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0045", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 45, "text_original": "今若夫攻城野戰，殺身爲名，此天下百姓之所皆難也。", "text_normalized": "今若夫攻城野戰，殺身爲名，此天下百姓之所皆難也。", "canonical_ref": "15.45", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0046", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 46, "text_original": "苟君說之，則士衆能爲之。", "text_normalized": "苟君說之，則士衆能爲之。", "canonical_ref": "15.46", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0047", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 47, "text_original": "況於兼相愛、交相利，則與此異！", "text_normalized": "況於兼相愛、交相利，則與此異！", "canonical_ref": "15.47", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0048", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 48, "text_original": "夫愛人者，人必從而愛之。", "text_normalized": "夫愛人者，人必從而愛之。", "canonical_ref": "15.48", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0049", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 49, "text_original": "利人者，人必從而利之。", "text_normalized": "利人者，人必從而利之。", "canonical_ref": "15.49", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0050", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 50, "text_original": "惡人者，人必從而惡之。", "text_normalized": "惡人者，人必從而惡之。", "canonical_ref": "15.50", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0051", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 51, "text_original": "害人者，人必從而害之。", "text_normalized": "害人者，人必從而害之。", "canonical_ref": "15.51", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0052", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 52, "text_original": "此何難之有？", "text_normalized": "此何難之有？", "canonical_ref": "15.52", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0053", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 53, "text_original": "特上弗以爲政、士不以爲行故也。", "text_normalized": "特上弗以爲政、士不以爲行故也。", "canonical_ref": "15.53", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0054", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 54, "text_original": "昔者晉文公好士之惡衣，故文公之臣皆牂羊之裘，韋以帶劍，練帛之冠，入以見於君，出以踐於朝。", "text_normalized": "昔者晉文公好士之惡衣，故文公之臣皆牂羊之裘，韋以帶劍，練帛之冠，入以見於君，出以踐於朝。", "canonical_ref": "15.54", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0055", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 55, "text_original": "是其故何也？", "text_normalized": "是其故何也？", "canonical_ref": "15.55", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0056", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 56, "text_original": "君說之，故臣爲之也。", "text_normalized": "君說之，故臣爲之也。", "canonical_ref": "15.56", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0057", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 57, "text_original": "昔者楚靈王好士細要，故靈王之臣皆以一飯爲節，脇息然後帶，扶牆然後起。", "text_normalized": "昔者楚靈王好士細要，故靈王之臣皆以一飯爲節，脇息然後帶，扶牆然後起。", "canonical_ref": "15.57", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0058", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 58, "text_original": "比期年，朝有黧黑之色。", "text_normalized": "比期年，朝有黧黑之色。", "canonical_ref": "15.58", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0059", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 59, "text_original": "是其故何也？", "text_normalized": "是其故何也？", "canonical_ref": "15.59", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0060", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 60, "text_original": "君說之，故臣能之也。", "text_normalized": "君說之，故臣能之也。", "canonical_ref": "15.60", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0061", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 61, "text_original": "昔越王句踐好士之勇，教馴其臣，和合之，焚舟失火，試其士曰：", "text_normalized": "昔越王句踐好士之勇，教馴其臣，和合之，焚舟失火，試其士曰：", "canonical_ref": "15.61", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0062", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 62, "text_original": "「越國之寶盡在此！", "text_normalized": "「越國之寶盡在此！", "canonical_ref": "15.62", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0063", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 63, "text_original": "」越王親自鼓其士而進之，土聞鼓音，破碎亂行，蹈火而死者，左右百人有餘，越王擊金而退之。", "text_normalized": "」越王親自鼓其士而進之，土聞鼓音，破碎亂行，蹈火而死者，左右百人有餘，越王擊金而退之。", "canonical_ref": "15.63", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0064", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 64, "text_original": "是其故何也？", "text_normalized": "是其故何也？", "canonical_ref": "15.64", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0065", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 65, "text_original": "君說之，故臣爲之也。", "text_normalized": "君說之，故臣爲之也。", "canonical_ref": "15.65", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0066", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 66, "text_original": "是故子墨子言曰：", "text_normalized": "是故子墨子言曰：", "canonical_ref": "15.66", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0067", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 67, "text_original": "乃若夫少食惡衣，殺身而爲名，此天下百姓之所皆難也。", "text_normalized": "乃若夫少食惡衣，殺身而爲名，此天下百姓之所皆難也。", "canonical_ref": "15.67", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0068", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 68, "text_original": "若苟君說之，則衆能爲之。", "text_normalized": "若苟君說之，則衆能爲之。", "canonical_ref": "15.68", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0069", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 69, "text_original": "況兼相愛、交相利，與此異矣！", "text_normalized": "況兼相愛、交相利，與此異矣！", "canonical_ref": "15.69", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0070", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 70, "text_original": "夫愛人者，人亦從而愛之。", "text_normalized": "夫愛人者，人亦從而愛之。", "canonical_ref": "15.70", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0071", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 71, "text_original": "利人者，人亦從而利之。", "text_normalized": "利人者，人亦從而利之。", "canonical_ref": "15.71", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0072", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 72, "text_original": "惡人者，人亦從而惡之。", "text_normalized": "惡人者，人亦從而惡之。", "canonical_ref": "15.72", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0073", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 73, "text_original": "害人者，人亦從而害之。", "text_normalized": "害人者，人亦從而害之。", "canonical_ref": "15.73", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0074", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 74, "text_original": "此何難之有焉？", "text_normalized": "此何難之有焉？", "canonical_ref": "15.74", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0075", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 75, "text_original": "特士不以爲政而士不以爲行故也。", "text_normalized": "特士不以爲政而士不以爲行故也。", "canonical_ref": "15.75", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0076", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 76, "text_original": "然而今天下之士君子曰：", "text_normalized": "然而今天下之士君子曰：", "canonical_ref": "15.76", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0077", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 77, "text_original": "然！", "text_normalized": "然！", "canonical_ref": "15.77", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0078", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 78, "text_original": "乃若兼則善矣。", "text_normalized": "乃若兼則善矣。", "canonical_ref": "15.78", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0079", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 79, "text_original": "雖然，不可行之物也。", "text_normalized": "雖然，不可行之物也。", "canonical_ref": "15.79", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0080", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 80, "text_original": "譬若挈太山、越河濟也。", "text_normalized": "譬若挈太山、越河濟也。", "canonical_ref": "15.80", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0081", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 81, "text_original": "子墨子言：", "text_normalized": "子墨子言：", "canonical_ref": "15.81", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0082", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 82, "text_original": "是非其譬也。", "text_normalized": "是非其譬也。", "canonical_ref": "15.82", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0083", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 83, "text_original": "夫挈太山而越河濟，可謂畢劫有力矣。", "text_normalized": "夫挈太山而越河濟，可謂畢劫有力矣。", "canonical_ref": "15.83", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0084", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 84, "text_original": "自古及今，未有能行之者也。", "text_normalized": "自古及今，未有能行之者也。", "canonical_ref": "15.84", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0085", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 85, "text_original": "況乎兼相愛、交相利，則與此異，古者聖王行之。", "text_normalized": "況乎兼相愛、交相利，則與此異，古者聖王行之。", "canonical_ref": "15.85", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0086", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 86, "text_original": "何以知其然？", "text_normalized": "何以知其然？", "canonical_ref": "15.86", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0087", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 87, "text_original": "古者禹治天下，西爲西河漁竇，以洩渠孫皇之水。", "text_normalized": "古者禹治天下，西爲西河漁竇，以洩渠孫皇之水。", "canonical_ref": "15.87", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0088", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 88, "text_original": "北爲防原泒，注后之邸、嘑池之竇，洒爲底柱，鑿爲龍門，以利燕代胡貉與西河之民。", "text_normalized": "北爲防原泒，注后之邸、嘑池之竇，洒爲底柱，鑿爲龍門，以利燕代胡貉與西河之民。", "canonical_ref": "15.88", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0089", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 89, "text_original": "東方漏之陸，防孟諸之澤，灑爲九澮，以楗東土之水，以利冀州之民。", "text_normalized": "東方漏之陸，防孟諸之澤，灑爲九澮，以楗東土之水，以利冀州之民。", "canonical_ref": "15.89", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0090", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 90, "text_original": "南爲江漢淮汝，東流之，注五湖之處，以利荊楚干越與南夷之民。", "text_normalized": "南爲江漢淮汝，東流之，注五湖之處，以利荊楚干越與南夷之民。", "canonical_ref": "15.90", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0091", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 91, "text_original": "此言禹之事，吾今行兼矣。", "text_normalized": "此言禹之事，吾今行兼矣。", "canonical_ref": "15.91", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0092", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 92, "text_original": "昔者文王之治西土，若日若月，乍光於四方，于西土。", "text_normalized": "昔者文王之治西土，若日若月，乍光於四方，于西土。", "canonical_ref": "15.92", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0093", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 93, "text_original": "不爲大國侮小國，不爲衆庶侮鰥寡，不爲暴勢奪穡人黍稷狗彘。", "text_normalized": "不爲大國侮小國，不爲衆庶侮鰥寡，不爲暴勢奪穡人黍稷狗彘。", "canonical_ref": "15.93", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0094", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 94, "text_original": "天屑臨文王慈，是以老而無子者，有所得終其壽。", "text_normalized": "天屑臨文王慈，是以老而無子者，有所得終其壽。", "canonical_ref": "15.94", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0095", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 95, "text_original": "連獨無兄弟者，有所雜於生人之間。", "text_normalized": "連獨無兄弟者，有所雜於生人之間。", "canonical_ref": "15.95", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0096", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 96, "text_original": "少失其父母者，有所放依而長。", "text_normalized": "少失其父母者，有所放依而長。", "canonical_ref": "15.96", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0097", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 97, "text_original": "此文王之事，則吾今行兼矣。", "text_normalized": "此文王之事，則吾今行兼矣。", "canonical_ref": "15.97", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0098", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 98, "text_original": "昔者武王將事泰山隧。", "text_normalized": "昔者武王將事泰山隧。", "canonical_ref": "15.98", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0099", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 99, "text_original": "傳曰：", "text_normalized": "傳曰：", "canonical_ref": "15.99", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0100", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 100, "text_original": "「泰山，有道曾孫周王有事。", "text_normalized": "「泰山，有道曾孫周王有事。", "canonical_ref": "15.100", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0101", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 101, "text_original": "大事旣獲，仁人尚作，以祗商夏、蠻夷醜貉。", "text_normalized": "大事旣獲，仁人尚作，以祗商夏、蠻夷醜貉。", "canonical_ref": "15.101", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0102", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 102, "text_original": "雖有周親，不若仁人萬方有罪，維予一人。", "text_normalized": "雖有周親，不若仁人萬方有罪，維予一人。", "canonical_ref": "15.102", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0103", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 103, "text_original": "」此言武王之事，吾今行兼矣。", "text_normalized": "」此言武王之事，吾今行兼矣。", "canonical_ref": "15.103", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0104", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 104, "text_original": "是故子墨子言曰：", "text_normalized": "是故子墨子言曰：", "canonical_ref": "15.104", "notes": ""}
{"segment_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3__seg-0105", "section_id": "mozi-015-universal-love-ii", "source_id": "mozi-015-universal-love-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 105, "text_original": "今天下之士君子，忠實欲天下之富而惡其貧，欲天下之治而惡其亂，當兼相愛、交相利，此聖王之法，天下之治道也，不可不務爲也。", "text_normalized": "今天下之士君子，忠實欲天下之富而惡其貧，欲天下之治而惡其亂，當兼相愛、交相利，此聖王之法，天下之治道也，不可不務爲也。", "canonical_ref": "15.105", "notes": ""}
