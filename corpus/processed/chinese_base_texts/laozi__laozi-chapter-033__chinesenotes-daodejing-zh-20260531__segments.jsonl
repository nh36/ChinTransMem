{"segment_id": "laozi-chapter-033__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-033", "source_id": "laozi-chapter-033__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 33.1", "sort_key": "033.001", "text_original": "知人者智，", "text_normalized": "知人者智，", "notes": ""}
{"segment_id": "laozi-chapter-033__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-033", "source_id": "laozi-chapter-033__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 33.2", "sort_key": "033.002", "text_original": "自知者明。", "text_normalized": "自知者明。", "notes": ""}
{"segment_id": "laozi-chapter-033__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-033", "source_id": "laozi-chapter-033__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 33.3", "sort_key": "033.003", "text_original": "勝人者有力，", "text_normalized": "勝人者有力，", "notes": ""}
{"segment_id": "laozi-chapter-033__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-033", "source_id": "laozi-chapter-033__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 33.4", "sort_key": "033.004", "text_original": "自勝者強。", "text_normalized": "自勝者強。", "notes": ""}
{"segment_id": "laozi-chapter-033__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-033", "source_id": "laozi-chapter-033__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 33.5", "sort_key": "033.005", "text_original": "知足者富。", "text_normalized": "知足者富。", "notes": ""}
{"segment_id": "laozi-chapter-033__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-033", "source_id": "laozi-chapter-033__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 33.6", "sort_key": "033.006", "text_original": "強行者有志。", "text_normalized": "強行者有志。", "notes": ""}
{"segment_id": "laozi-chapter-033__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-033", "source_id": "laozi-chapter-033__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 33.7", "sort_key": "033.007", "text_original": "不失其所者久。", "text_normalized": "不失其所者久。", "notes": ""}
{"segment_id": "laozi-chapter-033__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-033", "source_id": "laozi-chapter-033__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 33.8", "sort_key": "033.008", "text_original": "死而不亡者壽。", "text_normalized": "死而不亡者壽。", "notes": ""}
