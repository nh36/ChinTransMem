{"segment_id": "laozi-chapter-008__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-008", "source_id": "laozi-chapter-008__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 8.1", "sort_key": "008.001", "text_original": "上善若水。", "text_normalized": "上善若水。", "notes": ""}
{"segment_id": "laozi-chapter-008__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-008", "source_id": "laozi-chapter-008__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 8.2", "sort_key": "008.002", "text_original": "水善利萬物而不爭，處眾人之所惡，", "text_normalized": "水善利萬物而不爭，處眾人之所惡，", "notes": ""}
{"segment_id": "laozi-chapter-008__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-008", "source_id": "laozi-chapter-008__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 8.3", "sort_key": "008.003", "text_original": "故幾於道。", "text_normalized": "故幾於道。", "notes": ""}
{"segment_id": "laozi-chapter-008__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-008", "source_id": "laozi-chapter-008__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 8.4", "sort_key": "008.004", "text_original": "居善地，心善淵，與善仁，言善信，正善治，事善能，動善時。", "text_normalized": "居善地，心善淵，與善仁，言善信，正善治，事善能，動善時。", "notes": ""}
{"segment_id": "laozi-chapter-008__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-008", "source_id": "laozi-chapter-008__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 8.5", "sort_key": "008.005", "text_original": "夫唯不爭，故無尤。", "text_normalized": "夫唯不爭，故無尤。", "notes": ""}
