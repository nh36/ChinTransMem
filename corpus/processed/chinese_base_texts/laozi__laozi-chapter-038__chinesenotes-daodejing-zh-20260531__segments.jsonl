{"segment_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-038", "source_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 38.1", "sort_key": "038.001", "text_original": "上德不德，", "text_normalized": "上德不德，", "notes": ""}
{"segment_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-038", "source_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 38.2", "sort_key": "038.002", "text_original": "是以有德；", "text_normalized": "是以有德；", "notes": ""}
{"segment_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-038", "source_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 38.3", "sort_key": "038.003", "text_original": "下德不失德，", "text_normalized": "下德不失德，", "notes": ""}
{"segment_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-038", "source_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 38.4", "sort_key": "038.004", "text_original": "是以無德。", "text_normalized": "是以無德。", "notes": ""}
{"segment_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-038", "source_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 38.5", "sort_key": "038.005", "text_original": "上德無為而無以為，", "text_normalized": "上德無為而無以為，", "notes": ""}
{"segment_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-038", "source_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 38.6", "sort_key": "038.006", "text_original": "下德為之而有以為。", "text_normalized": "下德為之而有以為。", "notes": ""}
{"segment_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-038", "source_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 38.7", "sort_key": "038.007", "text_original": "上仁為之而無以為，", "text_normalized": "上仁為之而無以為，", "notes": ""}
{"segment_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-038", "source_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 38.8", "sort_key": "038.008", "text_original": "上義為之而有以為。", "text_normalized": "上義為之而有以為。", "notes": ""}
{"segment_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-038", "source_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 38.9", "sort_key": "038.009", "text_original": "上禮為之而莫之應，", "text_normalized": "上禮為之而莫之應，", "notes": ""}
{"segment_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-038", "source_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 38.10", "sort_key": "038.010", "text_original": "則攘臂而扔之。", "text_normalized": "則攘臂而扔之。", "notes": ""}
{"segment_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-038", "source_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 38.11", "sort_key": "038.011", "text_original": "故失道而後德，", "text_normalized": "故失道而後德，", "notes": ""}
{"segment_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531__seg-012", "work_id": "laozi", "section_id": "laozi-chapter-038", "source_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 12, "canonical_ref": "老子 38.12", "sort_key": "038.012", "text_original": "失德而後仁，", "text_normalized": "失德而後仁，", "notes": ""}
{"segment_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531__seg-013", "work_id": "laozi", "section_id": "laozi-chapter-038", "source_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 13, "canonical_ref": "老子 38.13", "sort_key": "038.013", "text_original": "失仁而後義，", "text_normalized": "失仁而後義，", "notes": ""}
{"segment_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531__seg-014", "work_id": "laozi", "section_id": "laozi-chapter-038", "source_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 14, "canonical_ref": "老子 38.14", "sort_key": "038.014", "text_original": "失義而後禮。", "text_normalized": "失義而後禮。", "notes": ""}
{"segment_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531__seg-015", "work_id": "laozi", "section_id": "laozi-chapter-038", "source_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 15, "canonical_ref": "老子 38.15", "sort_key": "038.015", "text_original": "夫禮者，", "text_normalized": "夫禮者，", "notes": ""}
{"segment_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531__seg-016", "work_id": "laozi", "section_id": "laozi-chapter-038", "source_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 16, "canonical_ref": "老子 38.16", "sort_key": "038.016", "text_original": "忠信之薄，", "text_normalized": "忠信之薄，", "notes": ""}
{"segment_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531__seg-017", "work_id": "laozi", "section_id": "laozi-chapter-038", "source_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 17, "canonical_ref": "老子 38.17", "sort_key": "038.017", "text_original": "而亂之首。", "text_normalized": "而亂之首。", "notes": ""}
{"segment_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531__seg-018", "work_id": "laozi", "section_id": "laozi-chapter-038", "source_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 18, "canonical_ref": "老子 38.18", "sort_key": "038.018", "text_original": "前識者，", "text_normalized": "前識者，", "notes": ""}
{"segment_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531__seg-019", "work_id": "laozi", "section_id": "laozi-chapter-038", "source_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 19, "canonical_ref": "老子 38.19", "sort_key": "038.019", "text_original": "道之華，", "text_normalized": "道之華，", "notes": ""}
{"segment_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531__seg-020", "work_id": "laozi", "section_id": "laozi-chapter-038", "source_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 20, "canonical_ref": "老子 38.20", "sort_key": "038.020", "text_original": "而愚之始。", "text_normalized": "而愚之始。", "notes": ""}
{"segment_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531__seg-021", "work_id": "laozi", "section_id": "laozi-chapter-038", "source_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 21, "canonical_ref": "老子 38.21", "sort_key": "038.021", "text_original": "是以大丈夫處其厚，", "text_normalized": "是以大丈夫處其厚，", "notes": ""}
{"segment_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531__seg-022", "work_id": "laozi", "section_id": "laozi-chapter-038", "source_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 22, "canonical_ref": "老子 38.22", "sort_key": "038.022", "text_original": "不居其薄；", "text_normalized": "不居其薄；", "notes": ""}
{"segment_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531__seg-023", "work_id": "laozi", "section_id": "laozi-chapter-038", "source_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 23, "canonical_ref": "老子 38.23", "sort_key": "038.023", "text_original": "處其實，", "text_normalized": "處其實，", "notes": ""}
{"segment_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531__seg-024", "work_id": "laozi", "section_id": "laozi-chapter-038", "source_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 24, "canonical_ref": "老子 38.24", "sort_key": "038.024", "text_original": "不居其華。", "text_normalized": "不居其華。", "notes": ""}
{"segment_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531__seg-025", "work_id": "laozi", "section_id": "laozi-chapter-038", "source_id": "laozi-chapter-038__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 25, "canonical_ref": "老子 38.25", "sort_key": "038.025", "text_original": "故去彼取此。", "text_normalized": "故去彼取此。", "notes": ""}
