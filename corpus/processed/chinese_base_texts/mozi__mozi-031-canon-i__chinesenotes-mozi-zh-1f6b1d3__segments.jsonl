{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-001", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 1, "canonical_ref": "墨子 031.1", "text_original": "故，所得而後成也，止以久也。", "text_normalized": "故，所得而後成也，止以久也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-002", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 2, "canonical_ref": "墨子 031.2", "text_original": "體，分於兼也，必不已也。", "text_normalized": "體，分於兼也，必不已也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-003", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 3, "canonical_ref": "墨子 031.3", "text_original": "智，材也。", "text_normalized": "智，材也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-004", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 4, "canonical_ref": "墨子 031.4", "text_original": "平，同高也。", "text_normalized": "平，同高也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-005", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 5, "canonical_ref": "墨子 031.5", "text_original": "慮，求也。", "text_normalized": "慮，求也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-006", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 6, "canonical_ref": "墨子 031.6", "text_original": "同長，以擊缶相盡也。", "text_normalized": "同長，以擊缶相盡也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-007", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 7, "canonical_ref": "墨子 031.7", "text_original": "知，接也。", "text_normalized": "知，接也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-008", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 8, "canonical_ref": "墨子 031.8", "text_original": "中，同長也。", "text_normalized": "中，同長也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-009", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 9, "canonical_ref": "墨子 031.9", "text_original": "𢜔，明也。", "text_normalized": "𢜔，明也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-010", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 10, "canonical_ref": "墨子 031.10", "text_original": "厚，有所大也。", "text_normalized": "厚，有所大也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-011", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 11, "canonical_ref": "墨子 031.11", "text_original": "仁，體愛也。", "text_normalized": "仁，體愛也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-012", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 12, "canonical_ref": "墨子 031.12", "text_original": "日中，缶南也。", "text_normalized": "日中，缶南也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-013", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 13, "canonical_ref": "墨子 031.13", "text_original": "義，利也。", "text_normalized": "義，利也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-014", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 14, "canonical_ref": "墨子 031.14", "text_original": "直，參也。", "text_normalized": "直，參也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-015", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 15, "canonical_ref": "墨子 031.15", "text_original": "禮，敬也。", "text_normalized": "禮，敬也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-016", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 16, "canonical_ref": "墨子 031.16", "text_original": "圜，一中同長也。", "text_normalized": "圜，一中同長也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-017", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 17, "canonical_ref": "墨子 031.17", "text_original": "行，為也。", "text_normalized": "行，為也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-018", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 18, "canonical_ref": "墨子 031.18", "text_original": "方柱，隅四讙也。", "text_normalized": "方柱，隅四讙也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-019", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 19, "canonical_ref": "墨子 031.19", "text_original": "實，榮也。", "text_normalized": "實，榮也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-020", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 20, "canonical_ref": "墨子 031.20", "text_original": "倍，為二也。", "text_normalized": "倍，為二也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-021", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 21, "canonical_ref": "墨子 031.21", "text_original": "忠，以為利而強低也。", "text_normalized": "忠，以為利而強低也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-022", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 22, "canonical_ref": "墨子 031.22", "text_original": "端，體之無序而最前者也。", "text_normalized": "端，體之無序而最前者也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-023", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 23, "canonical_ref": "墨子 031.23", "text_original": "孝，利親也。", "text_normalized": "孝，利親也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-024", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 24, "canonical_ref": "墨子 031.24", "text_original": "有，間中也。", "text_normalized": "有，間中也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-025", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 25, "canonical_ref": "墨子 031.25", "text_original": "信，言合於意也。", "text_normalized": "信，言合於意也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-026", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 26, "canonical_ref": "墨子 031.26", "text_original": "佴，自作也。", "text_normalized": "佴，自作也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-027", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 27, "canonical_ref": "墨子 031.27", "text_original": "間，不及旁也。", "text_normalized": "間，不及旁也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-028", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 28, "canonical_ref": "墨子 031.28", "text_original": "佴，自作也。", "text_normalized": "佴，自作也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-029", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 29, "canonical_ref": "墨子 031.29", "text_original": "纑，間虛也。", "text_normalized": "纑，間虛也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-030", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 30, "canonical_ref": "墨子 031.30", "text_original": "𧨜，作嗛也。", "text_normalized": "𧨜，作嗛也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-031", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 31, "canonical_ref": "墨子 031.31", "text_original": "盈，莫不有也。", "text_normalized": "盈，莫不有也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-032", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 32, "canonical_ref": "墨子 031.32", "text_original": "廉，作非也。", "text_normalized": "廉，作非也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-033", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 33, "canonical_ref": "墨子 031.33", "text_original": "堅白，不相外也。", "text_normalized": "堅白，不相外也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-034", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 34, "canonical_ref": "墨子 031.34", "text_original": "令，不為所作也攖，相得也。", "text_normalized": "令，不為所作也攖，相得也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-035", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 35, "canonical_ref": "墨子 031.35", "text_original": "任，士損己而益所為也。", "text_normalized": "任，士損己而益所為也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-036", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 36, "canonical_ref": "墨子 031.36", "text_original": "似，有以相攖有不相攖也。", "text_normalized": "似，有以相攖有不相攖也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-037", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 37, "canonical_ref": "墨子 031.37", "text_original": "勇，志之所以敢也。", "text_normalized": "勇，志之所以敢也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-038", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 38, "canonical_ref": "墨子 031.38", "text_original": "次，無間而不攖攖也。", "text_normalized": "次，無間而不攖攖也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-039", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 39, "canonical_ref": "墨子 031.39", "text_original": "力，刑之所以奮也。", "text_normalized": "力，刑之所以奮也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-040", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 40, "canonical_ref": "墨子 031.40", "text_original": "法，所若而然也。", "text_normalized": "法，所若而然也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-041", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 41, "canonical_ref": "墨子 031.41", "text_original": "生，刑與知處也。", "text_normalized": "生，刑與知處也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-042", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 42, "canonical_ref": "墨子 031.42", "text_original": "佴，所然也。", "text_normalized": "佴，所然也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-043", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 43, "canonical_ref": "墨子 031.43", "text_original": "臥，知無知也。", "text_normalized": "臥，知無知也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-044", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 44, "canonical_ref": "墨子 031.44", "text_original": "說，所以明也。", "text_normalized": "說，所以明也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-045", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 45, "canonical_ref": "墨子 031.45", "text_original": "夢，臥而以為然也。", "text_normalized": "夢，臥而以為然也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-046", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 46, "canonical_ref": "墨子 031.46", "text_original": "攸，不可兩不可也。", "text_normalized": "攸，不可兩不可也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-047", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 47, "canonical_ref": "墨子 031.47", "text_original": "平，知無欲惡也。", "text_normalized": "平，知無欲惡也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-048", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 48, "canonical_ref": "墨子 031.48", "text_original": "辯，爭攸也。", "text_normalized": "辯，爭攸也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-049", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 49, "canonical_ref": "墨子 031.49", "text_original": "辯，勝當也。", "text_normalized": "辯，勝當也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-050", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 50, "canonical_ref": "墨子 031.50", "text_original": "利，所得而喜也。", "text_normalized": "利，所得而喜也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-051", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 51, "canonical_ref": "墨子 031.51", "text_original": "為，窮知而𠐴於欲也。", "text_normalized": "為，窮知而𠐴於欲也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-052", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 52, "canonical_ref": "墨子 031.52", "text_original": "害，所得而惡也，已成亡。", "text_normalized": "害，所得而惡也，已成亡。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-053", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 53, "canonical_ref": "墨子 031.53", "text_original": "治，求得也，使謂故。", "text_normalized": "治，求得也，使謂故。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-054", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 54, "canonical_ref": "墨子 031.54", "text_original": "譽，明美也，名達類私。", "text_normalized": "譽，明美也，名達類私。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-055", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 55, "canonical_ref": "墨子 031.55", "text_original": "誹，明惡也，謂疑舉加。", "text_normalized": "誹，明惡也，謂疑舉加。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-056", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 56, "canonical_ref": "墨子 031.56", "text_original": "舉，擬實也，知間說親，名實合為。", "text_normalized": "舉，擬實也，知間說親，名實合為。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-057", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 57, "canonical_ref": "墨子 031.57", "text_original": "言，出舉也，聞博親且。", "text_normalized": "言，出舉也，聞博親且。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-058", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 58, "canonical_ref": "墨子 031.58", "text_original": "且，言然也，見體盡。", "text_normalized": "且，言然也，見體盡。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-059", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 59, "canonical_ref": "墨子 031.59", "text_original": "君，臣萌通約也，合缶宜必。", "text_normalized": "君，臣萌通約也，合缶宜必。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-060", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 60, "canonical_ref": "墨子 031.60", "text_original": "功，利民也，欲缶權利且惡缶權害。", "text_normalized": "功，利民也，欲缶權利且惡缶權害。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-061", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 61, "canonical_ref": "墨子 031.61", "text_original": "賞，上報下之功也，為存亡、易蕩、治化。", "text_normalized": "賞，上報下之功也，為存亡、易蕩、治化。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-062", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 62, "canonical_ref": "墨子 031.62", "text_original": "罪，犯禁也，同重體合類。", "text_normalized": "罪，犯禁也，同重體合類。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-063", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 63, "canonical_ref": "墨子 031.63", "text_original": "罰，上報下之罪也。異二體，不合不類，同異而俱於之一也。同異交得放有無。", "text_normalized": "罰，上報下之罪也。異二體，不合不類，同異而俱於之一也。同異交得放有無。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-064", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 64, "canonical_ref": "墨子 031.64", "text_original": "久，彌異時也。", "text_normalized": "久，彌異時也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-065", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 65, "canonical_ref": "墨子 031.65", "text_original": "守，彌異所也。", "text_normalized": "守，彌異所也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-066", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 66, "canonical_ref": "墨子 031.66", "text_original": "聞，耳之聰也。", "text_normalized": "聞，耳之聰也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-067", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 67, "canonical_ref": "墨子 031.67", "text_original": "窮，或有前不容尺也，循所聞而得其意心也察也。", "text_normalized": "窮，或有前不容尺也，循所聞而得其意心也察也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-068", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 68, "canonical_ref": "墨子 031.68", "text_original": "盡，莫不然也。", "text_normalized": "盡，莫不然也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-069", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 69, "canonical_ref": "墨子 031.69", "text_original": "言，口之利也。", "text_normalized": "言，口之利也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-070", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 70, "canonical_ref": "墨子 031.70", "text_original": "始，當時也，執所言而意得見心之辯也。", "text_normalized": "始，當時也，執所言而意得見心之辯也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-071", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 71, "canonical_ref": "墨子 031.71", "text_original": "化，徵易也，諾不一利用。", "text_normalized": "化，徵易也，諾不一利用。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-072", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 72, "canonical_ref": "墨子 031.72", "text_original": "損，偏去也。", "text_normalized": "損，偏去也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-073", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 73, "canonical_ref": "墨子 031.73", "text_original": "服執說巧，轉則求其故，大益。", "text_normalized": "服執說巧，轉則求其故，大益。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-074", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 74, "canonical_ref": "墨子 031.74", "text_original": "儇𥟭秪，法同則觀其同，庫易也；法異則觀其宜，動或從也。", "text_normalized": "儇𥟭秪，法同則觀其同，庫易也；法異則觀其宜，動或從也。", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3__seg-075", "work_id": "mozi", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-mozi-zh-1f6b1d3", "segment_type": "block", "segment_order": 75, "canonical_ref": "墨子 031.75", "text_original": "止因以別道讀此書，旁行缶無非。", "text_normalized": "止因以別道讀此書，旁行缶無非。", "notes": ""}
