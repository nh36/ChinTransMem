{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0001", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 1, "text_original": "禽子再拜再拜，曰：", "text_normalized": "禽子再拜再拜，曰：", "canonical_ref": "47.1", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0002", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 2, "text_original": "「敢問古人有善攻者，穴土而入，縛柱施火，以壞吾城，城壞，或中人為之柰何？", "text_normalized": "「敢問古人有善攻者，穴土而入，縛柱施火，以壞吾城，城壞，或中人為之柰何？", "canonical_ref": "47.2", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0003", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 3, "text_original": "」子墨子曰：", "text_normalized": "」子墨子曰：", "canonical_ref": "47.3", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0004", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 4, "text_original": "「問穴土之守邪？", "text_normalized": "「問穴土之守邪？", "canonical_ref": "47.4", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0005", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 5, "text_original": "備穴者城內為高樓，以謹候望適人。", "text_normalized": "備穴者城內為高樓，以謹候望適人。", "canonical_ref": "47.5", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0006", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 6, "text_original": "適人為變，築垣聚土非常者，若彭有水濁非常者，此穴土也，急塹城內穴亓土直之。", "text_normalized": "適人為變，築垣聚土非常者，若彭有水濁非常者，此穴土也，急塹城內穴亓土直之。", "canonical_ref": "47.6", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0007", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 7, "text_original": "穿井城內，五步一井，傅城足，高地，丈五尺，下地，得泉三尺而止。", "text_normalized": "穿井城內，五步一井，傅城足，高地，丈五尺，下地，得泉三尺而止。", "canonical_ref": "47.7", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0008", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 8, "text_original": "令陶者為罌，容四十斗以上，固幎之以薄皮革，置井中，使聰耳者伏罌而聽之，審知穴之所在，鑿穴迎之。", "text_normalized": "令陶者為罌，容四十斗以上，固幎之以薄皮革，置井中，使聰耳者伏罌而聽之，審知穴之所在，鑿穴迎之。", "canonical_ref": "47.8", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0009", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 9, "text_original": "令陶者為月明，長二尺五寸六圍，中判之，合而施之穴中，偃一，覆一。", "text_normalized": "令陶者為月明，長二尺五寸六圍，中判之，合而施之穴中，偃一，覆一。", "canonical_ref": "47.9", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0010", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 10, "text_original": "柱之外善周塗，亓傅柱者勿燒。", "text_normalized": "柱之外善周塗，亓傅柱者勿燒。", "canonical_ref": "47.10", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0011", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 11, "text_original": "柱者勿燒柱善塗亓竇際，勿令泄。", "text_normalized": "柱者勿燒柱善塗亓竇際，勿令泄。", "canonical_ref": "47.11", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0012", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 12, "text_original": "兩旁皆如此，與穴俱前。", "text_normalized": "兩旁皆如此，與穴俱前。", "canonical_ref": "47.12", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0013", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 13, "text_original": "下迫地，置康若灰亓中，勿滿。", "text_normalized": "下迫地，置康若灰亓中，勿滿。", "canonical_ref": "47.13", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0014", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 14, "text_original": "灰康長五竇，左右俱雜相如也。", "text_normalized": "灰康長五竇，左右俱雜相如也。", "canonical_ref": "47.14", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0015", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 15, "text_original": "穴內口為灶，令如窯，令容七八員艾，左右竇皆如此，灶用四橐。", "text_normalized": "穴內口為灶，令如窯，令容七八員艾，左右竇皆如此，灶用四橐。", "canonical_ref": "47.15", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0016", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 16, "text_original": "穴且遇，以頡皋衝之，疾鼓橐熏之，必令明習橐事者勿令離灶口。", "text_normalized": "穴且遇，以頡皋衝之，疾鼓橐熏之，必令明習橐事者勿令離灶口。", "canonical_ref": "47.16", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0017", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 17, "text_original": "連版以穴高下、廣陜為度，令穴者與版俱前，鑿亓版令容矛，參分亓疏數，令可以救竇。", "text_normalized": "連版以穴高下、廣陜為度，令穴者與版俱前，鑿亓版令容矛，參分亓疏數，令可以救竇。", "canonical_ref": "47.17", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0018", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 18, "text_original": "穴則遇，以版當之，以矛救竇，勿令塞竇，竇則塞，引版而卻，過一竇而塞之，鑿亓竇，通亓煙，煙通，疾鼓橐以熏之。", "text_normalized": "穴則遇，以版當之，以矛救竇，勿令塞竇，竇則塞，引版而卻，過一竇而塞之，鑿亓竇，通亓煙，煙通，疾鼓橐以熏之。", "canonical_ref": "47.18", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0019", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 19, "text_original": "從穴內聽穴之左右，急絕亓前，勿令得行。", "text_normalized": "從穴內聽穴之左右，急絕亓前，勿令得行。", "canonical_ref": "47.19", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0020", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 20, "text_original": "若集客穴，塞之以柴塗，令無可燒版也。", "text_normalized": "若集客穴，塞之以柴塗，令無可燒版也。", "canonical_ref": "47.20", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0021", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 21, "text_original": "然則穴土之攻敗矣。", "text_normalized": "然則穴土之攻敗矣。", "canonical_ref": "47.21", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0022", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 22, "text_original": "寇至吾城，急非常也，謹備穴。", "text_normalized": "寇至吾城，急非常也，謹備穴。", "canonical_ref": "47.22", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0023", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 23, "text_original": "穴疑有應寇，急穴穴未得，慎毋追。", "text_normalized": "穴疑有應寇，急穴穴未得，慎毋追。", "canonical_ref": "47.23", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0024", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 24, "text_original": "凡殺以穴攻者，二十步一置穴，穴高十尺，鑿十尺，鑿如前，步下三尺，十步擁穴，左右橫行，高廣各十尺殺。", "text_normalized": "凡殺以穴攻者，二十步一置穴，穴高十尺，鑿十尺，鑿如前，步下三尺，十步擁穴，左右橫行，高廣各十尺殺。", "canonical_ref": "47.24", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0025", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 25, "text_original": "俚兩罌，深平城置板亓上，連板以井聽。", "text_normalized": "俚兩罌，深平城置板亓上，連板以井聽。", "canonical_ref": "47.25", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0026", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 26, "text_original": "五步一密。", "text_normalized": "五步一密。", "canonical_ref": "47.26", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0027", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 27, "text_original": "用梓若松為穴戶，戶穴有兩蒺藜，皆長極亓戶，戶為環，壘石外埻，高七尺，加堞亓上。", "text_normalized": "用梓若松為穴戶，戶穴有兩蒺藜，皆長極亓戶，戶為環，壘石外埻，高七尺，加堞亓上。", "canonical_ref": "47.27", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0028", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 28, "text_original": "勿為陛與石，以縣陛上下出入。", "text_normalized": "勿為陛與石，以縣陛上下出入。", "canonical_ref": "47.28", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0029", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 29, "text_original": "具鑪橐，橐以牛皮，鑪有兩缶，以橋鼓之百十，每亦熏四十什，然炭杜之，滿鑪而蓋之，毋令氣出。", "text_normalized": "具鑪橐，橐以牛皮，鑪有兩缶，以橋鼓之百十，每亦熏四十什，然炭杜之，滿鑪而蓋之，毋令氣出。", "canonical_ref": "47.29", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0030", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 30, "text_original": "適人疾近五百穴穴高若下，不至吾穴，即以伯鑿而求通之。", "text_normalized": "適人疾近五百穴穴高若下，不至吾穴，即以伯鑿而求通之。", "canonical_ref": "47.30", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0031", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 31, "text_original": "穴中與適人遇，則皆圉而毋逐，且戰北，以須鑪火之然也，即去而入壅穴殺。", "text_normalized": "穴中與適人遇，則皆圉而毋逐，且戰北，以須鑪火之然也，即去而入壅穴殺。", "canonical_ref": "47.31", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0032", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 32, "text_original": "有鼠竄，為之戶及關籥獨順，得往來行亓中。", "text_normalized": "有鼠竄，為之戶及關籥獨順，得往來行亓中。", "canonical_ref": "47.32", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0033", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 33, "text_original": "穴壘之中各一狗，狗吠即有人也。", "text_normalized": "穴壘之中各一狗，狗吠即有人也。", "canonical_ref": "47.33", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0034", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 34, "text_original": "斬艾與柴長尺，乃置窯灶中，先壘窯壁迎穴為連版。", "text_normalized": "斬艾與柴長尺，乃置窯灶中，先壘窯壁迎穴為連版。", "canonical_ref": "47.34", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0035", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 35, "text_original": "鑿井傳城足，三丈一，視外之廣陜而為鑿井，慎勿失。", "text_normalized": "鑿井傳城足，三丈一，視外之廣陜而為鑿井，慎勿失。", "canonical_ref": "47.35", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0036", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 36, "text_original": "城卑穴高從穴難。", "text_normalized": "城卑穴高從穴難。", "canonical_ref": "47.36", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0037", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 37, "text_original": "鑿井城上，為三四井，內新甀井中，伏而聽之。", "text_normalized": "鑿井城上，為三四井，內新甀井中，伏而聽之。", "canonical_ref": "47.37", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0038", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 38, "text_original": "審之知穴之所在，穴而迎之。", "text_normalized": "審之知穴之所在，穴而迎之。", "canonical_ref": "47.38", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0039", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 39, "text_original": "穴且遇，為頡皋，必以堅材為夫，以利斧施之，命有力者三人用頡皋衝之，灌以不潔十餘石。", "text_normalized": "穴且遇，為頡皋，必以堅材為夫，以利斧施之，命有力者三人用頡皋衝之，灌以不潔十餘石。", "canonical_ref": "47.39", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0040", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 40, "text_original": "趣伏此井中，置艾亓上，七八員，盆蓋井口，毋令煙上泄，旁亓橐口，疾鼓之。", "text_normalized": "趣伏此井中，置艾亓上，七八員，盆蓋井口，毋令煙上泄，旁亓橐口，疾鼓之。", "canonical_ref": "47.40", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0041", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 41, "text_original": "以車輪為轀。", "text_normalized": "以車輪為轀。", "canonical_ref": "47.41", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0042", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 42, "text_original": "一束樵，染麻索塗中以束之。", "text_normalized": "一束樵，染麻索塗中以束之。", "canonical_ref": "47.42", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0043", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 43, "text_original": "鐵鎖，縣正當寇穴口。", "text_normalized": "鐵鎖，縣正當寇穴口。", "canonical_ref": "47.43", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0044", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 44, "text_original": "鐵鎖長三丈，端環，一端鉤。", "text_normalized": "鐵鎖長三丈，端環，一端鉤。", "canonical_ref": "47.44", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0045", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 45, "text_original": "鼠穴高七尺，五寸廣，柱閒也尺，二尺一柱，柱下傅舄，二柱共一員十一。", "text_normalized": "鼠穴高七尺，五寸廣，柱閒也尺，二尺一柱，柱下傅舄，二柱共一員十一。", "canonical_ref": "47.45", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0046", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 46, "text_original": "兩柱同質，橫員士，柱大二圍半，必固亓員士，無柱與柱交者。", "text_normalized": "兩柱同質，橫員士，柱大二圍半，必固亓員士，無柱與柱交者。", "canonical_ref": "47.46", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0047", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 47, "text_original": "穴二窯，皆為穴月屋，為置吏、舍人，各一人，必置水。", "text_normalized": "穴二窯，皆為穴月屋，為置吏、舍人，各一人，必置水。", "canonical_ref": "47.47", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0048", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 48, "text_original": "塞穴門以車兩走，為轀，塗亓上，以穴高下廣陜為度，令入穴中四五尺，維置之。", "text_normalized": "塞穴門以車兩走，為轀，塗亓上，以穴高下廣陜為度，令入穴中四五尺，維置之。", "canonical_ref": "47.48", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0049", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 49, "text_original": "當穴者客爭伏門，轉而塞之為窯，容三員艾者，令亓突入伏尺。", "text_normalized": "當穴者客爭伏門，轉而塞之為窯，容三員艾者，令亓突入伏尺。", "canonical_ref": "47.49", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0050", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 50, "text_original": "伏傅突一旁，以二橐守之，勿離。", "text_normalized": "伏傅突一旁，以二橐守之，勿離。", "canonical_ref": "47.50", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0051", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 51, "text_original": "穴矛以鐵，長四尺半，大如鐵服說，即刃之二矛。", "text_normalized": "穴矛以鐵，長四尺半，大如鐵服說，即刃之二矛。", "canonical_ref": "47.51", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0052", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 52, "text_original": "內去竇尺，邪鑿之，上穴當心，亓矛長七尺。", "text_normalized": "內去竇尺，邪鑿之，上穴當心，亓矛長七尺。", "canonical_ref": "47.52", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0053", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 53, "text_original": "穴中為環利率，穴二。", "text_normalized": "穴中為環利率，穴二。", "canonical_ref": "47.53", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0054", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 54, "text_original": "鑿井城下，俟亓身井且通，居版上，而鑿亓一遍，已而移版，鑿一遍。", "text_normalized": "鑿井城下，俟亓身井且通，居版上，而鑿亓一遍，已而移版，鑿一遍。", "canonical_ref": "47.54", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0055", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 55, "text_original": "頡皋為兩夫，而旁貍亓植，而數鉤亓兩端。", "text_normalized": "頡皋為兩夫，而旁貍亓植，而數鉤亓兩端。", "canonical_ref": "47.55", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0056", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 56, "text_original": "諸作穴者五十人，男女相半。", "text_normalized": "諸作穴者五十人，男女相半。", "canonical_ref": "47.56", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0057", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 57, "text_original": "五十人。", "text_normalized": "五十人。", "canonical_ref": "47.57", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0058", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 58, "text_original": "攻內為傳士之口，受六參，約枲繩以牛亓下，可提而與投，已則穴七人守退，壘之中為大廡一，藏穴具亓中。", "text_normalized": "攻內為傳士之口，受六參，約枲繩以牛亓下，可提而與投，已則穴七人守退，壘之中為大廡一，藏穴具亓中。", "canonical_ref": "47.58", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0059", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 59, "text_original": "難穴，取城外池脣木月散之什，斬亓穴，深到泉。", "text_normalized": "難穴，取城外池脣木月散之什，斬亓穴，深到泉。", "canonical_ref": "47.59", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0060", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 60, "text_original": "難近穴為鐵鈇。", "text_normalized": "難近穴為鐵鈇。", "canonical_ref": "47.60", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0061", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 61, "text_original": "金與扶林長四尺，財自足。", "text_normalized": "金與扶林長四尺，財自足。", "canonical_ref": "47.61", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0062", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 62, "text_original": "客即穴，亦穴而應之。", "text_normalized": "客即穴，亦穴而應之。", "canonical_ref": "47.62", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0063", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 63, "text_original": "為鐵鉤鉅長四尺者，財自足，穴徹，以鉤客穴者。", "text_normalized": "為鐵鉤鉅長四尺者，財自足，穴徹，以鉤客穴者。", "canonical_ref": "47.63", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0064", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 64, "text_original": "為短矛、短戟、短弩、虻矢，財自足，穴徹以鬥。", "text_normalized": "為短矛、短戟、短弩、虻矢，財自足，穴徹以鬥。", "canonical_ref": "47.64", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0065", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 65, "text_original": "以金劍為難，長五尺，為銎、木柄；", "text_normalized": "以金劍為難，長五尺，為銎、木柄；", "canonical_ref": "47.65", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0066", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 66, "text_original": "柄有慮枚，以左客穴。", "text_normalized": "柄有慮枚，以左客穴。", "canonical_ref": "47.66", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0067", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 67, "text_original": "戒持罌，容三十斗以上，貍穴中，丈一，以聽穴者聲。", "text_normalized": "戒持罌，容三十斗以上，貍穴中，丈一，以聽穴者聲。", "canonical_ref": "47.67", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0068", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 68, "text_original": "為穴，高八尺，廣，善為傅置。", "text_normalized": "為穴，高八尺，廣，善為傅置。", "canonical_ref": "47.68", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0069", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 69, "text_original": "具鑪牛皮橐，皮及缶，衛穴二，蓋陳靃及艾，穴徹熏之以。", "text_normalized": "具鑪牛皮橐，皮及缶，衛穴二，蓋陳靃及艾，穴徹熏之以。", "canonical_ref": "47.69", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0070", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 70, "text_original": "斧金為斫，柯長三尺，衛穴四。", "text_normalized": "斧金為斫，柯長三尺，衛穴四。", "canonical_ref": "47.70", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0071", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 71, "text_original": "為壘，衛穴四十，屬四。", "text_normalized": "為壘，衛穴四十，屬四。", "canonical_ref": "47.71", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0072", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 72, "text_original": "為斤、斧、鋸、鑿、瞿、財自足。", "text_normalized": "為斤、斧、鋸、鑿、瞿、財自足。", "canonical_ref": "47.72", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0073", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 73, "text_original": "為鐵校，衛穴四。", "text_normalized": "為鐵校，衛穴四。", "canonical_ref": "47.73", "notes": ""}
{"segment_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3__seg-0074", "section_id": "mozi-047-preparation-against-tunnelling", "source_id": "mozi-047-preparation-against-tunnelling__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 74, "text_original": "為中櫓，高十丈半，廣四尺。", "text_normalized": "為中櫓，高十丈半，廣四尺。", "canonical_ref": "47.74", "notes": ""}
