{"segment_id": "shijing__daya-shengmin-003__001__zhwikisource-20260530", "work_id": "shijing", "section_id": "daya-shengmin-003", "source_id": "daya-shengmin-003__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 1, "canonical_ref": "詩經·大雅·生民之什·003.1", "text_original": "既醉以酒，既飽以德。君子萬年，介爾景福。", "text_normalized": "既醉以酒，既飽以德。君子萬年，介爾景福。", "notes": "既醉 Chinese stanza 1."}
{"segment_id": "shijing__daya-shengmin-003__002__zhwikisource-20260530", "work_id": "shijing", "section_id": "daya-shengmin-003", "source_id": "daya-shengmin-003__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 2, "canonical_ref": "詩經·大雅·生民之什·003.2", "text_original": "既醉以酒，爾殽既將。君子萬年，介爾昭明。", "text_normalized": "既醉以酒，爾殽既將。君子萬年，介爾昭明。", "notes": "既醉 Chinese stanza 2."}
{"segment_id": "shijing__daya-shengmin-003__003__zhwikisource-20260530", "work_id": "shijing", "section_id": "daya-shengmin-003", "source_id": "daya-shengmin-003__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 3, "canonical_ref": "詩經·大雅·生民之什·003.3", "text_original": "昭明有融，高朗令終。令終有俶，公尸嘉告。", "text_normalized": "昭明有融，高朗令終。令終有俶，公尸嘉告。", "notes": "既醉 Chinese stanza 3."}
{"segment_id": "shijing__daya-shengmin-003__004__zhwikisource-20260530", "work_id": "shijing", "section_id": "daya-shengmin-003", "source_id": "daya-shengmin-003__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 4, "canonical_ref": "詩經·大雅·生民之什·003.4", "text_original": "其告維何？籩豆靜嘉。朋友攸攝，攝以威儀。", "text_normalized": "其告維何？籩豆靜嘉。朋友攸攝，攝以威儀。", "notes": "既醉 Chinese stanza 4."}
{"segment_id": "shijing__daya-shengmin-003__005__zhwikisource-20260530", "work_id": "shijing", "section_id": "daya-shengmin-003", "source_id": "daya-shengmin-003__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 5, "canonical_ref": "詩經·大雅·生民之什·003.5", "text_original": "威儀孔時，君子有孝子。孝子不匱，永錫爾類。", "text_normalized": "威儀孔時，君子有孝子。孝子不匱，永錫爾類。", "notes": "既醉 Chinese stanza 5."}
{"segment_id": "shijing__daya-shengmin-003__006__zhwikisource-20260530", "work_id": "shijing", "section_id": "daya-shengmin-003", "source_id": "daya-shengmin-003__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 6, "canonical_ref": "詩經·大雅·生民之什·003.6", "text_original": "其類維何？室家之壼。君子萬年，永錫祚胤。", "text_normalized": "其類維何？室家之壼。君子萬年，永錫祚胤。", "notes": "既醉 Chinese stanza 6."}
{"segment_id": "shijing__daya-shengmin-003__007__zhwikisource-20260530", "work_id": "shijing", "section_id": "daya-shengmin-003", "source_id": "daya-shengmin-003__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 7, "canonical_ref": "詩經·大雅·生民之什·003.7", "text_original": "其胤維何？天被爾祿。君子萬年，景命有僕。", "text_normalized": "其胤維何？天被爾祿。君子萬年，景命有僕。", "notes": "既醉 Chinese stanza 7."}
{"segment_id": "shijing__daya-shengmin-003__008__zhwikisource-20260530", "work_id": "shijing", "section_id": "daya-shengmin-003", "source_id": "daya-shengmin-003__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 8, "canonical_ref": "詩經·大雅·生民之什·003.8", "text_original": "其僕維何？釐爾女士。釐爾女士，從以孫子。", "text_normalized": "其僕維何？釐爾女士。釐爾女士，從以孫子。", "notes": "既醉 Chinese stanza 8."}
