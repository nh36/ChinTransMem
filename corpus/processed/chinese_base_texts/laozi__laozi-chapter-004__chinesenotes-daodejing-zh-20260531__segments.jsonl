{"segment_id": "laozi-chapter-004__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-004", "source_id": "laozi-chapter-004__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 4.1", "sort_key": "004.001", "text_original": "道沖而用之或不盈，", "text_normalized": "道沖而用之或不盈，", "notes": ""}
{"segment_id": "laozi-chapter-004__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-004", "source_id": "laozi-chapter-004__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 4.2", "sort_key": "004.002", "text_original": "淵兮似萬物之宗；", "text_normalized": "淵兮似萬物之宗；", "notes": ""}
{"segment_id": "laozi-chapter-004__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-004", "source_id": "laozi-chapter-004__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 4.3", "sort_key": "004.003", "text_original": "挫其銳，", "text_normalized": "挫其銳，", "notes": ""}
{"segment_id": "laozi-chapter-004__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-004", "source_id": "laozi-chapter-004__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 4.4", "sort_key": "004.004", "text_original": "解其紛，", "text_normalized": "解其紛，", "notes": ""}
{"segment_id": "laozi-chapter-004__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-004", "source_id": "laozi-chapter-004__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 4.5", "sort_key": "004.005", "text_original": "和其光，", "text_normalized": "和其光，", "notes": ""}
{"segment_id": "laozi-chapter-004__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-004", "source_id": "laozi-chapter-004__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 4.6", "sort_key": "004.006", "text_original": "同其塵，", "text_normalized": "同其塵，", "notes": ""}
{"segment_id": "laozi-chapter-004__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-004", "source_id": "laozi-chapter-004__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 4.7", "sort_key": "004.007", "text_original": "湛兮似或存。", "text_normalized": "湛兮似或存。", "notes": ""}
{"segment_id": "laozi-chapter-004__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-004", "source_id": "laozi-chapter-004__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 4.8", "sort_key": "004.008", "text_original": "吾不知誰之子，", "text_normalized": "吾不知誰之子，", "notes": ""}
{"segment_id": "laozi-chapter-004__chinesenotes-daodejing-zh-20260531__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-004", "source_id": "laozi-chapter-004__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 4.9", "sort_key": "004.009", "text_original": "象帝之先。", "text_normalized": "象帝之先。", "notes": ""}
