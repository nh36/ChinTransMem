{"segment_id": "laozi-chapter-031__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-031", "source_id": "laozi-chapter-031__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 31.1", "sort_key": "031.001", "text_original": "夫佳兵者，", "text_normalized": "夫佳兵者，", "notes": ""}
{"segment_id": "laozi-chapter-031__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-031", "source_id": "laozi-chapter-031__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 31.2", "sort_key": "031.002", "text_original": "不祥之器，", "text_normalized": "不祥之器，", "notes": ""}
{"segment_id": "laozi-chapter-031__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-031", "source_id": "laozi-chapter-031__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 31.3", "sort_key": "031.003", "text_original": "物或惡之，", "text_normalized": "物或惡之，", "notes": ""}
{"segment_id": "laozi-chapter-031__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-031", "source_id": "laozi-chapter-031__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 31.4", "sort_key": "031.004", "text_original": "故有道者不處。", "text_normalized": "故有道者不處。", "notes": ""}
{"segment_id": "laozi-chapter-031__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-031", "source_id": "laozi-chapter-031__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 31.5", "sort_key": "031.005", "text_original": "君子居則貴左，", "text_normalized": "君子居則貴左，", "notes": ""}
{"segment_id": "laozi-chapter-031__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-031", "source_id": "laozi-chapter-031__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 31.6", "sort_key": "031.006", "text_original": "用兵則貴右。", "text_normalized": "用兵則貴右。", "notes": ""}
{"segment_id": "laozi-chapter-031__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-031", "source_id": "laozi-chapter-031__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 31.7", "sort_key": "031.007", "text_original": "兵者不祥之器，", "text_normalized": "兵者不祥之器，", "notes": ""}
{"segment_id": "laozi-chapter-031__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-031", "source_id": "laozi-chapter-031__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 31.8", "sort_key": "031.008", "text_original": "非君子之器，", "text_normalized": "非君子之器，", "notes": ""}
{"segment_id": "laozi-chapter-031__chinesenotes-daodejing-zh-20260531__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-031", "source_id": "laozi-chapter-031__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 31.9", "sort_key": "031.009", "text_original": "不得已而用之，", "text_normalized": "不得已而用之，", "notes": ""}
{"segment_id": "laozi-chapter-031__chinesenotes-daodejing-zh-20260531__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-031", "source_id": "laozi-chapter-031__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 31.10", "sort_key": "031.010", "text_original": "恬淡為上。", "text_normalized": "恬淡為上。", "notes": ""}
{"segment_id": "laozi-chapter-031__chinesenotes-daodejing-zh-20260531__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-031", "source_id": "laozi-chapter-031__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 31.11", "sort_key": "031.011", "text_original": "勝而不美，", "text_normalized": "勝而不美，", "notes": ""}
{"segment_id": "laozi-chapter-031__chinesenotes-daodejing-zh-20260531__seg-012", "work_id": "laozi", "section_id": "laozi-chapter-031", "source_id": "laozi-chapter-031__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 12, "canonical_ref": "老子 31.12", "sort_key": "031.012", "text_original": "而美之者，", "text_normalized": "而美之者，", "notes": ""}
{"segment_id": "laozi-chapter-031__chinesenotes-daodejing-zh-20260531__seg-013", "work_id": "laozi", "section_id": "laozi-chapter-031", "source_id": "laozi-chapter-031__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 13, "canonical_ref": "老子 31.13", "sort_key": "031.013", "text_original": "是樂殺人。", "text_normalized": "是樂殺人。", "notes": ""}
{"segment_id": "laozi-chapter-031__chinesenotes-daodejing-zh-20260531__seg-014", "work_id": "laozi", "section_id": "laozi-chapter-031", "source_id": "laozi-chapter-031__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 14, "canonical_ref": "老子 31.14", "sort_key": "031.014", "text_original": "夫樂殺人者，", "text_normalized": "夫樂殺人者，", "notes": ""}
{"segment_id": "laozi-chapter-031__chinesenotes-daodejing-zh-20260531__seg-015", "work_id": "laozi", "section_id": "laozi-chapter-031", "source_id": "laozi-chapter-031__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 15, "canonical_ref": "老子 31.15", "sort_key": "031.015", "text_original": "則不可以得志於天下矣。", "text_normalized": "則不可以得志於天下矣。", "notes": ""}
{"segment_id": "laozi-chapter-031__chinesenotes-daodejing-zh-20260531__seg-016", "work_id": "laozi", "section_id": "laozi-chapter-031", "source_id": "laozi-chapter-031__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 16, "canonical_ref": "老子 31.16", "sort_key": "031.016", "text_original": "吉事尚左，", "text_normalized": "吉事尚左，", "notes": ""}
{"segment_id": "laozi-chapter-031__chinesenotes-daodejing-zh-20260531__seg-017", "work_id": "laozi", "section_id": "laozi-chapter-031", "source_id": "laozi-chapter-031__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 17, "canonical_ref": "老子 31.17", "sort_key": "031.017", "text_original": "凶事尚右。", "text_normalized": "凶事尚右。", "notes": ""}
{"segment_id": "laozi-chapter-031__chinesenotes-daodejing-zh-20260531__seg-018", "work_id": "laozi", "section_id": "laozi-chapter-031", "source_id": "laozi-chapter-031__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 18, "canonical_ref": "老子 31.18", "sort_key": "031.018", "text_original": "偏將軍居左，", "text_normalized": "偏將軍居左，", "notes": ""}
{"segment_id": "laozi-chapter-031__chinesenotes-daodejing-zh-20260531__seg-019", "work_id": "laozi", "section_id": "laozi-chapter-031", "source_id": "laozi-chapter-031__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 19, "canonical_ref": "老子 31.19", "sort_key": "031.019", "text_original": "上將軍居右，", "text_normalized": "上將軍居右，", "notes": ""}
{"segment_id": "laozi-chapter-031__chinesenotes-daodejing-zh-20260531__seg-020", "work_id": "laozi", "section_id": "laozi-chapter-031", "source_id": "laozi-chapter-031__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 20, "canonical_ref": "老子 31.20", "sort_key": "031.020", "text_original": "言以喪禮處之。", "text_normalized": "言以喪禮處之。", "notes": ""}
{"segment_id": "laozi-chapter-031__chinesenotes-daodejing-zh-20260531__seg-021", "work_id": "laozi", "section_id": "laozi-chapter-031", "source_id": "laozi-chapter-031__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 21, "canonical_ref": "老子 31.21", "sort_key": "031.021", "text_original": "殺人之眾，", "text_normalized": "殺人之眾，", "notes": ""}
{"segment_id": "laozi-chapter-031__chinesenotes-daodejing-zh-20260531__seg-022", "work_id": "laozi", "section_id": "laozi-chapter-031", "source_id": "laozi-chapter-031__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 22, "canonical_ref": "老子 31.22", "sort_key": "031.022", "text_original": "以哀悲泣之，", "text_normalized": "以哀悲泣之，", "notes": ""}
{"segment_id": "laozi-chapter-031__chinesenotes-daodejing-zh-20260531__seg-023", "work_id": "laozi", "section_id": "laozi-chapter-031", "source_id": "laozi-chapter-031__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 23, "canonical_ref": "老子 31.23", "sort_key": "031.023", "text_original": "戰勝，", "text_normalized": "戰勝，", "notes": ""}
{"segment_id": "laozi-chapter-031__chinesenotes-daodejing-zh-20260531__seg-024", "work_id": "laozi", "section_id": "laozi-chapter-031", "source_id": "laozi-chapter-031__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 24, "canonical_ref": "老子 31.24", "sort_key": "031.024", "text_original": "以喪禮處之。", "text_normalized": "以喪禮處之。", "notes": ""}
