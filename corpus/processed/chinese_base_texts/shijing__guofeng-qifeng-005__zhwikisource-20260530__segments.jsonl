{"segment_id": "shijing__guofeng-qifeng-005__001__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-qifeng-005", "source_id": "guofeng-qifeng-005__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 1, "canonical_ref": "詩經·國風·齊風·005.1", "text_original": "東方未明，顛倒衣裳。顛之倒之，自公召之。", "text_normalized": "東方未明，顛倒衣裳。顛之倒之，自公召之。", "notes": "東方未明 Chinese stanza 1."}
{"segment_id": "shijing__guofeng-qifeng-005__002__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-qifeng-005", "source_id": "guofeng-qifeng-005__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 2, "canonical_ref": "詩經·國風·齊風·005.2", "text_original": "東方未晞，顛倒裳衣。倒之顛之，自公令之。", "text_normalized": "東方未晞，顛倒裳衣。倒之顛之，自公令之。", "notes": "東方未明 Chinese stanza 2."}
{"segment_id": "shijing__guofeng-qifeng-005__003__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-qifeng-005", "source_id": "guofeng-qifeng-005__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 3, "canonical_ref": "詩經·國風·齊風·005.3", "text_original": "折柳樊圃，狂夫瞿瞿。不能辰夜，不夙則莫。", "text_normalized": "折柳樊圃，狂夫瞿瞿。不能辰夜，不夙則莫。", "notes": "東方未明 Chinese stanza 3."}
