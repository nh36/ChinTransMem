{"segment_id": "laozi-chapter-066__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-066", "source_id": "laozi-chapter-066__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 66.1", "sort_key": "066.001", "text_original": "江海所以能為百谷王者，", "text_normalized": "江海所以能為百谷王者，", "notes": ""}
{"segment_id": "laozi-chapter-066__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-066", "source_id": "laozi-chapter-066__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 66.2", "sort_key": "066.002", "text_original": "以其善下之，", "text_normalized": "以其善下之，", "notes": ""}
{"segment_id": "laozi-chapter-066__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-066", "source_id": "laozi-chapter-066__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 66.3", "sort_key": "066.003", "text_original": "故能為百谷王。", "text_normalized": "故能為百谷王。", "notes": ""}
{"segment_id": "laozi-chapter-066__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-066", "source_id": "laozi-chapter-066__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 66.4", "sort_key": "066.004", "text_original": "是以欲上民，", "text_normalized": "是以欲上民，", "notes": ""}
{"segment_id": "laozi-chapter-066__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-066", "source_id": "laozi-chapter-066__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 66.5", "sort_key": "066.005", "text_original": "必以言下之。", "text_normalized": "必以言下之。", "notes": ""}
{"segment_id": "laozi-chapter-066__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-066", "source_id": "laozi-chapter-066__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 66.6", "sort_key": "066.006", "text_original": "欲先民，", "text_normalized": "欲先民，", "notes": ""}
{"segment_id": "laozi-chapter-066__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-066", "source_id": "laozi-chapter-066__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 66.7", "sort_key": "066.007", "text_original": "必以身後之。", "text_normalized": "必以身後之。", "notes": ""}
{"segment_id": "laozi-chapter-066__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-066", "source_id": "laozi-chapter-066__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 66.8", "sort_key": "066.008", "text_original": "是以聖人處上而民不重，", "text_normalized": "是以聖人處上而民不重，", "notes": ""}
{"segment_id": "laozi-chapter-066__chinesenotes-daodejing-zh-20260531__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-066", "source_id": "laozi-chapter-066__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 66.9", "sort_key": "066.009", "text_original": "處前而民不害。", "text_normalized": "處前而民不害。", "notes": ""}
{"segment_id": "laozi-chapter-066__chinesenotes-daodejing-zh-20260531__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-066", "source_id": "laozi-chapter-066__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 66.10", "sort_key": "066.010", "text_original": "是以天下樂推而不厭，", "text_normalized": "是以天下樂推而不厭，", "notes": ""}
{"segment_id": "laozi-chapter-066__chinesenotes-daodejing-zh-20260531__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-066", "source_id": "laozi-chapter-066__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 66.11", "sort_key": "066.011", "text_original": "以其不爭，", "text_normalized": "以其不爭，", "notes": ""}
{"segment_id": "laozi-chapter-066__chinesenotes-daodejing-zh-20260531__seg-012", "work_id": "laozi", "section_id": "laozi-chapter-066", "source_id": "laozi-chapter-066__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 12, "canonical_ref": "老子 66.12", "sort_key": "066.012", "text_original": "故天下莫能與之爭。", "text_normalized": "故天下莫能與之爭。", "notes": ""}
