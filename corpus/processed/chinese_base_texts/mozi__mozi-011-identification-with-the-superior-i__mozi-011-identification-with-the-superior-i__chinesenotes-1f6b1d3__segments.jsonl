{"segment_id": "mozi-011-identification-with-the-superior-i__chinesenotes-1f6b1d3__seg-0040", "section_id": "mozi-011-identification-with-the-superior-i", "source_id": "mozi-011-identification-with-the-superior-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 40, "text_original": "「聞善而不善者，必以告國君。", "text_normalized": "「聞善而不善者，必以告國君。", "canonical_ref": "11.40", "notes": ""}
{"segment_id": "mozi-011-identification-with-the-superior-i__chinesenotes-1f6b1d3__seg-0041", "section_id": "mozi-011-identification-with-the-superior-i", "source_id": "mozi-011-identification-with-the-superior-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 41, "text_original": "國君之所是，必皆是之。", "text_normalized": "國君之所是，必皆是之。", "canonical_ref": "11.41", "notes": ""}
{"segment_id": "mozi-011-identification-with-the-superior-i__chinesenotes-1f6b1d3__seg-0042", "section_id": "mozi-011-identification-with-the-superior-i", "source_id": "mozi-011-identification-with-the-superior-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 42, "text_original": "國君之所非，必皆非之。", "text_normalized": "國君之所非，必皆非之。", "canonical_ref": "11.42", "notes": ""}
{"segment_id": "mozi-011-identification-with-the-superior-i__chinesenotes-1f6b1d3__seg-0043", "section_id": "mozi-011-identification-with-the-superior-i", "source_id": "mozi-011-identification-with-the-superior-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 43, "text_original": "去若不善言，學國君之善言。", "text_normalized": "去若不善言，學國君之善言。", "canonical_ref": "11.43", "notes": ""}
{"segment_id": "mozi-011-identification-with-the-superior-i__chinesenotes-1f6b1d3__seg-0044", "section_id": "mozi-011-identification-with-the-superior-i", "source_id": "mozi-011-identification-with-the-superior-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 44, "text_original": "去若不善行，學國君之善行。", "text_normalized": "去若不善行，學國君之善行。", "canonical_ref": "11.44", "notes": ""}
{"segment_id": "mozi-011-identification-with-the-superior-i__chinesenotes-1f6b1d3__seg-0045", "section_id": "mozi-011-identification-with-the-superior-i", "source_id": "mozi-011-identification-with-the-superior-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 45, "text_original": "則國何說以亂哉？", "text_normalized": "則國何說以亂哉？", "canonical_ref": "11.45", "notes": ""}
{"segment_id": "mozi-011-identification-with-the-superior-i__chinesenotes-1f6b1d3__seg-0046", "section_id": "mozi-011-identification-with-the-superior-i", "source_id": "mozi-011-identification-with-the-superior-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 46, "text_original": "」察國之所以治者，何也？", "text_normalized": "」察國之所以治者，何也？", "canonical_ref": "11.46", "notes": ""}
{"segment_id": "mozi-011-identification-with-the-superior-i__chinesenotes-1f6b1d3__seg-0047", "section_id": "mozi-011-identification-with-the-superior-i", "source_id": "mozi-011-identification-with-the-superior-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 47, "text_original": "國君唯能壹同國之義，是以國治也。", "text_normalized": "國君唯能壹同國之義，是以國治也。", "canonical_ref": "11.47", "notes": ""}
{"segment_id": "mozi-011-identification-with-the-superior-i__chinesenotes-1f6b1d3__seg-0048", "section_id": "mozi-011-identification-with-the-superior-i", "source_id": "mozi-011-identification-with-the-superior-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 48, "text_original": "國君者，國之仁人也。", "text_normalized": "國君者，國之仁人也。", "canonical_ref": "11.48", "notes": ""}
{"segment_id": "mozi-011-identification-with-the-superior-i__chinesenotes-1f6b1d3__seg-0049", "section_id": "mozi-011-identification-with-the-superior-i", "source_id": "mozi-011-identification-with-the-superior-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 49, "text_original": "國君發政國之百姓，言曰：", "text_normalized": "國君發政國之百姓，言曰：", "canonical_ref": "11.49", "notes": ""}
{"segment_id": "mozi-011-identification-with-the-superior-i__chinesenotes-1f6b1d3__seg-0050", "section_id": "mozi-011-identification-with-the-superior-i", "source_id": "mozi-011-identification-with-the-superior-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 50, "text_original": "「聞善而不善，必以告天子。", "text_normalized": "「聞善而不善，必以告天子。", "canonical_ref": "11.50", "notes": ""}
{"segment_id": "mozi-011-identification-with-the-superior-i__chinesenotes-1f6b1d3__seg-0051", "section_id": "mozi-011-identification-with-the-superior-i", "source_id": "mozi-011-identification-with-the-superior-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 51, "text_original": "天子之所是，皆是之。", "text_normalized": "天子之所是，皆是之。", "canonical_ref": "11.51", "notes": ""}
{"segment_id": "mozi-011-identification-with-the-superior-i__chinesenotes-1f6b1d3__seg-0052", "section_id": "mozi-011-identification-with-the-superior-i", "source_id": "mozi-011-identification-with-the-superior-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 52, "text_original": "天子之所非，皆非之。", "text_normalized": "天子之所非，皆非之。", "canonical_ref": "11.52", "notes": ""}
{"segment_id": "mozi-011-identification-with-the-superior-i__chinesenotes-1f6b1d3__seg-0053", "section_id": "mozi-011-identification-with-the-superior-i", "source_id": "mozi-011-identification-with-the-superior-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 53, "text_original": "去若不善言，學天子之善言，去若不善行，學天子之善行。", "text_normalized": "去若不善言，學天子之善言，去若不善行，學天子之善行。", "canonical_ref": "11.53", "notes": ""}
{"segment_id": "mozi-011-identification-with-the-superior-i__chinesenotes-1f6b1d3__seg-0054", "section_id": "mozi-011-identification-with-the-superior-i", "source_id": "mozi-011-identification-with-the-superior-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 54, "text_original": "則天下何說以亂哉？", "text_normalized": "則天下何說以亂哉？", "canonical_ref": "11.54", "notes": ""}
{"segment_id": "mozi-011-identification-with-the-superior-i__chinesenotes-1f6b1d3__seg-0055", "section_id": "mozi-011-identification-with-the-superior-i", "source_id": "mozi-011-identification-with-the-superior-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 55, "text_original": "」察天下之所以治者，何也？", "text_normalized": "」察天下之所以治者，何也？", "canonical_ref": "11.55", "notes": ""}
{"segment_id": "mozi-011-identification-with-the-superior-i__chinesenotes-1f6b1d3__seg-0056", "section_id": "mozi-011-identification-with-the-superior-i", "source_id": "mozi-011-identification-with-the-superior-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 56, "text_original": "天子唯能壹同天下之義，是以天下以治也。", "text_normalized": "天子唯能壹同天下之義，是以天下以治也。", "canonical_ref": "11.56", "notes": ""}
{"segment_id": "mozi-011-identification-with-the-superior-i__chinesenotes-1f6b1d3__seg-0057", "section_id": "mozi-011-identification-with-the-superior-i", "source_id": "mozi-011-identification-with-the-superior-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 57, "text_original": "天下之百姓，皆上同於天子，而不上同於天，則菑猶未去也。", "text_normalized": "天下之百姓，皆上同於天子，而不上同於天，則菑猶未去也。", "canonical_ref": "11.57", "notes": ""}
{"segment_id": "mozi-011-identification-with-the-superior-i__chinesenotes-1f6b1d3__seg-0058", "section_id": "mozi-011-identification-with-the-superior-i", "source_id": "mozi-011-identification-with-the-superior-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 58, "text_original": "今若天飄風苦雨，溱溱而至者，此天之所以罰百姓之不上同於天者也。", "text_normalized": "今若天飄風苦雨，溱溱而至者，此天之所以罰百姓之不上同於天者也。", "canonical_ref": "11.58", "notes": ""}
{"segment_id": "mozi-011-identification-with-the-superior-i__chinesenotes-1f6b1d3__seg-0059", "section_id": "mozi-011-identification-with-the-superior-i", "source_id": "mozi-011-identification-with-the-superior-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 59, "text_original": "是故子墨子言曰：", "text_normalized": "是故子墨子言曰：", "canonical_ref": "11.59", "notes": ""}
{"segment_id": "mozi-011-identification-with-the-superior-i__chinesenotes-1f6b1d3__seg-0060", "section_id": "mozi-011-identification-with-the-superior-i", "source_id": "mozi-011-identification-with-the-superior-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 60, "text_original": "古者聖王爲五刑，請以治其民。", "text_normalized": "古者聖王爲五刑，請以治其民。", "canonical_ref": "11.60", "notes": ""}
{"segment_id": "mozi-011-identification-with-the-superior-i__chinesenotes-1f6b1d3__seg-0061", "section_id": "mozi-011-identification-with-the-superior-i", "source_id": "mozi-011-identification-with-the-superior-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 61, "text_original": "譬若絲縷之有紀，罔罟之有綱，所連收天下之百姓不尚同其上者也。", "text_normalized": "譬若絲縷之有紀，罔罟之有綱，所連收天下之百姓不尚同其上者也。", "canonical_ref": "11.61", "notes": ""}
