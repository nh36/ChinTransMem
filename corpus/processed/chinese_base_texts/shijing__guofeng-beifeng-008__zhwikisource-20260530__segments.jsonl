{"segment_id": "shijing__guofeng-beifeng-008__001__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-beifeng-008", "source_id": "guofeng-beifeng-008__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 1, "canonical_ref": "詩經·國風·邶風·008.1", "text_original": "雄雉于飛，泄泄其羽，我之懷矣，自詒伊阻。", "text_normalized": "雄雉于飛，泄泄其羽，我之懷矣，自詒伊阻。", "notes": "雄雉 Chinese stanza 1."}
{"segment_id": "shijing__guofeng-beifeng-008__002__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-beifeng-008", "source_id": "guofeng-beifeng-008__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 2, "canonical_ref": "詩經·國風·邶風·008.2", "text_original": "雄雉于飛，下上其音，展矣君子，實勞我心。", "text_normalized": "雄雉于飛，下上其音，展矣君子，實勞我心。", "notes": "雄雉 Chinese stanza 2."}
{"segment_id": "shijing__guofeng-beifeng-008__003__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-beifeng-008", "source_id": "guofeng-beifeng-008__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 3, "canonical_ref": "詩經·國風·邶風·008.3", "text_original": "瞻彼日月，悠悠我思，道之云遠，曷云能來。", "text_normalized": "瞻彼日月，悠悠我思，道之云遠，曷云能來。", "notes": "雄雉 Chinese stanza 3."}
{"segment_id": "shijing__guofeng-beifeng-008__004__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-beifeng-008", "source_id": "guofeng-beifeng-008__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 4, "canonical_ref": "詩經·國風·邶風·008.4", "text_original": "百爾君子，不知德行，不忮不求，何用不臧。", "text_normalized": "百爾君子，不知德行，不忮不求，何用不臧。", "notes": "雄雉 Chinese stanza 4."}
