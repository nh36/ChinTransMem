{"segment_id": "laozi-chapter-067__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-067", "source_id": "laozi-chapter-067__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 67.1", "sort_key": "067.001", "text_original": "天下皆謂我道大，", "text_normalized": "天下皆謂我道大，", "notes": ""}
{"segment_id": "laozi-chapter-067__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-067", "source_id": "laozi-chapter-067__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 67.2", "sort_key": "067.002", "text_original": "似不肖。", "text_normalized": "似不肖。", "notes": ""}
{"segment_id": "laozi-chapter-067__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-067", "source_id": "laozi-chapter-067__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 67.3", "sort_key": "067.003", "text_original": "夫唯大，", "text_normalized": "夫唯大，", "notes": ""}
{"segment_id": "laozi-chapter-067__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-067", "source_id": "laozi-chapter-067__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 67.4", "sort_key": "067.004", "text_original": "故似不肖。", "text_normalized": "故似不肖。", "notes": ""}
{"segment_id": "laozi-chapter-067__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-067", "source_id": "laozi-chapter-067__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 67.5", "sort_key": "067.005", "text_original": "若肖，", "text_normalized": "若肖，", "notes": ""}
{"segment_id": "laozi-chapter-067__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-067", "source_id": "laozi-chapter-067__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 67.6", "sort_key": "067.006", "text_original": "久矣其細也夫！", "text_normalized": "久矣其細也夫！", "notes": ""}
{"segment_id": "laozi-chapter-067__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-067", "source_id": "laozi-chapter-067__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 67.7", "sort_key": "067.007", "text_original": "我有三寶，", "text_normalized": "我有三寶，", "notes": ""}
{"segment_id": "laozi-chapter-067__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-067", "source_id": "laozi-chapter-067__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 67.8", "sort_key": "067.008", "text_original": "持而保之。", "text_normalized": "持而保之。", "notes": ""}
{"segment_id": "laozi-chapter-067__chinesenotes-daodejing-zh-20260531__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-067", "source_id": "laozi-chapter-067__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 67.9", "sort_key": "067.009", "text_original": "一曰慈，", "text_normalized": "一曰慈，", "notes": ""}
{"segment_id": "laozi-chapter-067__chinesenotes-daodejing-zh-20260531__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-067", "source_id": "laozi-chapter-067__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 67.10", "sort_key": "067.010", "text_original": "二曰儉，", "text_normalized": "二曰儉，", "notes": ""}
{"segment_id": "laozi-chapter-067__chinesenotes-daodejing-zh-20260531__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-067", "source_id": "laozi-chapter-067__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 67.11", "sort_key": "067.011", "text_original": "三曰不敢為天下先。", "text_normalized": "三曰不敢為天下先。", "notes": ""}
{"segment_id": "laozi-chapter-067__chinesenotes-daodejing-zh-20260531__seg-012", "work_id": "laozi", "section_id": "laozi-chapter-067", "source_id": "laozi-chapter-067__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 12, "canonical_ref": "老子 67.12", "sort_key": "067.012", "text_original": "慈故能勇，", "text_normalized": "慈故能勇，", "notes": ""}
{"segment_id": "laozi-chapter-067__chinesenotes-daodejing-zh-20260531__seg-013", "work_id": "laozi", "section_id": "laozi-chapter-067", "source_id": "laozi-chapter-067__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 13, "canonical_ref": "老子 67.13", "sort_key": "067.013", "text_original": "儉故能廣，", "text_normalized": "儉故能廣，", "notes": ""}
{"segment_id": "laozi-chapter-067__chinesenotes-daodejing-zh-20260531__seg-014", "work_id": "laozi", "section_id": "laozi-chapter-067", "source_id": "laozi-chapter-067__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 14, "canonical_ref": "老子 67.14", "sort_key": "067.014", "text_original": "不敢為天下先，", "text_normalized": "不敢為天下先，", "notes": ""}
{"segment_id": "laozi-chapter-067__chinesenotes-daodejing-zh-20260531__seg-015", "work_id": "laozi", "section_id": "laozi-chapter-067", "source_id": "laozi-chapter-067__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 15, "canonical_ref": "老子 67.15", "sort_key": "067.015", "text_original": "故能成器長。", "text_normalized": "故能成器長。", "notes": ""}
{"segment_id": "laozi-chapter-067__chinesenotes-daodejing-zh-20260531__seg-016", "work_id": "laozi", "section_id": "laozi-chapter-067", "source_id": "laozi-chapter-067__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 16, "canonical_ref": "老子 67.16", "sort_key": "067.016", "text_original": "今舍慈且勇，", "text_normalized": "今舍慈且勇，", "notes": ""}
{"segment_id": "laozi-chapter-067__chinesenotes-daodejing-zh-20260531__seg-017", "work_id": "laozi", "section_id": "laozi-chapter-067", "source_id": "laozi-chapter-067__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 17, "canonical_ref": "老子 67.17", "sort_key": "067.017", "text_original": "舍儉且廣，", "text_normalized": "舍儉且廣，", "notes": ""}
{"segment_id": "laozi-chapter-067__chinesenotes-daodejing-zh-20260531__seg-018", "work_id": "laozi", "section_id": "laozi-chapter-067", "source_id": "laozi-chapter-067__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 18, "canonical_ref": "老子 67.18", "sort_key": "067.018", "text_original": "舍後且先，", "text_normalized": "舍後且先，", "notes": ""}
{"segment_id": "laozi-chapter-067__chinesenotes-daodejing-zh-20260531__seg-019", "work_id": "laozi", "section_id": "laozi-chapter-067", "source_id": "laozi-chapter-067__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 19, "canonical_ref": "老子 67.19", "sort_key": "067.019", "text_original": "死矣！", "text_normalized": "死矣！", "notes": ""}
{"segment_id": "laozi-chapter-067__chinesenotes-daodejing-zh-20260531__seg-020", "work_id": "laozi", "section_id": "laozi-chapter-067", "source_id": "laozi-chapter-067__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 20, "canonical_ref": "老子 67.20", "sort_key": "067.020", "text_original": "夫慈以戰則勝，", "text_normalized": "夫慈以戰則勝，", "notes": ""}
{"segment_id": "laozi-chapter-067__chinesenotes-daodejing-zh-20260531__seg-021", "work_id": "laozi", "section_id": "laozi-chapter-067", "source_id": "laozi-chapter-067__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 21, "canonical_ref": "老子 67.21", "sort_key": "067.021", "text_original": "以守則固。", "text_normalized": "以守則固。", "notes": ""}
{"segment_id": "laozi-chapter-067__chinesenotes-daodejing-zh-20260531__seg-022", "work_id": "laozi", "section_id": "laozi-chapter-067", "source_id": "laozi-chapter-067__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 22, "canonical_ref": "老子 67.22", "sort_key": "067.022", "text_original": "天將救之，", "text_normalized": "天將救之，", "notes": ""}
{"segment_id": "laozi-chapter-067__chinesenotes-daodejing-zh-20260531__seg-023", "work_id": "laozi", "section_id": "laozi-chapter-067", "source_id": "laozi-chapter-067__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 23, "canonical_ref": "老子 67.23", "sort_key": "067.023", "text_original": "以慈衛之。", "text_normalized": "以慈衛之。", "notes": ""}
