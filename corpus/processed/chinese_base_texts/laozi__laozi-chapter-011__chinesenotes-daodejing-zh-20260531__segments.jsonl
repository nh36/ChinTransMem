{"segment_id": "laozi-chapter-011__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-011", "source_id": "laozi-chapter-011__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 11.1", "sort_key": "011.001", "text_original": "三十輻共一轂，當其無，有車之用。", "text_normalized": "三十輻共一轂，當其無，有車之用。", "notes": ""}
{"segment_id": "laozi-chapter-011__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-011", "source_id": "laozi-chapter-011__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 11.2", "sort_key": "011.002", "text_original": "埏埴以為器，當其無，有器之用。", "text_normalized": "埏埴以為器，當其無，有器之用。", "notes": ""}
{"segment_id": "laozi-chapter-011__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-011", "source_id": "laozi-chapter-011__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 11.3", "sort_key": "011.003", "text_original": "鑿戶牖以為室，當其無，有室之用。", "text_normalized": "鑿戶牖以為室，當其無，有室之用。", "notes": ""}
{"segment_id": "laozi-chapter-011__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-011", "source_id": "laozi-chapter-011__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 11.4", "sort_key": "011.004", "text_original": "故有之以為利，無之以為用。", "text_normalized": "故有之以為利，無之以為用。", "notes": ""}
