{"segment_id": "laozi-chapter-054__chinesenotes-daodejing-zh-20260531__seg-018", "work_id": "laozi", "section_id": "laozi-chapter-054", "source_id": "laozi-chapter-054__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 18, "canonical_ref": "老子 54.18", "sort_key": "054.018", "text_original": "以天下觀天下。", "text_normalized": "以天下觀天下。", "notes": ""}
{"segment_id": "laozi-chapter-054__chinesenotes-daodejing-zh-20260531__seg-019", "work_id": "laozi", "section_id": "laozi-chapter-054", "source_id": "laozi-chapter-054__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 19, "canonical_ref": "老子 54.19", "sort_key": "054.019", "text_original": "吾何以知天下然哉？", "text_normalized": "吾何以知天下然哉？", "notes": ""}
