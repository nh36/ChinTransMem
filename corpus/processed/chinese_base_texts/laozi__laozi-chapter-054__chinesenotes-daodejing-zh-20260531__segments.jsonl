{"segment_id": "laozi-chapter-054__chinesenotes-daodejing-zh-20260531__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-054", "source_id": "laozi-chapter-054__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 54.10", "sort_key": "054.010", "text_original": "修之於國，", "text_normalized": "修之於國，", "notes": ""}
{"segment_id": "laozi-chapter-054__chinesenotes-daodejing-zh-20260531__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-054", "source_id": "laozi-chapter-054__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 54.11", "sort_key": "054.011", "text_original": "其德乃豐；", "text_normalized": "其德乃豐；", "notes": ""}
{"segment_id": "laozi-chapter-054__chinesenotes-daodejing-zh-20260531__seg-012", "work_id": "laozi", "section_id": "laozi-chapter-054", "source_id": "laozi-chapter-054__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 12, "canonical_ref": "老子 54.12", "sort_key": "054.012", "text_original": "修之於天下，", "text_normalized": "修之於天下，", "notes": ""}
{"segment_id": "laozi-chapter-054__chinesenotes-daodejing-zh-20260531__seg-013", "work_id": "laozi", "section_id": "laozi-chapter-054", "source_id": "laozi-chapter-054__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 13, "canonical_ref": "老子 54.13", "sort_key": "054.013", "text_original": "其德乃普。", "text_normalized": "其德乃普。", "notes": ""}
{"segment_id": "laozi-chapter-054__chinesenotes-daodejing-zh-20260531__seg-014", "work_id": "laozi", "section_id": "laozi-chapter-054", "source_id": "laozi-chapter-054__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 14, "canonical_ref": "老子 54.14", "sort_key": "054.014", "text_original": "故以身觀身，", "text_normalized": "故以身觀身，", "notes": ""}
