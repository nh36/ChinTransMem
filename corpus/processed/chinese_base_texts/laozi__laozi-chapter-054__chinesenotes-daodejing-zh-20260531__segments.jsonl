{"segment_id": "laozi-chapter-054__chinesenotes-daodejing-zh-20260531__seg-016", "work_id": "laozi", "section_id": "laozi-chapter-054", "source_id": "laozi-chapter-054__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 16, "canonical_ref": "老子 54.16", "sort_key": "054.016", "text_original": "以鄉觀鄉，", "text_normalized": "以鄉觀鄉，", "notes": ""}
