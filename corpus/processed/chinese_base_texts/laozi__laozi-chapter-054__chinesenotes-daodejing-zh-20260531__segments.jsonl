{"segment_id": "laozi-chapter-054__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-054", "source_id": "laozi-chapter-054__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 54.5", "sort_key": "054.005", "text_original": "其德乃真；", "text_normalized": "其德乃真；", "notes": ""}
{"segment_id": "laozi-chapter-054__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-054", "source_id": "laozi-chapter-054__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 54.6", "sort_key": "054.006", "text_original": "修之於家，", "text_normalized": "修之於家，", "notes": ""}
{"segment_id": "laozi-chapter-054__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-054", "source_id": "laozi-chapter-054__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 54.7", "sort_key": "054.007", "text_original": "其德乃餘；", "text_normalized": "其德乃餘；", "notes": ""}
