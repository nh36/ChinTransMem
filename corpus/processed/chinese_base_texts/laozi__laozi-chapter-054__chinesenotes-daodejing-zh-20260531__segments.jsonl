{"segment_id": "laozi-chapter-054__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-054", "source_id": "laozi-chapter-054__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 54.1", "sort_key": "054.001", "text_original": "善建者不拔，", "text_normalized": "善建者不拔，", "notes": ""}
