{"segment_id": "laozi-chapter-007__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-007", "source_id": "laozi-chapter-007__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 7.1", "sort_key": "007.001", "text_original": "天長地久。", "text_normalized": "天長地久。", "notes": ""}
{"segment_id": "laozi-chapter-007__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-007", "source_id": "laozi-chapter-007__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 7.2", "sort_key": "007.002", "text_original": "天地所以能長且久者，", "text_normalized": "天地所以能長且久者，", "notes": ""}
{"segment_id": "laozi-chapter-007__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-007", "source_id": "laozi-chapter-007__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 7.3", "sort_key": "007.003", "text_original": "以其不自生，", "text_normalized": "以其不自生，", "notes": ""}
{"segment_id": "laozi-chapter-007__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-007", "source_id": "laozi-chapter-007__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 7.4", "sort_key": "007.004", "text_original": "故能長生。", "text_normalized": "故能長生。", "notes": ""}
{"segment_id": "laozi-chapter-007__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-007", "source_id": "laozi-chapter-007__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 7.5", "sort_key": "007.005", "text_original": "是以聖人後其身而身先；", "text_normalized": "是以聖人後其身而身先；", "notes": ""}
{"segment_id": "laozi-chapter-007__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-007", "source_id": "laozi-chapter-007__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 7.6", "sort_key": "007.006", "text_original": "外其身而身存。", "text_normalized": "外其身而身存。", "notes": ""}
{"segment_id": "laozi-chapter-007__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-007", "source_id": "laozi-chapter-007__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 7.7", "sort_key": "007.007", "text_original": "非以其無私邪，", "text_normalized": "非以其無私邪，", "notes": ""}
{"segment_id": "laozi-chapter-007__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-007", "source_id": "laozi-chapter-007__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 7.8", "sort_key": "007.008", "text_original": "故能成其私。", "text_normalized": "故能成其私。", "notes": ""}
