{"segment_id": "laozi-chapter-025__chinesenotes-daodejing-zh-20260531__seg-013", "work_id": "laozi", "section_id": "laozi-chapter-025", "source_id": "laozi-chapter-025__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 13, "canonical_ref": "老子 25.13", "sort_key": "025.013", "text_original": "故道大，", "text_normalized": "故道大，", "notes": ""}
