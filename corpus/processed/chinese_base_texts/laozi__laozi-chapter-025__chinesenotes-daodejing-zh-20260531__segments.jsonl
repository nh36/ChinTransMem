{"segment_id": "laozi-chapter-025__chinesenotes-daodejing-zh-20260531__seg-016", "work_id": "laozi", "section_id": "laozi-chapter-025", "source_id": "laozi-chapter-025__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 16, "canonical_ref": "老子 25.16", "sort_key": "025.016", "text_original": "王亦大。", "text_normalized": "王亦大。", "notes": ""}
{"segment_id": "laozi-chapter-025__chinesenotes-daodejing-zh-20260531__seg-017", "work_id": "laozi", "section_id": "laozi-chapter-025", "source_id": "laozi-chapter-025__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 17, "canonical_ref": "老子 25.17", "sort_key": "025.017", "text_original": "域中有四大，", "text_normalized": "域中有四大，", "notes": ""}
{"segment_id": "laozi-chapter-025__chinesenotes-daodejing-zh-20260531__seg-018", "work_id": "laozi", "section_id": "laozi-chapter-025", "source_id": "laozi-chapter-025__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 18, "canonical_ref": "老子 25.18", "sort_key": "025.018", "text_original": "而王居其一焉。", "text_normalized": "而王居其一焉。", "notes": ""}
