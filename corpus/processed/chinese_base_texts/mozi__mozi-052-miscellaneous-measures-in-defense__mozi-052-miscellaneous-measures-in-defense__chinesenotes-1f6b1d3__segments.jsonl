{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0001", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 1, "text_original": "禽子問曰：", "text_normalized": "禽子問曰：", "canonical_ref": "52.1", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0002", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 2, "text_original": "「客眾而勇，輕意見威，以駭主人。", "text_normalized": "「客眾而勇，輕意見威，以駭主人。", "canonical_ref": "52.2", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0003", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 3, "text_original": "薪土俱上，以為羊坽，積土為高，以臨民，蒙櫓俱前，遂屬之城，兵弩俱上，為之柰何？", "text_normalized": "薪土俱上，以為羊坽，積土為高，以臨民，蒙櫓俱前，遂屬之城，兵弩俱上，為之柰何？", "canonical_ref": "52.3", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0004", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 4, "text_original": "」子墨子曰：", "text_normalized": "」子墨子曰：", "canonical_ref": "52.4", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0005", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 5, "text_original": "「子問羊坽之守邪？", "text_normalized": "「子問羊坽之守邪？", "canonical_ref": "52.5", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0006", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 6, "text_original": "羊坽者攻之拙者也，足以勞卒，不足以害城。", "text_normalized": "羊坽者攻之拙者也，足以勞卒，不足以害城。", "canonical_ref": "52.6", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0007", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 7, "text_original": "羊坽之政，遠攻則遠害，近城則近害，不至城。", "text_normalized": "羊坽之政，遠攻則遠害，近城則近害，不至城。", "canonical_ref": "52.7", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0008", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 8, "text_original": "矢石無休，左右趣射，蘭為柱後，望以固。", "text_normalized": "矢石無休，左右趣射，蘭為柱後，望以固。", "canonical_ref": "52.8", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0009", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 9, "text_original": "厲吾銳卒，慎無使顧，守者重下，攻者輕去。", "text_normalized": "厲吾銳卒，慎無使顧，守者重下，攻者輕去。", "canonical_ref": "52.9", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0010", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 10, "text_original": "養勇高奮，民心百倍，多執數少，卒乃不怠。", "text_normalized": "養勇高奮，民心百倍，多執數少，卒乃不怠。", "canonical_ref": "52.10", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0011", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 11, "text_original": "作土不休，不能禁禦，遂屬之城，以禦雲梯之法應之。", "text_normalized": "作土不休，不能禁禦，遂屬之城，以禦雲梯之法應之。", "canonical_ref": "52.11", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0012", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 12, "text_original": "凡待煙、衝、雲梯、臨之法，必應城以禦之曰不足，則以木槨之。", "text_normalized": "凡待煙、衝、雲梯、臨之法，必應城以禦之曰不足，則以木槨之。", "canonical_ref": "52.12", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0013", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 13, "text_original": "左百步，右百步，繁下矢、石、沙、炭以雨之，薪火、水湯以濟之。", "text_normalized": "左百步，右百步，繁下矢、石、沙、炭以雨之，薪火、水湯以濟之。", "canonical_ref": "52.13", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0014", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 14, "text_original": "選厲銳卒，慎無使顧，審賞行罰，以靜為故，從之以急，無使生慮恙恿高憤，民心百倍，多執數賞，卒乃不怠。", "text_normalized": "選厲銳卒，慎無使顧，審賞行罰，以靜為故，從之以急，無使生慮恙恿高憤，民心百倍，多執數賞，卒乃不怠。", "canonical_ref": "52.14", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0015", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 15, "text_original": "衝、臨、梯皆以衝衝之。", "text_normalized": "衝、臨、梯皆以衝衝之。", "canonical_ref": "52.15", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0016", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 16, "text_original": "渠長丈五尺，其埋者三尺，夫長丈二尺。", "text_normalized": "渠長丈五尺，其埋者三尺，夫長丈二尺。", "canonical_ref": "52.16", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0017", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 17, "text_original": "渠廣丈六尺，其弟丈二尺，渠之垂者四尺。", "text_normalized": "渠廣丈六尺，其弟丈二尺，渠之垂者四尺。", "canonical_ref": "52.17", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0018", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 18, "text_original": "樹渠無傅堞五寸，梯渠十丈一梯，渠荅大數，里二百五十八，渠荅百二十九。", "text_normalized": "樹渠無傅堞五寸，梯渠十丈一梯，渠荅大數，里二百五十八，渠荅百二十九。", "canonical_ref": "52.18", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0019", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 19, "text_original": "諸外道可要塞以難寇，其甚害者為築三亭，亭三隅，織女之，令能相救。", "text_normalized": "諸外道可要塞以難寇，其甚害者為築三亭，亭三隅，織女之，令能相救。", "canonical_ref": "52.19", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0020", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 20, "text_original": "諸距阜、山林、溝瀆、丘陵、阡陌、郭門、若閻術，可要塞及為微職，可以跡知往來者少多及所伏藏之處。", "text_normalized": "諸距阜、山林、溝瀆、丘陵、阡陌、郭門、若閻術，可要塞及為微職，可以跡知往來者少多及所伏藏之處。", "canonical_ref": "52.20", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0021", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 21, "text_original": "葆民，先舉城中官府、民宅、室署，大小調處，葆者或欲從兄弟、知識者許之。", "text_normalized": "葆民，先舉城中官府、民宅、室署，大小調處，葆者或欲從兄弟、知識者許之。", "canonical_ref": "52.21", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0022", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 22, "text_original": "外宅粟米、畜產、財物諸可以佐城者，送入城中，事即急，則使積門內。", "text_normalized": "外宅粟米、畜產、財物諸可以佐城者，送入城中，事即急，則使積門內。", "canonical_ref": "52.22", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0023", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 23, "text_original": "民獻粟米布帛金錢牛馬畜產，皆為置平賈，與主券書之。", "text_normalized": "民獻粟米布帛金錢牛馬畜產，皆為置平賈，與主券書之。", "canonical_ref": "52.23", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0024", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 24, "text_original": "使人各得其所長，天下事當，鈞其分職，天下事得，皆其所喜，天下事備，強弱有數，天下事具矣。", "text_normalized": "使人各得其所長，天下事當，鈞其分職，天下事得，皆其所喜，天下事備，強弱有數，天下事具矣。", "canonical_ref": "52.24", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0025", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 25, "text_original": "築郵亭者圜之，高三丈以上，令侍殺。", "text_normalized": "築郵亭者圜之，高三丈以上，令侍殺。", "canonical_ref": "52.25", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0026", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 26, "text_original": "為辟梯，梯兩臂長三尺，連門三尺，報以繩連之。", "text_normalized": "為辟梯，梯兩臂長三尺，連門三尺，報以繩連之。", "canonical_ref": "52.26", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0027", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 27, "text_original": "槧再雜為縣梁。", "text_normalized": "槧再雜為縣梁。", "canonical_ref": "52.27", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0028", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 28, "text_original": "壟灶，亭一鼓。", "text_normalized": "壟灶，亭一鼓。", "canonical_ref": "52.28", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0029", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 29, "text_original": "寇烽、驚烽、亂烽，傳火以次應之，至主國止，其事急者引而上下之。", "text_normalized": "寇烽、驚烽、亂烽，傳火以次應之，至主國止，其事急者引而上下之。", "canonical_ref": "52.29", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0030", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 30, "text_original": "烽火以舉，輒五鼓傳，又以火屬之，言寇所從來者少多，旦弇還，去來屬次烽勿罷。", "text_normalized": "烽火以舉，輒五鼓傳，又以火屬之，言寇所從來者少多，旦弇還，去來屬次烽勿罷。", "canonical_ref": "52.30", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0031", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 31, "text_original": "望見寇，舉一烽；", "text_normalized": "望見寇，舉一烽；", "canonical_ref": "52.31", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0032", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 32, "text_original": "入境，舉二烽；", "text_normalized": "入境，舉二烽；", "canonical_ref": "52.32", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0033", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 33, "text_original": "射妻，舉三烽一藍；", "text_normalized": "射妻，舉三烽一藍；", "canonical_ref": "52.33", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0034", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 34, "text_original": "郭會，舉四烽二藍；", "text_normalized": "郭會，舉四烽二藍；", "canonical_ref": "52.34", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0035", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 35, "text_original": "城會，舉五烽五藍；", "text_normalized": "城會，舉五烽五藍；", "canonical_ref": "52.35", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0036", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 36, "text_original": "夜以火，如此數。", "text_normalized": "夜以火，如此數。", "canonical_ref": "52.36", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0037", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 37, "text_original": "守烽者事急。", "text_normalized": "守烽者事急。", "canonical_ref": "52.37", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0038", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 38, "text_original": "候無過五十，寇至葉，隨去之，唯弇逮。", "text_normalized": "候無過五十，寇至葉，隨去之，唯弇逮。", "canonical_ref": "52.38", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0039", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 39, "text_original": "日暮出之，令皆為微職。", "text_normalized": "日暮出之，令皆為微職。", "canonical_ref": "52.39", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0040", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 40, "text_original": "距阜、山林，皆令可以跡，平明而跡。", "text_normalized": "距阜、山林，皆令可以跡，平明而跡。", "canonical_ref": "52.40", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0041", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 41, "text_original": "無跡，各立其表，下城之應。", "text_normalized": "無跡，各立其表，下城之應。", "canonical_ref": "52.41", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0042", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 42, "text_original": "候出置田表，斥坐郭內外立旗幟，卒半在內，令多少無可知。", "text_normalized": "候出置田表，斥坐郭內外立旗幟，卒半在內，令多少無可知。", "canonical_ref": "52.42", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0043", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 43, "text_original": "即有驚，舉孔表，見寇，舉次表。", "text_normalized": "即有驚，舉孔表，見寇，舉次表。", "canonical_ref": "52.43", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0044", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 44, "text_original": "城上以麾指之，斥步鼓整旗，旗以備戰從麾所指。", "text_normalized": "城上以麾指之，斥步鼓整旗，旗以備戰從麾所指。", "canonical_ref": "52.44", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0045", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 45, "text_original": "田者男子以備備從斥，女子亟走入。", "text_normalized": "田者男子以備備從斥，女子亟走入。", "canonical_ref": "52.45", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0046", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 46, "text_original": "即見寇，到傳到城止。", "text_normalized": "即見寇，到傳到城止。", "canonical_ref": "52.46", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0047", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 47, "text_original": "守表者三人，更立捶表而望，守數令騎若吏行旁視，有以知為所為。", "text_normalized": "守表者三人，更立捶表而望，守數令騎若吏行旁視，有以知為所為。", "canonical_ref": "52.47", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0048", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 48, "text_original": "其曹一鼓。", "text_normalized": "其曹一鼓。", "canonical_ref": "52.48", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0049", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 49, "text_original": "望見寇，鼓傳到城止。", "text_normalized": "望見寇，鼓傳到城止。", "canonical_ref": "52.49", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0050", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 50, "text_original": "斗食，終歲三十六石；", "text_normalized": "斗食，終歲三十六石；", "canonical_ref": "52.50", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0051", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 51, "text_original": "參食，終歲二十四石；", "text_normalized": "參食，終歲二十四石；", "canonical_ref": "52.51", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0052", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 52, "text_original": "四食，終歲十八石；", "text_normalized": "四食，終歲十八石；", "canonical_ref": "52.52", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0053", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 53, "text_original": "五食，終歲十四石四斗；", "text_normalized": "五食，終歲十四石四斗；", "canonical_ref": "52.53", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0054", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 54, "text_original": "六食，終歲十二石。", "text_normalized": "六食，終歲十二石。", "canonical_ref": "52.54", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0055", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 55, "text_original": "斗食食五升，參食食參升小半，四食食二升半，五食食二升，六食食一升大半，日再食。", "text_normalized": "斗食食五升，參食食參升小半，四食食二升半，五食食二升，六食食一升大半，日再食。", "canonical_ref": "52.55", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0056", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 56, "text_original": "救死之時，日二升者二十日，日三升者三十日，日四升者四十日，如是，而民免於九十日之約矣。", "text_normalized": "救死之時，日二升者二十日，日三升者三十日，日四升者四十日，如是，而民免於九十日之約矣。", "canonical_ref": "52.56", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0057", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 57, "text_original": "寇近，亟收諸雜鄉金器，若銅鐵及他可以左守事者。", "text_normalized": "寇近，亟收諸雜鄉金器，若銅鐵及他可以左守事者。", "canonical_ref": "52.57", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0058", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 58, "text_original": "先舉縣官室居、官府不急者，材之大小長短及凡數，即急先發。", "text_normalized": "先舉縣官室居、官府不急者，材之大小長短及凡數，即急先發。", "canonical_ref": "52.58", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0059", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 59, "text_original": "寇薄，發屋，伐木，雖有請謁，勿聽。", "text_normalized": "寇薄，發屋，伐木，雖有請謁，勿聽。", "canonical_ref": "52.59", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0060", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 60, "text_original": "入柴，勿積魚鱗簪，當隊，令易取也。", "text_normalized": "入柴，勿積魚鱗簪，當隊，令易取也。", "canonical_ref": "52.60", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0061", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 61, "text_original": "材木不能盡入者，燔之，無令寇得用之。", "text_normalized": "材木不能盡入者，燔之，無令寇得用之。", "canonical_ref": "52.61", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0062", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 62, "text_original": "積木，各以長短大小惡美形相從，城四面外各積其內，諸木大者皆以為關鼻，乃積聚之。", "text_normalized": "積木，各以長短大小惡美形相從，城四面外各積其內，諸木大者皆以為關鼻，乃積聚之。", "canonical_ref": "52.62", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0063", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 63, "text_original": "城守司馬以上，父母、昆弟、妻子，有質在主所，乃可以堅守。", "text_normalized": "城守司馬以上，父母、昆弟、妻子，有質在主所，乃可以堅守。", "canonical_ref": "52.63", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0064", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 64, "text_original": "署都司空，大城四人，候二人，縣候面一，亭尉、次司空、亭一人。", "text_normalized": "署都司空，大城四人，候二人，縣候面一，亭尉、次司空、亭一人。", "canonical_ref": "52.64", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0065", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 65, "text_original": "吏侍守所者財足，廉信，父母昆弟妻子有在葆宮中者，乃得為侍吏。", "text_normalized": "吏侍守所者財足，廉信，父母昆弟妻子有在葆宮中者，乃得為侍吏。", "canonical_ref": "52.65", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0066", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 66, "text_original": "諸吏必有質，乃得任事。", "text_normalized": "諸吏必有質，乃得任事。", "canonical_ref": "52.66", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0067", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 67, "text_original": "守大門者二人，夾門而立，令行者趣其外。", "text_normalized": "守大門者二人，夾門而立，令行者趣其外。", "canonical_ref": "52.67", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0068", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 68, "text_original": "各四戟，夾門立，而其人坐其下。", "text_normalized": "各四戟，夾門立，而其人坐其下。", "canonical_ref": "52.68", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0069", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 69, "text_original": "吏日五閱之，上逋者名。", "text_normalized": "吏日五閱之，上逋者名。", "canonical_ref": "52.69", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0070", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 70, "text_original": "池外廉有要有害，必為疑人，令往來行夜者射之，謀其疏者。", "text_normalized": "池外廉有要有害，必為疑人，令往來行夜者射之，謀其疏者。", "canonical_ref": "52.70", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0071", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 71, "text_original": "牆外水中，為竹箭，箭尺廣二步，箭下於水五寸，雜長短，前外廉三行，外外鄉，內亦內鄉。", "text_normalized": "牆外水中，為竹箭，箭尺廣二步，箭下於水五寸，雜長短，前外廉三行，外外鄉，內亦內鄉。", "canonical_ref": "52.71", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0072", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 72, "text_original": "三十步一弩廬，廬廣十尺，袤丈二尺。", "text_normalized": "三十步一弩廬，廬廣十尺，袤丈二尺。", "canonical_ref": "52.72", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0073", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 73, "text_original": "隊有急，極發其近者往佐，其次襲其處。", "text_normalized": "隊有急，極發其近者往佐，其次襲其處。", "canonical_ref": "52.73", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0074", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 74, "text_original": "守節出入，使主節必疏書，署其情，令若其事，而須其還報以參驗之。", "text_normalized": "守節出入，使主節必疏書，署其情，令若其事，而須其還報以參驗之。", "canonical_ref": "52.74", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0075", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 75, "text_original": "節出，使所出門者，輒言節出時摻者名。", "text_normalized": "節出，使所出門者，輒言節出時摻者名。", "canonical_ref": "52.75", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0076", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 76, "text_original": "百步一隊。", "text_normalized": "百步一隊。", "canonical_ref": "52.76", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0077", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 77, "text_original": "閤通守舍，相錯穿室。", "text_normalized": "閤通守舍，相錯穿室。", "canonical_ref": "52.77", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0078", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 78, "text_original": "治復道，為築墉，墉善其上。", "text_normalized": "治復道，為築墉，墉善其上。", "canonical_ref": "52.78", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0079", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 79, "text_original": "取疏，令民家有三年畜蔬食，以備湛旱、歲不為。", "text_normalized": "取疏，令民家有三年畜蔬食，以備湛旱、歲不為。", "canonical_ref": "52.79", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0080", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 80, "text_original": "常令邊縣豫種畜芫、芸、烏喙、袾葉，外宅溝井窴可，塞不可，置此其中。", "text_normalized": "常令邊縣豫種畜芫、芸、烏喙、袾葉，外宅溝井窴可，塞不可，置此其中。", "canonical_ref": "52.80", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0081", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 81, "text_original": "安則示以危，危示以安。", "text_normalized": "安則示以危，危示以安。", "canonical_ref": "52.81", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0082", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 82, "text_original": "寇至，諸門戶令皆鑿而類竅之，各為二類，一鑿而屬繩，繩長四尺，大如指。", "text_normalized": "寇至，諸門戶令皆鑿而類竅之，各為二類，一鑿而屬繩，繩長四尺，大如指。", "canonical_ref": "52.82", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0083", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 83, "text_original": "寇至，先殺牛、羊、雞、狗、烏、鴈，收其皮革、筋、角、脂、腦、羽。", "text_normalized": "寇至，先殺牛、羊、雞、狗、烏、鴈，收其皮革、筋、角、脂、腦、羽。", "canonical_ref": "52.83", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0084", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 84, "text_original": "彘皆剝之。", "text_normalized": "彘皆剝之。", "canonical_ref": "52.84", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0085", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 85, "text_original": "使檟桐自，為鐵錍，後蘭為衡柱。", "text_normalized": "使檟桐自，為鐵錍，後蘭為衡柱。", "canonical_ref": "52.85", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0086", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 86, "text_original": "事急，卒不可遠，令掘外宅林。", "text_normalized": "事急，卒不可遠，令掘外宅林。", "canonical_ref": "52.86", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0087", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 87, "text_original": "課多少，若治城上為擊，三隅之。", "text_normalized": "課多少，若治城上為擊，三隅之。", "canonical_ref": "52.87", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0088", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 88, "text_original": "重五斤已上諸林木，渥水中，無過一茷。", "text_normalized": "重五斤已上諸林木，渥水中，無過一茷。", "canonical_ref": "52.88", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0089", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 89, "text_original": "塗茅屋若積薪者，厚五寸已上。", "text_normalized": "塗茅屋若積薪者，厚五寸已上。", "canonical_ref": "52.89", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0090", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 90, "text_original": "吏各舉其步界中財物可以左守備者上。", "text_normalized": "吏各舉其步界中財物可以左守備者上。", "canonical_ref": "52.90", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0091", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 91, "text_original": "有讒人，有利人，有惡人，有善人，有長人，有謀士，有勇士，有巧士，有使士，有內人者，外人者，有善人者，有善門人者，守必察其所以然者，應名乃內之。", "text_normalized": "有讒人，有利人，有惡人，有善人，有長人，有謀士，有勇士，有巧士，有使士，有內人者，外人者，有善人者，有善門人者，守必察其所以然者，應名乃內之。", "canonical_ref": "52.91", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0092", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 92, "text_original": "民相惡，若議吏，吏所解，皆札書藏之，以須告之至以參驗之。", "text_normalized": "民相惡，若議吏，吏所解，皆札書藏之，以須告之至以參驗之。", "canonical_ref": "52.92", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0093", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 93, "text_original": "睨者小五尺，不可卒者，為署吏，令給事官府若舍。", "text_normalized": "睨者小五尺，不可卒者，為署吏，令給事官府若舍。", "canonical_ref": "52.93", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0094", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 94, "text_original": "藺石、厲矢，諸材器用，皆謹部，各有積分數。", "text_normalized": "藺石、厲矢，諸材器用，皆謹部，各有積分數。", "canonical_ref": "52.94", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0095", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 95, "text_original": "為軺車以梓，載矢以軺車，輪轂，廣十尺，轅長丈，為三輻，廣六尺。", "text_normalized": "為軺車以梓，載矢以軺車，輪轂，廣十尺，轅長丈，為三輻，廣六尺。", "canonical_ref": "52.95", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0096", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 96, "text_original": "為板箱長與轅等高四尺，善蓋上治中令可載矢。", "text_normalized": "為板箱長與轅等高四尺，善蓋上治中令可載矢。", "canonical_ref": "52.96", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0097", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 97, "text_original": "」", "text_normalized": "」", "canonical_ref": "52.97", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0098", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 98, "text_original": "子墨子曰：", "text_normalized": "子墨子曰：", "canonical_ref": "52.98", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0099", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 99, "text_original": "「凡不守者有五：", "text_normalized": "「凡不守者有五：", "canonical_ref": "52.99", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0100", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 100, "text_original": "城大人少，一不守也；", "text_normalized": "城大人少，一不守也；", "canonical_ref": "52.100", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0101", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 101, "text_original": "城小人眾，二不守也；", "text_normalized": "城小人眾，二不守也；", "canonical_ref": "52.101", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0102", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 102, "text_original": "人眾食寡，三不守也；", "text_normalized": "人眾食寡，三不守也；", "canonical_ref": "52.102", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0103", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 103, "text_original": "市去城遠，四不守也；", "text_normalized": "市去城遠，四不守也；", "canonical_ref": "52.103", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0104", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 104, "text_original": "畜積在外，富人在虛，五不守也。", "text_normalized": "畜積在外，富人在虛，五不守也。", "canonical_ref": "52.104", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0105", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 105, "text_original": "率萬家而城方三里。", "text_normalized": "率萬家而城方三里。", "canonical_ref": "52.105", "notes": ""}
{"segment_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3__seg-0106", "section_id": "mozi-052-miscellaneous-measures-in-defense", "source_id": "mozi-052-miscellaneous-measures-in-defense__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 106, "text_original": "」", "text_normalized": "」", "canonical_ref": "52.106", "notes": ""}
