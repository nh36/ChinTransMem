{"segment_id": "laozi-chapter-075__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-075", "source_id": "laozi-chapter-075__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 75.5", "sort_key": "075.005", "text_original": "以其上之有為，", "text_normalized": "以其上之有為，", "notes": ""}
{"segment_id": "laozi-chapter-075__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-075", "source_id": "laozi-chapter-075__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 75.6", "sort_key": "075.006", "text_original": "是以難治。", "text_normalized": "是以難治。", "notes": ""}
{"segment_id": "laozi-chapter-075__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-075", "source_id": "laozi-chapter-075__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 75.7", "sort_key": "075.007", "text_original": "民之輕死，", "text_normalized": "民之輕死，", "notes": ""}
{"segment_id": "laozi-chapter-075__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-075", "source_id": "laozi-chapter-075__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 75.8", "sort_key": "075.008", "text_original": "以其上求生之厚，", "text_normalized": "以其上求生之厚，", "notes": ""}
{"segment_id": "laozi-chapter-075__chinesenotes-daodejing-zh-20260531__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-075", "source_id": "laozi-chapter-075__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 75.9", "sort_key": "075.009", "text_original": "是以輕死。", "text_normalized": "是以輕死。", "notes": ""}
{"segment_id": "laozi-chapter-075__chinesenotes-daodejing-zh-20260531__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-075", "source_id": "laozi-chapter-075__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 75.10", "sort_key": "075.010", "text_original": "夫唯無以生為者，", "text_normalized": "夫唯無以生為者，", "notes": ""}
{"segment_id": "laozi-chapter-075__chinesenotes-daodejing-zh-20260531__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-075", "source_id": "laozi-chapter-075__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 75.11", "sort_key": "075.011", "text_original": "是賢於貴生。", "text_normalized": "是賢於貴生。", "notes": ""}
