{"segment_id": "laozi-chapter-075__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-075", "source_id": "laozi-chapter-075__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 75.1", "sort_key": "075.001", "text_original": "民之饑，", "text_normalized": "民之饑，", "notes": ""}
{"segment_id": "laozi-chapter-075__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-075", "source_id": "laozi-chapter-075__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 75.2", "sort_key": "075.002", "text_original": "以其上食稅之多，", "text_normalized": "以其上食稅之多，", "notes": ""}
