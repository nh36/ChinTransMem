{"segment_id": "laozi-chapter-048__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-048", "source_id": "laozi-chapter-048__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 48.4", "sort_key": "048.004", "text_original": "以至於無為。", "text_normalized": "以至於無為。", "notes": ""}
{"segment_id": "laozi-chapter-048__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-048", "source_id": "laozi-chapter-048__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 48.5", "sort_key": "048.005", "text_original": "無為而無不為。", "text_normalized": "無為而無不為。", "notes": ""}
{"segment_id": "laozi-chapter-048__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-048", "source_id": "laozi-chapter-048__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 48.6", "sort_key": "048.006", "text_original": "取天下常以無事，", "text_normalized": "取天下常以無事，", "notes": ""}
{"segment_id": "laozi-chapter-048__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-048", "source_id": "laozi-chapter-048__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 48.7", "sort_key": "048.007", "text_original": "及其有事，", "text_normalized": "及其有事，", "notes": ""}
{"segment_id": "laozi-chapter-048__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-048", "source_id": "laozi-chapter-048__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 48.8", "sort_key": "048.008", "text_original": "不足以取天下。", "text_normalized": "不足以取天下。", "notes": ""}
