{"segment_id": "laozi-chapter-048__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-048", "source_id": "laozi-chapter-048__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 48.2", "sort_key": "048.002", "text_original": "為道日損。", "text_normalized": "為道日損。", "notes": ""}
