{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0001", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 1, "text_original": "故，所得而後成也，止以久也。", "text_normalized": "故，所得而後成也，止以久也。", "canonical_ref": "31.1", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0002", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 2, "text_original": "體，分於兼也，必不已也。", "text_normalized": "體，分於兼也，必不已也。", "canonical_ref": "31.2", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0003", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 3, "text_original": "智，材也。", "text_normalized": "智，材也。", "canonical_ref": "31.3", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0004", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 4, "text_original": "平，同高也。", "text_normalized": "平，同高也。", "canonical_ref": "31.4", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0005", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 5, "text_original": "慮，求也。", "text_normalized": "慮，求也。", "canonical_ref": "31.5", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0006", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 6, "text_original": "同長，以擊缶相盡也。", "text_normalized": "同長，以擊缶相盡也。", "canonical_ref": "31.6", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0007", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 7, "text_original": "知，接也。", "text_normalized": "知，接也。", "canonical_ref": "31.7", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0008", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 8, "text_original": "中，同長也。", "text_normalized": "中，同長也。", "canonical_ref": "31.8", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0009", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 9, "text_original": "𢜔，明也。", "text_normalized": "𢜔，明也。", "canonical_ref": "31.9", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0010", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 10, "text_original": "厚，有所大也。", "text_normalized": "厚，有所大也。", "canonical_ref": "31.10", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0011", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 11, "text_original": "仁，體愛也。", "text_normalized": "仁，體愛也。", "canonical_ref": "31.11", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0012", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 12, "text_original": "日中，缶南也。", "text_normalized": "日中，缶南也。", "canonical_ref": "31.12", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0013", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 13, "text_original": "義，利也。", "text_normalized": "義，利也。", "canonical_ref": "31.13", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0014", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 14, "text_original": "直，參也。", "text_normalized": "直，參也。", "canonical_ref": "31.14", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0015", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 15, "text_original": "禮，敬也。", "text_normalized": "禮，敬也。", "canonical_ref": "31.15", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0016", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 16, "text_original": "圜，一中同長也。", "text_normalized": "圜，一中同長也。", "canonical_ref": "31.16", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0017", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 17, "text_original": "行，為也。", "text_normalized": "行，為也。", "canonical_ref": "31.17", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0018", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 18, "text_original": "方柱，隅四讙也。", "text_normalized": "方柱，隅四讙也。", "canonical_ref": "31.18", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0019", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 19, "text_original": "實，榮也。", "text_normalized": "實，榮也。", "canonical_ref": "31.19", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0020", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 20, "text_original": "倍，為二也。", "text_normalized": "倍，為二也。", "canonical_ref": "31.20", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0021", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 21, "text_original": "忠，以為利而強低也。", "text_normalized": "忠，以為利而強低也。", "canonical_ref": "31.21", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0022", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 22, "text_original": "端，體之無序而最前者也。", "text_normalized": "端，體之無序而最前者也。", "canonical_ref": "31.22", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0023", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 23, "text_original": "孝，利親也。", "text_normalized": "孝，利親也。", "canonical_ref": "31.23", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0024", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 24, "text_original": "有，間中也。", "text_normalized": "有，間中也。", "canonical_ref": "31.24", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0025", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 25, "text_original": "信，言合於意也。", "text_normalized": "信，言合於意也。", "canonical_ref": "31.25", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0026", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 26, "text_original": "佴，自作也。", "text_normalized": "佴，自作也。", "canonical_ref": "31.26", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0027", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 27, "text_original": "間，不及旁也。", "text_normalized": "間，不及旁也。", "canonical_ref": "31.27", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0028", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 28, "text_original": "佴，自作也。", "text_normalized": "佴，自作也。", "canonical_ref": "31.28", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0029", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 29, "text_original": "纑，間虛也。", "text_normalized": "纑，間虛也。", "canonical_ref": "31.29", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0030", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 30, "text_original": "𧨜，作嗛也。", "text_normalized": "𧨜，作嗛也。", "canonical_ref": "31.30", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0031", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 31, "text_original": "盈，莫不有也。", "text_normalized": "盈，莫不有也。", "canonical_ref": "31.31", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0032", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 32, "text_original": "廉，作非也。", "text_normalized": "廉，作非也。", "canonical_ref": "31.32", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0033", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 33, "text_original": "堅白，不相外也。", "text_normalized": "堅白，不相外也。", "canonical_ref": "31.33", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0034", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 34, "text_original": "令，不為所作也攖，相得也。", "text_normalized": "令，不為所作也攖，相得也。", "canonical_ref": "31.34", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0035", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 35, "text_original": "任，士損己而益所為也。", "text_normalized": "任，士損己而益所為也。", "canonical_ref": "31.35", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0036", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 36, "text_original": "似，有以相攖有不相攖也。", "text_normalized": "似，有以相攖有不相攖也。", "canonical_ref": "31.36", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0037", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 37, "text_original": "勇，志之所以敢也。", "text_normalized": "勇，志之所以敢也。", "canonical_ref": "31.37", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0038", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 38, "text_original": "次，無間而不攖攖也。", "text_normalized": "次，無間而不攖攖也。", "canonical_ref": "31.38", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0039", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 39, "text_original": "力，刑之所以奮也。", "text_normalized": "力，刑之所以奮也。", "canonical_ref": "31.39", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0040", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 40, "text_original": "法，所若而然也。", "text_normalized": "法，所若而然也。", "canonical_ref": "31.40", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0041", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 41, "text_original": "生，刑與知處也。", "text_normalized": "生，刑與知處也。", "canonical_ref": "31.41", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0042", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 42, "text_original": "佴，所然也。", "text_normalized": "佴，所然也。", "canonical_ref": "31.42", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0043", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 43, "text_original": "臥，知無知也。", "text_normalized": "臥，知無知也。", "canonical_ref": "31.43", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0044", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 44, "text_original": "說，所以明也。", "text_normalized": "說，所以明也。", "canonical_ref": "31.44", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0045", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 45, "text_original": "夢，臥而以為然也。", "text_normalized": "夢，臥而以為然也。", "canonical_ref": "31.45", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0046", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 46, "text_original": "攸，不可兩不可也。", "text_normalized": "攸，不可兩不可也。", "canonical_ref": "31.46", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0047", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 47, "text_original": "平，知無欲惡也。", "text_normalized": "平，知無欲惡也。", "canonical_ref": "31.47", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0048", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 48, "text_original": "辯，爭攸也。", "text_normalized": "辯，爭攸也。", "canonical_ref": "31.48", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0049", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 49, "text_original": "辯，勝當也。", "text_normalized": "辯，勝當也。", "canonical_ref": "31.49", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0050", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 50, "text_original": "利，所得而喜也。", "text_normalized": "利，所得而喜也。", "canonical_ref": "31.50", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0051", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 51, "text_original": "為，窮知而𠐴於欲也。", "text_normalized": "為，窮知而𠐴於欲也。", "canonical_ref": "31.51", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0052", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 52, "text_original": "害，所得而惡也，已成亡。", "text_normalized": "害，所得而惡也，已成亡。", "canonical_ref": "31.52", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0053", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 53, "text_original": "治，求得也，使謂故。", "text_normalized": "治，求得也，使謂故。", "canonical_ref": "31.53", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0054", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 54, "text_original": "譽，明美也，名達類私。", "text_normalized": "譽，明美也，名達類私。", "canonical_ref": "31.54", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0055", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 55, "text_original": "誹，明惡也，謂疑舉加。", "text_normalized": "誹，明惡也，謂疑舉加。", "canonical_ref": "31.55", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0056", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 56, "text_original": "舉，擬實也，知間說親，名實合為。", "text_normalized": "舉，擬實也，知間說親，名實合為。", "canonical_ref": "31.56", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0057", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 57, "text_original": "言，出舉也，聞博親且。", "text_normalized": "言，出舉也，聞博親且。", "canonical_ref": "31.57", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0058", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 58, "text_original": "且，言然也，見體盡。", "text_normalized": "且，言然也，見體盡。", "canonical_ref": "31.58", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0059", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 59, "text_original": "君，臣萌通約也，合缶宜必。", "text_normalized": "君，臣萌通約也，合缶宜必。", "canonical_ref": "31.59", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0060", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 60, "text_original": "功，利民也，欲缶權利且惡缶權害。", "text_normalized": "功，利民也，欲缶權利且惡缶權害。", "canonical_ref": "31.60", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0061", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 61, "text_original": "賞，上報下之功也，為存亡、易蕩、治化。", "text_normalized": "賞，上報下之功也，為存亡、易蕩、治化。", "canonical_ref": "31.61", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0062", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 62, "text_original": "罪，犯禁也，同重體合類。", "text_normalized": "罪，犯禁也，同重體合類。", "canonical_ref": "31.62", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0063", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 63, "text_original": "罰，上報下之罪也。", "text_normalized": "罰，上報下之罪也。", "canonical_ref": "31.63", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0064", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 64, "text_original": "異二體，不合不類，同異而俱於之一也。", "text_normalized": "異二體，不合不類，同異而俱於之一也。", "canonical_ref": "31.64", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0065", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 65, "text_original": "同異交得放有無。", "text_normalized": "同異交得放有無。", "canonical_ref": "31.65", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0066", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 66, "text_original": "久，彌異時也。", "text_normalized": "久，彌異時也。", "canonical_ref": "31.66", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0067", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 67, "text_original": "守，彌異所也。", "text_normalized": "守，彌異所也。", "canonical_ref": "31.67", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0068", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 68, "text_original": "聞，耳之聰也。", "text_normalized": "聞，耳之聰也。", "canonical_ref": "31.68", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0069", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 69, "text_original": "窮，或有前不容尺也，循所聞而得其意心也察也。", "text_normalized": "窮，或有前不容尺也，循所聞而得其意心也察也。", "canonical_ref": "31.69", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0070", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 70, "text_original": "盡，莫不然也。", "text_normalized": "盡，莫不然也。", "canonical_ref": "31.70", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0071", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 71, "text_original": "言，口之利也。", "text_normalized": "言，口之利也。", "canonical_ref": "31.71", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0072", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 72, "text_original": "始，當時也，執所言而意得見心之辯也。", "text_normalized": "始，當時也，執所言而意得見心之辯也。", "canonical_ref": "31.72", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0073", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 73, "text_original": "化，徵易也，諾不一利用。", "text_normalized": "化，徵易也，諾不一利用。", "canonical_ref": "31.73", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0074", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 74, "text_original": "損，偏去也。", "text_normalized": "損，偏去也。", "canonical_ref": "31.74", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0075", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 75, "text_original": "服執說巧，轉則求其故，大益。", "text_normalized": "服執說巧，轉則求其故，大益。", "canonical_ref": "31.75", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0076", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 76, "text_original": "儇𥟭秪，法同則觀其同，庫易也；", "text_normalized": "儇𥟭秪，法同則觀其同，庫易也；", "canonical_ref": "31.76", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0077", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 77, "text_original": "法異則觀其宜，動或從也。", "text_normalized": "法異則觀其宜，動或從也。", "canonical_ref": "31.77", "notes": ""}
{"segment_id": "mozi-031-canon-i__chinesenotes-1f6b1d3__seg-0078", "section_id": "mozi-031-canon-i", "source_id": "mozi-031-canon-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 78, "text_original": "止因以別道讀此書，旁行缶無非。", "text_normalized": "止因以別道讀此書，旁行缶無非。", "canonical_ref": "31.78", "notes": ""}
