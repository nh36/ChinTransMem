{"segment_id": "laozi-chapter-046__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-046", "source_id": "laozi-chapter-046__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 46.1", "sort_key": "046.001", "text_original": "天下有道，", "text_normalized": "天下有道，", "notes": ""}
{"segment_id": "laozi-chapter-046__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-046", "source_id": "laozi-chapter-046__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 46.2", "sort_key": "046.002", "text_original": "卻走馬以糞。", "text_normalized": "卻走馬以糞。", "notes": ""}
{"segment_id": "laozi-chapter-046__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-046", "source_id": "laozi-chapter-046__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 46.3", "sort_key": "046.003", "text_original": "天下無道，", "text_normalized": "天下無道，", "notes": ""}
{"segment_id": "laozi-chapter-046__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-046", "source_id": "laozi-chapter-046__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 46.4", "sort_key": "046.004", "text_original": "戎馬生於郊。", "text_normalized": "戎馬生於郊。", "notes": ""}
{"segment_id": "laozi-chapter-046__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-046", "source_id": "laozi-chapter-046__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 46.5", "sort_key": "046.005", "text_original": "〉禍莫大於不知足；", "text_normalized": "〉禍莫大於不知足；", "notes": ""}
{"segment_id": "laozi-chapter-046__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-046", "source_id": "laozi-chapter-046__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 46.6", "sort_key": "046.006", "text_original": "咎莫大於欲得。", "text_normalized": "咎莫大於欲得。", "notes": ""}
{"segment_id": "laozi-chapter-046__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-046", "source_id": "laozi-chapter-046__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 46.7", "sort_key": "046.007", "text_original": "故知足之足，", "text_normalized": "故知足之足，", "notes": ""}
{"segment_id": "laozi-chapter-046__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-046", "source_id": "laozi-chapter-046__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 46.8", "sort_key": "046.008", "text_original": "常足矣。", "text_normalized": "常足矣。", "notes": ""}
