{"segment_id": "laozi-chapter-023__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-023", "source_id": "laozi-chapter-023__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 23.1", "sort_key": "023.001", "text_original": "希言自然。", "text_normalized": "希言自然。", "notes": ""}
{"segment_id": "laozi-chapter-023__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-023", "source_id": "laozi-chapter-023__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 23.2", "sort_key": "023.002", "text_original": "故飄風不終朝，", "text_normalized": "故飄風不終朝，", "notes": ""}
{"segment_id": "laozi-chapter-023__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-023", "source_id": "laozi-chapter-023__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 23.3", "sort_key": "023.003", "text_original": "驟雨不終日。", "text_normalized": "驟雨不終日。", "notes": ""}
{"segment_id": "laozi-chapter-023__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-023", "source_id": "laozi-chapter-023__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 23.4", "sort_key": "023.004", "text_original": "孰為此者？", "text_normalized": "孰為此者？", "notes": ""}
{"segment_id": "laozi-chapter-023__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-023", "source_id": "laozi-chapter-023__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 23.5", "sort_key": "023.005", "text_original": "天地。", "text_normalized": "天地。", "notes": ""}
{"segment_id": "laozi-chapter-023__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-023", "source_id": "laozi-chapter-023__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 23.6", "sort_key": "023.006", "text_original": "天地尚不能久，", "text_normalized": "天地尚不能久，", "notes": ""}
{"segment_id": "laozi-chapter-023__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-023", "source_id": "laozi-chapter-023__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 23.7", "sort_key": "023.007", "text_original": "而況於人乎？", "text_normalized": "而況於人乎？", "notes": ""}
{"segment_id": "laozi-chapter-023__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-023", "source_id": "laozi-chapter-023__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 23.8", "sort_key": "023.008", "text_original": "故從事於道者，", "text_normalized": "故從事於道者，", "notes": ""}
{"segment_id": "laozi-chapter-023__chinesenotes-daodejing-zh-20260531__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-023", "source_id": "laozi-chapter-023__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 23.9", "sort_key": "023.009", "text_original": "道者同於道，", "text_normalized": "道者同於道，", "notes": ""}
{"segment_id": "laozi-chapter-023__chinesenotes-daodejing-zh-20260531__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-023", "source_id": "laozi-chapter-023__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 23.10", "sort_key": "023.010", "text_original": "德者同於德，", "text_normalized": "德者同於德，", "notes": ""}
{"segment_id": "laozi-chapter-023__chinesenotes-daodejing-zh-20260531__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-023", "source_id": "laozi-chapter-023__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 23.11", "sort_key": "023.011", "text_original": "失者同於失。", "text_normalized": "失者同於失。", "notes": ""}
{"segment_id": "laozi-chapter-023__chinesenotes-daodejing-zh-20260531__seg-012", "work_id": "laozi", "section_id": "laozi-chapter-023", "source_id": "laozi-chapter-023__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 12, "canonical_ref": "老子 23.12", "sort_key": "023.012", "text_original": "同於道者，", "text_normalized": "同於道者，", "notes": ""}
{"segment_id": "laozi-chapter-023__chinesenotes-daodejing-zh-20260531__seg-013", "work_id": "laozi", "section_id": "laozi-chapter-023", "source_id": "laozi-chapter-023__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 13, "canonical_ref": "老子 23.13", "sort_key": "023.013", "text_original": "道亦樂得之；", "text_normalized": "道亦樂得之；", "notes": ""}
{"segment_id": "laozi-chapter-023__chinesenotes-daodejing-zh-20260531__seg-014", "work_id": "laozi", "section_id": "laozi-chapter-023", "source_id": "laozi-chapter-023__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 14, "canonical_ref": "老子 23.14", "sort_key": "023.014", "text_original": "同於德者，", "text_normalized": "同於德者，", "notes": ""}
{"segment_id": "laozi-chapter-023__chinesenotes-daodejing-zh-20260531__seg-015", "work_id": "laozi", "section_id": "laozi-chapter-023", "source_id": "laozi-chapter-023__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 15, "canonical_ref": "老子 23.15", "sort_key": "023.015", "text_original": "德亦樂得之；", "text_normalized": "德亦樂得之；", "notes": ""}
{"segment_id": "laozi-chapter-023__chinesenotes-daodejing-zh-20260531__seg-016", "work_id": "laozi", "section_id": "laozi-chapter-023", "source_id": "laozi-chapter-023__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 16, "canonical_ref": "老子 23.16", "sort_key": "023.016", "text_original": "同於失者，", "text_normalized": "同於失者，", "notes": ""}
{"segment_id": "laozi-chapter-023__chinesenotes-daodejing-zh-20260531__seg-017", "work_id": "laozi", "section_id": "laozi-chapter-023", "source_id": "laozi-chapter-023__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 17, "canonical_ref": "老子 23.17", "sort_key": "023.017", "text_original": "失亦樂得之。", "text_normalized": "失亦樂得之。", "notes": ""}
{"segment_id": "laozi-chapter-023__chinesenotes-daodejing-zh-20260531__seg-018", "work_id": "laozi", "section_id": "laozi-chapter-023", "source_id": "laozi-chapter-023__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 18, "canonical_ref": "老子 23.18", "sort_key": "023.018", "text_original": "信不足焉，", "text_normalized": "信不足焉，", "notes": ""}
{"segment_id": "laozi-chapter-023__chinesenotes-daodejing-zh-20260531__seg-019", "work_id": "laozi", "section_id": "laozi-chapter-023", "source_id": "laozi-chapter-023__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 19, "canonical_ref": "老子 23.19", "sort_key": "023.019", "text_original": "有不信焉。", "text_normalized": "有不信焉。", "notes": ""}
