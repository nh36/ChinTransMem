{"segment_id": "shijing__guofeng-qinfeng-007__001__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-qinfeng-007", "source_id": "guofeng-qinfeng-007__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 1, "canonical_ref": "詩經·國風·秦風·007.1", "text_original": "鴥彼晨風，鬱彼北林，未見君子，憂心欽欽，如何如何，忘我實多。", "text_normalized": "鴥彼晨風，鬱彼北林，未見君子，憂心欽欽，如何如何，忘我實多。", "notes": "晨風 Chinese stanza 1."}
{"segment_id": "shijing__guofeng-qinfeng-007__002__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-qinfeng-007", "source_id": "guofeng-qinfeng-007__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 2, "canonical_ref": "詩經·國風·秦風·007.2", "text_original": "山有苞櫟，隰有六駮，未見君子，憂心靡樂，如何如何，忘我實多。", "text_normalized": "山有苞櫟，隰有六駮，未見君子，憂心靡樂，如何如何，忘我實多。", "notes": "晨風 Chinese stanza 2."}
