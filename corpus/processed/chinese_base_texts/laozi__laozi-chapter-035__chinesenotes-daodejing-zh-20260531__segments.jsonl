{"segment_id": "laozi-chapter-035__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-035", "source_id": "laozi-chapter-035__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 35.1", "sort_key": "035.001", "text_original": "執大象，天下往。", "text_normalized": "執大象，天下往。", "notes": ""}
{"segment_id": "laozi-chapter-035__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-035", "source_id": "laozi-chapter-035__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 35.2", "sort_key": "035.002", "text_original": "往而不害，安平太。", "text_normalized": "往而不害，安平太。", "notes": ""}
{"segment_id": "laozi-chapter-035__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-035", "source_id": "laozi-chapter-035__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 35.3", "sort_key": "035.003", "text_original": "樂與餌，過客止。", "text_normalized": "樂與餌，過客止。", "notes": ""}
{"segment_id": "laozi-chapter-035__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-035", "source_id": "laozi-chapter-035__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 35.4", "sort_key": "035.004", "text_original": "道之出口，淡乎其無味，視之不足見，聽之不足聞，用之不足既。", "text_normalized": "道之出口，淡乎其無味，視之不足見，聽之不足聞，用之不足既。", "notes": ""}
