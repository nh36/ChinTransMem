{"segment_id": "laozi-chapter-074__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-074", "source_id": "laozi-chapter-074__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 74.1", "sort_key": "074.001", "text_original": "民不畏死，", "text_normalized": "民不畏死，", "notes": ""}
{"segment_id": "laozi-chapter-074__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-074", "source_id": "laozi-chapter-074__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 74.2", "sort_key": "074.002", "text_original": "奈何以死懼之？", "text_normalized": "奈何以死懼之？", "notes": ""}
{"segment_id": "laozi-chapter-074__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-074", "source_id": "laozi-chapter-074__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 74.3", "sort_key": "074.003", "text_original": "若使民常畏死，", "text_normalized": "若使民常畏死，", "notes": ""}
{"segment_id": "laozi-chapter-074__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-074", "source_id": "laozi-chapter-074__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 74.4", "sort_key": "074.004", "text_original": "而為奇者，", "text_normalized": "而為奇者，", "notes": ""}
{"segment_id": "laozi-chapter-074__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-074", "source_id": "laozi-chapter-074__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 74.5", "sort_key": "074.005", "text_original": "吾得執而殺之，", "text_normalized": "吾得執而殺之，", "notes": ""}
{"segment_id": "laozi-chapter-074__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-074", "source_id": "laozi-chapter-074__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 74.6", "sort_key": "074.006", "text_original": "孰敢？", "text_normalized": "孰敢？", "notes": ""}
{"segment_id": "laozi-chapter-074__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-074", "source_id": "laozi-chapter-074__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 74.7", "sort_key": "074.007", "text_original": "常有司殺者殺，", "text_normalized": "常有司殺者殺，", "notes": ""}
{"segment_id": "laozi-chapter-074__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-074", "source_id": "laozi-chapter-074__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 74.8", "sort_key": "074.008", "text_original": "夫代司殺者殺，", "text_normalized": "夫代司殺者殺，", "notes": ""}
{"segment_id": "laozi-chapter-074__chinesenotes-daodejing-zh-20260531__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-074", "source_id": "laozi-chapter-074__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 74.9", "sort_key": "074.009", "text_original": "是謂代大匠斲。", "text_normalized": "是謂代大匠斲。", "notes": ""}
{"segment_id": "laozi-chapter-074__chinesenotes-daodejing-zh-20260531__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-074", "source_id": "laozi-chapter-074__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 74.10", "sort_key": "074.010", "text_original": "夫代大匠斲者，", "text_normalized": "夫代大匠斲者，", "notes": ""}
{"segment_id": "laozi-chapter-074__chinesenotes-daodejing-zh-20260531__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-074", "source_id": "laozi-chapter-074__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 74.11", "sort_key": "074.011", "text_original": "希有不傷其手矣。", "text_normalized": "希有不傷其手矣。", "notes": ""}
