{"segment_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3__seg-0001", "section_id": "mozi-014-universal-love-i", "source_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 1, "text_original": "聖人以治天下爲事者也，必知亂之所自起，焉能治之。", "text_normalized": "聖人以治天下爲事者也，必知亂之所自起，焉能治之。", "canonical_ref": "14.1", "notes": ""}
{"segment_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3__seg-0002", "section_id": "mozi-014-universal-love-i", "source_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 2, "text_original": "不知亂之所自起，則不能治。", "text_normalized": "不知亂之所自起，則不能治。", "canonical_ref": "14.2", "notes": ""}
{"segment_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3__seg-0003", "section_id": "mozi-014-universal-love-i", "source_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 3, "text_original": "譬之如醫之攻人之疾者然，必知疾之所自起，焉能攻之。", "text_normalized": "譬之如醫之攻人之疾者然，必知疾之所自起，焉能攻之。", "canonical_ref": "14.3", "notes": ""}
{"segment_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3__seg-0004", "section_id": "mozi-014-universal-love-i", "source_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 4, "text_original": "不知疾之所自起，則弗能攻。", "text_normalized": "不知疾之所自起，則弗能攻。", "canonical_ref": "14.4", "notes": ""}
{"segment_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3__seg-0005", "section_id": "mozi-014-universal-love-i", "source_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 5, "text_original": "治亂者何獨不然？", "text_normalized": "治亂者何獨不然？", "canonical_ref": "14.5", "notes": ""}
{"segment_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3__seg-0006", "section_id": "mozi-014-universal-love-i", "source_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 6, "text_original": "必知亂之所自起，焉能治之。", "text_normalized": "必知亂之所自起，焉能治之。", "canonical_ref": "14.6", "notes": ""}
{"segment_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3__seg-0007", "section_id": "mozi-014-universal-love-i", "source_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 7, "text_original": "不知亂之所自起，則弗能治。", "text_normalized": "不知亂之所自起，則弗能治。", "canonical_ref": "14.7", "notes": ""}
{"segment_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3__seg-0008", "section_id": "mozi-014-universal-love-i", "source_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 8, "text_original": "聖人以治天下爲事者也，不可不察亂之所自起。", "text_normalized": "聖人以治天下爲事者也，不可不察亂之所自起。", "canonical_ref": "14.8", "notes": ""}
{"segment_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3__seg-0009", "section_id": "mozi-014-universal-love-i", "source_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 9, "text_original": "當察亂何自起？", "text_normalized": "當察亂何自起？", "canonical_ref": "14.9", "notes": ""}
{"segment_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3__seg-0010", "section_id": "mozi-014-universal-love-i", "source_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 10, "text_original": "起不相愛。", "text_normalized": "起不相愛。", "canonical_ref": "14.10", "notes": ""}
{"segment_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3__seg-0011", "section_id": "mozi-014-universal-love-i", "source_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 11, "text_original": "臣子之不孝君父，所謂亂也。", "text_normalized": "臣子之不孝君父，所謂亂也。", "canonical_ref": "14.11", "notes": ""}
{"segment_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3__seg-0012", "section_id": "mozi-014-universal-love-i", "source_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 12, "text_original": "子自愛，不愛父，故虧父而自利。", "text_normalized": "子自愛，不愛父，故虧父而自利。", "canonical_ref": "14.12", "notes": ""}
{"segment_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3__seg-0013", "section_id": "mozi-014-universal-love-i", "source_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 13, "text_original": "弟自愛，不愛兄，故虧兄而自利。", "text_normalized": "弟自愛，不愛兄，故虧兄而自利。", "canonical_ref": "14.13", "notes": ""}
{"segment_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3__seg-0014", "section_id": "mozi-014-universal-love-i", "source_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 14, "text_original": "臣自愛，不愛君，故虧君而自利。", "text_normalized": "臣自愛，不愛君，故虧君而自利。", "canonical_ref": "14.14", "notes": ""}
{"segment_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3__seg-0015", "section_id": "mozi-014-universal-love-i", "source_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 15, "text_original": "此所謂亂也。", "text_normalized": "此所謂亂也。", "canonical_ref": "14.15", "notes": ""}
{"segment_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3__seg-0016", "section_id": "mozi-014-universal-love-i", "source_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 16, "text_original": "雖父之不慈子，兄之不慈弟，君之不慈臣，此亦天下之所謂亂也。", "text_normalized": "雖父之不慈子，兄之不慈弟，君之不慈臣，此亦天下之所謂亂也。", "canonical_ref": "14.16", "notes": ""}
{"segment_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3__seg-0017", "section_id": "mozi-014-universal-love-i", "source_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 17, "text_original": "父自愛也，不愛子，故虧子而自利。", "text_normalized": "父自愛也，不愛子，故虧子而自利。", "canonical_ref": "14.17", "notes": ""}
{"segment_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3__seg-0018", "section_id": "mozi-014-universal-love-i", "source_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 18, "text_original": "兄自愛也，不愛弟，故虧弟而自利。", "text_normalized": "兄自愛也，不愛弟，故虧弟而自利。", "canonical_ref": "14.18", "notes": ""}
{"segment_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3__seg-0019", "section_id": "mozi-014-universal-love-i", "source_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 19, "text_original": "君自愛也，不愛臣，故虧臣而自利。", "text_normalized": "君自愛也，不愛臣，故虧臣而自利。", "canonical_ref": "14.19", "notes": ""}
{"segment_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3__seg-0020", "section_id": "mozi-014-universal-love-i", "source_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 20, "text_original": "是何也？", "text_normalized": "是何也？", "canonical_ref": "14.20", "notes": ""}
{"segment_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3__seg-0021", "section_id": "mozi-014-universal-love-i", "source_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 21, "text_original": "皆起不相愛。", "text_normalized": "皆起不相愛。", "canonical_ref": "14.21", "notes": ""}
{"segment_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3__seg-0022", "section_id": "mozi-014-universal-love-i", "source_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 22, "text_original": "雖至天下之爲盜賊者亦然。", "text_normalized": "雖至天下之爲盜賊者亦然。", "canonical_ref": "14.22", "notes": ""}
{"segment_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3__seg-0023", "section_id": "mozi-014-universal-love-i", "source_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 23, "text_original": "盜愛其室，不愛其異室，故竊異室以利其室。", "text_normalized": "盜愛其室，不愛其異室，故竊異室以利其室。", "canonical_ref": "14.23", "notes": ""}
{"segment_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3__seg-0024", "section_id": "mozi-014-universal-love-i", "source_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 24, "text_original": "賊愛其身，不愛人，故賊人以利其身。", "text_normalized": "賊愛其身，不愛人，故賊人以利其身。", "canonical_ref": "14.24", "notes": ""}
{"segment_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3__seg-0025", "section_id": "mozi-014-universal-love-i", "source_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 25, "text_original": "此何也？", "text_normalized": "此何也？", "canonical_ref": "14.25", "notes": ""}
{"segment_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3__seg-0026", "section_id": "mozi-014-universal-love-i", "source_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 26, "text_original": "皆起不相愛。", "text_normalized": "皆起不相愛。", "canonical_ref": "14.26", "notes": ""}
{"segment_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3__seg-0027", "section_id": "mozi-014-universal-love-i", "source_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 27, "text_original": "雖至大夫之相亂家、諸侯之相攻國者亦然。", "text_normalized": "雖至大夫之相亂家、諸侯之相攻國者亦然。", "canonical_ref": "14.27", "notes": ""}
{"segment_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3__seg-0028", "section_id": "mozi-014-universal-love-i", "source_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 28, "text_original": "大夫各愛其家，不愛異家，故亂異家以利其家。", "text_normalized": "大夫各愛其家，不愛異家，故亂異家以利其家。", "canonical_ref": "14.28", "notes": ""}
{"segment_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3__seg-0029", "section_id": "mozi-014-universal-love-i", "source_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 29, "text_original": "諸侯各愛其國，不愛異國，故攻異國以利其國。", "text_normalized": "諸侯各愛其國，不愛異國，故攻異國以利其國。", "canonical_ref": "14.29", "notes": ""}
{"segment_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3__seg-0030", "section_id": "mozi-014-universal-love-i", "source_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 30, "text_original": "天下之亂物，具此而已矣！", "text_normalized": "天下之亂物，具此而已矣！", "canonical_ref": "14.30", "notes": ""}
{"segment_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3__seg-0031", "section_id": "mozi-014-universal-love-i", "source_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 31, "text_original": "察此何自起，皆起不相愛。", "text_normalized": "察此何自起，皆起不相愛。", "canonical_ref": "14.31", "notes": ""}
{"segment_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3__seg-0032", "section_id": "mozi-014-universal-love-i", "source_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 32, "text_original": "若使天下兼相愛，愛人若愛其身，猶有不孝者乎？", "text_normalized": "若使天下兼相愛，愛人若愛其身，猶有不孝者乎？", "canonical_ref": "14.32", "notes": ""}
{"segment_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3__seg-0033", "section_id": "mozi-014-universal-love-i", "source_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 33, "text_original": "視父、兄與君若其身，惡施不孝？", "text_normalized": "視父、兄與君若其身，惡施不孝？", "canonical_ref": "14.33", "notes": ""}
{"segment_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3__seg-0034", "section_id": "mozi-014-universal-love-i", "source_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 34, "text_original": "猶有不慈者乎？", "text_normalized": "猶有不慈者乎？", "canonical_ref": "14.34", "notes": ""}
{"segment_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3__seg-0035", "section_id": "mozi-014-universal-love-i", "source_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 35, "text_original": "視弟子與臣若其身，惡施不慈？", "text_normalized": "視弟子與臣若其身，惡施不慈？", "canonical_ref": "14.35", "notes": ""}
{"segment_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3__seg-0036", "section_id": "mozi-014-universal-love-i", "source_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 36, "text_original": "故不孝、不慈、亡有，猶有盜賊乎？", "text_normalized": "故不孝、不慈、亡有，猶有盜賊乎？", "canonical_ref": "14.36", "notes": ""}
{"segment_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3__seg-0037", "section_id": "mozi-014-universal-love-i", "source_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 37, "text_original": "故視人之室若其室，誰竊？", "text_normalized": "故視人之室若其室，誰竊？", "canonical_ref": "14.37", "notes": ""}
{"segment_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3__seg-0038", "section_id": "mozi-014-universal-love-i", "source_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 38, "text_original": "視人身若其身，誰賊？", "text_normalized": "視人身若其身，誰賊？", "canonical_ref": "14.38", "notes": ""}
{"segment_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3__seg-0039", "section_id": "mozi-014-universal-love-i", "source_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 39, "text_original": "故盜賊亡有。", "text_normalized": "故盜賊亡有。", "canonical_ref": "14.39", "notes": ""}
{"segment_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3__seg-0040", "section_id": "mozi-014-universal-love-i", "source_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 40, "text_original": "猶有大夫之相亂家、諸侯之相攻國者乎？", "text_normalized": "猶有大夫之相亂家、諸侯之相攻國者乎？", "canonical_ref": "14.40", "notes": ""}
{"segment_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3__seg-0041", "section_id": "mozi-014-universal-love-i", "source_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 41, "text_original": "視人家若其家，誰亂？", "text_normalized": "視人家若其家，誰亂？", "canonical_ref": "14.41", "notes": ""}
{"segment_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3__seg-0042", "section_id": "mozi-014-universal-love-i", "source_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 42, "text_original": "視人國若其國，誰攻？", "text_normalized": "視人國若其國，誰攻？", "canonical_ref": "14.42", "notes": ""}
{"segment_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3__seg-0043", "section_id": "mozi-014-universal-love-i", "source_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 43, "text_original": "故大夫之相亂家、諸侯之相攻國者亡有。", "text_normalized": "故大夫之相亂家、諸侯之相攻國者亡有。", "canonical_ref": "14.43", "notes": ""}
{"segment_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3__seg-0044", "section_id": "mozi-014-universal-love-i", "source_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 44, "text_original": "若使人下兼相愛，國與國不相攻，家與家不相亂，盜賊無有，君臣父子皆能孝慈，若此則天下治。", "text_normalized": "若使人下兼相愛，國與國不相攻，家與家不相亂，盜賊無有，君臣父子皆能孝慈，若此則天下治。", "canonical_ref": "14.44", "notes": ""}
{"segment_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3__seg-0045", "section_id": "mozi-014-universal-love-i", "source_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 45, "text_original": "故聖人以治天下爲事者，惡得不禁惡而勸愛？", "text_normalized": "故聖人以治天下爲事者，惡得不禁惡而勸愛？", "canonical_ref": "14.45", "notes": ""}
{"segment_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3__seg-0046", "section_id": "mozi-014-universal-love-i", "source_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 46, "text_original": "故天下兼相愛則治，交相惡則亂。", "text_normalized": "故天下兼相愛則治，交相惡則亂。", "canonical_ref": "14.46", "notes": ""}
{"segment_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3__seg-0047", "section_id": "mozi-014-universal-love-i", "source_id": "mozi-014-universal-love-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 47, "text_original": "故子墨子曰不可以不勸愛人者，此也。", "text_normalized": "故子墨子曰不可以不勸愛人者，此也。", "canonical_ref": "14.47", "notes": ""}
