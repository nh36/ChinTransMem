{"segment_id": "laozi-chapter-003__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-003", "source_id": "laozi-chapter-003__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 3.1", "sort_key": "003.001", "text_original": "不尚賢，", "text_normalized": "不尚賢，", "notes": ""}
{"segment_id": "laozi-chapter-003__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-003", "source_id": "laozi-chapter-003__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 3.2", "sort_key": "003.002", "text_original": "使民不爭；", "text_normalized": "使民不爭；", "notes": ""}
{"segment_id": "laozi-chapter-003__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-003", "source_id": "laozi-chapter-003__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 3.3", "sort_key": "003.003", "text_original": "不貴難得之貨，", "text_normalized": "不貴難得之貨，", "notes": ""}
{"segment_id": "laozi-chapter-003__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-003", "source_id": "laozi-chapter-003__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 3.4", "sort_key": "003.004", "text_original": "使民不為盜；", "text_normalized": "使民不為盜；", "notes": ""}
{"segment_id": "laozi-chapter-003__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-003", "source_id": "laozi-chapter-003__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 3.5", "sort_key": "003.005", "text_original": "不見可欲，", "text_normalized": "不見可欲，", "notes": ""}
{"segment_id": "laozi-chapter-003__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-003", "source_id": "laozi-chapter-003__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 3.6", "sort_key": "003.006", "text_original": "使民心不亂。", "text_normalized": "使民心不亂。", "notes": ""}
{"segment_id": "laozi-chapter-003__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-003", "source_id": "laozi-chapter-003__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 3.7", "sort_key": "003.007", "text_original": "是以聖人之治，", "text_normalized": "是以聖人之治，", "notes": ""}
{"segment_id": "laozi-chapter-003__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-003", "source_id": "laozi-chapter-003__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 3.8", "sort_key": "003.008", "text_original": "虛其心，", "text_normalized": "虛其心，", "notes": ""}
{"segment_id": "laozi-chapter-003__chinesenotes-daodejing-zh-20260531__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-003", "source_id": "laozi-chapter-003__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 3.9", "sort_key": "003.009", "text_original": "實其腹，", "text_normalized": "實其腹，", "notes": ""}
{"segment_id": "laozi-chapter-003__chinesenotes-daodejing-zh-20260531__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-003", "source_id": "laozi-chapter-003__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 3.10", "sort_key": "003.010", "text_original": "弱其志，", "text_normalized": "弱其志，", "notes": ""}
{"segment_id": "laozi-chapter-003__chinesenotes-daodejing-zh-20260531__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-003", "source_id": "laozi-chapter-003__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 3.11", "sort_key": "003.011", "text_original": "強其骨。", "text_normalized": "強其骨。", "notes": ""}
{"segment_id": "laozi-chapter-003__chinesenotes-daodejing-zh-20260531__seg-012", "work_id": "laozi", "section_id": "laozi-chapter-003", "source_id": "laozi-chapter-003__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 12, "canonical_ref": "老子 3.12", "sort_key": "003.012", "text_original": "常使民無知無欲。", "text_normalized": "常使民無知無欲。", "notes": ""}
{"segment_id": "laozi-chapter-003__chinesenotes-daodejing-zh-20260531__seg-013", "work_id": "laozi", "section_id": "laozi-chapter-003", "source_id": "laozi-chapter-003__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 13, "canonical_ref": "老子 3.13", "sort_key": "003.013", "text_original": "使夫智者不敢為也。", "text_normalized": "使夫智者不敢為也。", "notes": ""}
{"segment_id": "laozi-chapter-003__chinesenotes-daodejing-zh-20260531__seg-014", "work_id": "laozi", "section_id": "laozi-chapter-003", "source_id": "laozi-chapter-003__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 14, "canonical_ref": "老子 3.14", "sort_key": "003.014", "text_original": "為無為，", "text_normalized": "為無為，", "notes": ""}
{"segment_id": "laozi-chapter-003__chinesenotes-daodejing-zh-20260531__seg-015", "work_id": "laozi", "section_id": "laozi-chapter-003", "source_id": "laozi-chapter-003__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 15, "canonical_ref": "老子 3.15", "sort_key": "003.015", "text_original": "則無不治。", "text_normalized": "則無不治。", "notes": ""}
