{"segment_id": "shijing__guofeng-beifeng-002__001__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-beifeng-002", "source_id": "guofeng-beifeng-002__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 1, "canonical_ref": "詩經·國風·邶風·002.1", "text_original": "綠兮衣兮，綠衣黃裏，心之憂矣，曷維其已。", "text_normalized": "綠兮衣兮，綠衣黃裏，心之憂矣，曷維其已。", "notes": "綠衣 Chinese stanza 1."}
{"segment_id": "shijing__guofeng-beifeng-002__002__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-beifeng-002", "source_id": "guofeng-beifeng-002__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 2, "canonical_ref": "詩經·國風·邶風·002.2", "text_original": "綠兮衣兮，綠衣黃裳，心之憂矣，曷維其亡。", "text_normalized": "綠兮衣兮，綠衣黃裳，心之憂矣，曷維其亡。", "notes": "綠衣 Chinese stanza 2."}
{"segment_id": "shijing__guofeng-beifeng-002__003__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-beifeng-002", "source_id": "guofeng-beifeng-002__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 3, "canonical_ref": "詩經·國風·邶風·002.3", "text_original": "綠兮絲兮，女所治兮，我思古人，俾無訧兮。", "text_normalized": "綠兮絲兮，女所治兮，我思古人，俾無訧兮。", "notes": "綠衣 Chinese stanza 3."}
{"segment_id": "shijing__guofeng-beifeng-002__004__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-beifeng-002", "source_id": "guofeng-beifeng-002__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 4, "canonical_ref": "詩經·國風·邶風·002.4", "text_original": "絺兮綌兮，淒其以風，我思古人，實獲我心。", "text_normalized": "絺兮綌兮，淒其以風，我思古人，實獲我心。", "notes": "綠衣 Chinese stanza 4."}
