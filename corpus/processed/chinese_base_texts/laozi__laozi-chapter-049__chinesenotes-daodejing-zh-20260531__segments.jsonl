{"segment_id": "laozi-chapter-049__chinesenotes-daodejing-zh-20260531__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-049", "source_id": "laozi-chapter-049__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 49.11", "sort_key": "049.011", "text_original": "吾亦信之，", "text_normalized": "吾亦信之，", "notes": ""}
{"segment_id": "laozi-chapter-049__chinesenotes-daodejing-zh-20260531__seg-012", "work_id": "laozi", "section_id": "laozi-chapter-049", "source_id": "laozi-chapter-049__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 12, "canonical_ref": "老子 49.12", "sort_key": "049.012", "text_original": "德信。", "text_normalized": "德信。", "notes": ""}
{"segment_id": "laozi-chapter-049__chinesenotes-daodejing-zh-20260531__seg-013", "work_id": "laozi", "section_id": "laozi-chapter-049", "source_id": "laozi-chapter-049__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 13, "canonical_ref": "老子 49.13", "sort_key": "049.013", "text_original": "聖人在天下歙歙，", "text_normalized": "聖人在天下歙歙，", "notes": ""}
{"segment_id": "laozi-chapter-049__chinesenotes-daodejing-zh-20260531__seg-014", "work_id": "laozi", "section_id": "laozi-chapter-049", "source_id": "laozi-chapter-049__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 14, "canonical_ref": "老子 49.14", "sort_key": "049.014", "text_original": "為天下渾其心，", "text_normalized": "為天下渾其心，", "notes": ""}
{"segment_id": "laozi-chapter-049__chinesenotes-daodejing-zh-20260531__seg-015", "work_id": "laozi", "section_id": "laozi-chapter-049", "source_id": "laozi-chapter-049__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 15, "canonical_ref": "老子 49.15", "sort_key": "049.015", "text_original": "百姓皆注其耳目,聖人皆孩之。", "text_normalized": "百姓皆注其耳目,聖人皆孩之。", "notes": ""}
