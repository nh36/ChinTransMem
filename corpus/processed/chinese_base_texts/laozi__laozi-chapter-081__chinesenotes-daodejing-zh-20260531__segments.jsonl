{"segment_id": "laozi-chapter-081__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-081", "source_id": "laozi-chapter-081__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 81.3", "sort_key": "081.003", "text_original": "善者不辯，", "text_normalized": "善者不辯，", "notes": ""}
{"segment_id": "laozi-chapter-081__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-081", "source_id": "laozi-chapter-081__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 81.4", "sort_key": "081.004", "text_original": "辯者不善。", "text_normalized": "辯者不善。", "notes": ""}
{"segment_id": "laozi-chapter-081__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-081", "source_id": "laozi-chapter-081__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 81.5", "sort_key": "081.005", "text_original": "知者不博，", "text_normalized": "知者不博，", "notes": ""}
{"segment_id": "laozi-chapter-081__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-081", "source_id": "laozi-chapter-081__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 81.6", "sort_key": "081.006", "text_original": "博者不知。", "text_normalized": "博者不知。", "notes": ""}
{"segment_id": "laozi-chapter-081__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-081", "source_id": "laozi-chapter-081__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 81.7", "sort_key": "081.007", "text_original": "聖人不積，", "text_normalized": "聖人不積，", "notes": ""}
{"segment_id": "laozi-chapter-081__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-081", "source_id": "laozi-chapter-081__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 81.8", "sort_key": "081.008", "text_original": "既以為人己愈有，", "text_normalized": "既以為人己愈有，", "notes": ""}
{"segment_id": "laozi-chapter-081__chinesenotes-daodejing-zh-20260531__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-081", "source_id": "laozi-chapter-081__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 81.9", "sort_key": "081.009", "text_original": "既以與人己愈多。", "text_normalized": "既以與人己愈多。", "notes": ""}
{"segment_id": "laozi-chapter-081__chinesenotes-daodejing-zh-20260531__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-081", "source_id": "laozi-chapter-081__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 81.10", "sort_key": "081.010", "text_original": "天之道，", "text_normalized": "天之道，", "notes": ""}
{"segment_id": "laozi-chapter-081__chinesenotes-daodejing-zh-20260531__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-081", "source_id": "laozi-chapter-081__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 81.11", "sort_key": "081.011", "text_original": "利而不害；", "text_normalized": "利而不害；", "notes": ""}
{"segment_id": "laozi-chapter-081__chinesenotes-daodejing-zh-20260531__seg-012", "work_id": "laozi", "section_id": "laozi-chapter-081", "source_id": "laozi-chapter-081__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 12, "canonical_ref": "老子 81.12", "sort_key": "081.012", "text_original": "聖人之道，", "text_normalized": "聖人之道，", "notes": ""}
{"segment_id": "laozi-chapter-081__chinesenotes-daodejing-zh-20260531__seg-013", "work_id": "laozi", "section_id": "laozi-chapter-081", "source_id": "laozi-chapter-081__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 13, "canonical_ref": "老子 81.13", "sort_key": "081.013", "text_original": "為而不爭。", "text_normalized": "為而不爭。", "notes": ""}
