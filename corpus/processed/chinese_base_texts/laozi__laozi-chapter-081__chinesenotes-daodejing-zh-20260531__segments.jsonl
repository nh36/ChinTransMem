{"segment_id": "laozi-chapter-081__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-081", "source_id": "laozi-chapter-081__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 81.1", "sort_key": "081.001", "text_original": "信言不美，", "text_normalized": "信言不美，", "notes": ""}
