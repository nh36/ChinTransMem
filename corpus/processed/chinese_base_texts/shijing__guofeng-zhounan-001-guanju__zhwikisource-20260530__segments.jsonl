{"segment_id": "shijing__guofeng-zhounan-001-guanju__001__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-zhounan-001-guanju", "source_id": "guofeng-zhounan-001-guanju__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 1, "canonical_ref": "詩經·國風·周南·001.1", "text_original": "關關雎鳩，在河之洲。\n窈窕淑女，君子好逑。", "text_normalized": "關關雎鳩，在河之洲。\n窈窕淑女，君子好逑。", "notes": "關雎 Chinese stanza 1."}
{"segment_id": "shijing__guofeng-zhounan-001-guanju__002__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-zhounan-001-guanju", "source_id": "guofeng-zhounan-001-guanju__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 2, "canonical_ref": "詩經·國風·周南·001.2", "text_original": "參差荇菜，左右流之。\n窈窕淑女，寤寐求之。", "text_normalized": "參差荇菜，左右流之。\n窈窕淑女，寤寐求之。", "notes": "關雎 Chinese stanza 2."}
{"segment_id": "shijing__guofeng-zhounan-001-guanju__003__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-zhounan-001-guanju", "source_id": "guofeng-zhounan-001-guanju__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 3, "canonical_ref": "詩經·國風·周南·001.3", "text_original": "求之不得，寤寐思服。\n悠哉悠哉，輾轉反側。", "text_normalized": "求之不得，寤寐思服。\n悠哉悠哉，輾轉反側。", "notes": "關雎 Chinese stanza 3."}
{"segment_id": "shijing__guofeng-zhounan-001-guanju__004__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-zhounan-001-guanju", "source_id": "guofeng-zhounan-001-guanju__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 4, "canonical_ref": "詩經·國風·周南·001.4", "text_original": "參差荇菜，左右采之。\n窈窕淑女，琴瑟友之。", "text_normalized": "參差荇菜，左右采之。\n窈窕淑女，琴瑟友之。", "notes": "關雎 Chinese stanza 4."}
{"segment_id": "shijing__guofeng-zhounan-001-guanju__005__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-zhounan-001-guanju", "source_id": "guofeng-zhounan-001-guanju__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 5, "canonical_ref": "詩經·國風·周南·001.5", "text_original": "參差荇菜，左右芼之。\n窈窕淑女，鐘鼓樂之。", "text_normalized": "參差荇菜，左右芼之。\n窈窕淑女，鐘鼓樂之。", "notes": "關雎 Chinese stanza 5."}
