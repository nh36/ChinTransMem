{"segment_id": "laozi-chapter-032__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-032", "source_id": "laozi-chapter-032__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 32.1", "sort_key": "032.001", "text_original": "道常無名，", "text_normalized": "道常無名，", "notes": ""}
{"segment_id": "laozi-chapter-032__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-032", "source_id": "laozi-chapter-032__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 32.2", "sort_key": "032.002", "text_original": "樸雖小，", "text_normalized": "樸雖小，", "notes": ""}
{"segment_id": "laozi-chapter-032__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-032", "source_id": "laozi-chapter-032__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 32.3", "sort_key": "032.003", "text_original": "天下莫能臣也。", "text_normalized": "天下莫能臣也。", "notes": ""}
{"segment_id": "laozi-chapter-032__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-032", "source_id": "laozi-chapter-032__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 32.4", "sort_key": "032.004", "text_original": "侯王若能守之，", "text_normalized": "侯王若能守之，", "notes": ""}
{"segment_id": "laozi-chapter-032__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-032", "source_id": "laozi-chapter-032__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 32.5", "sort_key": "032.005", "text_original": "萬物將自賓。", "text_normalized": "萬物將自賓。", "notes": ""}
{"segment_id": "laozi-chapter-032__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-032", "source_id": "laozi-chapter-032__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 32.6", "sort_key": "032.006", "text_original": "天地相合，", "text_normalized": "天地相合，", "notes": ""}
{"segment_id": "laozi-chapter-032__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-032", "source_id": "laozi-chapter-032__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 32.7", "sort_key": "032.007", "text_original": "以降甘露，", "text_normalized": "以降甘露，", "notes": ""}
{"segment_id": "laozi-chapter-032__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-032", "source_id": "laozi-chapter-032__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 32.8", "sort_key": "032.008", "text_original": "民莫之令而自均。", "text_normalized": "民莫之令而自均。", "notes": ""}
{"segment_id": "laozi-chapter-032__chinesenotes-daodejing-zh-20260531__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-032", "source_id": "laozi-chapter-032__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 32.9", "sort_key": "032.009", "text_original": "始制有名，", "text_normalized": "始制有名，", "notes": ""}
{"segment_id": "laozi-chapter-032__chinesenotes-daodejing-zh-20260531__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-032", "source_id": "laozi-chapter-032__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 32.10", "sort_key": "032.010", "text_original": "名亦既有，", "text_normalized": "名亦既有，", "notes": ""}
{"segment_id": "laozi-chapter-032__chinesenotes-daodejing-zh-20260531__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-032", "source_id": "laozi-chapter-032__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 32.11", "sort_key": "032.011", "text_original": "夫亦將知止，", "text_normalized": "夫亦將知止，", "notes": ""}
{"segment_id": "laozi-chapter-032__chinesenotes-daodejing-zh-20260531__seg-012", "work_id": "laozi", "section_id": "laozi-chapter-032", "source_id": "laozi-chapter-032__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 12, "canonical_ref": "老子 32.12", "sort_key": "032.012", "text_original": "知止所以不殆。", "text_normalized": "知止所以不殆。", "notes": ""}
{"segment_id": "laozi-chapter-032__chinesenotes-daodejing-zh-20260531__seg-013", "work_id": "laozi", "section_id": "laozi-chapter-032", "source_id": "laozi-chapter-032__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 13, "canonical_ref": "老子 32.13", "sort_key": "032.013", "text_original": "譬道之在天下，", "text_normalized": "譬道之在天下，", "notes": ""}
{"segment_id": "laozi-chapter-032__chinesenotes-daodejing-zh-20260531__seg-014", "work_id": "laozi", "section_id": "laozi-chapter-032", "source_id": "laozi-chapter-032__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 14, "canonical_ref": "老子 32.14", "sort_key": "032.014", "text_original": "猶川谷之於江海。", "text_normalized": "猶川谷之於江海。", "notes": ""}
