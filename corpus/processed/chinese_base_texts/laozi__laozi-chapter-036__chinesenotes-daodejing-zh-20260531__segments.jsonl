{"segment_id": "laozi-chapter-036__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-036", "source_id": "laozi-chapter-036__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 36.1", "sort_key": "036.001", "text_original": "將欲歙之，", "text_normalized": "將欲歙之，", "notes": ""}
{"segment_id": "laozi-chapter-036__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-036", "source_id": "laozi-chapter-036__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 36.2", "sort_key": "036.002", "text_original": "必固張之；", "text_normalized": "必固張之；", "notes": ""}
{"segment_id": "laozi-chapter-036__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-036", "source_id": "laozi-chapter-036__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 36.3", "sort_key": "036.003", "text_original": "將欲弱之，", "text_normalized": "將欲弱之，", "notes": ""}
{"segment_id": "laozi-chapter-036__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-036", "source_id": "laozi-chapter-036__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 36.4", "sort_key": "036.004", "text_original": "必固強之；", "text_normalized": "必固強之；", "notes": ""}
{"segment_id": "laozi-chapter-036__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-036", "source_id": "laozi-chapter-036__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 36.5", "sort_key": "036.005", "text_original": "將欲廢之，", "text_normalized": "將欲廢之，", "notes": ""}
{"segment_id": "laozi-chapter-036__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-036", "source_id": "laozi-chapter-036__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 36.6", "sort_key": "036.006", "text_original": "必固興之；", "text_normalized": "必固興之；", "notes": ""}
{"segment_id": "laozi-chapter-036__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-036", "source_id": "laozi-chapter-036__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 36.7", "sort_key": "036.007", "text_original": "將欲奪之，", "text_normalized": "將欲奪之，", "notes": ""}
{"segment_id": "laozi-chapter-036__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-036", "source_id": "laozi-chapter-036__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 36.8", "sort_key": "036.008", "text_original": "必固與之。", "text_normalized": "必固與之。", "notes": ""}
{"segment_id": "laozi-chapter-036__chinesenotes-daodejing-zh-20260531__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-036", "source_id": "laozi-chapter-036__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 36.9", "sort_key": "036.009", "text_original": "是謂微明。", "text_normalized": "是謂微明。", "notes": ""}
{"segment_id": "laozi-chapter-036__chinesenotes-daodejing-zh-20260531__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-036", "source_id": "laozi-chapter-036__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 36.10", "sort_key": "036.010", "text_original": "柔弱勝剛強。", "text_normalized": "柔弱勝剛強。", "notes": ""}
{"segment_id": "laozi-chapter-036__chinesenotes-daodejing-zh-20260531__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-036", "source_id": "laozi-chapter-036__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 36.11", "sort_key": "036.011", "text_original": "魚不可脫於淵，", "text_normalized": "魚不可脫於淵，", "notes": ""}
{"segment_id": "laozi-chapter-036__chinesenotes-daodejing-zh-20260531__seg-012", "work_id": "laozi", "section_id": "laozi-chapter-036", "source_id": "laozi-chapter-036__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 12, "canonical_ref": "老子 36.12", "sort_key": "036.012", "text_original": "國之利器不可以示人。", "text_normalized": "國之利器不可以示人。", "notes": ""}
