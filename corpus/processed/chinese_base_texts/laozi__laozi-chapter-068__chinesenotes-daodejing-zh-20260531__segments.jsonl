{"segment_id": "laozi-chapter-068__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-068", "source_id": "laozi-chapter-068__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 68.1", "sort_key": "068.001", "text_original": "善為士者不武，", "text_normalized": "善為士者不武，", "notes": ""}
{"segment_id": "laozi-chapter-068__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-068", "source_id": "laozi-chapter-068__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 68.2", "sort_key": "068.002", "text_original": "善戰者不怒，", "text_normalized": "善戰者不怒，", "notes": ""}
{"segment_id": "laozi-chapter-068__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-068", "source_id": "laozi-chapter-068__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 68.3", "sort_key": "068.003", "text_original": "善勝敵者不與，", "text_normalized": "善勝敵者不與，", "notes": ""}
{"segment_id": "laozi-chapter-068__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-068", "source_id": "laozi-chapter-068__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 68.4", "sort_key": "068.004", "text_original": "善用人者為之下，", "text_normalized": "善用人者為之下，", "notes": ""}
{"segment_id": "laozi-chapter-068__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-068", "source_id": "laozi-chapter-068__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 68.5", "sort_key": "068.005", "text_original": "是謂不爭之德，", "text_normalized": "是謂不爭之德，", "notes": ""}
{"segment_id": "laozi-chapter-068__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-068", "source_id": "laozi-chapter-068__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 68.6", "sort_key": "068.006", "text_original": "是謂用人之力，", "text_normalized": "是謂用人之力，", "notes": ""}
{"segment_id": "laozi-chapter-068__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-068", "source_id": "laozi-chapter-068__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 68.7", "sort_key": "068.007", "text_original": "是謂配天古之極。", "text_normalized": "是謂配天古之極。", "notes": ""}
