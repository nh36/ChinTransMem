{"segment_id": "laozi-chapter-056__chinesenotes-daodejing-zh-20260531__seg-013", "work_id": "laozi", "section_id": "laozi-chapter-056", "source_id": "laozi-chapter-056__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 13, "canonical_ref": "老子 56.13", "sort_key": "056.013", "text_original": "不可得而害；", "text_normalized": "不可得而害；", "notes": ""}
