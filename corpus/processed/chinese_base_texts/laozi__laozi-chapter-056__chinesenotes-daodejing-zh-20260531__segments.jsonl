{"segment_id": "laozi-chapter-056__chinesenotes-daodejing-zh-20260531__seg-016", "work_id": "laozi", "section_id": "laozi-chapter-056", "source_id": "laozi-chapter-056__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 16, "canonical_ref": "老子 56.16", "sort_key": "056.016", "text_original": "故為天下貴。", "text_normalized": "故為天下貴。", "notes": ""}
