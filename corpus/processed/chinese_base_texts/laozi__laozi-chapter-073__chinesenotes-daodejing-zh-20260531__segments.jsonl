{"segment_id": "laozi-chapter-073__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-073", "source_id": "laozi-chapter-073__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 73.1", "sort_key": "073.001", "text_original": "勇於敢則殺，", "text_normalized": "勇於敢則殺，", "notes": ""}
{"segment_id": "laozi-chapter-073__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-073", "source_id": "laozi-chapter-073__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 73.2", "sort_key": "073.002", "text_original": "勇於不敢則活。", "text_normalized": "勇於不敢則活。", "notes": ""}
{"segment_id": "laozi-chapter-073__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-073", "source_id": "laozi-chapter-073__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 73.3", "sort_key": "073.003", "text_original": "此兩者，或利或害。", "text_normalized": "此兩者，或利或害。", "notes": ""}
{"segment_id": "laozi-chapter-073__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-073", "source_id": "laozi-chapter-073__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 73.4", "sort_key": "073.004", "text_original": "天之所惡，孰知其故？是以聖人猶難之。", "text_normalized": "天之所惡，孰知其故？是以聖人猶難之。", "notes": ""}
{"segment_id": "laozi-chapter-073__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-073", "source_id": "laozi-chapter-073__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 73.5", "sort_key": "073.005", "text_original": "天之道，不爭而善勝，", "text_normalized": "天之道，不爭而善勝，", "notes": ""}
{"segment_id": "laozi-chapter-073__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-073", "source_id": "laozi-chapter-073__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 73.6", "sort_key": "073.006", "text_original": "不言而善應，", "text_normalized": "不言而善應，", "notes": ""}
{"segment_id": "laozi-chapter-073__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-073", "source_id": "laozi-chapter-073__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 73.7", "sort_key": "073.007", "text_original": "不召而自來，", "text_normalized": "不召而自來，", "notes": ""}
{"segment_id": "laozi-chapter-073__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-073", "source_id": "laozi-chapter-073__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 73.8", "sort_key": "073.008", "text_original": "繟然而善謀。", "text_normalized": "繟然而善謀。", "notes": ""}
{"segment_id": "laozi-chapter-073__chinesenotes-daodejing-zh-20260531__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-073", "source_id": "laozi-chapter-073__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 73.9", "sort_key": "073.009", "text_original": "天網恢恢，疏而不失。", "text_normalized": "天網恢恢，疏而不失。", "notes": ""}
