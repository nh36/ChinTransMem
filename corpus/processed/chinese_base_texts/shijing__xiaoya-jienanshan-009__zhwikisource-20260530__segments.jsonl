{"segment_id": "shijing__xiaoya-jienanshan-009__001__zhwikisource-20260530", "work_id": "shijing", "section_id": "xiaoya-jienanshan-009", "source_id": "xiaoya-jienanshan-009__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 1, "canonical_ref": "詩經·小雅·節南山之什·009.1", "text_original": "彼何人斯？其心孔艱。胡逝我梁，不入我門？伊誰云從？維暴之云。", "text_normalized": "彼何人斯？其心孔艱。胡逝我梁，不入我門？伊誰云從？維暴之云。", "notes": "何人斯 Chinese stanza 1."}
{"segment_id": "shijing__xiaoya-jienanshan-009__002__zhwikisource-20260530", "work_id": "shijing", "section_id": "xiaoya-jienanshan-009", "source_id": "xiaoya-jienanshan-009__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 2, "canonical_ref": "詩經·小雅·節南山之什·009.2", "text_original": "二人從行，誰為此禍？胡逝我梁，不入唁我？始者不如今，云不我可。", "text_normalized": "二人從行，誰為此禍？胡逝我梁，不入唁我？始者不如今，云不我可。", "notes": "何人斯 Chinese stanza 2."}
{"segment_id": "shijing__xiaoya-jienanshan-009__003__zhwikisource-20260530", "work_id": "shijing", "section_id": "xiaoya-jienanshan-009", "source_id": "xiaoya-jienanshan-009__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 3, "canonical_ref": "詩經·小雅·節南山之什·009.3", "text_original": "彼何人斯，胡逝我陳？我聞其聲，不見其身。不愧于人。不畏于天。", "text_normalized": "彼何人斯，胡逝我陳？我聞其聲，不見其身。不愧于人。不畏于天。", "notes": "何人斯 Chinese stanza 3."}
{"segment_id": "shijing__xiaoya-jienanshan-009__004__zhwikisource-20260530", "work_id": "shijing", "section_id": "xiaoya-jienanshan-009", "source_id": "xiaoya-jienanshan-009__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 4, "canonical_ref": "詩經·小雅·節南山之什·009.4", "text_original": "彼何人斯？其為飄風。胡不自北？胡不自南？胡逝我梁？祇攪我心。", "text_normalized": "彼何人斯？其為飄風。胡不自北？胡不自南？胡逝我梁？祇攪我心。", "notes": "何人斯 Chinese stanza 4."}
{"segment_id": "shijing__xiaoya-jienanshan-009__005__zhwikisource-20260530", "work_id": "shijing", "section_id": "xiaoya-jienanshan-009", "source_id": "xiaoya-jienanshan-009__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 5, "canonical_ref": "詩經·小雅·節南山之什·009.5", "text_original": "爾之安行，亦不遑舍。爾之亟行，遑脂爾車？壹者之來，云何其盱。", "text_normalized": "爾之安行，亦不遑舍。爾之亟行，遑脂爾車？壹者之來，云何其盱。", "notes": "何人斯 Chinese stanza 5."}
{"segment_id": "shijing__xiaoya-jienanshan-009__006__zhwikisource-20260530", "work_id": "shijing", "section_id": "xiaoya-jienanshan-009", "source_id": "xiaoya-jienanshan-009__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 6, "canonical_ref": "詩經·小雅·節南山之什·009.6", "text_original": "爾還而入，我心易也。還而不入，否難知也。壹者之來，俾我祇也。", "text_normalized": "爾還而入，我心易也。還而不入，否難知也。壹者之來，俾我祇也。", "notes": "何人斯 Chinese stanza 6."}
{"segment_id": "shijing__xiaoya-jienanshan-009__007__zhwikisource-20260530", "work_id": "shijing", "section_id": "xiaoya-jienanshan-009", "source_id": "xiaoya-jienanshan-009__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 7, "canonical_ref": "詩經·小雅·節南山之什·009.7", "text_original": "伯氏吹壎，仲氏吹篪。及爾如貫，諒不我知。出此三物，以詛爾斯。", "text_normalized": "伯氏吹壎，仲氏吹篪。及爾如貫，諒不我知。出此三物，以詛爾斯。", "notes": "何人斯 Chinese stanza 7."}
{"segment_id": "shijing__xiaoya-jienanshan-009__008__zhwikisource-20260530", "work_id": "shijing", "section_id": "xiaoya-jienanshan-009", "source_id": "xiaoya-jienanshan-009__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 8, "canonical_ref": "詩經·小雅·節南山之什·009.8", "text_original": "為鬼為蜮，則不可得。有靦面目，視人罔極。作此好歌，以極反側。", "text_normalized": "為鬼為蜮，則不可得。有靦面目，視人罔極。作此好歌，以極反側。", "notes": "何人斯 Chinese stanza 8."}
