{"segment_id": "laozi-chapter-017__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-017", "source_id": "laozi-chapter-017__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 17.6", "sort_key": "017.006", "text_original": "信不足焉，", "text_normalized": "信不足焉，", "notes": ""}
{"segment_id": "laozi-chapter-017__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-017", "source_id": "laozi-chapter-017__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 17.7", "sort_key": "017.007", "text_original": "有不信焉。", "text_normalized": "有不信焉。", "notes": ""}
{"segment_id": "laozi-chapter-017__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-017", "source_id": "laozi-chapter-017__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 17.8", "sort_key": "017.008", "text_original": "悠兮其貴言，", "text_normalized": "悠兮其貴言，", "notes": ""}
{"segment_id": "laozi-chapter-017__chinesenotes-daodejing-zh-20260531__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-017", "source_id": "laozi-chapter-017__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 17.9", "sort_key": "017.009", "text_original": "功成事遂，", "text_normalized": "功成事遂，", "notes": ""}
{"segment_id": "laozi-chapter-017__chinesenotes-daodejing-zh-20260531__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-017", "source_id": "laozi-chapter-017__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 17.10", "sort_key": "017.010", "text_original": "百姓皆謂我自然。", "text_normalized": "百姓皆謂我自然。", "notes": ""}
