{"segment_id": "laozi-chapter-017__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-017", "source_id": "laozi-chapter-017__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 17.1", "sort_key": "017.001", "text_original": "大上，下知有之，", "text_normalized": "大上，下知有之，", "notes": ""}
{"segment_id": "laozi-chapter-017__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-017", "source_id": "laozi-chapter-017__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 17.2", "sort_key": "017.002", "text_original": "其次親而譽之，", "text_normalized": "其次親而譽之，", "notes": ""}
{"segment_id": "laozi-chapter-017__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-017", "source_id": "laozi-chapter-017__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 17.3", "sort_key": "017.003", "text_original": "其次畏之，", "text_normalized": "其次畏之，", "notes": ""}
{"segment_id": "laozi-chapter-017__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-017", "source_id": "laozi-chapter-017__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 17.4", "sort_key": "017.004", "text_original": "其次侮之。", "text_normalized": "其次侮之。", "notes": ""}
{"segment_id": "laozi-chapter-017__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-017", "source_id": "laozi-chapter-017__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 17.5", "sort_key": "017.005", "text_original": "信不足焉，有不信焉。", "text_normalized": "信不足焉，有不信焉。", "notes": ""}
{"segment_id": "laozi-chapter-017__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-017", "source_id": "laozi-chapter-017__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 17.6", "sort_key": "017.006", "text_original": "悠兮其貴言，功成事遂，百姓皆謂我自然。", "text_normalized": "悠兮其貴言，功成事遂，百姓皆謂我自然。", "notes": ""}
