{"segment_id": "shijing__guofeng-beifeng-018__001__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-beifeng-018", "source_id": "guofeng-beifeng-018__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 1, "canonical_ref": "詩經·國風·邶風·018.1", "text_original": "新臺有泚，河水瀰瀰，燕婉之求，蘧篨不鮮。", "text_normalized": "新臺有泚，河水瀰瀰，燕婉之求，蘧篨不鮮。", "notes": "新臺 Chinese stanza 1."}
{"segment_id": "shijing__guofeng-beifeng-018__002__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-beifeng-018", "source_id": "guofeng-beifeng-018__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 2, "canonical_ref": "詩經·國風·邶風·018.2", "text_original": "新臺有洒，河水浼浼，燕婉之求，蘧篨不殄。", "text_normalized": "新臺有洒，河水浼浼，燕婉之求，蘧篨不殄。", "notes": "新臺 Chinese stanza 2."}
{"segment_id": "shijing__guofeng-beifeng-018__003__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-beifeng-018", "source_id": "guofeng-beifeng-018__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 3, "canonical_ref": "詩經·國風·邶風·018.3", "text_original": "魚網之設，鴻則離之，燕婉之求，得此戚施。", "text_normalized": "魚網之設，鴻則離之，燕婉之求，得此戚施。", "notes": "新臺 Chinese stanza 3."}
