{"segment_id": "laozi-chapter-071__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-071", "source_id": "laozi-chapter-071__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "block", "segment_order": 1, "canonical_ref": "老子 71.1", "sort_key": "071.001", "text_original": "知不知上，不知知病。", "text_normalized": "知不知上，不知知病。", "notes": ""}
{"segment_id": "laozi-chapter-071__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-071", "source_id": "laozi-chapter-071__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "block", "segment_order": 2, "canonical_ref": "老子 71.2", "sort_key": "071.002", "text_original": "夫唯病病，是以不病。聖人不病，以其病病，是以不病。", "text_normalized": "夫唯病病，是以不病。聖人不病，以其病病，是以不病。", "notes": ""}
