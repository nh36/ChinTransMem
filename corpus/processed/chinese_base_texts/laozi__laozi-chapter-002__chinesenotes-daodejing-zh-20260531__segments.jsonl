{"segment_id": "laozi-chapter-002__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-002", "source_id": "laozi-chapter-002__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 2.1", "sort_key": "002.001", "text_original": "天下皆知美之為美，", "text_normalized": "天下皆知美之為美，", "notes": ""}
{"segment_id": "laozi-chapter-002__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-002", "source_id": "laozi-chapter-002__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 2.2", "sort_key": "002.002", "text_original": "斯惡已。", "text_normalized": "斯惡已。", "notes": ""}
{"segment_id": "laozi-chapter-002__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-002", "source_id": "laozi-chapter-002__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 2.3", "sort_key": "002.003", "text_original": "皆知善之為善，", "text_normalized": "皆知善之為善，", "notes": ""}
{"segment_id": "laozi-chapter-002__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-002", "source_id": "laozi-chapter-002__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 2.4", "sort_key": "002.004", "text_original": "斯不善已。", "text_normalized": "斯不善已。", "notes": ""}
{"segment_id": "laozi-chapter-002__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-002", "source_id": "laozi-chapter-002__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 2.5", "sort_key": "002.005", "text_original": "故有無相生，", "text_normalized": "故有無相生，", "notes": ""}
{"segment_id": "laozi-chapter-002__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-002", "source_id": "laozi-chapter-002__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 2.6", "sort_key": "002.006", "text_original": "難易相成，", "text_normalized": "難易相成，", "notes": ""}
{"segment_id": "laozi-chapter-002__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-002", "source_id": "laozi-chapter-002__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 2.7", "sort_key": "002.007", "text_original": "長短相較，", "text_normalized": "長短相較，", "notes": ""}
{"segment_id": "laozi-chapter-002__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-002", "source_id": "laozi-chapter-002__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 2.8", "sort_key": "002.008", "text_original": "高下相傾，", "text_normalized": "高下相傾，", "notes": ""}
{"segment_id": "laozi-chapter-002__chinesenotes-daodejing-zh-20260531__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-002", "source_id": "laozi-chapter-002__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 2.9", "sort_key": "002.009", "text_original": "音聲相和，", "text_normalized": "音聲相和，", "notes": ""}
{"segment_id": "laozi-chapter-002__chinesenotes-daodejing-zh-20260531__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-002", "source_id": "laozi-chapter-002__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 2.10", "sort_key": "002.010", "text_original": "前後相隨。", "text_normalized": "前後相隨。", "notes": ""}
{"segment_id": "laozi-chapter-002__chinesenotes-daodejing-zh-20260531__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-002", "source_id": "laozi-chapter-002__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 2.11", "sort_key": "002.011", "text_original": "是以聖人處無為之事，", "text_normalized": "是以聖人處無為之事，", "notes": ""}
{"segment_id": "laozi-chapter-002__chinesenotes-daodejing-zh-20260531__seg-012", "work_id": "laozi", "section_id": "laozi-chapter-002", "source_id": "laozi-chapter-002__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 12, "canonical_ref": "老子 2.12", "sort_key": "002.012", "text_original": "行不言之教；", "text_normalized": "行不言之教；", "notes": ""}
{"segment_id": "laozi-chapter-002__chinesenotes-daodejing-zh-20260531__seg-013", "work_id": "laozi", "section_id": "laozi-chapter-002", "source_id": "laozi-chapter-002__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 13, "canonical_ref": "老子 2.13", "sort_key": "002.013", "text_original": "萬物作焉而不辭，", "text_normalized": "萬物作焉而不辭，", "notes": ""}
{"segment_id": "laozi-chapter-002__chinesenotes-daodejing-zh-20260531__seg-014", "work_id": "laozi", "section_id": "laozi-chapter-002", "source_id": "laozi-chapter-002__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 14, "canonical_ref": "老子 2.14", "sort_key": "002.014", "text_original": "生而不有，", "text_normalized": "生而不有，", "notes": ""}
{"segment_id": "laozi-chapter-002__chinesenotes-daodejing-zh-20260531__seg-015", "work_id": "laozi", "section_id": "laozi-chapter-002", "source_id": "laozi-chapter-002__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 15, "canonical_ref": "老子 2.15", "sort_key": "002.015", "text_original": "為而不恃，", "text_normalized": "為而不恃，", "notes": ""}
{"segment_id": "laozi-chapter-002__chinesenotes-daodejing-zh-20260531__seg-016", "work_id": "laozi", "section_id": "laozi-chapter-002", "source_id": "laozi-chapter-002__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 16, "canonical_ref": "老子 2.16", "sort_key": "002.016", "text_original": "功成而弗居。", "text_normalized": "功成而弗居。", "notes": ""}
{"segment_id": "laozi-chapter-002__chinesenotes-daodejing-zh-20260531__seg-017", "work_id": "laozi", "section_id": "laozi-chapter-002", "source_id": "laozi-chapter-002__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 17, "canonical_ref": "老子 2.17", "sort_key": "002.017", "text_original": "夫唯弗居，", "text_normalized": "夫唯弗居，", "notes": ""}
{"segment_id": "laozi-chapter-002__chinesenotes-daodejing-zh-20260531__seg-018", "work_id": "laozi", "section_id": "laozi-chapter-002", "source_id": "laozi-chapter-002__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 18, "canonical_ref": "老子 2.18", "sort_key": "002.018", "text_original": "是以不去。", "text_normalized": "是以不去。", "notes": ""}
