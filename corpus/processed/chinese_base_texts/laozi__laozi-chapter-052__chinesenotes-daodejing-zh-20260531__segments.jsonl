{"segment_id": "laozi-chapter-052__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-052", "source_id": "laozi-chapter-052__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 52.1", "sort_key": "052.001", "text_original": "天下有始，", "text_normalized": "天下有始，", "notes": ""}
{"segment_id": "laozi-chapter-052__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-052", "source_id": "laozi-chapter-052__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 52.2", "sort_key": "052.002", "text_original": "以為天下母。", "text_normalized": "以為天下母。", "notes": ""}
{"segment_id": "laozi-chapter-052__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-052", "source_id": "laozi-chapter-052__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 52.3", "sort_key": "052.003", "text_original": "〉既得其母，", "text_normalized": "〉既得其母，", "notes": ""}
{"segment_id": "laozi-chapter-052__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-052", "source_id": "laozi-chapter-052__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 52.4", "sort_key": "052.004", "text_original": "以知其子，", "text_normalized": "以知其子，", "notes": ""}
{"segment_id": "laozi-chapter-052__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-052", "source_id": "laozi-chapter-052__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 52.5", "sort_key": "052.005", "text_original": "既知其子，", "text_normalized": "既知其子，", "notes": ""}
{"segment_id": "laozi-chapter-052__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-052", "source_id": "laozi-chapter-052__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 52.6", "sort_key": "052.006", "text_original": "復守其母，", "text_normalized": "復守其母，", "notes": ""}
{"segment_id": "laozi-chapter-052__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-052", "source_id": "laozi-chapter-052__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 52.7", "sort_key": "052.007", "text_original": "沒身不殆。", "text_normalized": "沒身不殆。", "notes": ""}
{"segment_id": "laozi-chapter-052__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-052", "source_id": "laozi-chapter-052__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 52.8", "sort_key": "052.008", "text_original": "塞其兌，", "text_normalized": "塞其兌，", "notes": ""}
{"segment_id": "laozi-chapter-052__chinesenotes-daodejing-zh-20260531__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-052", "source_id": "laozi-chapter-052__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 52.9", "sort_key": "052.009", "text_original": "閉其門，", "text_normalized": "閉其門，", "notes": ""}
{"segment_id": "laozi-chapter-052__chinesenotes-daodejing-zh-20260531__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-052", "source_id": "laozi-chapter-052__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 52.10", "sort_key": "052.010", "text_original": "終身不勤。", "text_normalized": "終身不勤。", "notes": ""}
{"segment_id": "laozi-chapter-052__chinesenotes-daodejing-zh-20260531__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-052", "source_id": "laozi-chapter-052__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 52.11", "sort_key": "052.011", "text_original": "開其兌，", "text_normalized": "開其兌，", "notes": ""}
{"segment_id": "laozi-chapter-052__chinesenotes-daodejing-zh-20260531__seg-012", "work_id": "laozi", "section_id": "laozi-chapter-052", "source_id": "laozi-chapter-052__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 12, "canonical_ref": "老子 52.12", "sort_key": "052.012", "text_original": "濟其事，", "text_normalized": "濟其事，", "notes": ""}
{"segment_id": "laozi-chapter-052__chinesenotes-daodejing-zh-20260531__seg-013", "work_id": "laozi", "section_id": "laozi-chapter-052", "source_id": "laozi-chapter-052__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 13, "canonical_ref": "老子 52.13", "sort_key": "052.013", "text_original": "終身不救。", "text_normalized": "終身不救。", "notes": ""}
{"segment_id": "laozi-chapter-052__chinesenotes-daodejing-zh-20260531__seg-014", "work_id": "laozi", "section_id": "laozi-chapter-052", "source_id": "laozi-chapter-052__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 14, "canonical_ref": "老子 52.14", "sort_key": "052.014", "text_original": "見小曰明，", "text_normalized": "見小曰明，", "notes": ""}
{"segment_id": "laozi-chapter-052__chinesenotes-daodejing-zh-20260531__seg-015", "work_id": "laozi", "section_id": "laozi-chapter-052", "source_id": "laozi-chapter-052__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 15, "canonical_ref": "老子 52.15", "sort_key": "052.015", "text_original": "守柔曰強。", "text_normalized": "守柔曰強。", "notes": ""}
{"segment_id": "laozi-chapter-052__chinesenotes-daodejing-zh-20260531__seg-016", "work_id": "laozi", "section_id": "laozi-chapter-052", "source_id": "laozi-chapter-052__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 16, "canonical_ref": "老子 52.16", "sort_key": "052.016", "text_original": "用其光，", "text_normalized": "用其光，", "notes": ""}
{"segment_id": "laozi-chapter-052__chinesenotes-daodejing-zh-20260531__seg-017", "work_id": "laozi", "section_id": "laozi-chapter-052", "source_id": "laozi-chapter-052__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 17, "canonical_ref": "老子 52.17", "sort_key": "052.017", "text_original": "復歸其明，", "text_normalized": "復歸其明，", "notes": ""}
{"segment_id": "laozi-chapter-052__chinesenotes-daodejing-zh-20260531__seg-018", "work_id": "laozi", "section_id": "laozi-chapter-052", "source_id": "laozi-chapter-052__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 18, "canonical_ref": "老子 52.18", "sort_key": "052.018", "text_original": "無遺身殃，", "text_normalized": "無遺身殃，", "notes": ""}
{"segment_id": "laozi-chapter-052__chinesenotes-daodejing-zh-20260531__seg-019", "work_id": "laozi", "section_id": "laozi-chapter-052", "source_id": "laozi-chapter-052__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 19, "canonical_ref": "老子 52.19", "sort_key": "052.019", "text_original": "是為習常。", "text_normalized": "是為習常。", "notes": ""}
