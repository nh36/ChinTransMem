{"segment_id": "laozi-chapter-060__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-060", "source_id": "laozi-chapter-060__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 60.4", "sort_key": "060.004", "text_original": "其鬼不神；", "text_normalized": "其鬼不神；", "notes": ""}
