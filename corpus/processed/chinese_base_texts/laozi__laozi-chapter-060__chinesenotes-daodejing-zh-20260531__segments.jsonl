{"segment_id": "laozi-chapter-060__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-060", "source_id": "laozi-chapter-060__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 60.1", "sort_key": "060.001", "text_original": "治大國，若烹小鮮。", "text_normalized": "治大國，若烹小鮮。", "notes": ""}
{"segment_id": "laozi-chapter-060__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-060", "source_id": "laozi-chapter-060__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 60.2", "sort_key": "060.002", "text_original": "以道莅天下，其鬼不神；", "text_normalized": "以道莅天下，其鬼不神；", "notes": ""}
{"segment_id": "laozi-chapter-060__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-060", "source_id": "laozi-chapter-060__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 60.3", "sort_key": "060.003", "text_original": "非其鬼不神，其神不傷人；", "text_normalized": "非其鬼不神，其神不傷人；", "notes": ""}
{"segment_id": "laozi-chapter-060__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-060", "source_id": "laozi-chapter-060__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 60.4", "sort_key": "060.004", "text_original": "非其神不傷人，聖人亦不傷人。", "text_normalized": "非其神不傷人，聖人亦不傷人。", "notes": ""}
{"segment_id": "laozi-chapter-060__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-060", "source_id": "laozi-chapter-060__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 60.5", "sort_key": "060.005", "text_original": "夫兩不相傷，故德交歸焉。", "text_normalized": "夫兩不相傷，故德交歸焉。", "notes": ""}
