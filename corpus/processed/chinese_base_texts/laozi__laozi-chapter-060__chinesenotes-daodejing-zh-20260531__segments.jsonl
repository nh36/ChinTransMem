{"segment_id": "laozi-chapter-060__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-060", "source_id": "laozi-chapter-060__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 60.6", "sort_key": "060.006", "text_original": "其神不傷人；", "text_normalized": "其神不傷人；", "notes": ""}
{"segment_id": "laozi-chapter-060__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-060", "source_id": "laozi-chapter-060__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 60.7", "sort_key": "060.007", "text_original": "非其神不傷人，", "text_normalized": "非其神不傷人，", "notes": ""}
{"segment_id": "laozi-chapter-060__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-060", "source_id": "laozi-chapter-060__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 60.8", "sort_key": "060.008", "text_original": "聖人亦不傷人。", "text_normalized": "聖人亦不傷人。", "notes": ""}
{"segment_id": "laozi-chapter-060__chinesenotes-daodejing-zh-20260531__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-060", "source_id": "laozi-chapter-060__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 60.9", "sort_key": "060.009", "text_original": "夫兩不相傷，", "text_normalized": "夫兩不相傷，", "notes": ""}
{"segment_id": "laozi-chapter-060__chinesenotes-daodejing-zh-20260531__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-060", "source_id": "laozi-chapter-060__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 60.10", "sort_key": "060.010", "text_original": "故德交歸焉。", "text_normalized": "故德交歸焉。", "notes": ""}
