{"segment_id": "shijing__song-chengong-009__001__zhwikisource-20260530", "work_id": "shijing", "section_id": "song-chengong-009", "source_id": "song-chengong-009__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 1, "canonical_ref": "詩經·頌·臣工之什·009.1", "text_original": "有客有客，亦白其馬。有萋有且，敦琢其旅。", "text_normalized": "有客有客，亦白其馬。有萋有且，敦琢其旅。", "notes": "有客 Chinese stanza 1."}
{"segment_id": "shijing__song-chengong-009__002__zhwikisource-20260530", "work_id": "shijing", "section_id": "song-chengong-009", "source_id": "song-chengong-009__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 2, "canonical_ref": "詩經·頌·臣工之什·009.2", "text_original": "有客宿宿，有客信信。言授之縶，以縶其馬。", "text_normalized": "有客宿宿，有客信信。言授之縶，以縶其馬。", "notes": "有客 Chinese stanza 2."}
{"segment_id": "shijing__song-chengong-009__003__zhwikisource-20260530", "work_id": "shijing", "section_id": "song-chengong-009", "source_id": "song-chengong-009__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 3, "canonical_ref": "詩經·頌·臣工之什·009.3", "text_original": "薄言追之，左右綏之。既有淫威，降福孔夷。", "text_normalized": "薄言追之，左右綏之。既有淫威，降福孔夷。", "notes": "有客 Chinese stanza 3."}
