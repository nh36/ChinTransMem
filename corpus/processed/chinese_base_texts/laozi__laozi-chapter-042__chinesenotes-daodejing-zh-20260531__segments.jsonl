{"segment_id": "laozi-chapter-042__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-042", "source_id": "laozi-chapter-042__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 42.1", "sort_key": "042.001", "text_original": "道生一，", "text_normalized": "道生一，", "notes": ""}
{"segment_id": "laozi-chapter-042__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-042", "source_id": "laozi-chapter-042__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 42.2", "sort_key": "042.002", "text_original": "一生二，", "text_normalized": "一生二，", "notes": ""}
{"segment_id": "laozi-chapter-042__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-042", "source_id": "laozi-chapter-042__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 42.3", "sort_key": "042.003", "text_original": "二生三，", "text_normalized": "二生三，", "notes": ""}
{"segment_id": "laozi-chapter-042__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-042", "source_id": "laozi-chapter-042__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 42.4", "sort_key": "042.004", "text_original": "三生萬物。", "text_normalized": "三生萬物。", "notes": ""}
{"segment_id": "laozi-chapter-042__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-042", "source_id": "laozi-chapter-042__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 42.5", "sort_key": "042.005", "text_original": "萬物負陰而抱陽，", "text_normalized": "萬物負陰而抱陽，", "notes": ""}
{"segment_id": "laozi-chapter-042__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-042", "source_id": "laozi-chapter-042__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 42.6", "sort_key": "042.006", "text_original": "沖氣以為和。", "text_normalized": "沖氣以為和。", "notes": ""}
{"segment_id": "laozi-chapter-042__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-042", "source_id": "laozi-chapter-042__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 42.7", "sort_key": "042.007", "text_original": "人之所惡，", "text_normalized": "人之所惡，", "notes": ""}
{"segment_id": "laozi-chapter-042__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-042", "source_id": "laozi-chapter-042__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 42.8", "sort_key": "042.008", "text_original": "唯孤﹑寡﹑不穀，", "text_normalized": "唯孤﹑寡﹑不穀，", "notes": ""}
{"segment_id": "laozi-chapter-042__chinesenotes-daodejing-zh-20260531__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-042", "source_id": "laozi-chapter-042__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 42.9", "sort_key": "042.009", "text_original": "而王公以為稱。", "text_normalized": "而王公以為稱。", "notes": ""}
{"segment_id": "laozi-chapter-042__chinesenotes-daodejing-zh-20260531__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-042", "source_id": "laozi-chapter-042__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 42.10", "sort_key": "042.010", "text_original": "故物或損之而益，", "text_normalized": "故物或損之而益，", "notes": ""}
{"segment_id": "laozi-chapter-042__chinesenotes-daodejing-zh-20260531__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-042", "source_id": "laozi-chapter-042__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 42.11", "sort_key": "042.011", "text_original": "或益之而損。", "text_normalized": "或益之而損。", "notes": ""}
{"segment_id": "laozi-chapter-042__chinesenotes-daodejing-zh-20260531__seg-012", "work_id": "laozi", "section_id": "laozi-chapter-042", "source_id": "laozi-chapter-042__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 12, "canonical_ref": "老子 42.12", "sort_key": "042.012", "text_original": "人之所教，", "text_normalized": "人之所教，", "notes": ""}
{"segment_id": "laozi-chapter-042__chinesenotes-daodejing-zh-20260531__seg-013", "work_id": "laozi", "section_id": "laozi-chapter-042", "source_id": "laozi-chapter-042__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 13, "canonical_ref": "老子 42.13", "sort_key": "042.013", "text_original": "我亦教之。", "text_normalized": "我亦教之。", "notes": ""}
{"segment_id": "laozi-chapter-042__chinesenotes-daodejing-zh-20260531__seg-014", "work_id": "laozi", "section_id": "laozi-chapter-042", "source_id": "laozi-chapter-042__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 14, "canonical_ref": "老子 42.14", "sort_key": "042.014", "text_original": "強梁者不得其死，", "text_normalized": "強梁者不得其死，", "notes": ""}
{"segment_id": "laozi-chapter-042__chinesenotes-daodejing-zh-20260531__seg-015", "work_id": "laozi", "section_id": "laozi-chapter-042", "source_id": "laozi-chapter-042__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 15, "canonical_ref": "老子 42.15", "sort_key": "042.015", "text_original": "吾將以為教父。", "text_normalized": "吾將以為教父。", "notes": ""}
