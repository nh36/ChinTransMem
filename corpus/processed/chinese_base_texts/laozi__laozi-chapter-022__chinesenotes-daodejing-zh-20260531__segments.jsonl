{"segment_id": "laozi-chapter-022__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-022", "source_id": "laozi-chapter-022__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 22.1", "sort_key": "022.001", "text_original": "曲則全，", "text_normalized": "曲則全，", "notes": ""}
{"segment_id": "laozi-chapter-022__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-022", "source_id": "laozi-chapter-022__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 22.2", "sort_key": "022.002", "text_original": "枉則直，", "text_normalized": "枉則直，", "notes": ""}
{"segment_id": "laozi-chapter-022__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-022", "source_id": "laozi-chapter-022__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 22.3", "sort_key": "022.003", "text_original": "窪則盈，", "text_normalized": "窪則盈，", "notes": ""}
{"segment_id": "laozi-chapter-022__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-022", "source_id": "laozi-chapter-022__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 22.4", "sort_key": "022.004", "text_original": "敝則新，", "text_normalized": "敝則新，", "notes": ""}
{"segment_id": "laozi-chapter-022__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-022", "source_id": "laozi-chapter-022__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 22.5", "sort_key": "022.005", "text_original": "少則得，", "text_normalized": "少則得，", "notes": ""}
{"segment_id": "laozi-chapter-022__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-022", "source_id": "laozi-chapter-022__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 22.6", "sort_key": "022.006", "text_original": "多則惑。", "text_normalized": "多則惑。", "notes": ""}
{"segment_id": "laozi-chapter-022__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-022", "source_id": "laozi-chapter-022__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 22.7", "sort_key": "022.007", "text_original": "是以聖人抱一為天下式。", "text_normalized": "是以聖人抱一為天下式。", "notes": ""}
{"segment_id": "laozi-chapter-022__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-022", "source_id": "laozi-chapter-022__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 22.8", "sort_key": "022.008", "text_original": "不自見故明，", "text_normalized": "不自見故明，", "notes": ""}
{"segment_id": "laozi-chapter-022__chinesenotes-daodejing-zh-20260531__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-022", "source_id": "laozi-chapter-022__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 22.9", "sort_key": "022.009", "text_original": "不自是故彰，", "text_normalized": "不自是故彰，", "notes": ""}
{"segment_id": "laozi-chapter-022__chinesenotes-daodejing-zh-20260531__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-022", "source_id": "laozi-chapter-022__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 22.10", "sort_key": "022.010", "text_original": "不自伐故有功，", "text_normalized": "不自伐故有功，", "notes": ""}
{"segment_id": "laozi-chapter-022__chinesenotes-daodejing-zh-20260531__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-022", "source_id": "laozi-chapter-022__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 22.11", "sort_key": "022.011", "text_original": "不自矜故長。", "text_normalized": "不自矜故長。", "notes": ""}
{"segment_id": "laozi-chapter-022__chinesenotes-daodejing-zh-20260531__seg-012", "work_id": "laozi", "section_id": "laozi-chapter-022", "source_id": "laozi-chapter-022__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 12, "canonical_ref": "老子 22.12", "sort_key": "022.012", "text_original": "夫唯不爭，", "text_normalized": "夫唯不爭，", "notes": ""}
{"segment_id": "laozi-chapter-022__chinesenotes-daodejing-zh-20260531__seg-013", "work_id": "laozi", "section_id": "laozi-chapter-022", "source_id": "laozi-chapter-022__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 13, "canonical_ref": "老子 22.13", "sort_key": "022.013", "text_original": "故天下莫能與之爭。", "text_normalized": "故天下莫能與之爭。", "notes": ""}
{"segment_id": "laozi-chapter-022__chinesenotes-daodejing-zh-20260531__seg-014", "work_id": "laozi", "section_id": "laozi-chapter-022", "source_id": "laozi-chapter-022__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 14, "canonical_ref": "老子 22.14", "sort_key": "022.014", "text_original": "古之所謂曲則全者，", "text_normalized": "古之所謂曲則全者，", "notes": ""}
{"segment_id": "laozi-chapter-022__chinesenotes-daodejing-zh-20260531__seg-015", "work_id": "laozi", "section_id": "laozi-chapter-022", "source_id": "laozi-chapter-022__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 15, "canonical_ref": "老子 22.15", "sort_key": "022.015", "text_original": "豈虛言哉！", "text_normalized": "豈虛言哉！", "notes": ""}
{"segment_id": "laozi-chapter-022__chinesenotes-daodejing-zh-20260531__seg-016", "work_id": "laozi", "section_id": "laozi-chapter-022", "source_id": "laozi-chapter-022__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 16, "canonical_ref": "老子 22.16", "sort_key": "022.016", "text_original": "誠全而歸之。", "text_normalized": "誠全而歸之。", "notes": ""}
