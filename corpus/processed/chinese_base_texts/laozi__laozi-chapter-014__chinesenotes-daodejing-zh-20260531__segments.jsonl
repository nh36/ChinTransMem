{"segment_id": "laozi-chapter-014__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-014", "source_id": "laozi-chapter-014__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 14.1", "sort_key": "014.001", "text_original": "視之不見名曰夷，", "text_normalized": "視之不見名曰夷，", "notes": ""}
{"segment_id": "laozi-chapter-014__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-014", "source_id": "laozi-chapter-014__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 14.2", "sort_key": "014.002", "text_original": "聽之不聞名曰希，", "text_normalized": "聽之不聞名曰希，", "notes": ""}
{"segment_id": "laozi-chapter-014__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-014", "source_id": "laozi-chapter-014__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 14.3", "sort_key": "014.003", "text_original": "搏之不得名曰微。", "text_normalized": "搏之不得名曰微。", "notes": ""}
{"segment_id": "laozi-chapter-014__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-014", "source_id": "laozi-chapter-014__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 14.4", "sort_key": "014.004", "text_original": "此三者，", "text_normalized": "此三者，", "notes": ""}
{"segment_id": "laozi-chapter-014__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-014", "source_id": "laozi-chapter-014__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 14.5", "sort_key": "014.005", "text_original": "不可致詰，", "text_normalized": "不可致詰，", "notes": ""}
{"segment_id": "laozi-chapter-014__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-014", "source_id": "laozi-chapter-014__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 14.6", "sort_key": "014.006", "text_original": "故混而為一。", "text_normalized": "故混而為一。", "notes": ""}
{"segment_id": "laozi-chapter-014__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-014", "source_id": "laozi-chapter-014__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 14.7", "sort_key": "014.007", "text_original": "其上不皦，", "text_normalized": "其上不皦，", "notes": ""}
{"segment_id": "laozi-chapter-014__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-014", "source_id": "laozi-chapter-014__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 14.8", "sort_key": "014.008", "text_original": "其下不昧。", "text_normalized": "其下不昧。", "notes": ""}
{"segment_id": "laozi-chapter-014__chinesenotes-daodejing-zh-20260531__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-014", "source_id": "laozi-chapter-014__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 14.9", "sort_key": "014.009", "text_original": "繩繩不可名，", "text_normalized": "繩繩不可名，", "notes": ""}
{"segment_id": "laozi-chapter-014__chinesenotes-daodejing-zh-20260531__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-014", "source_id": "laozi-chapter-014__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 14.10", "sort_key": "014.010", "text_original": "復歸於無物。", "text_normalized": "復歸於無物。", "notes": ""}
{"segment_id": "laozi-chapter-014__chinesenotes-daodejing-zh-20260531__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-014", "source_id": "laozi-chapter-014__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 14.11", "sort_key": "014.011", "text_original": "是謂無狀之狀，", "text_normalized": "是謂無狀之狀，", "notes": ""}
{"segment_id": "laozi-chapter-014__chinesenotes-daodejing-zh-20260531__seg-012", "work_id": "laozi", "section_id": "laozi-chapter-014", "source_id": "laozi-chapter-014__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 12, "canonical_ref": "老子 14.12", "sort_key": "014.012", "text_original": "無物之象，", "text_normalized": "無物之象，", "notes": ""}
{"segment_id": "laozi-chapter-014__chinesenotes-daodejing-zh-20260531__seg-013", "work_id": "laozi", "section_id": "laozi-chapter-014", "source_id": "laozi-chapter-014__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 13, "canonical_ref": "老子 14.13", "sort_key": "014.013", "text_original": "是謂惚恍。", "text_normalized": "是謂惚恍。", "notes": ""}
{"segment_id": "laozi-chapter-014__chinesenotes-daodejing-zh-20260531__seg-014", "work_id": "laozi", "section_id": "laozi-chapter-014", "source_id": "laozi-chapter-014__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 14, "canonical_ref": "老子 14.14", "sort_key": "014.014", "text_original": "迎之不見其首，", "text_normalized": "迎之不見其首，", "notes": ""}
{"segment_id": "laozi-chapter-014__chinesenotes-daodejing-zh-20260531__seg-015", "work_id": "laozi", "section_id": "laozi-chapter-014", "source_id": "laozi-chapter-014__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 15, "canonical_ref": "老子 14.15", "sort_key": "014.015", "text_original": "隨之不見其後。", "text_normalized": "隨之不見其後。", "notes": ""}
{"segment_id": "laozi-chapter-014__chinesenotes-daodejing-zh-20260531__seg-016", "work_id": "laozi", "section_id": "laozi-chapter-014", "source_id": "laozi-chapter-014__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 16, "canonical_ref": "老子 14.16", "sort_key": "014.016", "text_original": "執古之道，", "text_normalized": "執古之道，", "notes": ""}
{"segment_id": "laozi-chapter-014__chinesenotes-daodejing-zh-20260531__seg-017", "work_id": "laozi", "section_id": "laozi-chapter-014", "source_id": "laozi-chapter-014__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 17, "canonical_ref": "老子 14.17", "sort_key": "014.017", "text_original": "以御今之有。", "text_normalized": "以御今之有。", "notes": ""}
{"segment_id": "laozi-chapter-014__chinesenotes-daodejing-zh-20260531__seg-018", "work_id": "laozi", "section_id": "laozi-chapter-014", "source_id": "laozi-chapter-014__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 18, "canonical_ref": "老子 14.18", "sort_key": "014.018", "text_original": "能知古始，", "text_normalized": "能知古始，", "notes": ""}
{"segment_id": "laozi-chapter-014__chinesenotes-daodejing-zh-20260531__seg-019", "work_id": "laozi", "section_id": "laozi-chapter-014", "source_id": "laozi-chapter-014__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 19, "canonical_ref": "老子 14.19", "sort_key": "014.019", "text_original": "是謂道紀。", "text_normalized": "是謂道紀。", "notes": ""}
