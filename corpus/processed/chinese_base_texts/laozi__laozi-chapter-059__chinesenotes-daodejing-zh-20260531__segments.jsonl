{"segment_id": "laozi-chapter-059__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-059", "source_id": "laozi-chapter-059__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 59.1", "sort_key": "059.001", "text_original": "治人事天，莫若嗇。", "text_normalized": "治人事天，莫若嗇。", "notes": ""}
{"segment_id": "laozi-chapter-059__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-059", "source_id": "laozi-chapter-059__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 59.2", "sort_key": "059.002", "text_original": "夫唯嗇，是謂早服；", "text_normalized": "夫唯嗇，是謂早服；", "notes": ""}
{"segment_id": "laozi-chapter-059__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-059", "source_id": "laozi-chapter-059__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 59.3", "sort_key": "059.003", "text_original": "早服謂之重積德；", "text_normalized": "早服謂之重積德；", "notes": ""}
{"segment_id": "laozi-chapter-059__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-059", "source_id": "laozi-chapter-059__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 59.4", "sort_key": "059.004", "text_original": "重積德則無不克，無不克則莫知其極；", "text_normalized": "重積德則無不克，無不克則莫知其極；", "notes": ""}
{"segment_id": "laozi-chapter-059__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-059", "source_id": "laozi-chapter-059__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 59.5", "sort_key": "059.005", "text_original": "莫知其極，可以有國；", "text_normalized": "莫知其極，可以有國；", "notes": ""}
{"segment_id": "laozi-chapter-059__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-059", "source_id": "laozi-chapter-059__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 59.6", "sort_key": "059.006", "text_original": "有國之母，可以長久；", "text_normalized": "有國之母，可以長久；", "notes": ""}
{"segment_id": "laozi-chapter-059__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-059", "source_id": "laozi-chapter-059__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 59.7", "sort_key": "059.007", "text_original": "是謂深根固柢，長生久視之道。", "text_normalized": "是謂深根固柢，長生久視之道。", "notes": ""}
