{"segment_id": "laozi-chapter-070__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-070", "source_id": "laozi-chapter-070__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 70.4", "sort_key": "070.004", "text_original": "莫能行。", "text_normalized": "莫能行。", "notes": ""}
