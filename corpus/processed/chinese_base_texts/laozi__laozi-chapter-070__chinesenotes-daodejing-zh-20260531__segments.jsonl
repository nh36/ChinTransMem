{"segment_id": "laozi-chapter-070__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-070", "source_id": "laozi-chapter-070__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 70.6", "sort_key": "070.006", "text_original": "事有君。", "text_normalized": "事有君。", "notes": ""}
{"segment_id": "laozi-chapter-070__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-070", "source_id": "laozi-chapter-070__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 70.7", "sort_key": "070.007", "text_original": "夫唯無知，", "text_normalized": "夫唯無知，", "notes": ""}
{"segment_id": "laozi-chapter-070__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-070", "source_id": "laozi-chapter-070__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 70.8", "sort_key": "070.008", "text_original": "是以不我知。", "text_normalized": "是以不我知。", "notes": ""}
{"segment_id": "laozi-chapter-070__chinesenotes-daodejing-zh-20260531__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-070", "source_id": "laozi-chapter-070__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 70.9", "sort_key": "070.009", "text_original": "知我者希，", "text_normalized": "知我者希，", "notes": ""}
{"segment_id": "laozi-chapter-070__chinesenotes-daodejing-zh-20260531__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-070", "source_id": "laozi-chapter-070__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 70.10", "sort_key": "070.010", "text_original": "則我者貴。", "text_normalized": "則我者貴。", "notes": ""}
{"segment_id": "laozi-chapter-070__chinesenotes-daodejing-zh-20260531__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-070", "source_id": "laozi-chapter-070__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 70.11", "sort_key": "070.011", "text_original": "是以聖人被褐懷玉。", "text_normalized": "是以聖人被褐懷玉。", "notes": ""}
