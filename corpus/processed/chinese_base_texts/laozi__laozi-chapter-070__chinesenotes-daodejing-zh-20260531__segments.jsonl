{"segment_id": "laozi-chapter-070__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-070", "source_id": "laozi-chapter-070__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 70.1", "sort_key": "070.001", "text_original": "吾言甚易知，甚易行。天下莫能知，莫能行。", "text_normalized": "吾言甚易知，甚易行。天下莫能知，莫能行。", "notes": ""}
{"segment_id": "laozi-chapter-070__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-070", "source_id": "laozi-chapter-070__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 70.2", "sort_key": "070.002", "text_original": "言有宗，事有君。", "text_normalized": "言有宗，事有君。", "notes": ""}
{"segment_id": "laozi-chapter-070__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-070", "source_id": "laozi-chapter-070__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 70.3", "sort_key": "070.003", "text_original": "夫唯無知，是以不我知。", "text_normalized": "夫唯無知，是以不我知。", "notes": ""}
{"segment_id": "laozi-chapter-070__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-070", "source_id": "laozi-chapter-070__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 70.4", "sort_key": "070.004", "text_original": "知我者希，則我者貴。", "text_normalized": "知我者希，則我者貴。", "notes": ""}
{"segment_id": "laozi-chapter-070__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-070", "source_id": "laozi-chapter-070__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 70.5", "sort_key": "070.005", "text_original": "是以聖人被褐懷玉。", "text_normalized": "是以聖人被褐懷玉。", "notes": ""}
