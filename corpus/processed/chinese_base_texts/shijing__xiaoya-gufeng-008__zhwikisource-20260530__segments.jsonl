{"segment_id": "shijing__xiaoya-gufeng-008__001__zhwikisource-20260530", "work_id": "shijing", "section_id": "xiaoya-gufeng-008", "source_id": "xiaoya-gufeng-008__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 1, "canonical_ref": "詩經·小雅·谷風之什·008.1", "text_original": "鼓鍾將將，淮水湯湯。憂心且傷。淑人君子，懷允不忘。", "text_normalized": "鼓鍾將將，淮水湯湯。憂心且傷。淑人君子，懷允不忘。", "notes": "鼓鍾 Chinese stanza 1."}
{"segment_id": "shijing__xiaoya-gufeng-008__002__zhwikisource-20260530", "work_id": "shijing", "section_id": "xiaoya-gufeng-008", "source_id": "xiaoya-gufeng-008__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 2, "canonical_ref": "詩經·小雅·谷風之什·008.2", "text_original": "鼓鍾喈喈，淮水湝湝。憂心且悲。淑人君子，其德不回。", "text_normalized": "鼓鍾喈喈，淮水湝湝。憂心且悲。淑人君子，其德不回。", "notes": "鼓鍾 Chinese stanza 2."}
{"segment_id": "shijing__xiaoya-gufeng-008__003__zhwikisource-20260530", "work_id": "shijing", "section_id": "xiaoya-gufeng-008", "source_id": "xiaoya-gufeng-008__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 3, "canonical_ref": "詩經·小雅·谷風之什·008.3", "text_original": "鼓鍾伐鼛，淮有三洲。憂心且妯。淑人君子，其德不猶。", "text_normalized": "鼓鍾伐鼛，淮有三洲。憂心且妯。淑人君子，其德不猶。", "notes": "鼓鍾 Chinese stanza 3."}
{"segment_id": "shijing__xiaoya-gufeng-008__004__zhwikisource-20260530", "work_id": "shijing", "section_id": "xiaoya-gufeng-008", "source_id": "xiaoya-gufeng-008__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 4, "canonical_ref": "詩經·小雅·谷風之什·008.4", "text_original": "鼓鍾欽欽，鼓瑟鼓琴。笙磬同音。以雅以南，以籥不僭。", "text_normalized": "鼓鍾欽欽，鼓瑟鼓琴。笙磬同音。以雅以南，以籥不僭。", "notes": "鼓鍾 Chinese stanza 4."}
