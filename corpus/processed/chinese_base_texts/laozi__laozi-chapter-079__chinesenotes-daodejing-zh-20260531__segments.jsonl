{"segment_id": "laozi-chapter-079__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-079", "source_id": "laozi-chapter-079__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 79.1", "sort_key": "079.001", "text_original": "和大怨，必有餘怨，", "text_normalized": "和大怨，必有餘怨，", "notes": ""}
{"segment_id": "laozi-chapter-079__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-079", "source_id": "laozi-chapter-079__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 79.2", "sort_key": "079.002", "text_original": "安可以為善？是以聖人執左契，", "text_normalized": "安可以為善？是以聖人執左契，", "notes": ""}
{"segment_id": "laozi-chapter-079__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-079", "source_id": "laozi-chapter-079__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 79.3", "sort_key": "079.003", "text_original": "而不責於人。有德司契，", "text_normalized": "而不責於人。有德司契，", "notes": ""}
{"segment_id": "laozi-chapter-079__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-079", "source_id": "laozi-chapter-079__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 79.4", "sort_key": "079.004", "text_original": "無德司徹。", "text_normalized": "無德司徹。", "notes": ""}
{"segment_id": "laozi-chapter-079__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-079", "source_id": "laozi-chapter-079__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 79.5", "sort_key": "079.005", "text_original": "天道無親，常與善人。", "text_normalized": "天道無親，常與善人。", "notes": ""}
