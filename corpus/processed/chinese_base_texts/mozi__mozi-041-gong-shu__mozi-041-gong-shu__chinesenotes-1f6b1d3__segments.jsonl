{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0001", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 1, "text_original": "公輸盤為楚造雲梯之械，成，將以攻宋。", "text_normalized": "公輸盤為楚造雲梯之械，成，將以攻宋。", "canonical_ref": "41.1", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0002", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 2, "text_original": "子墨子聞之，起於齊，行十日十夜而至於郢，見公輸盤。", "text_normalized": "子墨子聞之，起於齊，行十日十夜而至於郢，見公輸盤。", "canonical_ref": "41.2", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0003", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 3, "text_original": "公輸盤曰：", "text_normalized": "公輸盤曰：", "canonical_ref": "41.3", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0004", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 4, "text_original": "「夫子何命焉為？", "text_normalized": "「夫子何命焉為？", "canonical_ref": "41.4", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0005", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 5, "text_original": "」子墨子曰：", "text_normalized": "」子墨子曰：", "canonical_ref": "41.5", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0006", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 6, "text_original": "「北方有侮臣，願藉子殺之。", "text_normalized": "「北方有侮臣，願藉子殺之。", "canonical_ref": "41.6", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0007", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 7, "text_original": "」公輸盤不說。", "text_normalized": "」公輸盤不說。", "canonical_ref": "41.7", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0008", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 8, "text_original": "子墨子曰：", "text_normalized": "子墨子曰：", "canonical_ref": "41.8", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0009", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 9, "text_original": "「請獻十金。", "text_normalized": "「請獻十金。", "canonical_ref": "41.9", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0010", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 10, "text_original": "」公輸盤曰：", "text_normalized": "」公輸盤曰：", "canonical_ref": "41.10", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0011", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 11, "text_original": "「吾義固不殺人。", "text_normalized": "「吾義固不殺人。", "canonical_ref": "41.11", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0012", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 12, "text_original": "」子墨子起，再拜曰：", "text_normalized": "」子墨子起，再拜曰：", "canonical_ref": "41.12", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0013", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 13, "text_original": "「請說之。", "text_normalized": "「請說之。", "canonical_ref": "41.13", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0014", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 14, "text_original": "吾從北方聞子為梯，將以攻宋。", "text_normalized": "吾從北方聞子為梯，將以攻宋。", "canonical_ref": "41.14", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0015", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 15, "text_original": "宋何罪之有？", "text_normalized": "宋何罪之有？", "canonical_ref": "41.15", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0016", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 16, "text_original": "荊國有餘於地，而不足於民，殺所不足而爭所有餘，不可謂智。", "text_normalized": "荊國有餘於地，而不足於民，殺所不足而爭所有餘，不可謂智。", "canonical_ref": "41.16", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0017", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 17, "text_original": "宋無罪而攻之，不可謂仁。", "text_normalized": "宋無罪而攻之，不可謂仁。", "canonical_ref": "41.17", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0018", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 18, "text_original": "知而不爭，不可謂忠。", "text_normalized": "知而不爭，不可謂忠。", "canonical_ref": "41.18", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0019", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 19, "text_original": "爭而不得，不可謂強。", "text_normalized": "爭而不得，不可謂強。", "canonical_ref": "41.19", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0020", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 20, "text_original": "義不殺少而殺眾，不可謂知類。", "text_normalized": "義不殺少而殺眾，不可謂知類。", "canonical_ref": "41.20", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0021", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 21, "text_original": "」公輸盤服。", "text_normalized": "」公輸盤服。", "canonical_ref": "41.21", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0022", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 22, "text_original": "子墨子曰：", "text_normalized": "子墨子曰：", "canonical_ref": "41.22", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0023", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 23, "text_original": "「然乎不已乎？", "text_normalized": "「然乎不已乎？", "canonical_ref": "41.23", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0024", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 24, "text_original": "」公輸盤曰：", "text_normalized": "」公輸盤曰：", "canonical_ref": "41.24", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0025", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 25, "text_original": "「不可，吾既已言之王矣。", "text_normalized": "「不可，吾既已言之王矣。", "canonical_ref": "41.25", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0026", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 26, "text_original": "」子墨子曰：", "text_normalized": "」子墨子曰：", "canonical_ref": "41.26", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0027", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 27, "text_original": "「胡不見我於王？", "text_normalized": "「胡不見我於王？", "canonical_ref": "41.27", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0028", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 28, "text_original": "」公輸盤曰：", "text_normalized": "」公輸盤曰：", "canonical_ref": "41.28", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0029", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 29, "text_original": "「諾。", "text_normalized": "「諾。", "canonical_ref": "41.29", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0030", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 30, "text_original": "」", "text_normalized": "」", "canonical_ref": "41.30", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0031", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 31, "text_original": "子墨子見王，曰：", "text_normalized": "子墨子見王，曰：", "canonical_ref": "41.31", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0032", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 32, "text_original": "「今有人於此，捨其文軒，鄰有敝輿，而欲竊之。", "text_normalized": "「今有人於此，捨其文軒，鄰有敝輿，而欲竊之。", "canonical_ref": "41.32", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0033", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 33, "text_original": "捨其錦繡，鄰有短褐而欲竊之。", "text_normalized": "捨其錦繡，鄰有短褐而欲竊之。", "canonical_ref": "41.33", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0034", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 34, "text_original": "捨其粱肉，鄰有糠糟而欲竊之。", "text_normalized": "捨其粱肉，鄰有糠糟而欲竊之。", "canonical_ref": "41.34", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0035", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 35, "text_original": "此為何若人？", "text_normalized": "此為何若人？", "canonical_ref": "41.35", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0036", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 36, "text_original": "」王曰：", "text_normalized": "」王曰：", "canonical_ref": "41.36", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0037", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 37, "text_original": "「必為竊疾矣。", "text_normalized": "「必為竊疾矣。", "canonical_ref": "41.37", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0038", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 38, "text_original": "」子墨子曰：", "text_normalized": "」子墨子曰：", "canonical_ref": "41.38", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0039", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 39, "text_original": "「荊之地方五千里，宋之地方五百里，此猶文軒之與敝輿也。", "text_normalized": "「荊之地方五千里，宋之地方五百里，此猶文軒之與敝輿也。", "canonical_ref": "41.39", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0040", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 40, "text_original": "荊有雲夢，犀兕麋鹿滿之，江漢之魚鱉黿鼉為天下富，宋所為無雉兔狐狸者也，此猶粱肉之與糠糟也。", "text_normalized": "荊有雲夢，犀兕麋鹿滿之，江漢之魚鱉黿鼉為天下富，宋所為無雉兔狐狸者也，此猶粱肉之與糠糟也。", "canonical_ref": "41.40", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0041", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 41, "text_original": "荊有長松、文梓、楩楠、豫章，宋無長木，此猶錦繡之與短褐也。", "text_normalized": "荊有長松、文梓、楩楠、豫章，宋無長木，此猶錦繡之與短褐也。", "canonical_ref": "41.41", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0042", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 42, "text_original": "臣以三事之攻宋也，為與此同類，臣見大王之必傷義而不得。", "text_normalized": "臣以三事之攻宋也，為與此同類，臣見大王之必傷義而不得。", "canonical_ref": "41.42", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0043", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 43, "text_original": "」王曰：", "text_normalized": "」王曰：", "canonical_ref": "41.43", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0044", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 44, "text_original": "「善哉！", "text_normalized": "「善哉！", "canonical_ref": "41.44", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0045", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 45, "text_original": "雖然，公輸盤為我為雲梯，必取宋。", "text_normalized": "雖然，公輸盤為我為雲梯，必取宋。", "canonical_ref": "41.45", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0046", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 46, "text_original": "」於是見公輸盤。", "text_normalized": "」於是見公輸盤。", "canonical_ref": "41.46", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0047", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 47, "text_original": "子墨子解帶為城，以牒為械，公輸盤九設攻城之機變，子墨子九距之。", "text_normalized": "子墨子解帶為城，以牒為械，公輸盤九設攻城之機變，子墨子九距之。", "canonical_ref": "41.47", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0048", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 48, "text_original": "公輸盤之攻械盡，子墨子之守圉有餘。", "text_normalized": "公輸盤之攻械盡，子墨子之守圉有餘。", "canonical_ref": "41.48", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0049", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 49, "text_original": "公輸盤詘，而曰：", "text_normalized": "公輸盤詘，而曰：", "canonical_ref": "41.49", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0050", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 50, "text_original": "「吾知所以距子矣，吾不言。", "text_normalized": "「吾知所以距子矣，吾不言。", "canonical_ref": "41.50", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0051", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 51, "text_original": "」子墨子亦曰：", "text_normalized": "」子墨子亦曰：", "canonical_ref": "41.51", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0052", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 52, "text_original": "「吾知子之所以距我，吾不言。", "text_normalized": "「吾知子之所以距我，吾不言。", "canonical_ref": "41.52", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0053", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 53, "text_original": "」楚王問其故，子墨子曰：", "text_normalized": "」楚王問其故，子墨子曰：", "canonical_ref": "41.53", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0054", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 54, "text_original": "「公輸子之意，不過欲殺臣。", "text_normalized": "「公輸子之意，不過欲殺臣。", "canonical_ref": "41.54", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0055", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 55, "text_original": "殺臣，宋莫能守，可攻也。", "text_normalized": "殺臣，宋莫能守，可攻也。", "canonical_ref": "41.55", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0056", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 56, "text_original": "然臣之弟子禽滑厘等三百人，已持臣守圉之器，在宋城上而待楚寇矣。", "text_normalized": "然臣之弟子禽滑厘等三百人，已持臣守圉之器，在宋城上而待楚寇矣。", "canonical_ref": "41.56", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0057", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 57, "text_original": "雖殺臣，不能絕也。", "text_normalized": "雖殺臣，不能絕也。", "canonical_ref": "41.57", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0058", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 58, "text_original": "」楚王曰：", "text_normalized": "」楚王曰：", "canonical_ref": "41.58", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0059", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 59, "text_original": "「善哉！", "text_normalized": "「善哉！", "canonical_ref": "41.59", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0060", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 60, "text_original": "吾請無攻宋矣。", "text_normalized": "吾請無攻宋矣。", "canonical_ref": "41.60", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0061", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 61, "text_original": "」子墨子歸，過宋。", "text_normalized": "」子墨子歸，過宋。", "canonical_ref": "41.61", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0062", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 62, "text_original": "天雨，庇其閭中，守閭者不內也。", "text_normalized": "天雨，庇其閭中，守閭者不內也。", "canonical_ref": "41.62", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0063", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 63, "text_original": "故曰：", "text_normalized": "故曰：", "canonical_ref": "41.63", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0064", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 64, "text_original": "治於神者，眾人不知其功。", "text_normalized": "治於神者，眾人不知其功。", "canonical_ref": "41.64", "notes": ""}
{"segment_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3__seg-0065", "section_id": "mozi-041-gong-shu", "source_id": "mozi-041-gong-shu__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 65, "text_original": "爭於明者，眾人知之。", "text_normalized": "爭於明者，眾人知之。", "canonical_ref": "41.65", "notes": ""}
