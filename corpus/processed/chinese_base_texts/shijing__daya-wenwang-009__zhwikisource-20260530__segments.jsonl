{"segment_id": "shijing__daya-wenwang-009__001__zhwikisource-20260530", "work_id": "shijing", "section_id": "daya-wenwang-009", "source_id": "daya-wenwang-009__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 1, "canonical_ref": "詩經·大雅·文王之什·009.1", "text_original": "下武維周，世有哲王。三后在天，王配于京。", "text_normalized": "下武維周，世有哲王。三后在天，王配于京。", "notes": "下武 Chinese stanza 1."}
{"segment_id": "shijing__daya-wenwang-009__002__zhwikisource-20260530", "work_id": "shijing", "section_id": "daya-wenwang-009", "source_id": "daya-wenwang-009__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 2, "canonical_ref": "詩經·大雅·文王之什·009.2", "text_original": "王配于京，世德作求。永言配命，成王之孚。", "text_normalized": "王配于京，世德作求。永言配命，成王之孚。", "notes": "下武 Chinese stanza 2."}
{"segment_id": "shijing__daya-wenwang-009__003__zhwikisource-20260530", "work_id": "shijing", "section_id": "daya-wenwang-009", "source_id": "daya-wenwang-009__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 3, "canonical_ref": "詩經·大雅·文王之什·009.3", "text_original": "成王之孚，下土之式。永言孝思，孝思維則。", "text_normalized": "成王之孚，下土之式。永言孝思，孝思維則。", "notes": "下武 Chinese stanza 3."}
{"segment_id": "shijing__daya-wenwang-009__004__zhwikisource-20260530", "work_id": "shijing", "section_id": "daya-wenwang-009", "source_id": "daya-wenwang-009__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 4, "canonical_ref": "詩經·大雅·文王之什·009.4", "text_original": "媚茲一人，應侯順德。永言孝思，昭哉嗣服。", "text_normalized": "媚茲一人，應侯順德。永言孝思，昭哉嗣服。", "notes": "下武 Chinese stanza 4."}
{"segment_id": "shijing__daya-wenwang-009__005__zhwikisource-20260530", "work_id": "shijing", "section_id": "daya-wenwang-009", "source_id": "daya-wenwang-009__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 5, "canonical_ref": "詩經·大雅·文王之什·009.5", "text_original": "昭茲來許，繩其祖武。於萬斯年，受天之祜。", "text_normalized": "昭茲來許，繩其祖武。於萬斯年，受天之祜。", "notes": "下武 Chinese stanza 5."}
{"segment_id": "shijing__daya-wenwang-009__006__zhwikisource-20260530", "work_id": "shijing", "section_id": "daya-wenwang-009", "source_id": "daya-wenwang-009__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 6, "canonical_ref": "詩經·大雅·文王之什·009.6", "text_original": "受天之祜，四方來賀。於萬斯年，不遐有佐。", "text_normalized": "受天之祜，四方來賀。於萬斯年，不遐有佐。", "notes": "下武 Chinese stanza 6."}
