{"segment_id": "laozi-chapter-030__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-030", "source_id": "laozi-chapter-030__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 30.1", "sort_key": "030.001", "text_original": "以道佐人主者，", "text_normalized": "以道佐人主者，", "notes": ""}
{"segment_id": "laozi-chapter-030__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-030", "source_id": "laozi-chapter-030__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 30.2", "sort_key": "030.002", "text_original": "不以兵強天下。", "text_normalized": "不以兵強天下。", "notes": ""}
{"segment_id": "laozi-chapter-030__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-030", "source_id": "laozi-chapter-030__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 30.3", "sort_key": "030.003", "text_original": "其事好還。", "text_normalized": "其事好還。", "notes": ""}
{"segment_id": "laozi-chapter-030__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-030", "source_id": "laozi-chapter-030__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 30.4", "sort_key": "030.004", "text_original": "師之所處，", "text_normalized": "師之所處，", "notes": ""}
{"segment_id": "laozi-chapter-030__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-030", "source_id": "laozi-chapter-030__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 30.5", "sort_key": "030.005", "text_original": "荊棘生焉。", "text_normalized": "荊棘生焉。", "notes": ""}
{"segment_id": "laozi-chapter-030__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-030", "source_id": "laozi-chapter-030__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 30.6", "sort_key": "030.006", "text_original": "大軍之後，", "text_normalized": "大軍之後，", "notes": ""}
{"segment_id": "laozi-chapter-030__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-030", "source_id": "laozi-chapter-030__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 30.7", "sort_key": "030.007", "text_original": "必有凶年。", "text_normalized": "必有凶年。", "notes": ""}
{"segment_id": "laozi-chapter-030__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-030", "source_id": "laozi-chapter-030__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 30.8", "sort_key": "030.008", "text_original": "善有果而已，", "text_normalized": "善有果而已，", "notes": ""}
{"segment_id": "laozi-chapter-030__chinesenotes-daodejing-zh-20260531__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-030", "source_id": "laozi-chapter-030__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 30.9", "sort_key": "030.009", "text_original": "不敢以取強。", "text_normalized": "不敢以取強。", "notes": ""}
{"segment_id": "laozi-chapter-030__chinesenotes-daodejing-zh-20260531__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-030", "source_id": "laozi-chapter-030__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 30.10", "sort_key": "030.010", "text_original": "果而勿矜，", "text_normalized": "果而勿矜，", "notes": ""}
{"segment_id": "laozi-chapter-030__chinesenotes-daodejing-zh-20260531__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-030", "source_id": "laozi-chapter-030__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 30.11", "sort_key": "030.011", "text_original": "果而勿伐，", "text_normalized": "果而勿伐，", "notes": ""}
{"segment_id": "laozi-chapter-030__chinesenotes-daodejing-zh-20260531__seg-012", "work_id": "laozi", "section_id": "laozi-chapter-030", "source_id": "laozi-chapter-030__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 12, "canonical_ref": "老子 30.12", "sort_key": "030.012", "text_original": "果而勿驕。", "text_normalized": "果而勿驕。", "notes": ""}
{"segment_id": "laozi-chapter-030__chinesenotes-daodejing-zh-20260531__seg-013", "work_id": "laozi", "section_id": "laozi-chapter-030", "source_id": "laozi-chapter-030__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 13, "canonical_ref": "老子 30.13", "sort_key": "030.013", "text_original": "果而不得已，", "text_normalized": "果而不得已，", "notes": ""}
{"segment_id": "laozi-chapter-030__chinesenotes-daodejing-zh-20260531__seg-014", "work_id": "laozi", "section_id": "laozi-chapter-030", "source_id": "laozi-chapter-030__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 14, "canonical_ref": "老子 30.14", "sort_key": "030.014", "text_original": "果而勿強。", "text_normalized": "果而勿強。", "notes": ""}
{"segment_id": "laozi-chapter-030__chinesenotes-daodejing-zh-20260531__seg-015", "work_id": "laozi", "section_id": "laozi-chapter-030", "source_id": "laozi-chapter-030__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 15, "canonical_ref": "老子 30.15", "sort_key": "030.015", "text_original": "物壯則老，", "text_normalized": "物壯則老，", "notes": ""}
{"segment_id": "laozi-chapter-030__chinesenotes-daodejing-zh-20260531__seg-016", "work_id": "laozi", "section_id": "laozi-chapter-030", "source_id": "laozi-chapter-030__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 16, "canonical_ref": "老子 30.16", "sort_key": "030.016", "text_original": "是謂不道，", "text_normalized": "是謂不道，", "notes": ""}
{"segment_id": "laozi-chapter-030__chinesenotes-daodejing-zh-20260531__seg-017", "work_id": "laozi", "section_id": "laozi-chapter-030", "source_id": "laozi-chapter-030__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 17, "canonical_ref": "老子 30.17", "sort_key": "030.017", "text_original": "不道早已。", "text_normalized": "不道早已。", "notes": ""}
