{"segment_id": "laozi-chapter-027__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-027", "source_id": "laozi-chapter-027__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 27.1", "sort_key": "027.001", "text_original": "善行無轍迹，", "text_normalized": "善行無轍迹，", "notes": ""}
{"segment_id": "laozi-chapter-027__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-027", "source_id": "laozi-chapter-027__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 27.2", "sort_key": "027.002", "text_original": "善言無瑕讁；", "text_normalized": "善言無瑕讁；", "notes": ""}
{"segment_id": "laozi-chapter-027__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-027", "source_id": "laozi-chapter-027__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 27.3", "sort_key": "027.003", "text_original": "善數不用籌策；", "text_normalized": "善數不用籌策；", "notes": ""}
{"segment_id": "laozi-chapter-027__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-027", "source_id": "laozi-chapter-027__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 27.4", "sort_key": "027.004", "text_original": "善閉無關楗而不可開，", "text_normalized": "善閉無關楗而不可開，", "notes": ""}
{"segment_id": "laozi-chapter-027__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-027", "source_id": "laozi-chapter-027__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 27.5", "sort_key": "027.005", "text_original": "善結無繩約而不可解。", "text_normalized": "善結無繩約而不可解。", "notes": ""}
{"segment_id": "laozi-chapter-027__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-027", "source_id": "laozi-chapter-027__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 27.6", "sort_key": "027.006", "text_original": "是以聖人常善救人，", "text_normalized": "是以聖人常善救人，", "notes": ""}
{"segment_id": "laozi-chapter-027__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-027", "source_id": "laozi-chapter-027__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 27.7", "sort_key": "027.007", "text_original": "故無棄人；", "text_normalized": "故無棄人；", "notes": ""}
{"segment_id": "laozi-chapter-027__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-027", "source_id": "laozi-chapter-027__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 27.8", "sort_key": "027.008", "text_original": "常善救物，", "text_normalized": "常善救物，", "notes": ""}
{"segment_id": "laozi-chapter-027__chinesenotes-daodejing-zh-20260531__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-027", "source_id": "laozi-chapter-027__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 27.9", "sort_key": "027.009", "text_original": "故無棄物，", "text_normalized": "故無棄物，", "notes": ""}
{"segment_id": "laozi-chapter-027__chinesenotes-daodejing-zh-20260531__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-027", "source_id": "laozi-chapter-027__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 27.10", "sort_key": "027.010", "text_original": "是謂襲明。", "text_normalized": "是謂襲明。", "notes": ""}
{"segment_id": "laozi-chapter-027__chinesenotes-daodejing-zh-20260531__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-027", "source_id": "laozi-chapter-027__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 27.11", "sort_key": "027.011", "text_original": "故善人者，", "text_normalized": "故善人者，", "notes": ""}
{"segment_id": "laozi-chapter-027__chinesenotes-daodejing-zh-20260531__seg-012", "work_id": "laozi", "section_id": "laozi-chapter-027", "source_id": "laozi-chapter-027__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 12, "canonical_ref": "老子 27.12", "sort_key": "027.012", "text_original": "不善人之師；", "text_normalized": "不善人之師；", "notes": ""}
{"segment_id": "laozi-chapter-027__chinesenotes-daodejing-zh-20260531__seg-013", "work_id": "laozi", "section_id": "laozi-chapter-027", "source_id": "laozi-chapter-027__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 13, "canonical_ref": "老子 27.13", "sort_key": "027.013", "text_original": "不善人者，", "text_normalized": "不善人者，", "notes": ""}
{"segment_id": "laozi-chapter-027__chinesenotes-daodejing-zh-20260531__seg-014", "work_id": "laozi", "section_id": "laozi-chapter-027", "source_id": "laozi-chapter-027__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 14, "canonical_ref": "老子 27.14", "sort_key": "027.014", "text_original": "善人之資。", "text_normalized": "善人之資。", "notes": ""}
{"segment_id": "laozi-chapter-027__chinesenotes-daodejing-zh-20260531__seg-015", "work_id": "laozi", "section_id": "laozi-chapter-027", "source_id": "laozi-chapter-027__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 15, "canonical_ref": "老子 27.15", "sort_key": "027.015", "text_original": "不貴其師，", "text_normalized": "不貴其師，", "notes": ""}
{"segment_id": "laozi-chapter-027__chinesenotes-daodejing-zh-20260531__seg-016", "work_id": "laozi", "section_id": "laozi-chapter-027", "source_id": "laozi-chapter-027__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 16, "canonical_ref": "老子 27.16", "sort_key": "027.016", "text_original": "不愛其資，", "text_normalized": "不愛其資，", "notes": ""}
{"segment_id": "laozi-chapter-027__chinesenotes-daodejing-zh-20260531__seg-017", "work_id": "laozi", "section_id": "laozi-chapter-027", "source_id": "laozi-chapter-027__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 17, "canonical_ref": "老子 27.17", "sort_key": "027.017", "text_original": "雖智大迷，", "text_normalized": "雖智大迷，", "notes": ""}
{"segment_id": "laozi-chapter-027__chinesenotes-daodejing-zh-20260531__seg-018", "work_id": "laozi", "section_id": "laozi-chapter-027", "source_id": "laozi-chapter-027__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 18, "canonical_ref": "老子 27.18", "sort_key": "027.018", "text_original": "是謂要妙。", "text_normalized": "是謂要妙。", "notes": ""}
