{"segment_id": "laozi-chapter-043__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-043", "source_id": "laozi-chapter-043__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 43.1", "sort_key": "043.001", "text_original": "天下之至柔，馳騁天下之至堅。", "text_normalized": "天下之至柔，馳騁天下之至堅。", "notes": ""}
{"segment_id": "laozi-chapter-043__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-043", "source_id": "laozi-chapter-043__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 43.2", "sort_key": "043.002", "text_original": "無有入無間，吾是以知無為之有益。", "text_normalized": "無有入無間，吾是以知無為之有益。", "notes": ""}
{"segment_id": "laozi-chapter-043__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-043", "source_id": "laozi-chapter-043__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 43.3", "sort_key": "043.003", "text_original": "不言之教，無為之益，天下希及之。", "text_normalized": "不言之教，無為之益，天下希及之。", "notes": ""}
