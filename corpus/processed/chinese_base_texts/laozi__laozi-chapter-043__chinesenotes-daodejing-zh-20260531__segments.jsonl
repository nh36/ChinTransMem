{"segment_id": "laozi-chapter-043__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-043", "source_id": "laozi-chapter-043__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 43.6", "sort_key": "043.006", "text_original": "無為之益，", "text_normalized": "無為之益，", "notes": ""}
{"segment_id": "laozi-chapter-043__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-043", "source_id": "laozi-chapter-043__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 43.7", "sort_key": "043.007", "text_original": "天下希及之。", "text_normalized": "天下希及之。", "notes": ""}
