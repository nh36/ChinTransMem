{"segment_id": "shijing__guofeng-kuaifeng-002__001__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-kuaifeng-002", "source_id": "guofeng-kuaifeng-002__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 1, "canonical_ref": "詩經·國風·檜風·002.1", "text_original": "庶見素冠兮，棘人欒欒兮，勞心慱慱兮。", "text_normalized": "庶見素冠兮，棘人欒欒兮，勞心慱慱兮。", "notes": "素冠 Chinese stanza 1."}
{"segment_id": "shijing__guofeng-kuaifeng-002__002__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-kuaifeng-002", "source_id": "guofeng-kuaifeng-002__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 2, "canonical_ref": "詩經·國風·檜風·002.2", "text_original": "庶見素衣兮，我心傷悲兮，聊與子同歸兮。", "text_normalized": "庶見素衣兮，我心傷悲兮，聊與子同歸兮。", "notes": "素冠 Chinese stanza 2."}
