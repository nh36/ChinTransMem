{"segment_id": "laozi-chapter-029__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-029", "source_id": "laozi-chapter-029__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 29.1", "sort_key": "029.001", "text_original": "將欲取天下而為之，", "text_normalized": "將欲取天下而為之，", "notes": ""}
{"segment_id": "laozi-chapter-029__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-029", "source_id": "laozi-chapter-029__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 29.2", "sort_key": "029.002", "text_original": "吾見其不得已。", "text_normalized": "吾見其不得已。", "notes": ""}
{"segment_id": "laozi-chapter-029__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-029", "source_id": "laozi-chapter-029__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 29.3", "sort_key": "029.003", "text_original": "天下神器，", "text_normalized": "天下神器，", "notes": ""}
{"segment_id": "laozi-chapter-029__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-029", "source_id": "laozi-chapter-029__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 29.4", "sort_key": "029.004", "text_original": "不可為也，", "text_normalized": "不可為也，", "notes": ""}
{"segment_id": "laozi-chapter-029__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-029", "source_id": "laozi-chapter-029__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 29.5", "sort_key": "029.005", "text_original": "為者敗之，", "text_normalized": "為者敗之，", "notes": ""}
{"segment_id": "laozi-chapter-029__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-029", "source_id": "laozi-chapter-029__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 29.6", "sort_key": "029.006", "text_original": "執者失之。", "text_normalized": "執者失之。", "notes": ""}
{"segment_id": "laozi-chapter-029__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-029", "source_id": "laozi-chapter-029__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 29.7", "sort_key": "029.007", "text_original": "故物或行或隨，", "text_normalized": "故物或行或隨，", "notes": ""}
{"segment_id": "laozi-chapter-029__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-029", "source_id": "laozi-chapter-029__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 29.8", "sort_key": "029.008", "text_original": "或歔或吹。", "text_normalized": "或歔或吹。", "notes": ""}
{"segment_id": "laozi-chapter-029__chinesenotes-daodejing-zh-20260531__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-029", "source_id": "laozi-chapter-029__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 29.9", "sort_key": "029.009", "text_original": "或強或羸，", "text_normalized": "或強或羸，", "notes": ""}
{"segment_id": "laozi-chapter-029__chinesenotes-daodejing-zh-20260531__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-029", "source_id": "laozi-chapter-029__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 29.10", "sort_key": "029.010", "text_original": "或挫或隳。", "text_normalized": "或挫或隳。", "notes": ""}
{"segment_id": "laozi-chapter-029__chinesenotes-daodejing-zh-20260531__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-029", "source_id": "laozi-chapter-029__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 29.11", "sort_key": "029.011", "text_original": "是以聖人去甚，", "text_normalized": "是以聖人去甚，", "notes": ""}
{"segment_id": "laozi-chapter-029__chinesenotes-daodejing-zh-20260531__seg-012", "work_id": "laozi", "section_id": "laozi-chapter-029", "source_id": "laozi-chapter-029__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 12, "canonical_ref": "老子 29.12", "sort_key": "029.012", "text_original": "去奢，", "text_normalized": "去奢，", "notes": ""}
{"segment_id": "laozi-chapter-029__chinesenotes-daodejing-zh-20260531__seg-013", "work_id": "laozi", "section_id": "laozi-chapter-029", "source_id": "laozi-chapter-029__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 13, "canonical_ref": "老子 29.13", "sort_key": "029.013", "text_original": "去泰。", "text_normalized": "去泰。", "notes": ""}
