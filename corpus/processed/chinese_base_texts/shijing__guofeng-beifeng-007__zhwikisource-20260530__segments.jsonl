{"segment_id": "shijing__guofeng-beifeng-007__001__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-beifeng-007", "source_id": "guofeng-beifeng-007__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 1, "canonical_ref": "詩經·國風·邶風·007.1", "text_original": "凱風自南，吹彼棘心；\n棘心夭夭，母氏劬勞。", "text_normalized": "凱風自南，吹彼棘心；\n棘心夭夭，母氏劬勞。", "notes": "凱風 Chinese stanza 1."}
{"segment_id": "shijing__guofeng-beifeng-007__002__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-beifeng-007", "source_id": "guofeng-beifeng-007__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 2, "canonical_ref": "詩經·國風·邶風·007.2", "text_original": "凱風自南，吹彼棘薪；\n母氏聖善，我無令人。", "text_normalized": "凱風自南，吹彼棘薪；\n母氏聖善，我無令人。", "notes": "凱風 Chinese stanza 2."}
{"segment_id": "shijing__guofeng-beifeng-007__003__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-beifeng-007", "source_id": "guofeng-beifeng-007__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 3, "canonical_ref": "詩經·國風·邶風·007.3", "text_original": "爰有寒泉，在浚之下；\n有子七人，母氏勞苦。", "text_normalized": "爰有寒泉，在浚之下；\n有子七人，母氏勞苦。", "notes": "凱風 Chinese stanza 3."}
{"segment_id": "shijing__guofeng-beifeng-007__004__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-beifeng-007", "source_id": "guofeng-beifeng-007__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 4, "canonical_ref": "詩經·國風·邶風·007.4", "text_original": "睍睆黃鳥，載好其音；\n有子七人，莫慰母心。", "text_normalized": "睍睆黃鳥，載好其音；\n有子七人，莫慰母心。", "notes": "凱風 Chinese stanza 4."}
