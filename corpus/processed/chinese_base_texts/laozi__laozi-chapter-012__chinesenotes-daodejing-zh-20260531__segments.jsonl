{"segment_id": "laozi-chapter-012__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-012", "source_id": "laozi-chapter-012__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 12.3", "sort_key": "012.003", "text_original": "五味令人口爽，", "text_normalized": "五味令人口爽，", "notes": ""}
{"segment_id": "laozi-chapter-012__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-012", "source_id": "laozi-chapter-012__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 12.4", "sort_key": "012.004", "text_original": "馳騁畋獵令人心發狂，", "text_normalized": "馳騁畋獵令人心發狂，", "notes": ""}
