{"segment_id": "laozi-chapter-012__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-012", "source_id": "laozi-chapter-012__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 12.6", "sort_key": "012.006", "text_original": "是以聖人為腹不為目，", "text_normalized": "是以聖人為腹不為目，", "notes": ""}
{"segment_id": "laozi-chapter-012__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-012", "source_id": "laozi-chapter-012__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 12.7", "sort_key": "012.007", "text_original": "故去彼取此。", "text_normalized": "故去彼取此。", "notes": ""}
