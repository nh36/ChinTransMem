{"segment_id": "laozi-chapter-012__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-012", "source_id": "laozi-chapter-012__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 12.1", "sort_key": "012.001", "text_original": "五色令人目盲，", "text_normalized": "五色令人目盲，", "notes": ""}
