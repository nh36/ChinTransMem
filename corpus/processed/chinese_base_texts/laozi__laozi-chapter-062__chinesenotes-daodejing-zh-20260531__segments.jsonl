{"segment_id": "laozi-chapter-062__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-062", "source_id": "laozi-chapter-062__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 62.4", "sort_key": "062.004", "text_original": "美言可以市，", "text_normalized": "美言可以市，", "notes": ""}
{"segment_id": "laozi-chapter-062__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-062", "source_id": "laozi-chapter-062__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 62.5", "sort_key": "062.005", "text_original": "尊行可以加人。", "text_normalized": "尊行可以加人。", "notes": ""}
{"segment_id": "laozi-chapter-062__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-062", "source_id": "laozi-chapter-062__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 62.6", "sort_key": "062.006", "text_original": "人之不善，", "text_normalized": "人之不善，", "notes": ""}
{"segment_id": "laozi-chapter-062__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-062", "source_id": "laozi-chapter-062__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 62.7", "sort_key": "062.007", "text_original": "何棄之有？", "text_normalized": "何棄之有？", "notes": ""}
{"segment_id": "laozi-chapter-062__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-062", "source_id": "laozi-chapter-062__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 62.8", "sort_key": "062.008", "text_original": "故立天子，", "text_normalized": "故立天子，", "notes": ""}
{"segment_id": "laozi-chapter-062__chinesenotes-daodejing-zh-20260531__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-062", "source_id": "laozi-chapter-062__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 62.9", "sort_key": "062.009", "text_original": "置三公，", "text_normalized": "置三公，", "notes": ""}
{"segment_id": "laozi-chapter-062__chinesenotes-daodejing-zh-20260531__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-062", "source_id": "laozi-chapter-062__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 62.10", "sort_key": "062.010", "text_original": "雖有拱璧以先駟馬，", "text_normalized": "雖有拱璧以先駟馬，", "notes": ""}
{"segment_id": "laozi-chapter-062__chinesenotes-daodejing-zh-20260531__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-062", "source_id": "laozi-chapter-062__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 62.11", "sort_key": "062.011", "text_original": "不如坐進此道。", "text_normalized": "不如坐進此道。", "notes": ""}
{"segment_id": "laozi-chapter-062__chinesenotes-daodejing-zh-20260531__seg-012", "work_id": "laozi", "section_id": "laozi-chapter-062", "source_id": "laozi-chapter-062__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 12, "canonical_ref": "老子 62.12", "sort_key": "062.012", "text_original": "古之所以貴此道者何？", "text_normalized": "古之所以貴此道者何？", "notes": ""}
{"segment_id": "laozi-chapter-062__chinesenotes-daodejing-zh-20260531__seg-013", "work_id": "laozi", "section_id": "laozi-chapter-062", "source_id": "laozi-chapter-062__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 13, "canonical_ref": "老子 62.13", "sort_key": "062.013", "text_original": "不曰以求得，", "text_normalized": "不曰以求得，", "notes": ""}
{"segment_id": "laozi-chapter-062__chinesenotes-daodejing-zh-20260531__seg-014", "work_id": "laozi", "section_id": "laozi-chapter-062", "source_id": "laozi-chapter-062__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 14, "canonical_ref": "老子 62.14", "sort_key": "062.014", "text_original": "有罪以免邪？", "text_normalized": "有罪以免邪？", "notes": ""}
{"segment_id": "laozi-chapter-062__chinesenotes-daodejing-zh-20260531__seg-015", "work_id": "laozi", "section_id": "laozi-chapter-062", "source_id": "laozi-chapter-062__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 15, "canonical_ref": "老子 62.15", "sort_key": "062.015", "text_original": "故為天下貴。", "text_normalized": "故為天下貴。", "notes": ""}
