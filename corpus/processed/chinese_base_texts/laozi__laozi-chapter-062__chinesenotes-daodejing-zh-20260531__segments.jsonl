{"segment_id": "laozi-chapter-062__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-062", "source_id": "laozi-chapter-062__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 62.1", "sort_key": "062.001", "text_original": "道者萬物之奧。", "text_normalized": "道者萬物之奧。", "notes": ""}
{"segment_id": "laozi-chapter-062__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-062", "source_id": "laozi-chapter-062__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 62.2", "sort_key": "062.002", "text_original": "善人之寶，", "text_normalized": "善人之寶，", "notes": ""}
