{"segment_id": "laozi-chapter-062__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-062", "source_id": "laozi-chapter-062__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 62.1", "sort_key": "062.001", "text_original": "道者萬物之奧。", "text_normalized": "道者萬物之奧。", "notes": ""}
{"segment_id": "laozi-chapter-062__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-062", "source_id": "laozi-chapter-062__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 62.2", "sort_key": "062.002", "text_original": "善人之寶，", "text_normalized": "善人之寶，", "notes": ""}
{"segment_id": "laozi-chapter-062__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-062", "source_id": "laozi-chapter-062__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 62.3", "sort_key": "062.003", "text_original": "不善人之所保。", "text_normalized": "不善人之所保。", "notes": ""}
{"segment_id": "laozi-chapter-062__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-062", "source_id": "laozi-chapter-062__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 62.4", "sort_key": "062.004", "text_original": "美言可以市，尊行可以加人。", "text_normalized": "美言可以市，尊行可以加人。", "notes": ""}
{"segment_id": "laozi-chapter-062__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-062", "source_id": "laozi-chapter-062__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 62.5", "sort_key": "062.005", "text_original": "人之不善，何棄之有？", "text_normalized": "人之不善，何棄之有？", "notes": ""}
{"segment_id": "laozi-chapter-062__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-062", "source_id": "laozi-chapter-062__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 62.6", "sort_key": "062.006", "text_original": "故立天子，置三公，", "text_normalized": "故立天子，置三公，", "notes": ""}
{"segment_id": "laozi-chapter-062__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-062", "source_id": "laozi-chapter-062__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 62.7", "sort_key": "062.007", "text_original": "雖有拱璧以先駟馬，不如坐進此道。", "text_normalized": "雖有拱璧以先駟馬，不如坐進此道。", "notes": ""}
{"segment_id": "laozi-chapter-062__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-062", "source_id": "laozi-chapter-062__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 62.8", "sort_key": "062.008", "text_original": "古之所以貴此道者何？", "text_normalized": "古之所以貴此道者何？", "notes": ""}
{"segment_id": "laozi-chapter-062__chinesenotes-daodejing-zh-20260531__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-062", "source_id": "laozi-chapter-062__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 62.9", "sort_key": "062.009", "text_original": "不曰以求得，有罪以免邪？", "text_normalized": "不曰以求得，有罪以免邪？", "notes": ""}
{"segment_id": "laozi-chapter-062__chinesenotes-daodejing-zh-20260531__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-062", "source_id": "laozi-chapter-062__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 62.10", "sort_key": "062.010", "text_original": "故為天下貴。", "text_normalized": "故為天下貴。", "notes": ""}
