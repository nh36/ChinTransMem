{"segment_id": "laozi-chapter-050__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-050", "source_id": "laozi-chapter-050__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 50.8", "sort_key": "050.008", "text_original": "亦十有三。", "text_normalized": "亦十有三。", "notes": ""}
{"segment_id": "laozi-chapter-050__chinesenotes-daodejing-zh-20260531__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-050", "source_id": "laozi-chapter-050__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 50.9", "sort_key": "050.009", "text_original": "夫何故？", "text_normalized": "夫何故？", "notes": ""}
{"segment_id": "laozi-chapter-050__chinesenotes-daodejing-zh-20260531__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-050", "source_id": "laozi-chapter-050__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 50.10", "sort_key": "050.010", "text_original": "以其生生之厚。", "text_normalized": "以其生生之厚。", "notes": ""}
{"segment_id": "laozi-chapter-050__chinesenotes-daodejing-zh-20260531__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-050", "source_id": "laozi-chapter-050__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 50.11", "sort_key": "050.011", "text_original": "蓋聞善攝生者，", "text_normalized": "蓋聞善攝生者，", "notes": ""}
{"segment_id": "laozi-chapter-050__chinesenotes-daodejing-zh-20260531__seg-012", "work_id": "laozi", "section_id": "laozi-chapter-050", "source_id": "laozi-chapter-050__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 12, "canonical_ref": "老子 50.12", "sort_key": "050.012", "text_original": "陸行不遇兕虎，", "text_normalized": "陸行不遇兕虎，", "notes": ""}
{"segment_id": "laozi-chapter-050__chinesenotes-daodejing-zh-20260531__seg-013", "work_id": "laozi", "section_id": "laozi-chapter-050", "source_id": "laozi-chapter-050__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 13, "canonical_ref": "老子 50.13", "sort_key": "050.013", "text_original": "入軍不被甲兵；", "text_normalized": "入軍不被甲兵；", "notes": ""}
{"segment_id": "laozi-chapter-050__chinesenotes-daodejing-zh-20260531__seg-014", "work_id": "laozi", "section_id": "laozi-chapter-050", "source_id": "laozi-chapter-050__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 14, "canonical_ref": "老子 50.14", "sort_key": "050.014", "text_original": "兕無所投其角，", "text_normalized": "兕無所投其角，", "notes": ""}
{"segment_id": "laozi-chapter-050__chinesenotes-daodejing-zh-20260531__seg-015", "work_id": "laozi", "section_id": "laozi-chapter-050", "source_id": "laozi-chapter-050__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 15, "canonical_ref": "老子 50.15", "sort_key": "050.015", "text_original": "虎無所措其爪，", "text_normalized": "虎無所措其爪，", "notes": ""}
{"segment_id": "laozi-chapter-050__chinesenotes-daodejing-zh-20260531__seg-016", "work_id": "laozi", "section_id": "laozi-chapter-050", "source_id": "laozi-chapter-050__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 16, "canonical_ref": "老子 50.16", "sort_key": "050.016", "text_original": "兵無所容其刃。", "text_normalized": "兵無所容其刃。", "notes": ""}
{"segment_id": "laozi-chapter-050__chinesenotes-daodejing-zh-20260531__seg-017", "work_id": "laozi", "section_id": "laozi-chapter-050", "source_id": "laozi-chapter-050__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 17, "canonical_ref": "老子 50.17", "sort_key": "050.017", "text_original": "夫何故？", "text_normalized": "夫何故？", "notes": ""}
{"segment_id": "laozi-chapter-050__chinesenotes-daodejing-zh-20260531__seg-018", "work_id": "laozi", "section_id": "laozi-chapter-050", "source_id": "laozi-chapter-050__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 18, "canonical_ref": "老子 50.18", "sort_key": "050.018", "text_original": "以其無死地。", "text_normalized": "以其無死地。", "notes": ""}
