{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0001", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 1, "text_original": "子墨子曰：", "text_normalized": "子墨子曰：", "canonical_ref": "5.1", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0002", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 2, "text_original": "國有七患。", "text_normalized": "國有七患。", "canonical_ref": "5.2", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0003", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 3, "text_original": "七患者何？", "text_normalized": "七患者何？", "canonical_ref": "5.3", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0004", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 4, "text_original": "城郭溝池不可守，而治宮室，一患也。", "text_normalized": "城郭溝池不可守，而治宮室，一患也。", "canonical_ref": "5.4", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0005", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 5, "text_original": "邊國至境，四鄰莫救，二患也。", "text_normalized": "邊國至境，四鄰莫救，二患也。", "canonical_ref": "5.5", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0006", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 6, "text_original": "先盡民力無用之功，賞賜無能之人，民力盡於無用，財寶虛於待客，三患也。", "text_normalized": "先盡民力無用之功，賞賜無能之人，民力盡於無用，財寶虛於待客，三患也。", "canonical_ref": "5.6", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0007", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 7, "text_original": "仕者持祿，游者愛佼，君修法討臣，臣懾而不敢拂，四患也。", "text_normalized": "仕者持祿，游者愛佼，君修法討臣，臣懾而不敢拂，四患也。", "canonical_ref": "5.7", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0008", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 8, "text_original": "君自以爲聖智而不問事，自以爲安彊而無守備，四鄰謀之不知戒，五患也。", "text_normalized": "君自以爲聖智而不問事，自以爲安彊而無守備，四鄰謀之不知戒，五患也。", "canonical_ref": "5.8", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0009", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 9, "text_original": "所信者不忠，所忠者不信，六患也。", "text_normalized": "所信者不忠，所忠者不信，六患也。", "canonical_ref": "5.9", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0010", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 10, "text_original": "畜種菽粟不足以食之，大臣不足以事之。", "text_normalized": "畜種菽粟不足以食之，大臣不足以事之。", "canonical_ref": "5.10", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0011", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 11, "text_original": "賞賜不能喜，誅罰不能威，七患也。", "text_normalized": "賞賜不能喜，誅罰不能威，七患也。", "canonical_ref": "5.11", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0012", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 12, "text_original": "以七患居國，必無社稷。", "text_normalized": "以七患居國，必無社稷。", "canonical_ref": "5.12", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0013", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 13, "text_original": "以七患守城，敵至國傾。", "text_normalized": "以七患守城，敵至國傾。", "canonical_ref": "5.13", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0014", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 14, "text_original": "七患之所當，國必有殃。", "text_normalized": "七患之所當，國必有殃。", "canonical_ref": "5.14", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0015", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 15, "text_original": "凡五穀者，民之所仰也，君之所以爲養也。", "text_normalized": "凡五穀者，民之所仰也，君之所以爲養也。", "canonical_ref": "5.15", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0016", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 16, "text_original": "故民無仰則君無養，民無食則不可事。", "text_normalized": "故民無仰則君無養，民無食則不可事。", "canonical_ref": "5.16", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0017", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 17, "text_original": "故食不可不務也，地不可不力也，用不可不節也。", "text_normalized": "故食不可不務也，地不可不力也，用不可不節也。", "canonical_ref": "5.17", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0018", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 18, "text_original": "五穀盡收則五味盡御於主，不盡收則不盡御。", "text_normalized": "五穀盡收則五味盡御於主，不盡收則不盡御。", "canonical_ref": "5.18", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0019", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 19, "text_original": "一谷不收謂之饉，二谷不收謂之旱，三谷不收謂之凶，四谷不收謂之餽，五穀不收謂之饑。", "text_normalized": "一谷不收謂之饉，二谷不收謂之旱，三谷不收謂之凶，四谷不收謂之餽，五穀不收謂之饑。", "canonical_ref": "5.19", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0020", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 20, "text_original": "歲饉，則仕者大夫以下皆損祿五分之一。", "text_normalized": "歲饉，則仕者大夫以下皆損祿五分之一。", "canonical_ref": "5.20", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0021", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 21, "text_original": "旱，則損五分之二。", "text_normalized": "旱，則損五分之二。", "canonical_ref": "5.21", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0022", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 22, "text_original": "凶，則損五分之三。", "text_normalized": "凶，則損五分之三。", "canonical_ref": "5.22", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0023", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 23, "text_original": "餽，則損五分之四。", "text_normalized": "餽，則損五分之四。", "canonical_ref": "5.23", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0024", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 24, "text_original": "饑，則盡無祿，稟食而已矣。", "text_normalized": "饑，則盡無祿，稟食而已矣。", "canonical_ref": "5.24", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0025", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 25, "text_original": "故凶饑存乎國，人君徹鼎食五分之五，大夫徹縣，士不入學，君朝之衣不革制，諸侯之客，四鄰之使，雍食而不盛，徹驂騑，塗不芸，馬不食粟，婢妾不衣帛，此告不足之至也。", "text_normalized": "故凶饑存乎國，人君徹鼎食五分之五，大夫徹縣，士不入學，君朝之衣不革制，諸侯之客，四鄰之使，雍食而不盛，徹驂騑，塗不芸，馬不食粟，婢妾不衣帛，此告不足之至也。", "canonical_ref": "5.25", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0026", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 26, "text_original": "今有負其子而汲者，隊其子於井中，其母必從而道之。", "text_normalized": "今有負其子而汲者，隊其子於井中，其母必從而道之。", "canonical_ref": "5.26", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0027", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 27, "text_original": "今歲凶、民饑、道餓，重其子此疚於隊，其可無察邪？", "text_normalized": "今歲凶、民饑、道餓，重其子此疚於隊，其可無察邪？", "canonical_ref": "5.27", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0028", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 28, "text_original": "故時年歲善，則民仁且良；", "text_normalized": "故時年歲善，則民仁且良；", "canonical_ref": "5.28", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0029", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 29, "text_original": "時年歲凶，則民吝且惡。", "text_normalized": "時年歲凶，則民吝且惡。", "canonical_ref": "5.29", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0030", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 30, "text_original": "夫民何常此之有？", "text_normalized": "夫民何常此之有？", "canonical_ref": "5.30", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0031", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 31, "text_original": "爲者疾，食者衆，則歲無豐。", "text_normalized": "爲者疾，食者衆，則歲無豐。", "canonical_ref": "5.31", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0032", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 32, "text_original": "故曰：", "text_normalized": "故曰：", "canonical_ref": "5.32", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0033", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 33, "text_original": "「財不足則反之時，食不足則反之用。", "text_normalized": "「財不足則反之時，食不足則反之用。", "canonical_ref": "5.33", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0034", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 34, "text_original": "」故先民以時生財，固本而用財，則財足。", "text_normalized": "」故先民以時生財，固本而用財，則財足。", "canonical_ref": "5.34", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0035", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 35, "text_original": "故雖上世之聖王，豈能使五穀常收，而旱水不至哉！", "text_normalized": "故雖上世之聖王，豈能使五穀常收，而旱水不至哉！", "canonical_ref": "5.35", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0036", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 36, "text_original": "然而無凍餓之民者，何也？", "text_normalized": "然而無凍餓之民者，何也？", "canonical_ref": "5.36", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0037", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 37, "text_original": "其力時急，而自養儉也。", "text_normalized": "其力時急，而自養儉也。", "canonical_ref": "5.37", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0038", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 38, "text_original": "故《夏書》曰「禹七年水。", "text_normalized": "故《夏書》曰「禹七年水。", "canonical_ref": "5.38", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0039", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 39, "text_original": "」《殷書》曰「湯五年旱。", "text_normalized": "」《殷書》曰「湯五年旱。", "canonical_ref": "5.39", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0040", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 40, "text_original": "」此其離凶餓甚矣。", "text_normalized": "」此其離凶餓甚矣。", "canonical_ref": "5.40", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0041", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 41, "text_original": "然而民不凍餓者，何也？", "text_normalized": "然而民不凍餓者，何也？", "canonical_ref": "5.41", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0042", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 42, "text_original": "其生財密，其用之節也。", "text_normalized": "其生財密，其用之節也。", "canonical_ref": "5.42", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0043", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 43, "text_original": "故倉無備粟，不可以待凶饑；", "text_normalized": "故倉無備粟，不可以待凶饑；", "canonical_ref": "5.43", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0044", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 44, "text_original": "庫無備兵，雖有義不能征無義。", "text_normalized": "庫無備兵，雖有義不能征無義。", "canonical_ref": "5.44", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0045", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 45, "text_original": "城郭不備全，不可以自守。", "text_normalized": "城郭不備全，不可以自守。", "canonical_ref": "5.45", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0046", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 46, "text_original": "心無備慮，不可以應卒。", "text_normalized": "心無備慮，不可以應卒。", "canonical_ref": "5.46", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0047", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 47, "text_original": "是若慶忌無去之心，不能輕出。", "text_normalized": "是若慶忌無去之心，不能輕出。", "canonical_ref": "5.47", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0048", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 48, "text_original": "夫桀無待湯之備，故放。", "text_normalized": "夫桀無待湯之備，故放。", "canonical_ref": "5.48", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0049", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 49, "text_original": "紂無待武王之備，故殺。", "text_normalized": "紂無待武王之備，故殺。", "canonical_ref": "5.49", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0050", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 50, "text_original": "桀、紂貴爲天子，富有天下。", "text_normalized": "桀、紂貴爲天子，富有天下。", "canonical_ref": "5.50", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0051", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 51, "text_original": "然而皆滅亡於百里之君者，何也？", "text_normalized": "然而皆滅亡於百里之君者，何也？", "canonical_ref": "5.51", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0052", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 52, "text_original": "有富貴而不爲備也。", "text_normalized": "有富貴而不爲備也。", "canonical_ref": "5.52", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0053", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 53, "text_original": "故備者國之重也。", "text_normalized": "故備者國之重也。", "canonical_ref": "5.53", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0054", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 54, "text_original": "食者國之寶也，兵者國之爪也，城者所以自守也，此三者國之具也。", "text_normalized": "食者國之寶也，兵者國之爪也，城者所以自守也，此三者國之具也。", "canonical_ref": "5.54", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0055", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 55, "text_original": "故曰：", "text_normalized": "故曰：", "canonical_ref": "5.55", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0056", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 56, "text_original": "以其極賞，以賜無功，虛其府庫，以備車馬衣裘奇怪。", "text_normalized": "以其極賞，以賜無功，虛其府庫，以備車馬衣裘奇怪。", "canonical_ref": "5.56", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0057", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 57, "text_original": "苦其役徒，以治宮室觀樂。", "text_normalized": "苦其役徒，以治宮室觀樂。", "canonical_ref": "5.57", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0058", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 58, "text_original": "死又厚爲棺槨，多爲衣裘。", "text_normalized": "死又厚爲棺槨，多爲衣裘。", "canonical_ref": "5.58", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0059", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 59, "text_original": "生時治臺榭，死又脩墳墓。", "text_normalized": "生時治臺榭，死又脩墳墓。", "canonical_ref": "5.59", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0060", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 60, "text_original": "故民苦於外，府庫單於內。", "text_normalized": "故民苦於外，府庫單於內。", "canonical_ref": "5.60", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0061", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 61, "text_original": "上不厭其樂，下不堪其苦。", "text_normalized": "上不厭其樂，下不堪其苦。", "canonical_ref": "5.61", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0062", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 62, "text_original": "故國離寇敵則傷，民見凶饑則亡，此皆備不具之罪也。", "text_normalized": "故國離寇敵則傷，民見凶饑則亡，此皆備不具之罪也。", "canonical_ref": "5.62", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0063", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 63, "text_original": "且夫食者，聖人之所寶也。", "text_normalized": "且夫食者，聖人之所寶也。", "canonical_ref": "5.63", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0064", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 64, "text_original": "故《周書》曰：", "text_normalized": "故《周書》曰：", "canonical_ref": "5.64", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0065", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 65, "text_original": "「國無三年之食者，國非其國也；", "text_normalized": "「國無三年之食者，國非其國也；", "canonical_ref": "5.65", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0066", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 66, "text_original": "家無三年之食者，子非其子也。", "text_normalized": "家無三年之食者，子非其子也。", "canonical_ref": "5.66", "notes": ""}
{"segment_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3__seg-0067", "section_id": "mozi-005-the-seven-worries", "source_id": "mozi-005-the-seven-worries__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 67, "text_original": "」此之謂國備。", "text_normalized": "」此之謂國備。", "canonical_ref": "5.67", "notes": ""}
