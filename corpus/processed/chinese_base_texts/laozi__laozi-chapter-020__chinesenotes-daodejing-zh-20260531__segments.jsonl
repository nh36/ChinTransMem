{"segment_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-020", "source_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 20.1", "sort_key": "020.001", "text_original": "絕學無憂，", "text_normalized": "絕學無憂，", "notes": ""}
{"segment_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-020", "source_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 20.2", "sort_key": "020.002", "text_original": "唯之與阿，", "text_normalized": "唯之與阿，", "notes": ""}
{"segment_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-020", "source_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 20.3", "sort_key": "020.003", "text_original": "相去幾何？", "text_normalized": "相去幾何？", "notes": ""}
{"segment_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-020", "source_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 20.4", "sort_key": "020.004", "text_original": "善之與惡，", "text_normalized": "善之與惡，", "notes": ""}
{"segment_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-020", "source_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 20.5", "sort_key": "020.005", "text_original": "相去若何？", "text_normalized": "相去若何？", "notes": ""}
{"segment_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-020", "source_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 20.6", "sort_key": "020.006", "text_original": "人之所畏，", "text_normalized": "人之所畏，", "notes": ""}
{"segment_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-020", "source_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 20.7", "sort_key": "020.007", "text_original": "不可不畏。", "text_normalized": "不可不畏。", "notes": ""}
{"segment_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-020", "source_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 20.8", "sort_key": "020.008", "text_original": "荒兮其未央哉﹗", "text_normalized": "荒兮其未央哉﹗", "notes": ""}
{"segment_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-020", "source_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 20.9", "sort_key": "020.009", "text_original": "眾人熙熙，", "text_normalized": "眾人熙熙，", "notes": ""}
{"segment_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-020", "source_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 20.10", "sort_key": "020.010", "text_original": "如享太牢，", "text_normalized": "如享太牢，", "notes": ""}
{"segment_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-020", "source_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 20.11", "sort_key": "020.011", "text_original": "如春登臺。", "text_normalized": "如春登臺。", "notes": ""}
{"segment_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531__seg-012", "work_id": "laozi", "section_id": "laozi-chapter-020", "source_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 12, "canonical_ref": "老子 20.12", "sort_key": "020.012", "text_original": "我獨泊兮其未兆，", "text_normalized": "我獨泊兮其未兆，", "notes": ""}
{"segment_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531__seg-013", "work_id": "laozi", "section_id": "laozi-chapter-020", "source_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 13, "canonical_ref": "老子 20.13", "sort_key": "020.013", "text_original": "如嬰兒之未孩；", "text_normalized": "如嬰兒之未孩；", "notes": ""}
{"segment_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531__seg-014", "work_id": "laozi", "section_id": "laozi-chapter-020", "source_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 14, "canonical_ref": "老子 20.14", "sort_key": "020.014", "text_original": "儽儽兮若無所歸。", "text_normalized": "儽儽兮若無所歸。", "notes": ""}
{"segment_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531__seg-015", "work_id": "laozi", "section_id": "laozi-chapter-020", "source_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 15, "canonical_ref": "老子 20.15", "sort_key": "020.015", "text_original": "眾人皆有餘，", "text_normalized": "眾人皆有餘，", "notes": ""}
{"segment_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531__seg-016", "work_id": "laozi", "section_id": "laozi-chapter-020", "source_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 16, "canonical_ref": "老子 20.16", "sort_key": "020.016", "text_original": "而我獨若遺。", "text_normalized": "而我獨若遺。", "notes": ""}
{"segment_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531__seg-017", "work_id": "laozi", "section_id": "laozi-chapter-020", "source_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 17, "canonical_ref": "老子 20.17", "sort_key": "020.017", "text_original": "我愚人之心也哉﹗", "text_normalized": "我愚人之心也哉﹗", "notes": ""}
{"segment_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531__seg-018", "work_id": "laozi", "section_id": "laozi-chapter-020", "source_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 18, "canonical_ref": "老子 20.18", "sort_key": "020.018", "text_original": "沌沌兮，", "text_normalized": "沌沌兮，", "notes": ""}
{"segment_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531__seg-019", "work_id": "laozi", "section_id": "laozi-chapter-020", "source_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 19, "canonical_ref": "老子 20.19", "sort_key": "020.019", "text_original": "俗人昭昭，", "text_normalized": "俗人昭昭，", "notes": ""}
{"segment_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531__seg-020", "work_id": "laozi", "section_id": "laozi-chapter-020", "source_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 20, "canonical_ref": "老子 20.20", "sort_key": "020.020", "text_original": "我獨昏昏。", "text_normalized": "我獨昏昏。", "notes": ""}
{"segment_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531__seg-021", "work_id": "laozi", "section_id": "laozi-chapter-020", "source_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 21, "canonical_ref": "老子 20.21", "sort_key": "020.021", "text_original": "俗人察察，", "text_normalized": "俗人察察，", "notes": ""}
{"segment_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531__seg-022", "work_id": "laozi", "section_id": "laozi-chapter-020", "source_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 22, "canonical_ref": "老子 20.22", "sort_key": "020.022", "text_original": "我獨悶悶。", "text_normalized": "我獨悶悶。", "notes": ""}
{"segment_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531__seg-023", "work_id": "laozi", "section_id": "laozi-chapter-020", "source_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 23, "canonical_ref": "老子 20.23", "sort_key": "020.023", "text_original": "澹兮其若海，", "text_normalized": "澹兮其若海，", "notes": ""}
{"segment_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531__seg-024", "work_id": "laozi", "section_id": "laozi-chapter-020", "source_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 24, "canonical_ref": "老子 20.24", "sort_key": "020.024", "text_original": "飂兮若無止。", "text_normalized": "飂兮若無止。", "notes": ""}
{"segment_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531__seg-025", "work_id": "laozi", "section_id": "laozi-chapter-020", "source_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 25, "canonical_ref": "老子 20.25", "sort_key": "020.025", "text_original": "眾人皆有以，", "text_normalized": "眾人皆有以，", "notes": ""}
{"segment_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531__seg-026", "work_id": "laozi", "section_id": "laozi-chapter-020", "source_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 26, "canonical_ref": "老子 20.26", "sort_key": "020.026", "text_original": "而我獨頑似鄙。", "text_normalized": "而我獨頑似鄙。", "notes": ""}
{"segment_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531__seg-027", "work_id": "laozi", "section_id": "laozi-chapter-020", "source_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 27, "canonical_ref": "老子 20.27", "sort_key": "020.027", "text_original": "我獨異於人，", "text_normalized": "我獨異於人，", "notes": ""}
{"segment_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531__seg-028", "work_id": "laozi", "section_id": "laozi-chapter-020", "source_id": "laozi-chapter-020__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 28, "canonical_ref": "老子 20.28", "sort_key": "020.028", "text_original": "而貴食母。", "text_normalized": "而貴食母。", "notes": ""}
