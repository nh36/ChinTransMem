{"segment_id": "shijing__guofeng-qifeng-011__001__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-qifeng-011", "source_id": "guofeng-qifeng-011__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 1, "canonical_ref": "詩經·國風·齊風·011.1", "text_original": "猗嗟昌兮！頎而長兮。抑若揚兮，美目揚兮。巧趨蹌兮。射則臧兮。", "text_normalized": "猗嗟昌兮！頎而長兮。抑若揚兮，美目揚兮。巧趨蹌兮。射則臧兮。", "notes": "猗嗟 Chinese stanza 1."}
{"segment_id": "shijing__guofeng-qifeng-011__002__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-qifeng-011", "source_id": "guofeng-qifeng-011__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 2, "canonical_ref": "詩經·國風·齊風·011.2", "text_original": "猗嗟名兮！美目清兮。儀既成兮，終日射侯，不出正兮，展我甥兮。", "text_normalized": "猗嗟名兮！美目清兮。儀既成兮，終日射侯，不出正兮，展我甥兮。", "notes": "猗嗟 Chinese stanza 2."}
{"segment_id": "shijing__guofeng-qifeng-011__003__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-qifeng-011", "source_id": "guofeng-qifeng-011__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 3, "canonical_ref": "詩經·國風·齊風·011.3", "text_original": "猗嗟孌兮！清揚婉兮。舞則選兮，射則貫兮，四矢反兮，以禦亂兮。", "text_normalized": "猗嗟孌兮！清揚婉兮。舞則選兮，射則貫兮，四矢反兮，以禦亂兮。", "notes": "猗嗟 Chinese stanza 3."}
