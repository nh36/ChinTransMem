{"segment_id": "shijing__xiaoya-hongyan-005__001__zhwikisource-20260530", "work_id": "shijing", "section_id": "xiaoya-hongyan-005", "source_id": "xiaoya-hongyan-005__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 1, "canonical_ref": "詩經·小雅·鴻鴈之什·005.1", "text_original": "祈父！予王之爪牙，胡轉予于恤？靡所止居。", "text_normalized": "祈父！予王之爪牙，胡轉予于恤？靡所止居。", "notes": "祈父 Chinese stanza 1."}
{"segment_id": "shijing__xiaoya-hongyan-005__002__zhwikisource-20260530", "work_id": "shijing", "section_id": "xiaoya-hongyan-005", "source_id": "xiaoya-hongyan-005__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 2, "canonical_ref": "詩經·小雅·鴻鴈之什·005.2", "text_original": "祈父！予王之爪士，胡轉予于恤？靡所厎止。", "text_normalized": "祈父！予王之爪士，胡轉予于恤？靡所厎止。", "notes": "祈父 Chinese stanza 2."}
{"segment_id": "shijing__xiaoya-hongyan-005__003__zhwikisource-20260530", "work_id": "shijing", "section_id": "xiaoya-hongyan-005", "source_id": "xiaoya-hongyan-005__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 3, "canonical_ref": "詩經·小雅·鴻鴈之什·005.3", "text_original": "祈父！亶不聦，胡轉予于恤？有母之尸饔。", "text_normalized": "祈父！亶不聦，胡轉予于恤？有母之尸饔。", "notes": "祈父 Chinese stanza 3."}
