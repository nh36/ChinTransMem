{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0001", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 1, "text_original": "止，類以行之，說在同。", "text_normalized": "止，類以行之，說在同。", "canonical_ref": "32.1", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0002", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 2, "text_original": "所存與存者，於存與孰存。", "text_normalized": "所存與存者，於存與孰存。", "canonical_ref": "32.2", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0003", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 3, "text_original": "駟異說推，類之難說，在之大小。", "text_normalized": "駟異說推，類之難說，在之大小。", "canonical_ref": "32.3", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0004", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 4, "text_original": "五行毋常，勝說在宜。", "text_normalized": "五行毋常，勝說在宜。", "canonical_ref": "32.4", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0005", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 5, "text_original": "物盡同名，說在二與鬬，子與愛，食與招，白與視，麗與暴，夫與履。", "text_normalized": "物盡同名，說在二與鬬，子與愛，食與招，白與視，麗與暴，夫與履。", "canonical_ref": "32.5", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0006", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 6, "text_original": "一，偏棄之，謂而固是也。", "text_normalized": "一，偏棄之，謂而固是也。", "canonical_ref": "32.6", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0007", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 7, "text_original": "說在因不可偏去而二。", "text_normalized": "說在因不可偏去而二。", "canonical_ref": "32.7", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0008", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 8, "text_original": "說在見與俱一，與二廣，與循無欲惡之為益損也。", "text_normalized": "說在見與俱一，與二廣，與循無欲惡之為益損也。", "canonical_ref": "32.8", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0009", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 9, "text_original": "說在宜不能而不害。", "text_normalized": "說在宜不能而不害。", "canonical_ref": "32.9", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0010", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 10, "text_original": "說在害損而不害。", "text_normalized": "說在害損而不害。", "canonical_ref": "32.10", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0011", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 11, "text_original": "說在餘異類不吡。", "text_normalized": "說在餘異類不吡。", "canonical_ref": "32.11", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0012", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 12, "text_original": "說在量知而不以五路。", "text_normalized": "說在量知而不以五路。", "canonical_ref": "32.12", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0013", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 13, "text_original": "說在久偏去莫加少。", "text_normalized": "說在久偏去莫加少。", "canonical_ref": "32.13", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0014", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 14, "text_original": "說在故必熱。", "text_normalized": "說在故必熱。", "canonical_ref": "32.14", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0015", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 15, "text_original": "說在頓假必誖。", "text_normalized": "說在頓假必誖。", "canonical_ref": "32.15", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0016", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 16, "text_original": "說在不然知其所不知。", "text_normalized": "說在不然知其所不知。", "canonical_ref": "32.16", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0017", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 17, "text_original": "說在以名取物之所以然，與所以知之，與所以使人知之，不必同。", "text_normalized": "說在以名取物之所以然，與所以知之，與所以使人知之，不必同。", "canonical_ref": "32.17", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0018", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 18, "text_original": "說在病無不必待有。", "text_normalized": "說在病無不必待有。", "canonical_ref": "32.18", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0019", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 19, "text_original": "說在所謂疑。", "text_normalized": "說在所謂疑。", "canonical_ref": "32.19", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0020", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 20, "text_original": "說在逢、循、遇、過。", "text_normalized": "說在逢、循、遇、過。", "canonical_ref": "32.20", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0021", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 21, "text_original": "擢慮不疑。", "text_normalized": "擢慮不疑。", "canonical_ref": "32.21", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0022", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 22, "text_original": "說在有無合與一，或復否。", "text_normalized": "說在有無合與一，或復否。", "canonical_ref": "32.22", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0023", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 23, "text_original": "說在拒且，然不可正，而不害用工。", "text_normalized": "說在拒且，然不可正，而不害用工。", "canonical_ref": "32.23", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0024", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 24, "text_original": "說在宜歐物一體也。", "text_normalized": "說在宜歐物一體也。", "canonical_ref": "32.24", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0025", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 25, "text_original": "說在俱一惟是。", "text_normalized": "說在俱一惟是。", "canonical_ref": "32.25", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0026", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 26, "text_original": "均之絕不。", "text_normalized": "均之絕不。", "canonical_ref": "32.26", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0027", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 27, "text_original": "說在所均宇或從。", "text_normalized": "說在所均宇或從。", "canonical_ref": "32.27", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0028", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 28, "text_original": "說在長宇久，堯之義也，聲於今而處於古，而異時。", "text_normalized": "說在長宇久，堯之義也，聲於今而處於古，而異時。", "canonical_ref": "32.28", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0029", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 29, "text_original": "說在所義，二臨鑑而立景，到多而若少。", "text_normalized": "說在所義，二臨鑑而立景，到多而若少。", "canonical_ref": "32.29", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0030", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 30, "text_original": "說在寡區狗犬也，而殺狗非殺犬也，可。", "text_normalized": "說在寡區狗犬也，而殺狗非殺犬也，可。", "canonical_ref": "32.30", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0031", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 31, "text_original": "說在重鑑位量，一小而易一大，而缶。", "text_normalized": "說在重鑑位量，一小而易一大，而缶。", "canonical_ref": "32.31", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0032", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 32, "text_original": "說在中之外，內使殷美。", "text_normalized": "說在中之外，內使殷美。", "canonical_ref": "32.32", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0033", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 33, "text_original": "說在使鑑團景，一不堅白。", "text_normalized": "說在使鑑團景，一不堅白。", "canonical_ref": "32.33", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0034", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 34, "text_original": "說在荊之大，其沈淺也。", "text_normalized": "說在荊之大，其沈淺也。", "canonical_ref": "32.34", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0035", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 35, "text_original": "說在具無久，與宇堅白。", "text_normalized": "說在具無久，與宇堅白。", "canonical_ref": "32.35", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0036", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 36, "text_original": "說在因以檻為摶，於以為無知也。", "text_normalized": "說在因以檻為摶，於以為無知也。", "canonical_ref": "32.36", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0037", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 37, "text_original": "說在意。", "text_normalized": "說在意。", "canonical_ref": "32.37", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0038", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 38, "text_original": "在諸其所然諸未然，說在於是推之。", "text_normalized": "在諸其所然諸未然，說在於是推之。", "canonical_ref": "32.38", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0039", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 39, "text_original": "意未可知，說在可用過仵。", "text_normalized": "意未可知，說在可用過仵。", "canonical_ref": "32.39", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0040", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 40, "text_original": "景不徙，說在改為。", "text_normalized": "景不徙，說在改為。", "canonical_ref": "32.40", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0041", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 41, "text_original": "一少於二，而多於五，說在建位。", "text_normalized": "一少於二，而多於五，說在建位。", "canonical_ref": "32.41", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0042", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 42, "text_original": "景二，說在重。", "text_normalized": "景二，說在重。", "canonical_ref": "32.42", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0043", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 43, "text_original": "非半弗斫，則不動，說在端。", "text_normalized": "非半弗斫，則不動，說在端。", "canonical_ref": "32.43", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0044", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 44, "text_original": "景倒，在午有端與景長，說在端。", "text_normalized": "景倒，在午有端與景長，說在端。", "canonical_ref": "32.44", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0045", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 45, "text_original": "可無也，有之而不可去，說在嘗然。", "text_normalized": "可無也，有之而不可去，說在嘗然。", "canonical_ref": "32.45", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0046", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 46, "text_original": "景迎日，說在轉。", "text_normalized": "景迎日，說在轉。", "canonical_ref": "32.46", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0047", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 47, "text_original": "正而不可擔，說在摶。", "text_normalized": "正而不可擔，說在摶。", "canonical_ref": "32.47", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0048", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 48, "text_original": "景之大小，說在杝正遠近。", "text_normalized": "景之大小，說在杝正遠近。", "canonical_ref": "32.48", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0049", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 49, "text_original": "宇進無近，說在敷。", "text_normalized": "宇進無近，說在敷。", "canonical_ref": "32.49", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0050", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 50, "text_original": "二，臨鑑而立，景到，多而若少。", "text_normalized": "二，臨鑑而立，景到，多而若少。", "canonical_ref": "32.50", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0051", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 51, "text_original": "說在寡區。", "text_normalized": "說在寡區。", "canonical_ref": "32.51", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0052", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 52, "text_original": "鑑立，景一小而易，一大而正，說在中之外內。", "text_normalized": "鑑立，景一小而易，一大而正，說在中之外內。", "canonical_ref": "32.52", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0053", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 53, "text_original": "鑑團，景一。", "text_normalized": "鑑團，景一。", "canonical_ref": "32.53", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0054", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 54, "text_original": "行脩以久，說在先後。", "text_normalized": "行脩以久，說在先後。", "canonical_ref": "32.54", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0055", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 55, "text_original": "負而不撓，說在勝。", "text_normalized": "負而不撓，說在勝。", "canonical_ref": "32.55", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0056", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 56, "text_original": "一法者之相與也，盡類，若方之相合也，說在方。", "text_normalized": "一法者之相與也，盡類，若方之相合也，說在方。", "canonical_ref": "32.56", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0057", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 57, "text_original": "衡而必正，說在得。", "text_normalized": "衡而必正，說在得。", "canonical_ref": "32.57", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0058", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 58, "text_original": "挈與收反，說在權。", "text_normalized": "挈與收反，說在權。", "canonical_ref": "32.58", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0059", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 59, "text_original": "狂舉不可以知異，說在有不可。", "text_normalized": "狂舉不可以知異，說在有不可。", "canonical_ref": "32.59", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0060", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 60, "text_original": "牛馬之非牛，與可之同，說在兼。", "text_normalized": "牛馬之非牛，與可之同，說在兼。", "canonical_ref": "32.60", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0061", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 61, "text_original": "倚者不可正，說在梯。", "text_normalized": "倚者不可正，說在梯。", "canonical_ref": "32.61", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0062", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 62, "text_original": "循此循此與彼此同，說在異。", "text_normalized": "循此循此與彼此同，說在異。", "canonical_ref": "32.62", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0063", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 63, "text_original": "柱之必住，說在廢材。", "text_normalized": "柱之必住，說在廢材。", "canonical_ref": "32.63", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0064", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 64, "text_original": "唱和同串，說在功。", "text_normalized": "唱和同串，說在功。", "canonical_ref": "32.64", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0065", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 65, "text_original": "買無貴，說在反其賈。", "text_normalized": "買無貴，說在反其賈。", "canonical_ref": "32.65", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0066", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 66, "text_original": "聞所不知，若所知，則兩知之，說在告。", "text_normalized": "聞所不知，若所知，則兩知之，說在告。", "canonical_ref": "32.66", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0067", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 67, "text_original": "賈宜則售，說在盡。", "text_normalized": "賈宜則售，說在盡。", "canonical_ref": "32.67", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0068", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 68, "text_original": "以言為盡誖，誖，說在其言。", "text_normalized": "以言為盡誖，誖，說在其言。", "canonical_ref": "32.68", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0069", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 69, "text_original": "無說而懼，說在弗心。", "text_normalized": "無說而懼，說在弗心。", "canonical_ref": "32.69", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0070", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 70, "text_original": "唯吾謂非名也則不可，說在反。", "text_normalized": "唯吾謂非名也則不可，說在反。", "canonical_ref": "32.70", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0071", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 71, "text_original": "域，過名也，說在實。", "text_normalized": "域，過名也，說在實。", "canonical_ref": "32.71", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0072", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 72, "text_original": "無窮不害兼，說在盈否。", "text_normalized": "無窮不害兼，說在盈否。", "canonical_ref": "32.72", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0073", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 73, "text_original": "知知之，否之，足用也。", "text_normalized": "知知之，否之，足用也。", "canonical_ref": "32.73", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0074", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 74, "text_original": "誖。", "text_normalized": "誖。", "canonical_ref": "32.74", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0075", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 75, "text_original": "說在無以也。", "text_normalized": "說在無以也。", "canonical_ref": "32.75", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0076", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 76, "text_original": "不知其數而知其盡也，說在明者。", "text_normalized": "不知其數而知其盡也，說在明者。", "canonical_ref": "32.76", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0077", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 77, "text_original": "謂辯無勝，必不當，說在辯。", "text_normalized": "謂辯無勝，必不當，說在辯。", "canonical_ref": "32.77", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0078", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 78, "text_original": "不知其所處，不害愛之，說在喪子者。", "text_normalized": "不知其所處，不害愛之，說在喪子者。", "canonical_ref": "32.78", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0079", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 79, "text_original": "無不讓也，不可，說在殆。", "text_normalized": "無不讓也，不可，說在殆。", "canonical_ref": "32.79", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0080", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 80, "text_original": "仁義之為內外也，罔，說在仵顏。", "text_normalized": "仁義之為內外也，罔，說在仵顏。", "canonical_ref": "32.80", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0081", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 81, "text_original": "於一有知焉，有不知焉，說在存。", "text_normalized": "於一有知焉，有不知焉，說在存。", "canonical_ref": "32.81", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0082", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 82, "text_original": "學之益也，說在誹者。", "text_normalized": "學之益也，說在誹者。", "canonical_ref": "32.82", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0083", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 83, "text_original": "有指於二，而不可逃，說在以二參。", "text_normalized": "有指於二，而不可逃，說在以二參。", "canonical_ref": "32.83", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0084", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 84, "text_original": "誹之可否，不以眾寡，說在可非。", "text_normalized": "誹之可否，不以眾寡，說在可非。", "canonical_ref": "32.84", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0085", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 85, "text_original": "所知而弗能指，說在春也、逃臣、狗犬、貴者。", "text_normalized": "所知而弗能指，說在春也、逃臣、狗犬、貴者。", "canonical_ref": "32.85", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0086", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 86, "text_original": "非誹者誖，說在弗非。", "text_normalized": "非誹者誖，說在弗非。", "canonical_ref": "32.86", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0087", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 87, "text_original": "知狗而自謂不知犬，過也，說在重。", "text_normalized": "知狗而自謂不知犬，過也，說在重。", "canonical_ref": "32.87", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0088", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 88, "text_original": "物甚不甚，說在若是。", "text_normalized": "物甚不甚，說在若是。", "canonical_ref": "32.88", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0089", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 89, "text_original": "通意後對，說在不知其誰謂也。", "text_normalized": "通意後對，說在不知其誰謂也。", "canonical_ref": "32.89", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0090", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 90, "text_original": "取下以求上也，說在澤。", "text_normalized": "取下以求上也，說在澤。", "canonical_ref": "32.90", "notes": ""}
{"segment_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3__seg-0091", "section_id": "mozi-032-canon-ii", "source_id": "mozi-032-canon-ii__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 91, "text_original": "不是與是同，說在不州。", "text_normalized": "不是與是同，說在不州。", "canonical_ref": "32.91", "notes": ""}
