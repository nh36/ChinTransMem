{"segment_id": "laozi-chapter-065__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-065", "source_id": "laozi-chapter-065__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 65.1", "sort_key": "065.001", "text_original": "古之善為道者，", "text_normalized": "古之善為道者，", "notes": ""}
{"segment_id": "laozi-chapter-065__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-065", "source_id": "laozi-chapter-065__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 65.2", "sort_key": "065.002", "text_original": "非以明民，", "text_normalized": "非以明民，", "notes": ""}
{"segment_id": "laozi-chapter-065__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-065", "source_id": "laozi-chapter-065__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 65.3", "sort_key": "065.003", "text_original": "將以愚之。", "text_normalized": "將以愚之。", "notes": ""}
{"segment_id": "laozi-chapter-065__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-065", "source_id": "laozi-chapter-065__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 65.4", "sort_key": "065.004", "text_original": "民之難治，", "text_normalized": "民之難治，", "notes": ""}
{"segment_id": "laozi-chapter-065__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-065", "source_id": "laozi-chapter-065__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 65.5", "sort_key": "065.005", "text_original": "以其智多。", "text_normalized": "以其智多。", "notes": ""}
{"segment_id": "laozi-chapter-065__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-065", "source_id": "laozi-chapter-065__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 65.6", "sort_key": "065.006", "text_original": "故以智治國，", "text_normalized": "故以智治國，", "notes": ""}
{"segment_id": "laozi-chapter-065__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-065", "source_id": "laozi-chapter-065__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 65.7", "sort_key": "065.007", "text_original": "國之賊，", "text_normalized": "國之賊，", "notes": ""}
{"segment_id": "laozi-chapter-065__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-065", "source_id": "laozi-chapter-065__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 65.8", "sort_key": "065.008", "text_original": "不以智治國，", "text_normalized": "不以智治國，", "notes": ""}
{"segment_id": "laozi-chapter-065__chinesenotes-daodejing-zh-20260531__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-065", "source_id": "laozi-chapter-065__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 65.9", "sort_key": "065.009", "text_original": "國之福。", "text_normalized": "國之福。", "notes": ""}
{"segment_id": "laozi-chapter-065__chinesenotes-daodejing-zh-20260531__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-065", "source_id": "laozi-chapter-065__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 65.10", "sort_key": "065.010", "text_original": "知此兩者亦稽式。", "text_normalized": "知此兩者亦稽式。", "notes": ""}
{"segment_id": "laozi-chapter-065__chinesenotes-daodejing-zh-20260531__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-065", "source_id": "laozi-chapter-065__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 65.11", "sort_key": "065.011", "text_original": "常知稽式，", "text_normalized": "常知稽式，", "notes": ""}
{"segment_id": "laozi-chapter-065__chinesenotes-daodejing-zh-20260531__seg-012", "work_id": "laozi", "section_id": "laozi-chapter-065", "source_id": "laozi-chapter-065__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 12, "canonical_ref": "老子 65.12", "sort_key": "065.012", "text_original": "是謂玄德。", "text_normalized": "是謂玄德。", "notes": ""}
{"segment_id": "laozi-chapter-065__chinesenotes-daodejing-zh-20260531__seg-013", "work_id": "laozi", "section_id": "laozi-chapter-065", "source_id": "laozi-chapter-065__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 13, "canonical_ref": "老子 65.13", "sort_key": "065.013", "text_original": "玄德深矣，", "text_normalized": "玄德深矣，", "notes": ""}
{"segment_id": "laozi-chapter-065__chinesenotes-daodejing-zh-20260531__seg-014", "work_id": "laozi", "section_id": "laozi-chapter-065", "source_id": "laozi-chapter-065__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 14, "canonical_ref": "老子 65.14", "sort_key": "065.014", "text_original": "遠矣，", "text_normalized": "遠矣，", "notes": ""}
{"segment_id": "laozi-chapter-065__chinesenotes-daodejing-zh-20260531__seg-015", "work_id": "laozi", "section_id": "laozi-chapter-065", "source_id": "laozi-chapter-065__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 15, "canonical_ref": "老子 65.15", "sort_key": "065.015", "text_original": "與物反矣，", "text_normalized": "與物反矣，", "notes": ""}
{"segment_id": "laozi-chapter-065__chinesenotes-daodejing-zh-20260531__seg-016", "work_id": "laozi", "section_id": "laozi-chapter-065", "source_id": "laozi-chapter-065__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 16, "canonical_ref": "老子 65.16", "sort_key": "065.016", "text_original": "然後乃至大順。", "text_normalized": "然後乃至大順。", "notes": ""}
