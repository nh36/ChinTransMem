{"segment_id": "laozi-chapter-037__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-037", "source_id": "laozi-chapter-037__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 37.2", "sort_key": "037.002", "text_original": "而無不為。", "text_normalized": "而無不為。", "notes": ""}
{"segment_id": "laozi-chapter-037__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-037", "source_id": "laozi-chapter-037__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 37.3", "sort_key": "037.003", "text_original": "侯王若能守之，", "text_normalized": "侯王若能守之，", "notes": ""}
{"segment_id": "laozi-chapter-037__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-037", "source_id": "laozi-chapter-037__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 37.4", "sort_key": "037.004", "text_original": "萬物將自化。", "text_normalized": "萬物將自化。", "notes": ""}
{"segment_id": "laozi-chapter-037__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-037", "source_id": "laozi-chapter-037__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 37.5", "sort_key": "037.005", "text_original": "化而欲作，", "text_normalized": "化而欲作，", "notes": ""}
{"segment_id": "laozi-chapter-037__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-037", "source_id": "laozi-chapter-037__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 37.6", "sort_key": "037.006", "text_original": "吾將鎮之以無名之樸。", "text_normalized": "吾將鎮之以無名之樸。", "notes": ""}
{"segment_id": "laozi-chapter-037__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-037", "source_id": "laozi-chapter-037__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 37.7", "sort_key": "037.007", "text_original": "無名之樸，", "text_normalized": "無名之樸，", "notes": ""}
{"segment_id": "laozi-chapter-037__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-037", "source_id": "laozi-chapter-037__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 37.8", "sort_key": "037.008", "text_original": "夫亦將無欲。", "text_normalized": "夫亦將無欲。", "notes": ""}
{"segment_id": "laozi-chapter-037__chinesenotes-daodejing-zh-20260531__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-037", "source_id": "laozi-chapter-037__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 37.9", "sort_key": "037.009", "text_original": "不欲以靜，", "text_normalized": "不欲以靜，", "notes": ""}
{"segment_id": "laozi-chapter-037__chinesenotes-daodejing-zh-20260531__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-037", "source_id": "laozi-chapter-037__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 37.10", "sort_key": "037.010", "text_original": "天下將自定。", "text_normalized": "天下將自定。", "notes": ""}
