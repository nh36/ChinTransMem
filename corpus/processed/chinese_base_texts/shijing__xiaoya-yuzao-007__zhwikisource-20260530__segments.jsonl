{"segment_id": "shijing__xiaoya-yuzao-007__001__zhwikisource-20260530", "work_id": "shijing", "section_id": "xiaoya-yuzao-007", "source_id": "xiaoya-yuzao-007__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 1, "canonical_ref": "詩經·小雅·魚藻之什·007.1", "text_original": "芃芃黍苗，陰雨膏之。悠悠南行，召伯勞之。", "text_normalized": "芃芃黍苗，陰雨膏之。悠悠南行，召伯勞之。", "notes": "黍苗 Chinese stanza 1."}
{"segment_id": "shijing__xiaoya-yuzao-007__002__zhwikisource-20260530", "work_id": "shijing", "section_id": "xiaoya-yuzao-007", "source_id": "xiaoya-yuzao-007__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 2, "canonical_ref": "詩經·小雅·魚藻之什·007.2", "text_original": "我任我輦，我車我牛。我行既集，蓋云歸哉。", "text_normalized": "我任我輦，我車我牛。我行既集，蓋云歸哉。", "notes": "黍苗 Chinese stanza 2."}
{"segment_id": "shijing__xiaoya-yuzao-007__003__zhwikisource-20260530", "work_id": "shijing", "section_id": "xiaoya-yuzao-007", "source_id": "xiaoya-yuzao-007__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 3, "canonical_ref": "詩經·小雅·魚藻之什·007.3", "text_original": "我徒我御，我師我旅。我行既集，蓋云歸處。", "text_normalized": "我徒我御，我師我旅。我行既集，蓋云歸處。", "notes": "黍苗 Chinese stanza 3."}
{"segment_id": "shijing__xiaoya-yuzao-007__004__zhwikisource-20260530", "work_id": "shijing", "section_id": "xiaoya-yuzao-007", "source_id": "xiaoya-yuzao-007__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 4, "canonical_ref": "詩經·小雅·魚藻之什·007.4", "text_original": "肅肅謝功，召伯營之。烈烈征師，召伯成之。", "text_normalized": "肅肅謝功，召伯營之。烈烈征師，召伯成之。", "notes": "黍苗 Chinese stanza 4."}
{"segment_id": "shijing__xiaoya-yuzao-007__005__zhwikisource-20260530", "work_id": "shijing", "section_id": "xiaoya-yuzao-007", "source_id": "xiaoya-yuzao-007__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 5, "canonical_ref": "詩經·小雅·魚藻之什·007.5", "text_original": "原隰既平，泉流既清。召伯有成，王心則寧。", "text_normalized": "原隰既平，泉流既清。召伯有成，王心則寧。", "notes": "黍苗 Chinese stanza 5."}
