{"segment_id": "laozi-chapter-005__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-005", "source_id": "laozi-chapter-005__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 5.1", "sort_key": "005.001", "text_original": "天地不仁，以萬物為芻狗；", "text_normalized": "天地不仁，以萬物為芻狗；", "notes": ""}
{"segment_id": "laozi-chapter-005__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-005", "source_id": "laozi-chapter-005__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 5.2", "sort_key": "005.002", "text_original": "聖人不仁，以百姓為芻狗。", "text_normalized": "聖人不仁，以百姓為芻狗。", "notes": ""}
{"segment_id": "laozi-chapter-005__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-005", "source_id": "laozi-chapter-005__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 5.3", "sort_key": "005.003", "text_original": "天地之間，其猶橐籥乎？", "text_normalized": "天地之間，其猶橐籥乎？", "notes": ""}
{"segment_id": "laozi-chapter-005__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-005", "source_id": "laozi-chapter-005__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 5.4", "sort_key": "005.004", "text_original": "虛而不屈，動而愈出。", "text_normalized": "虛而不屈，動而愈出。", "notes": ""}
{"segment_id": "laozi-chapter-005__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-005", "source_id": "laozi-chapter-005__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 5.5", "sort_key": "005.005", "text_original": "多言數窮，不如守中。", "text_normalized": "多言數窮，不如守中。", "notes": ""}
