{"segment_id": "laozi-chapter-069__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-069", "source_id": "laozi-chapter-069__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 69.6", "sort_key": "069.006", "text_original": "執無兵。", "text_normalized": "執無兵。", "notes": ""}
