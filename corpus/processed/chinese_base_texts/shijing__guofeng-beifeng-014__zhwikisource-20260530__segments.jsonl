{"segment_id": "shijing__guofeng-beifeng-014__001__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-beifeng-014", "source_id": "guofeng-beifeng-014__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 1, "canonical_ref": "詩經·國風·邶風·014.1", "text_original": "毖彼泉水，亦流于淇，有懷于衞，靡日不思，孌彼諸姬，聊與之謀。", "text_normalized": "毖彼泉水，亦流于淇，有懷于衞，靡日不思，孌彼諸姬，聊與之謀。", "notes": "泉水 Chinese stanza 1."}
{"segment_id": "shijing__guofeng-beifeng-014__002__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-beifeng-014", "source_id": "guofeng-beifeng-014__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 2, "canonical_ref": "詩經·國風·邶風·014.2", "text_original": "出宿于泲，飲餞于禰，女子有行，遠父母兄弟，問我諸姑，遂及伯姊。", "text_normalized": "出宿于泲，飲餞于禰，女子有行，遠父母兄弟，問我諸姑，遂及伯姊。", "notes": "泉水 Chinese stanza 2."}
{"segment_id": "shijing__guofeng-beifeng-014__003__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-beifeng-014", "source_id": "guofeng-beifeng-014__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 3, "canonical_ref": "詩經·國風·邶風·014.3", "text_original": "出宿于干，飲餞于言，載脂載舝，還車言邁，遄臻于衞，不瑕有害。", "text_normalized": "出宿于干，飲餞于言，載脂載舝，還車言邁，遄臻于衞，不瑕有害。", "notes": "泉水 Chinese stanza 3."}
{"segment_id": "shijing__guofeng-beifeng-014__004__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-beifeng-014", "source_id": "guofeng-beifeng-014__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 4, "canonical_ref": "詩經·國風·邶風·014.4", "text_original": "我思肥泉，茲之永歎，思須與漕，我心悠悠，駕言出遊，以寫我憂。", "text_normalized": "我思肥泉，茲之永歎，思須與漕，我心悠悠，駕言出遊，以寫我憂。", "notes": "泉水 Chinese stanza 4."}
