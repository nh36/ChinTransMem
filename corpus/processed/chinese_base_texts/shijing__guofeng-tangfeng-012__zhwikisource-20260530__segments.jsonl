{"segment_id": "shijing__guofeng-tangfeng-012__001__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-tangfeng-012", "source_id": "guofeng-tangfeng-012__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 1, "canonical_ref": "詩經·國風·唐風·012.1", "text_original": "采苓采苓，首陽之巔。人之為言，苟亦無信。舍旃舍旃，苟亦無然。人之為言，胡得焉！", "text_normalized": "采苓采苓，首陽之巔。人之為言，苟亦無信。舍旃舍旃，苟亦無然。人之為言，胡得焉！", "notes": "采苓 Chinese stanza 1."}
{"segment_id": "shijing__guofeng-tangfeng-012__002__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-tangfeng-012", "source_id": "guofeng-tangfeng-012__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 2, "canonical_ref": "詩經·國風·唐風·012.2", "text_original": "采苦采苦，首陽之下。人之為言，苟亦無與。舍旃舍旃，苟亦無然。人之為言，胡得焉！", "text_normalized": "采苦采苦，首陽之下。人之為言，苟亦無與。舍旃舍旃，苟亦無然。人之為言，胡得焉！", "notes": "采苓 Chinese stanza 2."}
{"segment_id": "shijing__guofeng-tangfeng-012__003__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-tangfeng-012", "source_id": "guofeng-tangfeng-012__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 3, "canonical_ref": "詩經·國風·唐風·012.3", "text_original": "采葑采葑，首陽之東。人之為言，苟亦無從。舍旃舍旃，苟亦無然。人之為言，胡得焉！", "text_normalized": "采葑采葑，首陽之東。人之為言，苟亦無從。舍旃舍旃，苟亦無然。人之為言，胡得焉！", "notes": "采苓 Chinese stanza 3."}
