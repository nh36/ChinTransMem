{"segment_id": "laozi-chapter-009__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-009", "source_id": "laozi-chapter-009__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 9.1", "sort_key": "009.001", "text_original": "持而盈之，不如其已；", "text_normalized": "持而盈之，不如其已；", "notes": ""}
{"segment_id": "laozi-chapter-009__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-009", "source_id": "laozi-chapter-009__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 9.2", "sort_key": "009.002", "text_original": "揣而梲之，不可長保。", "text_normalized": "揣而梲之，不可長保。", "notes": ""}
{"segment_id": "laozi-chapter-009__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-009", "source_id": "laozi-chapter-009__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 9.3", "sort_key": "009.003", "text_original": "金玉滿堂，莫之能守；", "text_normalized": "金玉滿堂，莫之能守；", "notes": ""}
{"segment_id": "laozi-chapter-009__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-009", "source_id": "laozi-chapter-009__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 9.4", "sort_key": "009.004", "text_original": "富貴而驕，自遺其咎。", "text_normalized": "富貴而驕，自遺其咎。", "notes": ""}
{"segment_id": "laozi-chapter-009__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-009", "source_id": "laozi-chapter-009__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 9.5", "sort_key": "009.005", "text_original": "功遂身退，天之道。", "text_normalized": "功遂身退，天之道。", "notes": ""}
