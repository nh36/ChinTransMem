{"segment_id": "laozi-chapter-055__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-055", "source_id": "laozi-chapter-055__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 55.1", "sort_key": "055.001", "text_original": "含德之厚，比於赤子。", "text_normalized": "含德之厚，比於赤子。", "notes": ""}
{"segment_id": "laozi-chapter-055__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-055", "source_id": "laozi-chapter-055__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 55.2", "sort_key": "055.002", "text_original": "蜂蠆虺蛇不螫，猛獸不據，攫鳥不搏。", "text_normalized": "蜂蠆虺蛇不螫，猛獸不據，攫鳥不搏。", "notes": ""}
{"segment_id": "laozi-chapter-055__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-055", "source_id": "laozi-chapter-055__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 55.3", "sort_key": "055.003", "text_original": "骨弱筋柔而握固。", "text_normalized": "骨弱筋柔而握固。", "notes": ""}
{"segment_id": "laozi-chapter-055__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-055", "source_id": "laozi-chapter-055__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 55.4", "sort_key": "055.004", "text_original": "未知牝牡之合而全作，", "text_normalized": "未知牝牡之合而全作，", "notes": ""}
{"segment_id": "laozi-chapter-055__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-055", "source_id": "laozi-chapter-055__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 55.5", "sort_key": "055.005", "text_original": "精之至也。", "text_normalized": "精之至也。", "notes": ""}
{"segment_id": "laozi-chapter-055__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-055", "source_id": "laozi-chapter-055__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 55.6", "sort_key": "055.006", "text_original": "終日號而不嗄，", "text_normalized": "終日號而不嗄，", "notes": ""}
{"segment_id": "laozi-chapter-055__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-055", "source_id": "laozi-chapter-055__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 55.7", "sort_key": "055.007", "text_original": "和之至也。", "text_normalized": "和之至也。", "notes": ""}
{"segment_id": "laozi-chapter-055__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-055", "source_id": "laozi-chapter-055__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 55.8", "sort_key": "055.008", "text_original": "知和曰常，", "text_normalized": "知和曰常，", "notes": ""}
{"segment_id": "laozi-chapter-055__chinesenotes-daodejing-zh-20260531__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-055", "source_id": "laozi-chapter-055__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 55.9", "sort_key": "055.009", "text_original": "知常曰明。", "text_normalized": "知常曰明。", "notes": ""}
{"segment_id": "laozi-chapter-055__chinesenotes-daodejing-zh-20260531__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-055", "source_id": "laozi-chapter-055__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 55.10", "sort_key": "055.010", "text_original": "益生曰祥。", "text_normalized": "益生曰祥。", "notes": ""}
{"segment_id": "laozi-chapter-055__chinesenotes-daodejing-zh-20260531__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-055", "source_id": "laozi-chapter-055__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 55.11", "sort_key": "055.011", "text_original": "心使氣曰強。", "text_normalized": "心使氣曰強。", "notes": ""}
{"segment_id": "laozi-chapter-055__chinesenotes-daodejing-zh-20260531__seg-012", "work_id": "laozi", "section_id": "laozi-chapter-055", "source_id": "laozi-chapter-055__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 12, "canonical_ref": "老子 55.12", "sort_key": "055.012", "text_original": "物壯則老，謂之不道，不道早已。", "text_normalized": "物壯則老，謂之不道，不道早已。", "notes": ""}
