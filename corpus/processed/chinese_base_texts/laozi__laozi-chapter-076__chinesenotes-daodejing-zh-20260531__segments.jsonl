{"segment_id": "laozi-chapter-076__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-076", "source_id": "laozi-chapter-076__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 76.1", "sort_key": "076.001", "text_original": "人之生也柔弱，", "text_normalized": "人之生也柔弱，", "notes": ""}
{"segment_id": "laozi-chapter-076__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-076", "source_id": "laozi-chapter-076__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 76.2", "sort_key": "076.002", "text_original": "其死也堅強。", "text_normalized": "其死也堅強。", "notes": ""}
{"segment_id": "laozi-chapter-076__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-076", "source_id": "laozi-chapter-076__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 76.3", "sort_key": "076.003", "text_original": "萬物草木之生也柔脆，", "text_normalized": "萬物草木之生也柔脆，", "notes": ""}
{"segment_id": "laozi-chapter-076__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-076", "source_id": "laozi-chapter-076__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 76.4", "sort_key": "076.004", "text_original": "其死也枯槁。", "text_normalized": "其死也枯槁。", "notes": ""}
{"segment_id": "laozi-chapter-076__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-076", "source_id": "laozi-chapter-076__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 76.5", "sort_key": "076.005", "text_original": "故堅強者死之徒，", "text_normalized": "故堅強者死之徒，", "notes": ""}
{"segment_id": "laozi-chapter-076__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-076", "source_id": "laozi-chapter-076__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 76.6", "sort_key": "076.006", "text_original": "柔弱者生之徒。", "text_normalized": "柔弱者生之徒。", "notes": ""}
{"segment_id": "laozi-chapter-076__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-076", "source_id": "laozi-chapter-076__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 76.7", "sort_key": "076.007", "text_original": "是以兵強則不勝，", "text_normalized": "是以兵強則不勝，", "notes": ""}
{"segment_id": "laozi-chapter-076__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-076", "source_id": "laozi-chapter-076__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 76.8", "sort_key": "076.008", "text_original": "木強則兵。", "text_normalized": "木強則兵。", "notes": ""}
{"segment_id": "laozi-chapter-076__chinesenotes-daodejing-zh-20260531__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-076", "source_id": "laozi-chapter-076__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 76.9", "sort_key": "076.009", "text_original": "強大處下，", "text_normalized": "強大處下，", "notes": ""}
{"segment_id": "laozi-chapter-076__chinesenotes-daodejing-zh-20260531__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-076", "source_id": "laozi-chapter-076__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 76.10", "sort_key": "076.010", "text_original": "柔弱處上。", "text_normalized": "柔弱處上。", "notes": ""}
