{"segment_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3__seg-0001", "section_id": "mozi-044-defense-against-attack-with-ladders", "source_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 1, "text_original": "禽滑釐子事子墨子三年，手足胼胝，面目黧黑，役身給使，不敢問欲。", "text_normalized": "禽滑釐子事子墨子三年，手足胼胝，面目黧黑，役身給使，不敢問欲。", "canonical_ref": "44.1", "notes": ""}
{"segment_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3__seg-0002", "section_id": "mozi-044-defense-against-attack-with-ladders", "source_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 2, "text_original": "子墨子其哀之，乃管酒塊脯，寄于大山昧葇坐之，以樵禽子。", "text_normalized": "子墨子其哀之，乃管酒塊脯，寄于大山昧葇坐之，以樵禽子。", "canonical_ref": "44.2", "notes": ""}
{"segment_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3__seg-0003", "section_id": "mozi-044-defense-against-attack-with-ladders", "source_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 3, "text_original": "禽子再拜而嘆。", "text_normalized": "禽子再拜而嘆。", "canonical_ref": "44.3", "notes": ""}
{"segment_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3__seg-0004", "section_id": "mozi-044-defense-against-attack-with-ladders", "source_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 4, "text_original": "子墨子曰：", "text_normalized": "子墨子曰：", "canonical_ref": "44.4", "notes": ""}
{"segment_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3__seg-0005", "section_id": "mozi-044-defense-against-attack-with-ladders", "source_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 5, "text_original": "「亦何欲乎？", "text_normalized": "「亦何欲乎？", "canonical_ref": "44.5", "notes": ""}
{"segment_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3__seg-0006", "section_id": "mozi-044-defense-against-attack-with-ladders", "source_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 6, "text_original": "」禽子再拜再拜曰：", "text_normalized": "」禽子再拜再拜曰：", "canonical_ref": "44.6", "notes": ""}
{"segment_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3__seg-0007", "section_id": "mozi-044-defense-against-attack-with-ladders", "source_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 7, "text_original": "「敢問守道？", "text_normalized": "「敢問守道？", "canonical_ref": "44.7", "notes": ""}
{"segment_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3__seg-0008", "section_id": "mozi-044-defense-against-attack-with-ladders", "source_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 8, "text_original": "」子墨子曰：", "text_normalized": "」子墨子曰：", "canonical_ref": "44.8", "notes": ""}
{"segment_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3__seg-0009", "section_id": "mozi-044-defense-against-attack-with-ladders", "source_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 9, "text_original": "「姑亡，姑亡。", "text_normalized": "「姑亡，姑亡。", "canonical_ref": "44.9", "notes": ""}
{"segment_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3__seg-0010", "section_id": "mozi-044-defense-against-attack-with-ladders", "source_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 10, "text_original": "古有亓術者，內不親民，外不約治，以少閒眾，以弱輕強，身死國亡，為天下笑。", "text_normalized": "古有亓術者，內不親民，外不約治，以少閒眾，以弱輕強，身死國亡，為天下笑。", "canonical_ref": "44.10", "notes": ""}
{"segment_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3__seg-0011", "section_id": "mozi-044-defense-against-attack-with-ladders", "source_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 11, "text_original": "子亓慎之，恐為身薑。", "text_normalized": "子亓慎之，恐為身薑。", "canonical_ref": "44.11", "notes": ""}
{"segment_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3__seg-0012", "section_id": "mozi-044-defense-against-attack-with-ladders", "source_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 12, "text_original": "」禽子再拜頓首，願遂問守道。", "text_normalized": "」禽子再拜頓首，願遂問守道。", "canonical_ref": "44.12", "notes": ""}
{"segment_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3__seg-0013", "section_id": "mozi-044-defense-against-attack-with-ladders", "source_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 13, "text_original": "曰：", "text_normalized": "曰：", "canonical_ref": "44.13", "notes": ""}
{"segment_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3__seg-0014", "section_id": "mozi-044-defense-against-attack-with-ladders", "source_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 14, "text_original": "「敢問客眾而勇，煙資吾池，軍卒並進，雲梯既施，攻備已具，武士又多，爭上吾城，為之柰何？", "text_normalized": "「敢問客眾而勇，煙資吾池，軍卒並進，雲梯既施，攻備已具，武士又多，爭上吾城，為之柰何？", "canonical_ref": "44.14", "notes": ""}
{"segment_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3__seg-0015", "section_id": "mozi-044-defense-against-attack-with-ladders", "source_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 15, "text_original": "」子墨子曰：", "text_normalized": "」子墨子曰：", "canonical_ref": "44.15", "notes": ""}
{"segment_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3__seg-0016", "section_id": "mozi-044-defense-against-attack-with-ladders", "source_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 16, "text_original": "「問雲梯之守邪？", "text_normalized": "「問雲梯之守邪？", "canonical_ref": "44.16", "notes": ""}
{"segment_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3__seg-0017", "section_id": "mozi-044-defense-against-attack-with-ladders", "source_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 17, "text_original": "雲梯者重器也，亓動移甚難。", "text_normalized": "雲梯者重器也，亓動移甚難。", "canonical_ref": "44.17", "notes": ""}
{"segment_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3__seg-0018", "section_id": "mozi-044-defense-against-attack-with-ladders", "source_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 18, "text_original": "守為行城，雜樓相見，以環亓中。", "text_normalized": "守為行城，雜樓相見，以環亓中。", "canonical_ref": "44.18", "notes": ""}
{"segment_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3__seg-0019", "section_id": "mozi-044-defense-against-attack-with-ladders", "source_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 19, "text_original": "以適廣陜為度，環中藉幕，毋廣亓處。", "text_normalized": "以適廣陜為度，環中藉幕，毋廣亓處。", "canonical_ref": "44.19", "notes": ""}
{"segment_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3__seg-0020", "section_id": "mozi-044-defense-against-attack-with-ladders", "source_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 20, "text_original": "行城之法，高城二十尺，上加堞，廣十尺，左右出巨各二十尺，高、廣如行城之法。", "text_normalized": "行城之法，高城二十尺，上加堞，廣十尺，左右出巨各二十尺，高、廣如行城之法。", "canonical_ref": "44.20", "notes": ""}
{"segment_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3__seg-0021", "section_id": "mozi-044-defense-against-attack-with-ladders", "source_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 21, "text_original": "為雀穴煇鼠，施荅亓外，機、衝、錢、城，廣與隊等，雜亓閒以鐫、劍，持衝十人，執劍五人，皆以有力者。", "text_normalized": "為雀穴煇鼠，施荅亓外，機、衝、錢、城，廣與隊等，雜亓閒以鐫、劍，持衝十人，執劍五人，皆以有力者。", "canonical_ref": "44.21", "notes": ""}
{"segment_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3__seg-0022", "section_id": "mozi-044-defense-against-attack-with-ladders", "source_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 22, "text_original": "令案目者視適，以鼓發之，夾而射之，重而射之，披機藉之，城上繁下矢、石、沙、炭以雨之，薪火、水湯以濟之，審賞行罰，以靜為故，從之以急，毋使生慮。", "text_normalized": "令案目者視適，以鼓發之，夾而射之，重而射之，披機藉之，城上繁下矢、石、沙、炭以雨之，薪火、水湯以濟之，審賞行罰，以靜為故，從之以急，毋使生慮。", "canonical_ref": "44.22", "notes": ""}
{"segment_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3__seg-0023", "section_id": "mozi-044-defense-against-attack-with-ladders", "source_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 23, "text_original": "若此，則雲梯之攻敗矣。", "text_normalized": "若此，則雲梯之攻敗矣。", "canonical_ref": "44.23", "notes": ""}
{"segment_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3__seg-0024", "section_id": "mozi-044-defense-against-attack-with-ladders", "source_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 24, "text_original": "守為行堞，堞高六尺而一等，施劍亓面，以機發之，衝至則去之，不至則施之。", "text_normalized": "守為行堞，堞高六尺而一等，施劍亓面，以機發之，衝至則去之，不至則施之。", "canonical_ref": "44.24", "notes": ""}
{"segment_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3__seg-0025", "section_id": "mozi-044-defense-against-attack-with-ladders", "source_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 25, "text_original": "雀穴三尺而一，蒺藜投必遂而立，以車推引之。", "text_normalized": "雀穴三尺而一，蒺藜投必遂而立，以車推引之。", "canonical_ref": "44.25", "notes": ""}
{"segment_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3__seg-0026", "section_id": "mozi-044-defense-against-attack-with-ladders", "source_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 26, "text_original": "裾城外，去城十尺，裾厚十尺。", "text_normalized": "裾城外，去城十尺，裾厚十尺。", "canonical_ref": "44.26", "notes": ""}
{"segment_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3__seg-0027", "section_id": "mozi-044-defense-against-attack-with-ladders", "source_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 27, "text_original": "伐裾，小大盡本斷之，以十尺為傳，雜而深埋之，堅築，毋使可拔。", "text_normalized": "伐裾，小大盡本斷之，以十尺為傳，雜而深埋之，堅築，毋使可拔。", "canonical_ref": "44.27", "notes": ""}
{"segment_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3__seg-0028", "section_id": "mozi-044-defense-against-attack-with-ladders", "source_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 28, "text_original": "二十步一殺，殺有一鬲，鬲厚十尺，殺有兩門，門廣五尺。", "text_normalized": "二十步一殺，殺有一鬲，鬲厚十尺，殺有兩門，門廣五尺。", "canonical_ref": "44.28", "notes": ""}
{"segment_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3__seg-0029", "section_id": "mozi-044-defense-against-attack-with-ladders", "source_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 29, "text_original": "裾門一，施淺埋，弗築，令易拔。", "text_normalized": "裾門一，施淺埋，弗築，令易拔。", "canonical_ref": "44.29", "notes": ""}
{"segment_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3__seg-0030", "section_id": "mozi-044-defense-against-attack-with-ladders", "source_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 30, "text_original": "城希裾門而直桀。", "text_normalized": "城希裾門而直桀。", "canonical_ref": "44.30", "notes": ""}
{"segment_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3__seg-0031", "section_id": "mozi-044-defense-against-attack-with-ladders", "source_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 31, "text_original": "縣火，四尺一鉤樴，五步一灶，灶門有鑪炭。", "text_normalized": "縣火，四尺一鉤樴，五步一灶，灶門有鑪炭。", "canonical_ref": "44.31", "notes": ""}
{"segment_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3__seg-0032", "section_id": "mozi-044-defense-against-attack-with-ladders", "source_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 32, "text_original": "令適人盡入，煇火燒門，縣火次之。", "text_normalized": "令適人盡入，煇火燒門，縣火次之。", "canonical_ref": "44.32", "notes": ""}
{"segment_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3__seg-0033", "section_id": "mozi-044-defense-against-attack-with-ladders", "source_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 33, "text_original": "出載而立，亓廣終隊。", "text_normalized": "出載而立，亓廣終隊。", "canonical_ref": "44.33", "notes": ""}
{"segment_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3__seg-0034", "section_id": "mozi-044-defense-against-attack-with-ladders", "source_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 34, "text_original": "兩載之閒一火，皆立而待鼓而然火，即具發之。", "text_normalized": "兩載之閒一火，皆立而待鼓而然火，即具發之。", "canonical_ref": "44.34", "notes": ""}
{"segment_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3__seg-0035", "section_id": "mozi-044-defense-against-attack-with-ladders", "source_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 35, "text_original": "適人除火而復攻，縣火復下，適人甚病，故引兵而去。", "text_normalized": "適人除火而復攻，縣火復下，適人甚病，故引兵而去。", "canonical_ref": "44.35", "notes": ""}
{"segment_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3__seg-0036", "section_id": "mozi-044-defense-against-attack-with-ladders", "source_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 36, "text_original": "則令我死士左右出穴門擊潰師，令賁士、主將皆聽城鼓之音而出，又聽城鼓之音而入。", "text_normalized": "則令我死士左右出穴門擊潰師，令賁士、主將皆聽城鼓之音而出，又聽城鼓之音而入。", "canonical_ref": "44.36", "notes": ""}
{"segment_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3__seg-0037", "section_id": "mozi-044-defense-against-attack-with-ladders", "source_id": "mozi-044-defense-against-attack-with-ladders__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 37, "text_original": "因素出兵施伏，夜半城上四面鼓噪，適人必或，有此必破軍殺將。", "text_normalized": "因素出兵施伏，夜半城上四面鼓噪，適人必或，有此必破軍殺將。", "canonical_ref": "44.37", "notes": ""}
