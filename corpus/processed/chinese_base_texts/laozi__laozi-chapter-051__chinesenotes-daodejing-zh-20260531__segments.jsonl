{"segment_id": "laozi-chapter-051__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-051", "source_id": "laozi-chapter-051__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 51.1", "sort_key": "051.001", "text_original": "道生之，", "text_normalized": "道生之，", "notes": ""}
{"segment_id": "laozi-chapter-051__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-051", "source_id": "laozi-chapter-051__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 51.2", "sort_key": "051.002", "text_original": "德畜之，", "text_normalized": "德畜之，", "notes": ""}
{"segment_id": "laozi-chapter-051__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-051", "source_id": "laozi-chapter-051__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 51.3", "sort_key": "051.003", "text_original": "物形之，", "text_normalized": "物形之，", "notes": ""}
{"segment_id": "laozi-chapter-051__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-051", "source_id": "laozi-chapter-051__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 51.4", "sort_key": "051.004", "text_original": "勢成之。", "text_normalized": "勢成之。", "notes": ""}
{"segment_id": "laozi-chapter-051__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-051", "source_id": "laozi-chapter-051__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 51.5", "sort_key": "051.005", "text_original": "是以萬物莫不尊道而貴德。", "text_normalized": "是以萬物莫不尊道而貴德。", "notes": ""}
{"segment_id": "laozi-chapter-051__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-051", "source_id": "laozi-chapter-051__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 51.6", "sort_key": "051.006", "text_original": "道之尊，", "text_normalized": "道之尊，", "notes": ""}
{"segment_id": "laozi-chapter-051__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-051", "source_id": "laozi-chapter-051__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 51.7", "sort_key": "051.007", "text_original": "德之貴，", "text_normalized": "德之貴，", "notes": ""}
{"segment_id": "laozi-chapter-051__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-051", "source_id": "laozi-chapter-051__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 51.8", "sort_key": "051.008", "text_original": "夫莫之命而常自然。", "text_normalized": "夫莫之命而常自然。", "notes": ""}
{"segment_id": "laozi-chapter-051__chinesenotes-daodejing-zh-20260531__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-051", "source_id": "laozi-chapter-051__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 51.9", "sort_key": "051.009", "text_original": "故道生之，", "text_normalized": "故道生之，", "notes": ""}
{"segment_id": "laozi-chapter-051__chinesenotes-daodejing-zh-20260531__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-051", "source_id": "laozi-chapter-051__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 51.10", "sort_key": "051.010", "text_original": "德畜之。", "text_normalized": "德畜之。", "notes": ""}
{"segment_id": "laozi-chapter-051__chinesenotes-daodejing-zh-20260531__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-051", "source_id": "laozi-chapter-051__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 51.11", "sort_key": "051.011", "text_original": "長之育之，", "text_normalized": "長之育之，", "notes": ""}
{"segment_id": "laozi-chapter-051__chinesenotes-daodejing-zh-20260531__seg-012", "work_id": "laozi", "section_id": "laozi-chapter-051", "source_id": "laozi-chapter-051__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 12, "canonical_ref": "老子 51.12", "sort_key": "051.012", "text_original": "亭之毒之，", "text_normalized": "亭之毒之，", "notes": ""}
{"segment_id": "laozi-chapter-051__chinesenotes-daodejing-zh-20260531__seg-013", "work_id": "laozi", "section_id": "laozi-chapter-051", "source_id": "laozi-chapter-051__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 13, "canonical_ref": "老子 51.13", "sort_key": "051.013", "text_original": "蓋之覆之。", "text_normalized": "蓋之覆之。", "notes": ""}
{"segment_id": "laozi-chapter-051__chinesenotes-daodejing-zh-20260531__seg-014", "work_id": "laozi", "section_id": "laozi-chapter-051", "source_id": "laozi-chapter-051__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 14, "canonical_ref": "老子 51.14", "sort_key": "051.014", "text_original": "生而不有，", "text_normalized": "生而不有，", "notes": ""}
{"segment_id": "laozi-chapter-051__chinesenotes-daodejing-zh-20260531__seg-015", "work_id": "laozi", "section_id": "laozi-chapter-051", "source_id": "laozi-chapter-051__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 15, "canonical_ref": "老子 51.15", "sort_key": "051.015", "text_original": "為而不恃，", "text_normalized": "為而不恃，", "notes": ""}
{"segment_id": "laozi-chapter-051__chinesenotes-daodejing-zh-20260531__seg-016", "work_id": "laozi", "section_id": "laozi-chapter-051", "source_id": "laozi-chapter-051__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 16, "canonical_ref": "老子 51.16", "sort_key": "051.016", "text_original": "長而不宰。", "text_normalized": "長而不宰。", "notes": ""}
{"segment_id": "laozi-chapter-051__chinesenotes-daodejing-zh-20260531__seg-017", "work_id": "laozi", "section_id": "laozi-chapter-051", "source_id": "laozi-chapter-051__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 17, "canonical_ref": "老子 51.17", "sort_key": "051.017", "text_original": "是謂玄德。", "text_normalized": "是謂玄德。", "notes": ""}
