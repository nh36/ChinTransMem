{"segment_id": "laozi-chapter-058__chinesenotes-daodejing-zh-20260531__seg-013", "work_id": "laozi", "section_id": "laozi-chapter-058", "source_id": "laozi-chapter-058__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 13, "canonical_ref": "老子 58.13", "sort_key": "058.013", "text_original": "是以聖人方而不割，", "text_normalized": "是以聖人方而不割，", "notes": ""}
{"segment_id": "laozi-chapter-058__chinesenotes-daodejing-zh-20260531__seg-014", "work_id": "laozi", "section_id": "laozi-chapter-058", "source_id": "laozi-chapter-058__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 14, "canonical_ref": "老子 58.14", "sort_key": "058.014", "text_original": "廉而不劌，", "text_normalized": "廉而不劌，", "notes": ""}
{"segment_id": "laozi-chapter-058__chinesenotes-daodejing-zh-20260531__seg-015", "work_id": "laozi", "section_id": "laozi-chapter-058", "source_id": "laozi-chapter-058__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 15, "canonical_ref": "老子 58.15", "sort_key": "058.015", "text_original": "直而不肆，", "text_normalized": "直而不肆，", "notes": ""}
