{"segment_id": "laozi-chapter-015__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-015", "source_id": "laozi-chapter-015__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 15.1", "sort_key": "015.001", "text_original": "古之善為士者，", "text_normalized": "古之善為士者，", "notes": ""}
{"segment_id": "laozi-chapter-015__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-015", "source_id": "laozi-chapter-015__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 15.2", "sort_key": "015.002", "text_original": "微妙玄通，", "text_normalized": "微妙玄通，", "notes": ""}
{"segment_id": "laozi-chapter-015__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-015", "source_id": "laozi-chapter-015__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 15.3", "sort_key": "015.003", "text_original": "深不可識。", "text_normalized": "深不可識。", "notes": ""}
{"segment_id": "laozi-chapter-015__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-015", "source_id": "laozi-chapter-015__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 15.4", "sort_key": "015.004", "text_original": "夫唯不可識，", "text_normalized": "夫唯不可識，", "notes": ""}
{"segment_id": "laozi-chapter-015__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-015", "source_id": "laozi-chapter-015__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 15.5", "sort_key": "015.005", "text_original": "故強為之容。", "text_normalized": "故強為之容。", "notes": ""}
{"segment_id": "laozi-chapter-015__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-015", "source_id": "laozi-chapter-015__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 15.6", "sort_key": "015.006", "text_original": "豫焉若冬涉川，", "text_normalized": "豫焉若冬涉川，", "notes": ""}
{"segment_id": "laozi-chapter-015__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-015", "source_id": "laozi-chapter-015__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 15.7", "sort_key": "015.007", "text_original": "猶兮若畏四鄰，", "text_normalized": "猶兮若畏四鄰，", "notes": ""}
{"segment_id": "laozi-chapter-015__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-015", "source_id": "laozi-chapter-015__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 15.8", "sort_key": "015.008", "text_original": "儼兮其若容，", "text_normalized": "儼兮其若容，", "notes": ""}
{"segment_id": "laozi-chapter-015__chinesenotes-daodejing-zh-20260531__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-015", "source_id": "laozi-chapter-015__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 15.9", "sort_key": "015.009", "text_original": "渙兮若冰之將釋，", "text_normalized": "渙兮若冰之將釋，", "notes": ""}
{"segment_id": "laozi-chapter-015__chinesenotes-daodejing-zh-20260531__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-015", "source_id": "laozi-chapter-015__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 15.10", "sort_key": "015.010", "text_original": "敦兮其若樸，", "text_normalized": "敦兮其若樸，", "notes": ""}
{"segment_id": "laozi-chapter-015__chinesenotes-daodejing-zh-20260531__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-015", "source_id": "laozi-chapter-015__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 15.11", "sort_key": "015.011", "text_original": "曠兮其若谷，", "text_normalized": "曠兮其若谷，", "notes": ""}
{"segment_id": "laozi-chapter-015__chinesenotes-daodejing-zh-20260531__seg-012", "work_id": "laozi", "section_id": "laozi-chapter-015", "source_id": "laozi-chapter-015__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 12, "canonical_ref": "老子 15.12", "sort_key": "015.012", "text_original": "混兮其若濁。", "text_normalized": "混兮其若濁。", "notes": ""}
{"segment_id": "laozi-chapter-015__chinesenotes-daodejing-zh-20260531__seg-013", "work_id": "laozi", "section_id": "laozi-chapter-015", "source_id": "laozi-chapter-015__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 13, "canonical_ref": "老子 15.13", "sort_key": "015.013", "text_original": "孰能濁以靜之徐清？", "text_normalized": "孰能濁以靜之徐清？", "notes": ""}
{"segment_id": "laozi-chapter-015__chinesenotes-daodejing-zh-20260531__seg-014", "work_id": "laozi", "section_id": "laozi-chapter-015", "source_id": "laozi-chapter-015__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 14, "canonical_ref": "老子 15.14", "sort_key": "015.014", "text_original": "孰能安以久動之徐生？", "text_normalized": "孰能安以久動之徐生？", "notes": ""}
{"segment_id": "laozi-chapter-015__chinesenotes-daodejing-zh-20260531__seg-015", "work_id": "laozi", "section_id": "laozi-chapter-015", "source_id": "laozi-chapter-015__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 15, "canonical_ref": "老子 15.15", "sort_key": "015.015", "text_original": "保此道者不欲盈，", "text_normalized": "保此道者不欲盈，", "notes": ""}
{"segment_id": "laozi-chapter-015__chinesenotes-daodejing-zh-20260531__seg-016", "work_id": "laozi", "section_id": "laozi-chapter-015", "source_id": "laozi-chapter-015__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 16, "canonical_ref": "老子 15.16", "sort_key": "015.016", "text_original": "夫唯不盈，", "text_normalized": "夫唯不盈，", "notes": ""}
{"segment_id": "laozi-chapter-015__chinesenotes-daodejing-zh-20260531__seg-017", "work_id": "laozi", "section_id": "laozi-chapter-015", "source_id": "laozi-chapter-015__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 17, "canonical_ref": "老子 15.17", "sort_key": "015.017", "text_original": "故能蔽不新成。", "text_normalized": "故能蔽不新成。", "notes": ""}
