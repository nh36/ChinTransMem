{"segment_id": "laozi-chapter-063__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-063", "source_id": "laozi-chapter-063__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 63.1", "sort_key": "063.001", "text_original": "為無為，", "text_normalized": "為無為，", "notes": ""}
{"segment_id": "laozi-chapter-063__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-063", "source_id": "laozi-chapter-063__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 63.2", "sort_key": "063.002", "text_original": "事無事，", "text_normalized": "事無事，", "notes": ""}
{"segment_id": "laozi-chapter-063__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-063", "source_id": "laozi-chapter-063__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 63.3", "sort_key": "063.003", "text_original": "味無味。", "text_normalized": "味無味。", "notes": ""}
{"segment_id": "laozi-chapter-063__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-063", "source_id": "laozi-chapter-063__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 63.4", "sort_key": "063.004", "text_original": "大小多少，", "text_normalized": "大小多少，", "notes": ""}
{"segment_id": "laozi-chapter-063__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-063", "source_id": "laozi-chapter-063__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 63.5", "sort_key": "063.005", "text_original": "報怨以德。", "text_normalized": "報怨以德。", "notes": ""}
{"segment_id": "laozi-chapter-063__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-063", "source_id": "laozi-chapter-063__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 63.6", "sort_key": "063.006", "text_original": "圖難於其易，", "text_normalized": "圖難於其易，", "notes": ""}
{"segment_id": "laozi-chapter-063__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-063", "source_id": "laozi-chapter-063__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 63.7", "sort_key": "063.007", "text_original": "為大於其細；", "text_normalized": "為大於其細；", "notes": ""}
{"segment_id": "laozi-chapter-063__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-063", "source_id": "laozi-chapter-063__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 63.8", "sort_key": "063.008", "text_original": "天下難事必作於易，", "text_normalized": "天下難事必作於易，", "notes": ""}
{"segment_id": "laozi-chapter-063__chinesenotes-daodejing-zh-20260531__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-063", "source_id": "laozi-chapter-063__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 63.9", "sort_key": "063.009", "text_original": "天下大事必作於細。", "text_normalized": "天下大事必作於細。", "notes": ""}
{"segment_id": "laozi-chapter-063__chinesenotes-daodejing-zh-20260531__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-063", "source_id": "laozi-chapter-063__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 63.10", "sort_key": "063.010", "text_original": "是以聖人終不為大，", "text_normalized": "是以聖人終不為大，", "notes": ""}
{"segment_id": "laozi-chapter-063__chinesenotes-daodejing-zh-20260531__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-063", "source_id": "laozi-chapter-063__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 63.11", "sort_key": "063.011", "text_original": "故能成其大。", "text_normalized": "故能成其大。", "notes": ""}
{"segment_id": "laozi-chapter-063__chinesenotes-daodejing-zh-20260531__seg-012", "work_id": "laozi", "section_id": "laozi-chapter-063", "source_id": "laozi-chapter-063__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 12, "canonical_ref": "老子 63.12", "sort_key": "063.012", "text_original": "夫輕諾必寡信，", "text_normalized": "夫輕諾必寡信，", "notes": ""}
{"segment_id": "laozi-chapter-063__chinesenotes-daodejing-zh-20260531__seg-013", "work_id": "laozi", "section_id": "laozi-chapter-063", "source_id": "laozi-chapter-063__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 13, "canonical_ref": "老子 63.13", "sort_key": "063.013", "text_original": "多易必多難。", "text_normalized": "多易必多難。", "notes": ""}
{"segment_id": "laozi-chapter-063__chinesenotes-daodejing-zh-20260531__seg-014", "work_id": "laozi", "section_id": "laozi-chapter-063", "source_id": "laozi-chapter-063__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 14, "canonical_ref": "老子 63.14", "sort_key": "063.014", "text_original": "是以聖人猶難之，", "text_normalized": "是以聖人猶難之，", "notes": ""}
{"segment_id": "laozi-chapter-063__chinesenotes-daodejing-zh-20260531__seg-015", "work_id": "laozi", "section_id": "laozi-chapter-063", "source_id": "laozi-chapter-063__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 15, "canonical_ref": "老子 63.15", "sort_key": "063.015", "text_original": "故終無難矣", "text_normalized": "故終無難矣", "notes": ""}
