{"segment_id": "shijing__guofeng-zhaonan-011__001__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-zhaonan-011", "source_id": "guofeng-zhaonan-011__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 1, "canonical_ref": "詩經·國風·召南·011.1", "text_original": "江有汜，之子歸，不我以，不我以，其後也悔。", "text_normalized": "江有汜，之子歸，不我以，不我以，其後也悔。", "notes": "江有汜 Chinese stanza 1."}
{"segment_id": "shijing__guofeng-zhaonan-011__002__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-zhaonan-011", "source_id": "guofeng-zhaonan-011__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 2, "canonical_ref": "詩經·國風·召南·011.2", "text_original": "江有渚，之子歸，不我與，不我與，其後也處。", "text_normalized": "江有渚，之子歸，不我與，不我與，其後也處。", "notes": "江有汜 Chinese stanza 2."}
{"segment_id": "shijing__guofeng-zhaonan-011__003__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-zhaonan-011", "source_id": "guofeng-zhaonan-011__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 3, "canonical_ref": "詩經·國風·召南·011.3", "text_original": "江有沱，之子歸，不我過，不我過，其嘯也歌。", "text_normalized": "江有沱，之子歸，不我過，不我過，其嘯也歌。", "notes": "江有汜 Chinese stanza 3."}
