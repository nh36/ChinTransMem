{"segment_id": "shijing__guofeng-beifeng-006__001__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-beifeng-006", "source_id": "guofeng-beifeng-006__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 1, "canonical_ref": "詩經·國風·邶風·006.1", "text_original": "擊鼓其鏜，踴躍用兵，土國城漕，我獨南行。", "text_normalized": "擊鼓其鏜，踴躍用兵，土國城漕，我獨南行。", "notes": "擊鼓 Chinese stanza 1."}
{"segment_id": "shijing__guofeng-beifeng-006__002__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-beifeng-006", "source_id": "guofeng-beifeng-006__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 2, "canonical_ref": "詩經·國風·邶風·006.2", "text_original": "從孫子仲，平陳與宋，不我以歸，憂心有忡。", "text_normalized": "從孫子仲，平陳與宋，不我以歸，憂心有忡。", "notes": "擊鼓 Chinese stanza 2."}
{"segment_id": "shijing__guofeng-beifeng-006__003__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-beifeng-006", "source_id": "guofeng-beifeng-006__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 3, "canonical_ref": "詩經·國風·邶風·006.3", "text_original": "爰居爰處，爰喪其馬，于以求之，于林之下。", "text_normalized": "爰居爰處，爰喪其馬，于以求之，于林之下。", "notes": "擊鼓 Chinese stanza 3."}
{"segment_id": "shijing__guofeng-beifeng-006__004__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-beifeng-006", "source_id": "guofeng-beifeng-006__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 4, "canonical_ref": "詩經·國風·邶風·006.4", "text_original": "死生契闊，與子成說，執子之手，與子偕老。", "text_normalized": "死生契闊，與子成說，執子之手，與子偕老。", "notes": "擊鼓 Chinese stanza 4."}
{"segment_id": "shijing__guofeng-beifeng-006__005__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-beifeng-006", "source_id": "guofeng-beifeng-006__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 5, "canonical_ref": "詩經·國風·邶風·006.5", "text_original": "于嗟闊兮，不我活兮，于嗟洵兮，不我信兮。", "text_normalized": "于嗟闊兮，不我活兮，于嗟洵兮，不我信兮。", "notes": "擊鼓 Chinese stanza 5."}
