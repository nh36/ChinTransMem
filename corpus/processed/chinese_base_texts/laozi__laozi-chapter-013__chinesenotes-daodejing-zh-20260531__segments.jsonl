{"segment_id": "laozi-chapter-013__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-013", "source_id": "laozi-chapter-013__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 13.1", "sort_key": "013.001", "text_original": "寵辱若驚，", "text_normalized": "寵辱若驚，", "notes": ""}
{"segment_id": "laozi-chapter-013__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-013", "source_id": "laozi-chapter-013__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 13.2", "sort_key": "013.002", "text_original": "貴大患若身。", "text_normalized": "貴大患若身。", "notes": ""}
{"segment_id": "laozi-chapter-013__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-013", "source_id": "laozi-chapter-013__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 13.3", "sort_key": "013.003", "text_original": "何謂寵辱若驚？", "text_normalized": "何謂寵辱若驚？", "notes": ""}
{"segment_id": "laozi-chapter-013__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-013", "source_id": "laozi-chapter-013__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 13.4", "sort_key": "013.004", "text_original": "寵為下，", "text_normalized": "寵為下，", "notes": ""}
{"segment_id": "laozi-chapter-013__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-013", "source_id": "laozi-chapter-013__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 13.5", "sort_key": "013.005", "text_original": "得之若驚，", "text_normalized": "得之若驚，", "notes": ""}
{"segment_id": "laozi-chapter-013__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-013", "source_id": "laozi-chapter-013__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 13.6", "sort_key": "013.006", "text_original": "失之若驚，", "text_normalized": "失之若驚，", "notes": ""}
{"segment_id": "laozi-chapter-013__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-013", "source_id": "laozi-chapter-013__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 13.7", "sort_key": "013.007", "text_original": "是謂寵辱若驚。", "text_normalized": "是謂寵辱若驚。", "notes": ""}
{"segment_id": "laozi-chapter-013__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-013", "source_id": "laozi-chapter-013__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 13.8", "sort_key": "013.008", "text_original": "何謂貴大患若身？", "text_normalized": "何謂貴大患若身？", "notes": ""}
{"segment_id": "laozi-chapter-013__chinesenotes-daodejing-zh-20260531__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-013", "source_id": "laozi-chapter-013__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 13.9", "sort_key": "013.009", "text_original": "吾所以有大患者，", "text_normalized": "吾所以有大患者，", "notes": ""}
{"segment_id": "laozi-chapter-013__chinesenotes-daodejing-zh-20260531__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-013", "source_id": "laozi-chapter-013__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 13.10", "sort_key": "013.010", "text_original": "為吾有身，", "text_normalized": "為吾有身，", "notes": ""}
{"segment_id": "laozi-chapter-013__chinesenotes-daodejing-zh-20260531__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-013", "source_id": "laozi-chapter-013__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 13.11", "sort_key": "013.011", "text_original": "及吾無身，", "text_normalized": "及吾無身，", "notes": ""}
{"segment_id": "laozi-chapter-013__chinesenotes-daodejing-zh-20260531__seg-012", "work_id": "laozi", "section_id": "laozi-chapter-013", "source_id": "laozi-chapter-013__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 12, "canonical_ref": "老子 13.12", "sort_key": "013.012", "text_original": "吾有何患？", "text_normalized": "吾有何患？", "notes": ""}
{"segment_id": "laozi-chapter-013__chinesenotes-daodejing-zh-20260531__seg-013", "work_id": "laozi", "section_id": "laozi-chapter-013", "source_id": "laozi-chapter-013__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 13, "canonical_ref": "老子 13.13", "sort_key": "013.013", "text_original": "故貴以身為天下，", "text_normalized": "故貴以身為天下，", "notes": ""}
{"segment_id": "laozi-chapter-013__chinesenotes-daodejing-zh-20260531__seg-014", "work_id": "laozi", "section_id": "laozi-chapter-013", "source_id": "laozi-chapter-013__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 14, "canonical_ref": "老子 13.14", "sort_key": "013.014", "text_original": "若可寄天下；", "text_normalized": "若可寄天下；", "notes": ""}
{"segment_id": "laozi-chapter-013__chinesenotes-daodejing-zh-20260531__seg-015", "work_id": "laozi", "section_id": "laozi-chapter-013", "source_id": "laozi-chapter-013__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 15, "canonical_ref": "老子 13.15", "sort_key": "013.015", "text_original": "愛以身為天下，", "text_normalized": "愛以身為天下，", "notes": ""}
{"segment_id": "laozi-chapter-013__chinesenotes-daodejing-zh-20260531__seg-016", "work_id": "laozi", "section_id": "laozi-chapter-013", "source_id": "laozi-chapter-013__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 16, "canonical_ref": "老子 13.16", "sort_key": "013.016", "text_original": "若可託天下。", "text_normalized": "若可託天下。", "notes": ""}
