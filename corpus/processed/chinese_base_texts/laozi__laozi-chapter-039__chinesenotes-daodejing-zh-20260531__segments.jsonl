{"segment_id": "laozi-chapter-039__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-039", "source_id": "laozi-chapter-039__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 39.1", "sort_key": "039.001", "text_original": "昔之得一者，", "text_normalized": "昔之得一者，", "notes": ""}
{"segment_id": "laozi-chapter-039__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-039", "source_id": "laozi-chapter-039__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 39.2", "sort_key": "039.002", "text_original": "天得一以清，", "text_normalized": "天得一以清，", "notes": ""}
{"segment_id": "laozi-chapter-039__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-039", "source_id": "laozi-chapter-039__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 39.3", "sort_key": "039.003", "text_original": "地得一以寧，", "text_normalized": "地得一以寧，", "notes": ""}
{"segment_id": "laozi-chapter-039__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-039", "source_id": "laozi-chapter-039__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 39.4", "sort_key": "039.004", "text_original": "神得一以靈，", "text_normalized": "神得一以靈，", "notes": ""}
{"segment_id": "laozi-chapter-039__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-039", "source_id": "laozi-chapter-039__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 39.5", "sort_key": "039.005", "text_original": "谷得一以盈，", "text_normalized": "谷得一以盈，", "notes": ""}
{"segment_id": "laozi-chapter-039__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-039", "source_id": "laozi-chapter-039__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 39.6", "sort_key": "039.006", "text_original": "萬物得一以生，", "text_normalized": "萬物得一以生，", "notes": ""}
{"segment_id": "laozi-chapter-039__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-039", "source_id": "laozi-chapter-039__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 39.7", "sort_key": "039.007", "text_original": "侯王得一以為天下貞。", "text_normalized": "侯王得一以為天下貞。", "notes": ""}
{"segment_id": "laozi-chapter-039__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-039", "source_id": "laozi-chapter-039__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 39.8", "sort_key": "039.008", "text_original": "其致之，", "text_normalized": "其致之，", "notes": ""}
{"segment_id": "laozi-chapter-039__chinesenotes-daodejing-zh-20260531__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-039", "source_id": "laozi-chapter-039__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 39.9", "sort_key": "039.009", "text_original": "天無以清將恐裂，", "text_normalized": "天無以清將恐裂，", "notes": ""}
{"segment_id": "laozi-chapter-039__chinesenotes-daodejing-zh-20260531__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-039", "source_id": "laozi-chapter-039__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 39.10", "sort_key": "039.010", "text_original": "地無以寧將恐發，", "text_normalized": "地無以寧將恐發，", "notes": ""}
{"segment_id": "laozi-chapter-039__chinesenotes-daodejing-zh-20260531__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-039", "source_id": "laozi-chapter-039__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 39.11", "sort_key": "039.011", "text_original": "神無以靈將恐歇，", "text_normalized": "神無以靈將恐歇，", "notes": ""}
{"segment_id": "laozi-chapter-039__chinesenotes-daodejing-zh-20260531__seg-012", "work_id": "laozi", "section_id": "laozi-chapter-039", "source_id": "laozi-chapter-039__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 12, "canonical_ref": "老子 39.12", "sort_key": "039.012", "text_original": "谷無以盈將恐竭，", "text_normalized": "谷無以盈將恐竭，", "notes": ""}
{"segment_id": "laozi-chapter-039__chinesenotes-daodejing-zh-20260531__seg-013", "work_id": "laozi", "section_id": "laozi-chapter-039", "source_id": "laozi-chapter-039__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 13, "canonical_ref": "老子 39.13", "sort_key": "039.013", "text_original": "萬物無以生將恐滅，", "text_normalized": "萬物無以生將恐滅，", "notes": ""}
{"segment_id": "laozi-chapter-039__chinesenotes-daodejing-zh-20260531__seg-014", "work_id": "laozi", "section_id": "laozi-chapter-039", "source_id": "laozi-chapter-039__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 14, "canonical_ref": "老子 39.14", "sort_key": "039.014", "text_original": "侯王無以貴高將恐蹶。", "text_normalized": "侯王無以貴高將恐蹶。", "notes": ""}
{"segment_id": "laozi-chapter-039__chinesenotes-daodejing-zh-20260531__seg-015", "work_id": "laozi", "section_id": "laozi-chapter-039", "source_id": "laozi-chapter-039__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 15, "canonical_ref": "老子 39.15", "sort_key": "039.015", "text_original": "故貴以賤為本，", "text_normalized": "故貴以賤為本，", "notes": ""}
{"segment_id": "laozi-chapter-039__chinesenotes-daodejing-zh-20260531__seg-016", "work_id": "laozi", "section_id": "laozi-chapter-039", "source_id": "laozi-chapter-039__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 16, "canonical_ref": "老子 39.16", "sort_key": "039.016", "text_original": "高以下為基。", "text_normalized": "高以下為基。", "notes": ""}
{"segment_id": "laozi-chapter-039__chinesenotes-daodejing-zh-20260531__seg-017", "work_id": "laozi", "section_id": "laozi-chapter-039", "source_id": "laozi-chapter-039__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 17, "canonical_ref": "老子 39.17", "sort_key": "039.017", "text_original": "是以侯王自稱孤﹑寡﹑不穀。", "text_normalized": "是以侯王自稱孤﹑寡﹑不穀。", "notes": ""}
{"segment_id": "laozi-chapter-039__chinesenotes-daodejing-zh-20260531__seg-018", "work_id": "laozi", "section_id": "laozi-chapter-039", "source_id": "laozi-chapter-039__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 18, "canonical_ref": "老子 39.18", "sort_key": "039.018", "text_original": "此非以賤為本邪？", "text_normalized": "此非以賤為本邪？", "notes": ""}
{"segment_id": "laozi-chapter-039__chinesenotes-daodejing-zh-20260531__seg-019", "work_id": "laozi", "section_id": "laozi-chapter-039", "source_id": "laozi-chapter-039__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 19, "canonical_ref": "老子 39.19", "sort_key": "039.019", "text_original": "非乎？", "text_normalized": "非乎？", "notes": ""}
{"segment_id": "laozi-chapter-039__chinesenotes-daodejing-zh-20260531__seg-020", "work_id": "laozi", "section_id": "laozi-chapter-039", "source_id": "laozi-chapter-039__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 20, "canonical_ref": "老子 39.20", "sort_key": "039.020", "text_original": "故致數輿無輿，", "text_normalized": "故致數輿無輿，", "notes": ""}
{"segment_id": "laozi-chapter-039__chinesenotes-daodejing-zh-20260531__seg-021", "work_id": "laozi", "section_id": "laozi-chapter-039", "source_id": "laozi-chapter-039__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 21, "canonical_ref": "老子 39.21", "sort_key": "039.021", "text_original": "不欲琭琭如玉，", "text_normalized": "不欲琭琭如玉，", "notes": ""}
{"segment_id": "laozi-chapter-039__chinesenotes-daodejing-zh-20260531__seg-022", "work_id": "laozi", "section_id": "laozi-chapter-039", "source_id": "laozi-chapter-039__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 22, "canonical_ref": "老子 39.22", "sort_key": "039.022", "text_original": "珞珞如石。", "text_normalized": "珞珞如石。", "notes": ""}
