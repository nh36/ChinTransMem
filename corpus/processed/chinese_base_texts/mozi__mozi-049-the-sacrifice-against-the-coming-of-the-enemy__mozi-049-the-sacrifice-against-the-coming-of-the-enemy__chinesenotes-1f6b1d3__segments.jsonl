{"segment_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3__seg-0001", "section_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy", "source_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 1, "text_original": "敵以東方來，迎之東壇，壇高八尺，堂密八。", "text_normalized": "敵以東方來，迎之東壇，壇高八尺，堂密八。", "canonical_ref": "49.1", "notes": ""}
{"segment_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3__seg-0002", "section_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy", "source_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 2, "text_original": "年八十者八人，主祭青旗。", "text_normalized": "年八十者八人，主祭青旗。", "canonical_ref": "49.2", "notes": ""}
{"segment_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3__seg-0003", "section_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy", "source_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 3, "text_original": "青神長八尺者八，弩八，八發而止。", "text_normalized": "青神長八尺者八，弩八，八發而止。", "canonical_ref": "49.3", "notes": ""}
{"segment_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3__seg-0004", "section_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy", "source_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 4, "text_original": "將服必青，其牲以雞。", "text_normalized": "將服必青，其牲以雞。", "canonical_ref": "49.4", "notes": ""}
{"segment_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3__seg-0005", "section_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy", "source_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 5, "text_original": "敵以南方來，迎之南壇，壇高七尺，堂密七，年七十者七人，主祭赤旗，赤神長七尺者七。", "text_normalized": "敵以南方來，迎之南壇，壇高七尺，堂密七，年七十者七人，主祭赤旗，赤神長七尺者七。", "canonical_ref": "49.5", "notes": ""}
{"segment_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3__seg-0006", "section_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy", "source_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 6, "text_original": "弩七，七發而止。", "text_normalized": "弩七，七發而止。", "canonical_ref": "49.6", "notes": ""}
{"segment_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3__seg-0007", "section_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy", "source_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 7, "text_original": "將服必赤，其牲以狗。", "text_normalized": "將服必赤，其牲以狗。", "canonical_ref": "49.7", "notes": ""}
{"segment_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3__seg-0008", "section_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy", "source_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 8, "text_original": "敵以西方來，迎之西壇，壇高九尺，堂密九。", "text_normalized": "敵以西方來，迎之西壇，壇高九尺，堂密九。", "canonical_ref": "49.8", "notes": ""}
{"segment_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3__seg-0009", "section_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy", "source_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 9, "text_original": "年九十者九人，主祭白旗。", "text_normalized": "年九十者九人，主祭白旗。", "canonical_ref": "49.9", "notes": ""}
{"segment_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3__seg-0010", "section_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy", "source_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 10, "text_original": "素神長九尺者九，弩九，九發而止。", "text_normalized": "素神長九尺者九，弩九，九發而止。", "canonical_ref": "49.10", "notes": ""}
{"segment_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3__seg-0011", "section_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy", "source_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 11, "text_original": "將服必白，其牲以羊。", "text_normalized": "將服必白，其牲以羊。", "canonical_ref": "49.11", "notes": ""}
{"segment_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3__seg-0012", "section_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy", "source_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 12, "text_original": "敵以北方來，迎之北壇，壇高六尺，堂密六。", "text_normalized": "敵以北方來，迎之北壇，壇高六尺，堂密六。", "canonical_ref": "49.12", "notes": ""}
{"segment_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3__seg-0013", "section_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy", "source_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 13, "text_original": "年六十者六人主祭黑旗。", "text_normalized": "年六十者六人主祭黑旗。", "canonical_ref": "49.13", "notes": ""}
{"segment_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3__seg-0014", "section_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy", "source_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 14, "text_original": "黑神長六尺者六，弩六，六發而止。", "text_normalized": "黑神長六尺者六，弩六，六發而止。", "canonical_ref": "49.14", "notes": ""}
{"segment_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3__seg-0015", "section_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy", "source_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 15, "text_original": "將服必黑，其牲以彘。", "text_normalized": "將服必黑，其牲以彘。", "canonical_ref": "49.15", "notes": ""}
{"segment_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3__seg-0016", "section_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy", "source_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 16, "text_original": "從外宅諸名大祠，靈巫或禱焉，給禱牲。", "text_normalized": "從外宅諸名大祠，靈巫或禱焉，給禱牲。", "canonical_ref": "49.16", "notes": ""}
{"segment_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3__seg-0017", "section_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy", "source_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 17, "text_original": "凡望氣，有大將氣，有小將氣，有往氣，有來氣，有敗氣，能得明此者可知成敗、吉凶。", "text_normalized": "凡望氣，有大將氣，有小將氣，有往氣，有來氣，有敗氣，能得明此者可知成敗、吉凶。", "canonical_ref": "49.17", "notes": ""}
{"segment_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3__seg-0018", "section_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy", "source_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 18, "text_original": "舉巫、醫、卜有所，長具藥，宮之，善為舍。", "text_normalized": "舉巫、醫、卜有所，長具藥，宮之，善為舍。", "canonical_ref": "49.18", "notes": ""}
{"segment_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3__seg-0019", "section_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy", "source_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 19, "text_original": "巫必近公社，必敬神之。", "text_normalized": "巫必近公社，必敬神之。", "canonical_ref": "49.19", "notes": ""}
{"segment_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3__seg-0020", "section_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy", "source_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 20, "text_original": "巫卜以請守，守獨智巫卜望氣之請而已。", "text_normalized": "巫卜以請守，守獨智巫卜望氣之請而已。", "canonical_ref": "49.20", "notes": ""}
{"segment_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3__seg-0021", "section_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy", "source_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 21, "text_original": "其出入為流言，驚駭恐吏民，謹微察之，斷，罪不赦。", "text_normalized": "其出入為流言，驚駭恐吏民，謹微察之，斷，罪不赦。", "canonical_ref": "49.21", "notes": ""}
{"segment_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3__seg-0022", "section_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy", "source_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 22, "text_original": "望氣舍近守官。", "text_normalized": "望氣舍近守官。", "canonical_ref": "49.22", "notes": ""}
{"segment_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3__seg-0023", "section_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy", "source_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 23, "text_original": "牧賢大夫及有方技者若工，弟之。", "text_normalized": "牧賢大夫及有方技者若工，弟之。", "canonical_ref": "49.23", "notes": ""}
{"segment_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3__seg-0024", "section_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy", "source_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 24, "text_original": "舉屠、酤者置廚給事，弟之。", "text_normalized": "舉屠、酤者置廚給事，弟之。", "canonical_ref": "49.24", "notes": ""}
{"segment_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3__seg-0025", "section_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy", "source_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 25, "text_original": "凡守城之法，縣師受事，出葆，循溝防，築薦通塗，脩城。", "text_normalized": "凡守城之法，縣師受事，出葆，循溝防，築薦通塗，脩城。", "canonical_ref": "49.25", "notes": ""}
{"segment_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3__seg-0026", "section_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy", "source_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 26, "text_original": "百官共財，百工即事，司馬視城脩卒伍。", "text_normalized": "百官共財，百工即事，司馬視城脩卒伍。", "canonical_ref": "49.26", "notes": ""}
{"segment_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3__seg-0027", "section_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy", "source_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 27, "text_original": "設守門，二人掌右閹，二人掌左閹，四人掌閉，百甲坐之。", "text_normalized": "設守門，二人掌右閹，二人掌左閹，四人掌閉，百甲坐之。", "canonical_ref": "49.27", "notes": ""}
{"segment_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3__seg-0028", "section_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy", "source_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 28, "text_original": "城上步一甲、一戟，其贊三人。", "text_normalized": "城上步一甲、一戟，其贊三人。", "canonical_ref": "49.28", "notes": ""}
{"segment_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3__seg-0029", "section_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy", "source_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 29, "text_original": "五步有五長，十步有什長，百步有百長，旁有大率，中有大將，皆有司吏卒長。", "text_normalized": "五步有五長，十步有什長，百步有百長，旁有大率，中有大將，皆有司吏卒長。", "canonical_ref": "49.29", "notes": ""}
{"segment_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3__seg-0030", "section_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy", "source_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 30, "text_original": "城上當階，有司守之，移中中處澤急而奏之。", "text_normalized": "城上當階，有司守之，移中中處澤急而奏之。", "canonical_ref": "49.30", "notes": ""}
{"segment_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3__seg-0031", "section_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy", "source_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 31, "text_original": "士皆有職。", "text_normalized": "士皆有職。", "canonical_ref": "49.31", "notes": ""}
{"segment_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3__seg-0032", "section_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy", "source_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 32, "text_original": "城之外，矢之所遝，壞其牆，無以為客菌。", "text_normalized": "城之外，矢之所遝，壞其牆，無以為客菌。", "canonical_ref": "49.32", "notes": ""}
{"segment_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3__seg-0033", "section_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy", "source_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 33, "text_original": "三十里之內，薪、蒸、水皆入內。", "text_normalized": "三十里之內，薪、蒸、水皆入內。", "canonical_ref": "49.33", "notes": ""}
{"segment_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3__seg-0034", "section_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy", "source_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 34, "text_original": "狗、彘、豚、雞食其肉，斂其骸以為醢腹，病者以起。", "text_normalized": "狗、彘、豚、雞食其肉，斂其骸以為醢腹，病者以起。", "canonical_ref": "49.34", "notes": ""}
{"segment_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3__seg-0035", "section_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy", "source_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 35, "text_original": "城之內薪蒸廬室，矢之所遝皆為之涂菌。", "text_normalized": "城之內薪蒸廬室，矢之所遝皆為之涂菌。", "canonical_ref": "49.35", "notes": ""}
{"segment_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3__seg-0036", "section_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy", "source_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 36, "text_original": "令命昏緯狗纂馬，掔緯。", "text_normalized": "令命昏緯狗纂馬，掔緯。", "canonical_ref": "49.36", "notes": ""}
{"segment_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3__seg-0037", "section_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy", "source_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 37, "text_original": "靜夜聞鼓聲而譟，所以閹客之氣也，所以固民之意也，故時譟則民不疾矣。", "text_normalized": "靜夜聞鼓聲而譟，所以閹客之氣也，所以固民之意也，故時譟則民不疾矣。", "canonical_ref": "49.37", "notes": ""}
{"segment_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3__seg-0038", "section_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy", "source_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 38, "text_original": "祝、史乃告於四望、山川、社稷，先於戎，乃退。", "text_normalized": "祝、史乃告於四望、山川、社稷，先於戎，乃退。", "canonical_ref": "49.38", "notes": ""}
{"segment_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3__seg-0039", "section_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy", "source_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 39, "text_original": "公素服誓于太廟，曰：", "text_normalized": "公素服誓于太廟，曰：", "canonical_ref": "49.39", "notes": ""}
{"segment_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3__seg-0040", "section_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy", "source_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 40, "text_original": "「其人為不道，不脩義詳，唯乃是王，曰：", "text_normalized": "「其人為不道，不脩義詳，唯乃是王，曰：", "canonical_ref": "49.40", "notes": ""}
{"segment_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3__seg-0041", "section_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy", "source_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 41, "text_original": "予必懷亡爾社稷，滅爾百姓。", "text_normalized": "予必懷亡爾社稷，滅爾百姓。", "canonical_ref": "49.41", "notes": ""}
{"segment_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3__seg-0042", "section_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy", "source_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 42, "text_original": "二三子夙夜自厲，以勤寡人，和心比力兼左右，各死而守。", "text_normalized": "二三子夙夜自厲，以勤寡人，和心比力兼左右，各死而守。", "canonical_ref": "49.42", "notes": ""}
{"segment_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3__seg-0043", "section_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy", "source_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 43, "text_original": "既誓，公乃退食。", "text_normalized": "既誓，公乃退食。", "canonical_ref": "49.43", "notes": ""}
{"segment_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3__seg-0044", "section_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy", "source_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 44, "text_original": "舍於中太廟之右，祝、史舍于社。", "text_normalized": "舍於中太廟之右，祝、史舍于社。", "canonical_ref": "49.44", "notes": ""}
{"segment_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3__seg-0045", "section_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy", "source_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 45, "text_original": "百官具御，乃斗鼓于門，右置旂，左置旌于隅練名。", "text_normalized": "百官具御，乃斗鼓于門，右置旂，左置旌于隅練名。", "canonical_ref": "49.45", "notes": ""}
{"segment_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3__seg-0046", "section_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy", "source_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 46, "text_original": "射參發，告勝，五兵咸備，乃下，出挨，升望我郊。", "text_normalized": "射參發，告勝，五兵咸備，乃下，出挨，升望我郊。", "canonical_ref": "49.46", "notes": ""}
{"segment_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3__seg-0047", "section_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy", "source_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 47, "text_original": "乃命鼓，俄升，役司馬射自門右，蓬矢射之，茅參發，弓弩繼之，校自門左，先以揮，木石繼之。", "text_normalized": "乃命鼓，俄升，役司馬射自門右，蓬矢射之，茅參發，弓弩繼之，校自門左，先以揮，木石繼之。", "canonical_ref": "49.47", "notes": ""}
{"segment_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3__seg-0048", "section_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy", "source_id": "mozi-049-the-sacrifice-against-the-coming-of-the-enemy__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 48, "text_original": "祝、史、宗人告社，覆之以甑。", "text_normalized": "祝、史、宗人告社，覆之以甑。", "canonical_ref": "49.48", "notes": ""}
