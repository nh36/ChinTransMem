{"segment_id": "shijing__guofeng-caofeng-002__001__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-caofeng-002", "source_id": "guofeng-caofeng-002__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 1, "canonical_ref": "詩經·國風·曹風·002.1", "text_original": "彼候人兮，何戈與祋。彼其之子，三百赤芾。", "text_normalized": "彼候人兮，何戈與祋。彼其之子，三百赤芾。", "notes": "候人 Chinese stanza 1."}
{"segment_id": "shijing__guofeng-caofeng-002__002__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-caofeng-002", "source_id": "guofeng-caofeng-002__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 2, "canonical_ref": "詩經·國風·曹風·002.2", "text_original": "維鵜在梁，不濡其翼。彼其之子，不稱其服。", "text_normalized": "維鵜在梁，不濡其翼。彼其之子，不稱其服。", "notes": "候人 Chinese stanza 2."}
{"segment_id": "shijing__guofeng-caofeng-002__003__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-caofeng-002", "source_id": "guofeng-caofeng-002__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 3, "canonical_ref": "詩經·國風·曹風·002.3", "text_original": "維鵜在梁，不濡其咮。彼其之子，不遂其媾。", "text_normalized": "維鵜在梁，不濡其咮。彼其之子，不遂其媾。", "notes": "候人 Chinese stanza 3."}
{"segment_id": "shijing__guofeng-caofeng-002__004__zhwikisource-20260530", "work_id": "shijing", "section_id": "guofeng-caofeng-002", "source_id": "guofeng-caofeng-002__zhwikisource-20260530", "segment_type": "stanza", "segment_order": 4, "canonical_ref": "詩經·國風·曹風·002.4", "text_original": "薈兮蔚兮，南山朝隮。婉兮孌兮，季女斯飢。", "text_normalized": "薈兮蔚兮，南山朝隮。婉兮孌兮，季女斯飢。", "notes": "候人 Chinese stanza 4."}
