{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0001", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 1, "text_original": "夫辯者，將以明是非之分，審治亂之紀，明同異之處，察名實之理，處利害，決嫌疑。", "text_normalized": "夫辯者，將以明是非之分，審治亂之紀，明同異之處，察名實之理，處利害，決嫌疑。", "canonical_ref": "36.1", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0002", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 2, "text_original": "焉摹略萬物之然，論求群言之比。", "text_normalized": "焉摹略萬物之然，論求群言之比。", "canonical_ref": "36.2", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0003", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 3, "text_original": "以名舉實，以辭抒意，以說出故。", "text_normalized": "以名舉實，以辭抒意，以說出故。", "canonical_ref": "36.3", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0004", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 4, "text_original": "以類取，以類予。", "text_normalized": "以類取，以類予。", "canonical_ref": "36.4", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0005", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 5, "text_original": "有諸己不非諸人，無諸己不求諸人。", "text_normalized": "有諸己不非諸人，無諸己不求諸人。", "canonical_ref": "36.5", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0006", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 6, "text_original": "或也者，不盡也。", "text_normalized": "或也者，不盡也。", "canonical_ref": "36.6", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0007", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 7, "text_original": "假者，今不然也。", "text_normalized": "假者，今不然也。", "canonical_ref": "36.7", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0008", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 8, "text_original": "效者，為之法也；", "text_normalized": "效者，為之法也；", "canonical_ref": "36.8", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0009", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 9, "text_original": "所效者，所以為之法也。", "text_normalized": "所效者，所以為之法也。", "canonical_ref": "36.9", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0010", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 10, "text_original": "故中效則是也，不中效則非也，此效也。", "text_normalized": "故中效則是也，不中效則非也，此效也。", "canonical_ref": "36.10", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0011", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 11, "text_original": "辟也者，舉也物而以明之也。", "text_normalized": "辟也者，舉也物而以明之也。", "canonical_ref": "36.11", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0012", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 12, "text_original": "侔也者，比辭而俱行也。", "text_normalized": "侔也者，比辭而俱行也。", "canonical_ref": "36.12", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0013", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 13, "text_original": "援也者，曰子然，我奚獨不可以然也？", "text_normalized": "援也者，曰子然，我奚獨不可以然也？", "canonical_ref": "36.13", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0014", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 14, "text_original": "推也者，以其所不取之同於其所取者，予之也。", "text_normalized": "推也者，以其所不取之同於其所取者，予之也。", "canonical_ref": "36.14", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0015", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 15, "text_original": "是猶謂也者，同也。", "text_normalized": "是猶謂也者，同也。", "canonical_ref": "36.15", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0016", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 16, "text_original": "吾豈謂也者，異也。", "text_normalized": "吾豈謂也者，異也。", "canonical_ref": "36.16", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0017", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 17, "text_original": "夫物有以同而不率遂同。", "text_normalized": "夫物有以同而不率遂同。", "canonical_ref": "36.17", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0018", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 18, "text_original": "辭之侔也，有所至而正。", "text_normalized": "辭之侔也，有所至而正。", "canonical_ref": "36.18", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0019", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 19, "text_original": "其然也，有所以然也；", "text_normalized": "其然也，有所以然也；", "canonical_ref": "36.19", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0020", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 20, "text_original": "其然也同，其所以然不必同。", "text_normalized": "其然也同，其所以然不必同。", "canonical_ref": "36.20", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0021", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 21, "text_original": "其取之也，有所以取之。", "text_normalized": "其取之也，有所以取之。", "canonical_ref": "36.21", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0022", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 22, "text_original": "其取之也同，其所以取之不必同。", "text_normalized": "其取之也同，其所以取之不必同。", "canonical_ref": "36.22", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0023", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 23, "text_original": "是故辟、侔、援、推之辭，行而異，轉而危，遠而失，流而離本，則不可不審也，不可常用也。", "text_normalized": "是故辟、侔、援、推之辭，行而異，轉而危，遠而失，流而離本，則不可不審也，不可常用也。", "canonical_ref": "36.23", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0024", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 24, "text_original": "故言多方，殊類異故，則不可偏觀也。", "text_normalized": "故言多方，殊類異故，則不可偏觀也。", "canonical_ref": "36.24", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0025", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 25, "text_original": "夫物或乃是而然，或是而不然，或一周而一不周，或一是而一不是也，不可常用也。", "text_normalized": "夫物或乃是而然，或是而不然，或一周而一不周，或一是而一不是也，不可常用也。", "canonical_ref": "36.25", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0026", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 26, "text_original": "故言多方，殊類異故，則不可偏觀也。", "text_normalized": "故言多方，殊類異故，則不可偏觀也。", "canonical_ref": "36.26", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0027", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 27, "text_original": "非也。", "text_normalized": "非也。", "canonical_ref": "36.27", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0028", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 28, "text_original": "白馬，馬也，乘白馬，乘馬也。", "text_normalized": "白馬，馬也，乘白馬，乘馬也。", "canonical_ref": "36.28", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0029", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 29, "text_original": "驪馬，馬也，乘驪馬，乘馬也。", "text_normalized": "驪馬，馬也，乘驪馬，乘馬也。", "canonical_ref": "36.29", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0030", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 30, "text_original": "獲，人也，愛獲，愛人也。", "text_normalized": "獲，人也，愛獲，愛人也。", "canonical_ref": "36.30", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0031", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 31, "text_original": "臧，人也，愛臧，愛人也。", "text_normalized": "臧，人也，愛臧，愛人也。", "canonical_ref": "36.31", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0032", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 32, "text_original": "此乃是而然者也。", "text_normalized": "此乃是而然者也。", "canonical_ref": "36.32", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0033", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 33, "text_original": "獲之親，人也。", "text_normalized": "獲之親，人也。", "canonical_ref": "36.33", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0034", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 34, "text_original": "獲事其親，非事人也。", "text_normalized": "獲事其親，非事人也。", "canonical_ref": "36.34", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0035", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 35, "text_original": "其弟，美人也。", "text_normalized": "其弟，美人也。", "canonical_ref": "36.35", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0036", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 36, "text_original": "愛弟，非愛美人也。", "text_normalized": "愛弟，非愛美人也。", "canonical_ref": "36.36", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0037", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 37, "text_original": "車，木也。", "text_normalized": "車，木也。", "canonical_ref": "36.37", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0038", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 38, "text_original": "乘車，非乘木也。", "text_normalized": "乘車，非乘木也。", "canonical_ref": "36.38", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0039", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 39, "text_original": "船，木也。", "text_normalized": "船，木也。", "canonical_ref": "36.39", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0040", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 40, "text_original": "乘船，非人木也。", "text_normalized": "乘船，非人木也。", "canonical_ref": "36.40", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0041", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 41, "text_original": "盜人，人也。", "text_normalized": "盜人，人也。", "canonical_ref": "36.41", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0042", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 42, "text_original": "多盜，非多人也。", "text_normalized": "多盜，非多人也。", "canonical_ref": "36.42", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0043", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 43, "text_original": "無盜，非無人也。", "text_normalized": "無盜，非無人也。", "canonical_ref": "36.43", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0044", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 44, "text_original": "奚以明之？", "text_normalized": "奚以明之？", "canonical_ref": "36.44", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0045", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 45, "text_original": "惡多盜，非惡多人也。", "text_normalized": "惡多盜，非惡多人也。", "canonical_ref": "36.45", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0046", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 46, "text_original": "欲無盜，非欲無人也。", "text_normalized": "欲無盜，非欲無人也。", "canonical_ref": "36.46", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0047", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 47, "text_original": "世相與共是之。", "text_normalized": "世相與共是之。", "canonical_ref": "36.47", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0048", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 48, "text_original": "若若是，則雖盜人人也，愛盜非愛人也，不愛盜非不愛人也，殺盜人，非殺人也。", "text_normalized": "若若是，則雖盜人人也，愛盜非愛人也，不愛盜非不愛人也，殺盜人，非殺人也。", "canonical_ref": "36.48", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0049", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 49, "text_original": "無難盜無難矣。", "text_normalized": "無難盜無難矣。", "canonical_ref": "36.49", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0050", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 50, "text_original": "此與彼同類，世有彼而不自非也，墨者有此而非之，無也故焉，所謂內膠外閉與心毋空乎，內膠而不解也，此乃是而不然者也且夫讀書，非好書也。", "text_normalized": "此與彼同類，世有彼而不自非也，墨者有此而非之，無也故焉，所謂內膠外閉與心毋空乎，內膠而不解也，此乃是而不然者也且夫讀書，非好書也。", "canonical_ref": "36.50", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0051", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 51, "text_original": "且鬥雞，非雞也。", "text_normalized": "且鬥雞，非雞也。", "canonical_ref": "36.51", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0052", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 52, "text_original": "好鬥雞，好雞也。", "text_normalized": "好鬥雞，好雞也。", "canonical_ref": "36.52", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0053", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 53, "text_original": "且入井，非入井也。", "text_normalized": "且入井，非入井也。", "canonical_ref": "36.53", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0054", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 54, "text_original": "止且入井，止入井也。", "text_normalized": "止且入井，止入井也。", "canonical_ref": "36.54", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0055", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 55, "text_original": "且出門，非出門也。", "text_normalized": "且出門，非出門也。", "canonical_ref": "36.55", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0056", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 56, "text_original": "止且出門，止出門也。", "text_normalized": "止且出門，止出門也。", "canonical_ref": "36.56", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0057", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 57, "text_original": "若若是，且夭，非夭也。", "text_normalized": "若若是，且夭，非夭也。", "canonical_ref": "36.57", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0058", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 58, "text_original": "壽夭也，壽夭也。", "text_normalized": "壽夭也，壽夭也。", "canonical_ref": "36.58", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0059", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 59, "text_original": "有命，非命也；", "text_normalized": "有命，非命也；", "canonical_ref": "36.59", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0060", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 60, "text_original": "非執有命，非命也。", "text_normalized": "非執有命，非命也。", "canonical_ref": "36.60", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0061", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 61, "text_original": "無難矣，此與彼同類。", "text_normalized": "無難矣，此與彼同類。", "canonical_ref": "36.61", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0062", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 62, "text_original": "世有彼而不自非也，墨者有此而罪非之，無也故焉，所謂內膠外閉與心毋空乎，內膠而不解也。", "text_normalized": "世有彼而不自非也，墨者有此而罪非之，無也故焉，所謂內膠外閉與心毋空乎，內膠而不解也。", "canonical_ref": "36.62", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0063", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 63, "text_original": "此乃是而不然者也。", "text_normalized": "此乃是而不然者也。", "canonical_ref": "36.63", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0064", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 64, "text_original": "愛人，待周愛人而後為愛人。", "text_normalized": "愛人，待周愛人而後為愛人。", "canonical_ref": "36.64", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0065", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 65, "text_original": "不愛人，不待周不愛人。", "text_normalized": "不愛人，不待周不愛人。", "canonical_ref": "36.65", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0066", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 66, "text_original": "不周愛，因為不愛人矣。", "text_normalized": "不周愛，因為不愛人矣。", "canonical_ref": "36.66", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0067", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 67, "text_original": "乘馬，不待周乘馬然後為乘馬也。", "text_normalized": "乘馬，不待周乘馬然後為乘馬也。", "canonical_ref": "36.67", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0068", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 68, "text_original": "有乘於馬，因為乘馬矣。", "text_normalized": "有乘於馬，因為乘馬矣。", "canonical_ref": "36.68", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0069", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 69, "text_original": "逮至不乘馬，待周不乘馬而後為不乘馬。", "text_normalized": "逮至不乘馬，待周不乘馬而後為不乘馬。", "canonical_ref": "36.69", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0070", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 70, "text_original": "此一周而一不周者也。", "text_normalized": "此一周而一不周者也。", "canonical_ref": "36.70", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0071", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 71, "text_original": "居於國，則為居國；", "text_normalized": "居於國，則為居國；", "canonical_ref": "36.71", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0072", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 72, "text_original": "有一宅於國，而不為有國。", "text_normalized": "有一宅於國，而不為有國。", "canonical_ref": "36.72", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0073", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 73, "text_original": "桃之實，桃也，棘之實，非棘也。", "text_normalized": "桃之實，桃也，棘之實，非棘也。", "canonical_ref": "36.73", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0074", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 74, "text_original": "問人之病，問人也。", "text_normalized": "問人之病，問人也。", "canonical_ref": "36.74", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0075", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 75, "text_original": "惡人之病，非惡人也。", "text_normalized": "惡人之病，非惡人也。", "canonical_ref": "36.75", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0076", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 76, "text_original": "人之鬼，非人也。", "text_normalized": "人之鬼，非人也。", "canonical_ref": "36.76", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0077", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 77, "text_original": "兄之鬼，兄也。", "text_normalized": "兄之鬼，兄也。", "canonical_ref": "36.77", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0078", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 78, "text_original": "祭人之鬼，非祭人也。", "text_normalized": "祭人之鬼，非祭人也。", "canonical_ref": "36.78", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0079", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 79, "text_original": "祭兄之鬼，乃祭兄也。", "text_normalized": "祭兄之鬼，乃祭兄也。", "canonical_ref": "36.79", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0080", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 80, "text_original": "之馬之目盼，則為之馬盼。", "text_normalized": "之馬之目盼，則為之馬盼。", "canonical_ref": "36.80", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0081", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 81, "text_original": "之馬之目大，而不謂之馬大。", "text_normalized": "之馬之目大，而不謂之馬大。", "canonical_ref": "36.81", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0082", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 82, "text_original": "之牛之毛黃，則謂之牛黃。", "text_normalized": "之牛之毛黃，則謂之牛黃。", "canonical_ref": "36.82", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0083", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 83, "text_original": "之牛之毛眾，而不謂之牛眾。", "text_normalized": "之牛之毛眾，而不謂之牛眾。", "canonical_ref": "36.83", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0084", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 84, "text_original": "一馬，馬也。", "text_normalized": "一馬，馬也。", "canonical_ref": "36.84", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0085", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 85, "text_original": "二馬，馬也。", "text_normalized": "二馬，馬也。", "canonical_ref": "36.85", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0086", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 86, "text_original": "馬四足者，一馬而四足也，非兩馬而四足也。", "text_normalized": "馬四足者，一馬而四足也，非兩馬而四足也。", "canonical_ref": "36.86", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0087", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 87, "text_original": "一馬，馬也。", "text_normalized": "一馬，馬也。", "canonical_ref": "36.87", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0088", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 88, "text_original": "馬或白者，二馬而或白也，非一馬而或白。", "text_normalized": "馬或白者，二馬而或白也，非一馬而或白。", "canonical_ref": "36.88", "notes": ""}
{"segment_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3__seg-0089", "section_id": "mozi-036-minor-illustrations", "source_id": "mozi-036-minor-illustrations__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 89, "text_original": "此乃一是而一非者也。", "text_normalized": "此乃一是而一非者也。", "canonical_ref": "36.89", "notes": ""}
