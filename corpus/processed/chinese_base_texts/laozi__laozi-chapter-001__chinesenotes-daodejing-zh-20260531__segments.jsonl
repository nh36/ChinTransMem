{"segment_id": "laozi-chapter-001__chinesenotes-daodejing-zh-20260531__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-001", "source_id": "laozi-chapter-001__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 1.9", "sort_key": "001.009", "text_original": "常有欲、", "text_normalized": "常有欲、", "notes": ""}
{"segment_id": "laozi-chapter-001__chinesenotes-daodejing-zh-20260531__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-001", "source_id": "laozi-chapter-001__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 1.10", "sort_key": "001.010", "text_original": "以觀其徼；", "text_normalized": "以觀其徼；", "notes": ""}
{"segment_id": "laozi-chapter-001__chinesenotes-daodejing-zh-20260531__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-001", "source_id": "laozi-chapter-001__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 1.11", "sort_key": "001.011", "text_original": "此兩者、", "text_normalized": "此兩者、", "notes": ""}
{"segment_id": "laozi-chapter-001__chinesenotes-daodejing-zh-20260531__seg-012", "work_id": "laozi", "section_id": "laozi-chapter-001", "source_id": "laozi-chapter-001__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 12, "canonical_ref": "老子 1.12", "sort_key": "001.012", "text_original": "同出而異名，", "text_normalized": "同出而異名，", "notes": ""}
{"segment_id": "laozi-chapter-001__chinesenotes-daodejing-zh-20260531__seg-013", "work_id": "laozi", "section_id": "laozi-chapter-001", "source_id": "laozi-chapter-001__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 13, "canonical_ref": "老子 1.13", "sort_key": "001.013", "text_original": "同謂之玄、", "text_normalized": "同謂之玄、", "notes": ""}
{"segment_id": "laozi-chapter-001__chinesenotes-daodejing-zh-20260531__seg-014", "work_id": "laozi", "section_id": "laozi-chapter-001", "source_id": "laozi-chapter-001__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 14, "canonical_ref": "老子 1.14", "sort_key": "001.014", "text_original": "玄之又玄、", "text_normalized": "玄之又玄、", "notes": ""}
{"segment_id": "laozi-chapter-001__chinesenotes-daodejing-zh-20260531__seg-015", "work_id": "laozi", "section_id": "laozi-chapter-001", "source_id": "laozi-chapter-001__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 15, "canonical_ref": "老子 1.15", "sort_key": "001.015", "text_original": "眾妙之門。", "text_normalized": "眾妙之門。", "notes": ""}
