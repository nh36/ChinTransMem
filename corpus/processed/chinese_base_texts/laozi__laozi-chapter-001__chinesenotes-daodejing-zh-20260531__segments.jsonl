{"segment_id": "laozi-chapter-001__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-001", "source_id": "laozi-chapter-001__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 1.2", "sort_key": "001.002", "text_original": "非常道，", "text_normalized": "非常道，", "notes": ""}
{"segment_id": "laozi-chapter-001__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-001", "source_id": "laozi-chapter-001__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 1.3", "sort_key": "001.003", "text_original": "名可名、", "text_normalized": "名可名、", "notes": ""}
{"segment_id": "laozi-chapter-001__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-001", "source_id": "laozi-chapter-001__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 1.4", "sort_key": "001.004", "text_original": "非常名；", "text_normalized": "非常名；", "notes": ""}
{"segment_id": "laozi-chapter-001__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-001", "source_id": "laozi-chapter-001__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 1.5", "sort_key": "001.005", "text_original": "無名天地之始，", "text_normalized": "無名天地之始，", "notes": ""}
{"segment_id": "laozi-chapter-001__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-001", "source_id": "laozi-chapter-001__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 1.6", "sort_key": "001.006", "text_original": "有名萬物之母。", "text_normalized": "有名萬物之母。", "notes": ""}
{"segment_id": "laozi-chapter-001__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-001", "source_id": "laozi-chapter-001__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 1.7", "sort_key": "001.007", "text_original": "故常無欲、", "text_normalized": "故常無欲、", "notes": ""}
