{"segment_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-064", "source_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 64.1", "sort_key": "064.001", "text_original": "其安易持，", "text_normalized": "其安易持，", "notes": ""}
{"segment_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-064", "source_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 64.2", "sort_key": "064.002", "text_original": "其未兆易謀。", "text_normalized": "其未兆易謀。", "notes": ""}
{"segment_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-064", "source_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 64.3", "sort_key": "064.003", "text_original": "其脆易泮，", "text_normalized": "其脆易泮，", "notes": ""}
{"segment_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-064", "source_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 64.4", "sort_key": "064.004", "text_original": "其微易散。", "text_normalized": "其微易散。", "notes": ""}
{"segment_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-064", "source_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 64.5", "sort_key": "064.005", "text_original": "為之於未有，", "text_normalized": "為之於未有，", "notes": ""}
{"segment_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-064", "source_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 64.6", "sort_key": "064.006", "text_original": "治之於未亂。", "text_normalized": "治之於未亂。", "notes": ""}
{"segment_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-064", "source_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 64.7", "sort_key": "064.007", "text_original": "合抱之木，", "text_normalized": "合抱之木，", "notes": ""}
{"segment_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-064", "source_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 64.8", "sort_key": "064.008", "text_original": "生於毫末；", "text_normalized": "生於毫末；", "notes": ""}
{"segment_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-064", "source_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 64.9", "sort_key": "064.009", "text_original": "九層之臺，", "text_normalized": "九層之臺，", "notes": ""}
{"segment_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-064", "source_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 64.10", "sort_key": "064.010", "text_original": "起於累土；", "text_normalized": "起於累土；", "notes": ""}
{"segment_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-064", "source_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 64.11", "sort_key": "064.011", "text_original": "千里之行，", "text_normalized": "千里之行，", "notes": ""}
{"segment_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531__seg-012", "work_id": "laozi", "section_id": "laozi-chapter-064", "source_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 12, "canonical_ref": "老子 64.12", "sort_key": "064.012", "text_original": "始於足下。", "text_normalized": "始於足下。", "notes": ""}
{"segment_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531__seg-013", "work_id": "laozi", "section_id": "laozi-chapter-064", "source_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 13, "canonical_ref": "老子 64.13", "sort_key": "064.013", "text_original": "為者敗之，", "text_normalized": "為者敗之，", "notes": ""}
{"segment_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531__seg-014", "work_id": "laozi", "section_id": "laozi-chapter-064", "source_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 14, "canonical_ref": "老子 64.14", "sort_key": "064.014", "text_original": "執者失之。", "text_normalized": "執者失之。", "notes": ""}
{"segment_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531__seg-015", "work_id": "laozi", "section_id": "laozi-chapter-064", "source_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 15, "canonical_ref": "老子 64.15", "sort_key": "064.015", "text_original": "是以聖人無為故無敗，", "text_normalized": "是以聖人無為故無敗，", "notes": ""}
{"segment_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531__seg-016", "work_id": "laozi", "section_id": "laozi-chapter-064", "source_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 16, "canonical_ref": "老子 64.16", "sort_key": "064.016", "text_original": "無執故無失。", "text_normalized": "無執故無失。", "notes": ""}
{"segment_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531__seg-017", "work_id": "laozi", "section_id": "laozi-chapter-064", "source_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 17, "canonical_ref": "老子 64.17", "sort_key": "064.017", "text_original": "民之從事，", "text_normalized": "民之從事，", "notes": ""}
{"segment_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531__seg-018", "work_id": "laozi", "section_id": "laozi-chapter-064", "source_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 18, "canonical_ref": "老子 64.18", "sort_key": "064.018", "text_original": "常於幾成而敗之。", "text_normalized": "常於幾成而敗之。", "notes": ""}
{"segment_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531__seg-019", "work_id": "laozi", "section_id": "laozi-chapter-064", "source_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 19, "canonical_ref": "老子 64.19", "sort_key": "064.019", "text_original": "慎終如始，", "text_normalized": "慎終如始，", "notes": ""}
{"segment_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531__seg-020", "work_id": "laozi", "section_id": "laozi-chapter-064", "source_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 20, "canonical_ref": "老子 64.20", "sort_key": "064.020", "text_original": "則無敗事。", "text_normalized": "則無敗事。", "notes": ""}
{"segment_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531__seg-021", "work_id": "laozi", "section_id": "laozi-chapter-064", "source_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 21, "canonical_ref": "老子 64.21", "sort_key": "064.021", "text_original": "是以聖人欲不欲，", "text_normalized": "是以聖人欲不欲，", "notes": ""}
{"segment_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531__seg-022", "work_id": "laozi", "section_id": "laozi-chapter-064", "source_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 22, "canonical_ref": "老子 64.22", "sort_key": "064.022", "text_original": "不貴難得之貨；", "text_normalized": "不貴難得之貨；", "notes": ""}
{"segment_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531__seg-023", "work_id": "laozi", "section_id": "laozi-chapter-064", "source_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 23, "canonical_ref": "老子 64.23", "sort_key": "064.023", "text_original": "學不學，", "text_normalized": "學不學，", "notes": ""}
{"segment_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531__seg-024", "work_id": "laozi", "section_id": "laozi-chapter-064", "source_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 24, "canonical_ref": "老子 64.24", "sort_key": "064.024", "text_original": "復眾人之所過。", "text_normalized": "復眾人之所過。", "notes": ""}
{"segment_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531__seg-025", "work_id": "laozi", "section_id": "laozi-chapter-064", "source_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 25, "canonical_ref": "老子 64.25", "sort_key": "064.025", "text_original": "以輔萬物之自然，", "text_normalized": "以輔萬物之自然，", "notes": ""}
{"segment_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531__seg-026", "work_id": "laozi", "section_id": "laozi-chapter-064", "source_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 26, "canonical_ref": "老子 64.26", "sort_key": "064.026", "text_original": "而不敢為。", "text_normalized": "而不敢為。", "notes": ""}
