{"segment_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-064", "source_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 64.1", "sort_key": "064.001", "text_original": "其安易持，其未兆易謀。", "text_normalized": "其安易持，其未兆易謀。", "notes": ""}
{"segment_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-064", "source_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 64.2", "sort_key": "064.002", "text_original": "其脆易泮，其微易散。", "text_normalized": "其脆易泮，其微易散。", "notes": ""}
{"segment_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-064", "source_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 64.3", "sort_key": "064.003", "text_original": "為之於未有，", "text_normalized": "為之於未有，", "notes": ""}
{"segment_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-064", "source_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 64.4", "sort_key": "064.004", "text_original": "治之於未亂。", "text_normalized": "治之於未亂。", "notes": ""}
{"segment_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-064", "source_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 64.5", "sort_key": "064.005", "text_original": "合抱之木，生於毫末；九層之臺，起於累土；千里之行，始於足下。為者敗之，執者失之。", "text_normalized": "合抱之木，生於毫末；九層之臺，起於累土；千里之行，始於足下。為者敗之，執者失之。", "notes": ""}
{"segment_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-064", "source_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 64.6", "sort_key": "064.006", "text_original": "是以聖人無為故無敗，無執故無失。民之從事，常於幾成而敗之。", "text_normalized": "是以聖人無為故無敗，無執故無失。民之從事，常於幾成而敗之。", "notes": ""}
{"segment_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-064", "source_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 64.7", "sort_key": "064.007", "text_original": "慎終如始，則無敗事。是以聖人欲不欲，不貴難得之貨；", "text_normalized": "慎終如始，則無敗事。是以聖人欲不欲，不貴難得之貨；", "notes": ""}
{"segment_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-064", "source_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 64.8", "sort_key": "064.008", "text_original": "學不學，復眾人之所過。", "text_normalized": "學不學，復眾人之所過。", "notes": ""}
{"segment_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-064", "source_id": "laozi-chapter-064__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 64.9", "sort_key": "064.009", "text_original": "以輔萬物之自然，而不敢為。", "text_normalized": "以輔萬物之自然，而不敢為。", "notes": ""}
