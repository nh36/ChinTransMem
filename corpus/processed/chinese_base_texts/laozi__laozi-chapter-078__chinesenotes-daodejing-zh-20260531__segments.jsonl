{"segment_id": "laozi-chapter-078__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-078", "source_id": "laozi-chapter-078__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 78.1", "sort_key": "078.001", "text_original": "天下莫柔弱於水，", "text_normalized": "天下莫柔弱於水，", "notes": ""}
{"segment_id": "laozi-chapter-078__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-078", "source_id": "laozi-chapter-078__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 78.2", "sort_key": "078.002", "text_original": "而攻堅強者，", "text_normalized": "而攻堅強者，", "notes": ""}
{"segment_id": "laozi-chapter-078__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-078", "source_id": "laozi-chapter-078__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 78.3", "sort_key": "078.003", "text_original": "莫之能勝，", "text_normalized": "莫之能勝，", "notes": ""}
{"segment_id": "laozi-chapter-078__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-078", "source_id": "laozi-chapter-078__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 78.4", "sort_key": "078.004", "text_original": "其無以易之。", "text_normalized": "其無以易之。", "notes": ""}
{"segment_id": "laozi-chapter-078__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-078", "source_id": "laozi-chapter-078__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 78.5", "sort_key": "078.005", "text_original": "弱之勝強，", "text_normalized": "弱之勝強，", "notes": ""}
{"segment_id": "laozi-chapter-078__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-078", "source_id": "laozi-chapter-078__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 78.6", "sort_key": "078.006", "text_original": "柔之勝剛，", "text_normalized": "柔之勝剛，", "notes": ""}
{"segment_id": "laozi-chapter-078__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-078", "source_id": "laozi-chapter-078__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 78.7", "sort_key": "078.007", "text_original": "天下莫不知莫能行。", "text_normalized": "天下莫不知莫能行。", "notes": ""}
{"segment_id": "laozi-chapter-078__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-078", "source_id": "laozi-chapter-078__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 78.8", "sort_key": "078.008", "text_original": "是以聖人云﹕「受國之垢，", "text_normalized": "是以聖人云﹕「受國之垢，", "notes": ""}
{"segment_id": "laozi-chapter-078__chinesenotes-daodejing-zh-20260531__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-078", "source_id": "laozi-chapter-078__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 78.9", "sort_key": "078.009", "text_original": "是謂社稷主；", "text_normalized": "是謂社稷主；", "notes": ""}
{"segment_id": "laozi-chapter-078__chinesenotes-daodejing-zh-20260531__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-078", "source_id": "laozi-chapter-078__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 78.10", "sort_key": "078.010", "text_original": "受國不祥，", "text_normalized": "受國不祥，", "notes": ""}
{"segment_id": "laozi-chapter-078__chinesenotes-daodejing-zh-20260531__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-078", "source_id": "laozi-chapter-078__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 78.11", "sort_key": "078.011", "text_original": "是為天下王。", "text_normalized": "是為天下王。", "notes": ""}
{"segment_id": "laozi-chapter-078__chinesenotes-daodejing-zh-20260531__seg-012", "work_id": "laozi", "section_id": "laozi-chapter-078", "source_id": "laozi-chapter-078__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 12, "canonical_ref": "老子 78.12", "sort_key": "078.012", "text_original": "」正言若反。", "text_normalized": "」正言若反。", "notes": ""}
