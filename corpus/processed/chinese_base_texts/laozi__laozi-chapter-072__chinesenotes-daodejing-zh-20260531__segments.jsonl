{"segment_id": "laozi-chapter-072__chinesenotes-daodejing-zh-20260531__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-072", "source_id": "laozi-chapter-072__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 72.1", "sort_key": "072.001", "text_original": "民不畏威，", "text_normalized": "民不畏威，", "notes": ""}
{"segment_id": "laozi-chapter-072__chinesenotes-daodejing-zh-20260531__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-072", "source_id": "laozi-chapter-072__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 72.2", "sort_key": "072.002", "text_original": "則大威至。", "text_normalized": "則大威至。", "notes": ""}
{"segment_id": "laozi-chapter-072__chinesenotes-daodejing-zh-20260531__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-072", "source_id": "laozi-chapter-072__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 72.3", "sort_key": "072.003", "text_original": "無狎其所居，", "text_normalized": "無狎其所居，", "notes": ""}
{"segment_id": "laozi-chapter-072__chinesenotes-daodejing-zh-20260531__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-072", "source_id": "laozi-chapter-072__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 72.4", "sort_key": "072.004", "text_original": "無厭其所生。", "text_normalized": "無厭其所生。", "notes": ""}
{"segment_id": "laozi-chapter-072__chinesenotes-daodejing-zh-20260531__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-072", "source_id": "laozi-chapter-072__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 72.5", "sort_key": "072.005", "text_original": "夫唯不厭，", "text_normalized": "夫唯不厭，", "notes": ""}
{"segment_id": "laozi-chapter-072__chinesenotes-daodejing-zh-20260531__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-072", "source_id": "laozi-chapter-072__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 72.6", "sort_key": "072.006", "text_original": "是以不厭。", "text_normalized": "是以不厭。", "notes": ""}
{"segment_id": "laozi-chapter-072__chinesenotes-daodejing-zh-20260531__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-072", "source_id": "laozi-chapter-072__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 72.7", "sort_key": "072.007", "text_original": "是以聖人自知不自見，", "text_normalized": "是以聖人自知不自見，", "notes": ""}
{"segment_id": "laozi-chapter-072__chinesenotes-daodejing-zh-20260531__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-072", "source_id": "laozi-chapter-072__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 72.8", "sort_key": "072.008", "text_original": "自愛不自貴；", "text_normalized": "自愛不自貴；", "notes": ""}
{"segment_id": "laozi-chapter-072__chinesenotes-daodejing-zh-20260531__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-072", "source_id": "laozi-chapter-072__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 72.9", "sort_key": "072.009", "text_original": "故去彼取此。", "text_normalized": "故去彼取此。", "notes": ""}
