{"segment_id": "laozi-chapter-021__chinesenotes-daodejing-zh-20260531__seg-015", "work_id": "laozi", "section_id": "laozi-chapter-021", "source_id": "laozi-chapter-021__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 15, "canonical_ref": "老子 21.15", "sort_key": "021.015", "text_original": "以閱眾甫。", "text_normalized": "以閱眾甫。", "notes": ""}
