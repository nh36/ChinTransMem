{"segment_id": "laozi-chapter-021__chinesenotes-daodejing-zh-20260531__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-021", "source_id": "laozi-chapter-021__chinesenotes-daodejing-zh-20260531", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 21.11", "sort_key": "021.011", "text_original": "其精甚真，", "text_normalized": "其精甚真，", "notes": ""}
