{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0001", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 1, "text_original": "子墨子言曰：", "text_normalized": "子墨子言曰：", "canonical_ref": "8.1", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0002", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 2, "text_original": "今者王公大人爲政於國家者，皆欲國家之富，人民之衆，刑政之治。", "text_normalized": "今者王公大人爲政於國家者，皆欲國家之富，人民之衆，刑政之治。", "canonical_ref": "8.2", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0003", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 3, "text_original": "然而不得富而得貧，不得衆而得寡，不得治而得亂，則是本失其所欲，得其所惡。", "text_normalized": "然而不得富而得貧，不得衆而得寡，不得治而得亂，則是本失其所欲，得其所惡。", "canonical_ref": "8.3", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0004", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 4, "text_original": "是其故何也？", "text_normalized": "是其故何也？", "canonical_ref": "8.4", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0005", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 5, "text_original": "子墨子言曰：", "text_normalized": "子墨子言曰：", "canonical_ref": "8.5", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0006", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 6, "text_original": "是在王公大人爲政於國家者，不能以尚賢事能爲政也。", "text_normalized": "是在王公大人爲政於國家者，不能以尚賢事能爲政也。", "canonical_ref": "8.6", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0007", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 7, "text_original": "是故國有賢良之士衆，則國家之治厚，賢良之士寡，則國家之治薄。", "text_normalized": "是故國有賢良之士衆，則國家之治厚，賢良之士寡，則國家之治薄。", "canonical_ref": "8.7", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0008", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 8, "text_original": "故大人之務，將在於衆賢而已。", "text_normalized": "故大人之務，將在於衆賢而已。", "canonical_ref": "8.8", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0009", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 9, "text_original": "曰：", "text_normalized": "曰：", "canonical_ref": "8.9", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0010", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 10, "text_original": "然則衆賢之術，將奈何哉？", "text_normalized": "然則衆賢之術，將奈何哉？", "canonical_ref": "8.10", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0011", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 11, "text_original": "子墨子言曰：", "text_normalized": "子墨子言曰：", "canonical_ref": "8.11", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0012", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 12, "text_original": "譬若欲衆其國之善射御之士者，必將富之貴之，敬之譽之，然後國之善射御之士，將可得而衆也。", "text_normalized": "譬若欲衆其國之善射御之士者，必將富之貴之，敬之譽之，然後國之善射御之士，將可得而衆也。", "canonical_ref": "8.12", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0013", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 13, "text_original": "況又有賢良之士，厚乎德行，辯乎言談，博乎道術者乎？", "text_normalized": "況又有賢良之士，厚乎德行，辯乎言談，博乎道術者乎？", "canonical_ref": "8.13", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0014", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 14, "text_original": "此固國家之珍，而社稷之佐也。", "text_normalized": "此固國家之珍，而社稷之佐也。", "canonical_ref": "8.14", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0015", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 15, "text_original": "亦必且富之貴之，敬之譽之，然後國之良士，亦將可得而衆也。", "text_normalized": "亦必且富之貴之，敬之譽之，然後國之良士，亦將可得而衆也。", "canonical_ref": "8.15", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0016", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 16, "text_original": "是故古者聖王之爲政也，言曰：", "text_normalized": "是故古者聖王之爲政也，言曰：", "canonical_ref": "8.16", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0017", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 17, "text_original": "「不義不富，不義不貴，不義不親，不義不近。", "text_normalized": "「不義不富，不義不貴，不義不親，不義不近。", "canonical_ref": "8.17", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0018", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 18, "text_original": "」是以國之富貴人聞之，皆退而謀曰：", "text_normalized": "」是以國之富貴人聞之，皆退而謀曰：", "canonical_ref": "8.18", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0019", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 19, "text_original": "「始我所恃者，富貴也。", "text_normalized": "「始我所恃者，富貴也。", "canonical_ref": "8.19", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0020", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 20, "text_original": "今上舉義不辟貧賤，然則我不可不爲義。", "text_normalized": "今上舉義不辟貧賤，然則我不可不爲義。", "canonical_ref": "8.20", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0021", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 21, "text_original": "」親者聞之，亦退而謀曰：", "text_normalized": "」親者聞之，亦退而謀曰：", "canonical_ref": "8.21", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0022", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 22, "text_original": "「始我所恃者，親也。", "text_normalized": "「始我所恃者，親也。", "canonical_ref": "8.22", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0023", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 23, "text_original": "今上舉義不辟疏，然則我不可不爲義。", "text_normalized": "今上舉義不辟疏，然則我不可不爲義。", "canonical_ref": "8.23", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0024", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 24, "text_original": "」近者聞之，亦退而謀曰：", "text_normalized": "」近者聞之，亦退而謀曰：", "canonical_ref": "8.24", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0025", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 25, "text_original": "「始我所恃者，近也，今上舉義不辟遠，然則我不可不爲義。", "text_normalized": "「始我所恃者，近也，今上舉義不辟遠，然則我不可不爲義。", "canonical_ref": "8.25", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0026", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 26, "text_original": "」遠者聞之，亦退而謀曰：", "text_normalized": "」遠者聞之，亦退而謀曰：", "canonical_ref": "8.26", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0027", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 27, "text_original": "「我始以遠爲無恃，今上舉義不辟遠，然則我不可不爲義。", "text_normalized": "「我始以遠爲無恃，今上舉義不辟遠，然則我不可不爲義。", "canonical_ref": "8.27", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0028", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 28, "text_original": "」逮至遠鄙郊外之臣、門庭庶子、國中之衆、四鄙之萌人聞之，皆競爲義。", "text_normalized": "」逮至遠鄙郊外之臣、門庭庶子、國中之衆、四鄙之萌人聞之，皆競爲義。", "canonical_ref": "8.28", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0029", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 29, "text_original": "是其故何也？", "text_normalized": "是其故何也？", "canonical_ref": "8.29", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0030", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 30, "text_original": "曰：", "text_normalized": "曰：", "canonical_ref": "8.30", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0031", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 31, "text_original": "上之所以使下者，一物也。", "text_normalized": "上之所以使下者，一物也。", "canonical_ref": "8.31", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0032", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 32, "text_original": "下之所以事上者，一術也。", "text_normalized": "下之所以事上者，一術也。", "canonical_ref": "8.32", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0033", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 33, "text_original": "譬之富者，有高牆深宮。", "text_normalized": "譬之富者，有高牆深宮。", "canonical_ref": "8.33", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0034", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 34, "text_original": "牆立旣，謹上爲鑿一門，有盜人入，闔其自入而求之，盜其無自出。", "text_normalized": "牆立旣，謹上爲鑿一門，有盜人入，闔其自入而求之，盜其無自出。", "canonical_ref": "8.34", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0035", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 35, "text_original": "是其故何也？", "text_normalized": "是其故何也？", "canonical_ref": "8.35", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0036", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 36, "text_original": "則上得要也。", "text_normalized": "則上得要也。", "canonical_ref": "8.36", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0037", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 37, "text_original": "故古者聖王之爲政，列德而尚賢，雖在農與工肆之人，有能則舉之，高予之爵，重予之祿，任之以事，斷予之令，曰：", "text_normalized": "故古者聖王之爲政，列德而尚賢，雖在農與工肆之人，有能則舉之，高予之爵，重予之祿，任之以事，斷予之令，曰：", "canonical_ref": "8.37", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0038", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 38, "text_original": "「爵位不高則民弗敬，蓄祿不厚則民不信，政令不斷則民不畏。", "text_normalized": "「爵位不高則民弗敬，蓄祿不厚則民不信，政令不斷則民不畏。", "canonical_ref": "8.38", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0039", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 39, "text_original": "」舉三者授之賢者，非爲賢賜也，欲其事之成。", "text_normalized": "」舉三者授之賢者，非爲賢賜也，欲其事之成。", "canonical_ref": "8.39", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0040", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 40, "text_original": "故當是時，以德就列，以官服事，以勞殿賞，量功而分祿。", "text_normalized": "故當是時，以德就列，以官服事，以勞殿賞，量功而分祿。", "canonical_ref": "8.40", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0041", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 41, "text_original": "故官無常貴，而民無終賤。", "text_normalized": "故官無常貴，而民無終賤。", "canonical_ref": "8.41", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0042", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 42, "text_original": "有能則舉之，無能則下之。", "text_normalized": "有能則舉之，無能則下之。", "canonical_ref": "8.42", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0043", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 43, "text_original": "舉公義，辟私怨，此若言之謂也。", "text_normalized": "舉公義，辟私怨，此若言之謂也。", "canonical_ref": "8.43", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0044", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 44, "text_original": "故古者堯舉舜於服澤之陽，授之政，天下平。", "text_normalized": "故古者堯舉舜於服澤之陽，授之政，天下平。", "canonical_ref": "8.44", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0045", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 45, "text_original": "禹舉益於陰方之中，授之政，九州成。", "text_normalized": "禹舉益於陰方之中，授之政，九州成。", "canonical_ref": "8.45", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0046", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 46, "text_original": "湯舉伊尹於庖廚之中，授之政，其謀得。", "text_normalized": "湯舉伊尹於庖廚之中，授之政，其謀得。", "canonical_ref": "8.46", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0047", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 47, "text_original": "文王舉閎夭、泰顚於置罔之中，授之政，西土服。", "text_normalized": "文王舉閎夭、泰顚於置罔之中，授之政，西土服。", "canonical_ref": "8.47", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0048", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 48, "text_original": "故當是時，雖在於厚祿尊位之臣，莫不敬懼而施；", "text_normalized": "故當是時，雖在於厚祿尊位之臣，莫不敬懼而施；", "canonical_ref": "8.48", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0049", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 49, "text_original": "雖在農與工肆之人，莫不競勸而尚意。", "text_normalized": "雖在農與工肆之人，莫不競勸而尚意。", "canonical_ref": "8.49", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0050", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 50, "text_original": "故士者，所以爲輔相承嗣也。", "text_normalized": "故士者，所以爲輔相承嗣也。", "canonical_ref": "8.50", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0051", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 51, "text_original": "故得士則謀不睏，體不勞，名立而功成，美章而惡不生，則由得士也。", "text_normalized": "故得士則謀不睏，體不勞，名立而功成，美章而惡不生，則由得士也。", "canonical_ref": "8.51", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0052", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 52, "text_original": "是故子墨子言曰：", "text_normalized": "是故子墨子言曰：", "canonical_ref": "8.52", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0053", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 53, "text_original": "得意賢士不可不舉，不得意賢士不可不舉，尚欲祖述堯、舜、禹、湯之道，將不可以不尚賢。", "text_normalized": "得意賢士不可不舉，不得意賢士不可不舉，尚欲祖述堯、舜、禹、湯之道，將不可以不尚賢。", "canonical_ref": "8.53", "notes": ""}
{"segment_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3__seg-0054", "section_id": "mozi-008-exaltation-of-the-virtuous-i", "source_id": "mozi-008-exaltation-of-the-virtuous-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 54, "text_original": "夫尚賢者，政之本也。", "text_normalized": "夫尚賢者，政之本也。", "canonical_ref": "8.54", "notes": ""}
