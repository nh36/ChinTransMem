{"segment_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3__seg-0001", "section_id": "mozi-017-condemnation-of-offensive-war-i", "source_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 1, "text_original": "今有一人，入人園圃，竊其桃李，衆聞則非之，上爲政者得則罰之。", "text_normalized": "今有一人，入人園圃，竊其桃李，衆聞則非之，上爲政者得則罰之。", "canonical_ref": "17.1", "notes": ""}
{"segment_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3__seg-0002", "section_id": "mozi-017-condemnation-of-offensive-war-i", "source_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 2, "text_original": "此何也？", "text_normalized": "此何也？", "canonical_ref": "17.2", "notes": ""}
{"segment_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3__seg-0003", "section_id": "mozi-017-condemnation-of-offensive-war-i", "source_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 3, "text_original": "以虧人自利也。", "text_normalized": "以虧人自利也。", "canonical_ref": "17.3", "notes": ""}
{"segment_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3__seg-0004", "section_id": "mozi-017-condemnation-of-offensive-war-i", "source_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 4, "text_original": "至攘人犬豕雞豚者，其不義又甚入人園圃竊桃李。", "text_normalized": "至攘人犬豕雞豚者，其不義又甚入人園圃竊桃李。", "canonical_ref": "17.4", "notes": ""}
{"segment_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3__seg-0005", "section_id": "mozi-017-condemnation-of-offensive-war-i", "source_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 5, "text_original": "是何故也？", "text_normalized": "是何故也？", "canonical_ref": "17.5", "notes": ""}
{"segment_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3__seg-0006", "section_id": "mozi-017-condemnation-of-offensive-war-i", "source_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 6, "text_original": "以虧人愈多，其不仁茲甚，罪益厚。", "text_normalized": "以虧人愈多，其不仁茲甚，罪益厚。", "canonical_ref": "17.6", "notes": ""}
{"segment_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3__seg-0007", "section_id": "mozi-017-condemnation-of-offensive-war-i", "source_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 7, "text_original": "至入人欄廏，取人馬牛者，其不仁義又甚攘人犬豕雞豚。", "text_normalized": "至入人欄廏，取人馬牛者，其不仁義又甚攘人犬豕雞豚。", "canonical_ref": "17.7", "notes": ""}
{"segment_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3__seg-0008", "section_id": "mozi-017-condemnation-of-offensive-war-i", "source_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 8, "text_original": "此何故也？", "text_normalized": "此何故也？", "canonical_ref": "17.8", "notes": ""}
{"segment_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3__seg-0009", "section_id": "mozi-017-condemnation-of-offensive-war-i", "source_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 9, "text_original": "以其虧人愈多。", "text_normalized": "以其虧人愈多。", "canonical_ref": "17.9", "notes": ""}
{"segment_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3__seg-0010", "section_id": "mozi-017-condemnation-of-offensive-war-i", "source_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 10, "text_original": "苟虧人愈多，其不仁茲甚，罪益厚。", "text_normalized": "苟虧人愈多，其不仁茲甚，罪益厚。", "canonical_ref": "17.10", "notes": ""}
{"segment_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3__seg-0011", "section_id": "mozi-017-condemnation-of-offensive-war-i", "source_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 11, "text_original": "至殺不辜人也，扡其衣裘，取戈劍者，其不義又甚入人欄廄取人馬牛。", "text_normalized": "至殺不辜人也，扡其衣裘，取戈劍者，其不義又甚入人欄廄取人馬牛。", "canonical_ref": "17.11", "notes": ""}
{"segment_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3__seg-0012", "section_id": "mozi-017-condemnation-of-offensive-war-i", "source_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 12, "text_original": "此何故也？", "text_normalized": "此何故也？", "canonical_ref": "17.12", "notes": ""}
{"segment_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3__seg-0013", "section_id": "mozi-017-condemnation-of-offensive-war-i", "source_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 13, "text_original": "以其虧人愈多。", "text_normalized": "以其虧人愈多。", "canonical_ref": "17.13", "notes": ""}
{"segment_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3__seg-0014", "section_id": "mozi-017-condemnation-of-offensive-war-i", "source_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 14, "text_original": "苟虧人愈多，其不仁茲甚矣，罪益厚。", "text_normalized": "苟虧人愈多，其不仁茲甚矣，罪益厚。", "canonical_ref": "17.14", "notes": ""}
{"segment_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3__seg-0015", "section_id": "mozi-017-condemnation-of-offensive-war-i", "source_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 15, "text_original": "當此，天下之君子皆知而非之，謂之不義。", "text_normalized": "當此，天下之君子皆知而非之，謂之不義。", "canonical_ref": "17.15", "notes": ""}
{"segment_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3__seg-0016", "section_id": "mozi-017-condemnation-of-offensive-war-i", "source_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 16, "text_original": "今至大爲攻國，則弗知非，從而譽之，謂之義。", "text_normalized": "今至大爲攻國，則弗知非，從而譽之，謂之義。", "canonical_ref": "17.16", "notes": ""}
{"segment_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3__seg-0017", "section_id": "mozi-017-condemnation-of-offensive-war-i", "source_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 17, "text_original": "此可謂知義與不義之別乎？", "text_normalized": "此可謂知義與不義之別乎？", "canonical_ref": "17.17", "notes": ""}
{"segment_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3__seg-0018", "section_id": "mozi-017-condemnation-of-offensive-war-i", "source_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 18, "text_original": "殺一人謂之不義，必有一死罪矣，若以此說往，殺十人十重不義，必有十死罪矣；", "text_normalized": "殺一人謂之不義，必有一死罪矣，若以此說往，殺十人十重不義，必有十死罪矣；", "canonical_ref": "17.18", "notes": ""}
{"segment_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3__seg-0019", "section_id": "mozi-017-condemnation-of-offensive-war-i", "source_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 19, "text_original": "殺百人百重不義，必有百死罪矣。", "text_normalized": "殺百人百重不義，必有百死罪矣。", "canonical_ref": "17.19", "notes": ""}
{"segment_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3__seg-0020", "section_id": "mozi-017-condemnation-of-offensive-war-i", "source_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 20, "text_original": "當此，天下之君子皆知而非之，謂之不義。", "text_normalized": "當此，天下之君子皆知而非之，謂之不義。", "canonical_ref": "17.20", "notes": ""}
{"segment_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3__seg-0021", "section_id": "mozi-017-condemnation-of-offensive-war-i", "source_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 21, "text_original": "今至大爲不義攻國，則弗知非，從而譽之，謂之義，情不知其不義也，故書其言以遺後世。", "text_normalized": "今至大爲不義攻國，則弗知非，從而譽之，謂之義，情不知其不義也，故書其言以遺後世。", "canonical_ref": "17.21", "notes": ""}
{"segment_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3__seg-0022", "section_id": "mozi-017-condemnation-of-offensive-war-i", "source_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 22, "text_original": "若知其不義也，夫奚說書其不義以遺後世哉？", "text_normalized": "若知其不義也，夫奚說書其不義以遺後世哉？", "canonical_ref": "17.22", "notes": ""}
{"segment_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3__seg-0023", "section_id": "mozi-017-condemnation-of-offensive-war-i", "source_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 23, "text_original": "今有人於此，少見黑曰黑，多見黑曰白，則必以此人不知白黑之辯矣；", "text_normalized": "今有人於此，少見黑曰黑，多見黑曰白，則必以此人不知白黑之辯矣；", "canonical_ref": "17.23", "notes": ""}
{"segment_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3__seg-0024", "section_id": "mozi-017-condemnation-of-offensive-war-i", "source_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 24, "text_original": "少嘗苦曰苦，多嘗苦曰甘，則必以此人爲不知甘苦之辯矣。", "text_normalized": "少嘗苦曰苦，多嘗苦曰甘，則必以此人爲不知甘苦之辯矣。", "canonical_ref": "17.24", "notes": ""}
{"segment_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3__seg-0025", "section_id": "mozi-017-condemnation-of-offensive-war-i", "source_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 25, "text_original": "今小爲非，則知而非之。", "text_normalized": "今小爲非，則知而非之。", "canonical_ref": "17.25", "notes": ""}
{"segment_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3__seg-0026", "section_id": "mozi-017-condemnation-of-offensive-war-i", "source_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 26, "text_original": "大爲非攻國，則不知非，從而譽之，謂之義。", "text_normalized": "大爲非攻國，則不知非，從而譽之，謂之義。", "canonical_ref": "17.26", "notes": ""}
{"segment_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3__seg-0027", "section_id": "mozi-017-condemnation-of-offensive-war-i", "source_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 27, "text_original": "此可謂知義與不義之辯乎？", "text_normalized": "此可謂知義與不義之辯乎？", "canonical_ref": "17.27", "notes": ""}
{"segment_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3__seg-0028", "section_id": "mozi-017-condemnation-of-offensive-war-i", "source_id": "mozi-017-condemnation-of-offensive-war-i__chinesenotes-1f6b1d3", "work_id": "mozi", "segment_type": "sentence", "segment_order": 28, "text_original": "是以知天下之君子也，辯義與不義之亂也。", "text_normalized": "是以知天下之君子也，辯義與不義之亂也。", "canonical_ref": "17.28", "notes": ""}
