{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0064", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 64, "canonical_ref": "禮記·《射義》 64", "sort_key": "0064", "text_original": "故射者各射己之鵠。", "text_normalized": "故射者各射己之鵠。", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0065", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 65, "canonical_ref": "禮記·《射義》 65", "sort_key": "0065", "text_original": "故天子之大射謂之射侯；", "text_normalized": "故天子之大射謂之射侯；", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0066", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 66, "canonical_ref": "禮記·《射義》 66", "sort_key": "0066", "text_original": "射侯者，射為諸侯也。", "text_normalized": "射侯者，射為諸侯也。", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0067", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 67, "canonical_ref": "禮記·《射義》 67", "sort_key": "0067", "text_original": "射中則得為諸侯；", "text_normalized": "射中則得為諸侯；", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0068", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 68, "canonical_ref": "禮記·《射義》 68", "sort_key": "0068", "text_original": "射不中則不得為諸侯。", "text_normalized": "射不中則不得為諸侯。", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0069", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 69, "canonical_ref": "禮記·《射義》 69", "sort_key": "0069", "text_original": "天子將祭，必先習射於澤。", "text_normalized": "天子將祭，必先習射於澤。", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0070", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 70, "canonical_ref": "禮記·《射義》 70", "sort_key": "0070", "text_original": "澤者，所以擇士也。", "text_normalized": "澤者，所以擇士也。", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0071", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 71, "canonical_ref": "禮記·《射義》 71", "sort_key": "0071", "text_original": "已射於澤，而後射於射宮。", "text_normalized": "已射於澤，而後射於射宮。", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0072", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 72, "canonical_ref": "禮記·《射義》 72", "sort_key": "0072", "text_original": "射中者得與於祭；", "text_normalized": "射中者得與於祭；", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0073", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 73, "canonical_ref": "禮記·《射義》 73", "sort_key": "0073", "text_original": "不中者不得與於祭。", "text_normalized": "不中者不得與於祭。", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0074", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 74, "canonical_ref": "禮記·《射義》 74", "sort_key": "0074", "text_original": "不得與於祭者有讓，削以地；", "text_normalized": "不得與於祭者有讓，削以地；", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0075", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 75, "canonical_ref": "禮記·《射義》 75", "sort_key": "0075", "text_original": "得與於祭者有慶，益以地。", "text_normalized": "得與於祭者有慶，益以地。", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0076", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 76, "canonical_ref": "禮記·《射義》 76", "sort_key": "0076", "text_original": "進爵絀地是也。", "text_normalized": "進爵絀地是也。", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0077", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 77, "canonical_ref": "禮記·《射義》 77", "sort_key": "0077", "text_original": "故男子生，桑弧蓬矢六，以射天地四方。", "text_normalized": "故男子生，桑弧蓬矢六，以射天地四方。", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0078", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 78, "canonical_ref": "禮記·《射義》 78", "sort_key": "0078", "text_original": "天地四方者，男子之所有事也。", "text_normalized": "天地四方者，男子之所有事也。", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0079", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 79, "canonical_ref": "禮記·《射義》 79", "sort_key": "0079", "text_original": "故必先有志於其所有事，然後敢用穀也。", "text_normalized": "故必先有志於其所有事，然後敢用穀也。", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0080", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 80, "canonical_ref": "禮記·《射義》 80", "sort_key": "0080", "text_original": "飯食之謂也。", "text_normalized": "飯食之謂也。", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0081", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 81, "canonical_ref": "禮記·《射義》 81", "sort_key": "0081", "text_original": "射者，仁之道也。", "text_normalized": "射者，仁之道也。", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0082", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 82, "canonical_ref": "禮記·《射義》 82", "sort_key": "0082", "text_original": "射求正諸己，己正然後發，發而不中，則不怨勝己者，反求諸己而已矣。", "text_normalized": "射求正諸己，己正然後發，發而不中，則不怨勝己者，反求諸己而已矣。", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0083", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 83, "canonical_ref": "禮記·《射義》 83", "sort_key": "0083", "text_original": "孔子曰：", "text_normalized": "孔子曰：", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0084", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 84, "canonical_ref": "禮記·《射義》 84", "sort_key": "0084", "text_original": "「君子無所爭，必也射乎！", "text_normalized": "「君子無所爭，必也射乎！", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0085", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 85, "canonical_ref": "禮記·《射義》 85", "sort_key": "0085", "text_original": "揖讓而升，下而飲，其爭也君子。", "text_normalized": "揖讓而升，下而飲，其爭也君子。", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0086", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 86, "canonical_ref": "禮記·《射義》 86", "sort_key": "0086", "text_original": "」", "text_normalized": "」", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0087", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 87, "canonical_ref": "禮記·《射義》 87", "sort_key": "0087", "text_original": "孔子曰：", "text_normalized": "孔子曰：", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0088", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 88, "canonical_ref": "禮記·《射義》 88", "sort_key": "0088", "text_original": "「射者何以射？", "text_normalized": "「射者何以射？", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0089", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 89, "canonical_ref": "禮記·《射義》 89", "sort_key": "0089", "text_original": "何以聽？", "text_normalized": "何以聽？", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0090", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 90, "canonical_ref": "禮記·《射義》 90", "sort_key": "0090", "text_original": "循聲而發，發而不失正鵠者，其唯賢者乎！", "text_normalized": "循聲而發，發而不失正鵠者，其唯賢者乎！", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0091", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 91, "canonical_ref": "禮記·《射義》 91", "sort_key": "0091", "text_original": "若夫不肖之人，則彼將安能以中？", "text_normalized": "若夫不肖之人，則彼將安能以中？", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0092", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 92, "canonical_ref": "禮記·《射義》 92", "sort_key": "0092", "text_original": "」", "text_normalized": "」", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0093", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 93, "canonical_ref": "禮記·《射義》 93", "sort_key": "0093", "text_original": "《詩》云：", "text_normalized": "《詩》云：", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0094", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 94, "canonical_ref": "禮記·《射義》 94", "sort_key": "0094", "text_original": "「發彼有的，以祈爾爵。", "text_normalized": "「發彼有的，以祈爾爵。", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0095", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 95, "canonical_ref": "禮記·《射義》 95", "sort_key": "0095", "text_original": "」祈，求也；", "text_normalized": "」祈，求也；", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0096", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 96, "canonical_ref": "禮記·《射義》 96", "sort_key": "0096", "text_original": "求中以辭爵也。", "text_normalized": "求中以辭爵也。", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0097", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 97, "canonical_ref": "禮記·《射義》 97", "sort_key": "0097", "text_original": "酒者，所以養老也，所以養病也；", "text_normalized": "酒者，所以養老也，所以養病也；", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0098", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 98, "canonical_ref": "禮記·《射義》 98", "sort_key": "0098", "text_original": "求中以辭爵者，辭養也。", "text_normalized": "求中以辭爵者，辭養也。", "notes": ""}
