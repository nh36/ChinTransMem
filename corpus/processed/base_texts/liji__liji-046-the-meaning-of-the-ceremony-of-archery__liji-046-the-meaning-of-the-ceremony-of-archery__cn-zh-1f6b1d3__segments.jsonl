{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0001", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "禮記·《射義》 1", "sort_key": "0001", "text_original": "古者諸侯之射也，必先行燕禮；", "text_normalized": "古者諸侯之射也，必先行燕禮；", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0002", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "禮記·《射義》 2", "sort_key": "0002", "text_original": "卿、大夫、士之射也，必先行鄉飲酒之禮。", "text_normalized": "卿、大夫、士之射也，必先行鄉飲酒之禮。", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0003", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "禮記·《射義》 3", "sort_key": "0003", "text_original": "故燕禮者，所以明君臣之義也；", "text_normalized": "故燕禮者，所以明君臣之義也；", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0004", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "禮記·《射義》 4", "sort_key": "0004", "text_original": "鄉飲酒之禮者，所以明長幼之序也。", "text_normalized": "鄉飲酒之禮者，所以明長幼之序也。", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0005", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "禮記·《射義》 5", "sort_key": "0005", "text_original": "故射者，進退周還必中禮，內志正，外體直，然後持弓矢審固；", "text_normalized": "故射者，進退周還必中禮，內志正，外體直，然後持弓矢審固；", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0006", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "禮記·《射義》 6", "sort_key": "0006", "text_original": "持弓矢審固，然後可以言中，此可以觀德行矣。", "text_normalized": "持弓矢審固，然後可以言中，此可以觀德行矣。", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0007", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "禮記·《射義》 7", "sort_key": "0007", "text_original": "其節：", "text_normalized": "其節：", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0008", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "禮記·《射義》 8", "sort_key": "0008", "text_original": "天子以《騶虞》為節；", "text_normalized": "天子以《騶虞》為節；", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0009", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "禮記·《射義》 9", "sort_key": "0009", "text_original": "諸侯以《貍首》為節；", "text_normalized": "諸侯以《貍首》為節；", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0010", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "禮記·《射義》 10", "sort_key": "0010", "text_original": "卿大夫以《采蘋》為節；", "text_normalized": "卿大夫以《采蘋》為節；", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0011", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "禮記·《射義》 11", "sort_key": "0011", "text_original": "士以《采繁》為節。", "text_normalized": "士以《采繁》為節。", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0012", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 12, "canonical_ref": "禮記·《射義》 12", "sort_key": "0012", "text_original": "《騶虞》者，樂官備也，《貍首》者，樂會時也；", "text_normalized": "《騶虞》者，樂官備也，《貍首》者，樂會時也；", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0013", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 13, "canonical_ref": "禮記·《射義》 13", "sort_key": "0013", "text_original": "《采蘋》者，樂循法也；", "text_normalized": "《采蘋》者，樂循法也；", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0014", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 14, "canonical_ref": "禮記·《射義》 14", "sort_key": "0014", "text_original": "《采繁》者，樂不失職也。", "text_normalized": "《采繁》者，樂不失職也。", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0015", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 15, "canonical_ref": "禮記·《射義》 15", "sort_key": "0015", "text_original": "是故天子以備官為節；", "text_normalized": "是故天子以備官為節；", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0016", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 16, "canonical_ref": "禮記·《射義》 16", "sort_key": "0016", "text_original": "諸侯以時會天子為節；", "text_normalized": "諸侯以時會天子為節；", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0017", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 17, "canonical_ref": "禮記·《射義》 17", "sort_key": "0017", "text_original": "卿大夫以循法為節；", "text_normalized": "卿大夫以循法為節；", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0018", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 18, "canonical_ref": "禮記·《射義》 18", "sort_key": "0018", "text_original": "士以不失職為節。", "text_normalized": "士以不失職為節。", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0019", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 19, "canonical_ref": "禮記·《射義》 19", "sort_key": "0019", "text_original": "故明乎其節之志，以不失其事，則功成而德行立，德行立則無暴亂之禍矣。", "text_normalized": "故明乎其節之志，以不失其事，則功成而德行立，德行立則無暴亂之禍矣。", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0020", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 20, "canonical_ref": "禮記·《射義》 20", "sort_key": "0020", "text_original": "功成則國安。", "text_normalized": "功成則國安。", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0021", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 21, "canonical_ref": "禮記·《射義》 21", "sort_key": "0021", "text_original": "故曰：", "text_normalized": "故曰：", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0022", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 22, "canonical_ref": "禮記·《射義》 22", "sort_key": "0022", "text_original": "射者，所以觀盛德也。", "text_normalized": "射者，所以觀盛德也。", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0023", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 23, "canonical_ref": "禮記·《射義》 23", "sort_key": "0023", "text_original": "是故古者天子以射選諸侯、卿、大夫、士。", "text_normalized": "是故古者天子以射選諸侯、卿、大夫、士。", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0024", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 24, "canonical_ref": "禮記·《射義》 24", "sort_key": "0024", "text_original": "射者，男子之事也，因而飾之以禮樂也。", "text_normalized": "射者，男子之事也，因而飾之以禮樂也。", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0025", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 25, "canonical_ref": "禮記·《射義》 25", "sort_key": "0025", "text_original": "故事之盡禮樂，而可數為，以立德行者，莫若射，故聖王務焉。", "text_normalized": "故事之盡禮樂，而可數為，以立德行者，莫若射，故聖王務焉。", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0026", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 26, "canonical_ref": "禮記·《射義》 26", "sort_key": "0026", "text_original": "是故古者天子之制，諸侯歲獻貢士於天子，天子試之於射宮。", "text_normalized": "是故古者天子之制，諸侯歲獻貢士於天子，天子試之於射宮。", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0027", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 27, "canonical_ref": "禮記·《射義》 27", "sort_key": "0027", "text_original": "其容體比於禮，其節比於樂，而中多者，得與於祭。", "text_normalized": "其容體比於禮，其節比於樂，而中多者，得與於祭。", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0028", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 28, "canonical_ref": "禮記·《射義》 28", "sort_key": "0028", "text_original": "其容體不比於禮，其節不比於樂，而中少者，不得與於祭。", "text_normalized": "其容體不比於禮，其節不比於樂，而中少者，不得與於祭。", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0029", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 29, "canonical_ref": "禮記·《射義》 29", "sort_key": "0029", "text_original": "數與於祭而君有慶；", "text_normalized": "數與於祭而君有慶；", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0030", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 30, "canonical_ref": "禮記·《射義》 30", "sort_key": "0030", "text_original": "數不與於祭而君有讓。", "text_normalized": "數不與於祭而君有讓。", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0031", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 31, "canonical_ref": "禮記·《射義》 31", "sort_key": "0031", "text_original": "數有慶而益地；", "text_normalized": "數有慶而益地；", "notes": ""}
