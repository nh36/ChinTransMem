{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0035", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 35, "canonical_ref": "禮記·《射義》 35", "sort_key": "0035", "text_original": "是以諸侯君臣盡志於射，以習禮樂。", "text_normalized": "是以諸侯君臣盡志於射，以習禮樂。", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0036", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 36, "canonical_ref": "禮記·《射義》 36", "sort_key": "0036", "text_original": "夫君臣習禮樂而以流亡者，未之有也。", "text_normalized": "夫君臣習禮樂而以流亡者，未之有也。", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0037", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 37, "canonical_ref": "禮記·《射義》 37", "sort_key": "0037", "text_original": "故《詩》曰：", "text_normalized": "故《詩》曰：", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0038", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 38, "canonical_ref": "禮記·《射義》 38", "sort_key": "0038", "text_original": "「曾孫侯氏，四正具舉；", "text_normalized": "「曾孫侯氏，四正具舉；", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0039", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 39, "canonical_ref": "禮記·《射義》 39", "sort_key": "0039", "text_original": "大夫君子，凡以庶士，小大莫處，御于君所，以燕以射，則燕則譽。", "text_normalized": "大夫君子，凡以庶士，小大莫處，御于君所，以燕以射，則燕則譽。", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0040", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 40, "canonical_ref": "禮記·《射義》 40", "sort_key": "0040", "text_original": "」言君臣相與盡志於射，以習禮樂，則安則譽也。", "text_normalized": "」言君臣相與盡志於射，以習禮樂，則安則譽也。", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0041", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 41, "canonical_ref": "禮記·《射義》 41", "sort_key": "0041", "text_original": "是以天子制之，而諸侯務焉。", "text_normalized": "是以天子制之，而諸侯務焉。", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0042", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 42, "canonical_ref": "禮記·《射義》 42", "sort_key": "0042", "text_original": "此天子之所以養諸侯，而兵不用，諸侯自為正之具也。", "text_normalized": "此天子之所以養諸侯，而兵不用，諸侯自為正之具也。", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0043", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 43, "canonical_ref": "禮記·《射義》 43", "sort_key": "0043", "text_original": "孔子射於矍相之圃，蓋觀者如堵墻。", "text_normalized": "孔子射於矍相之圃，蓋觀者如堵墻。", "notes": ""}
{"segment_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3__seg-0044", "work_id": "liji", "section_id": "liji-046-the-meaning-of-the-ceremony-of-archery", "source_id": "liji-046-the-meaning-of-the-ceremony-of-archery__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "sentence", "segment_order": 44, "canonical_ref": "禮記·《射義》 44", "sort_key": "0044", "text_original": "射至於司馬，使子路執弓矢，出延射曰：", "text_normalized": "射至於司馬，使子路執弓矢，出延射曰：", "notes": ""}
