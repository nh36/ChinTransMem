{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0001", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 1, "canonical_ref": "禮記·《喪服小記》 block 1", "sort_key": "0001", "text_original": "斬衰，括髮以麻；為母，括髮以麻，免而以布。齊衰，惡笄以終喪。", "text_normalized": "斬衰，括髮以麻；為母，括髮以麻，免而以布。齊衰，惡笄以終喪。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0002", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 2, "canonical_ref": "禮記·《喪服小記》 block 2", "sort_key": "0002", "text_original": "男子冠而婦人笄，男子免而婦人髽。其義：為男子則免，為婦人則髽。", "text_normalized": "男子冠而婦人笄，男子免而婦人髽。其義：為男子則免，為婦人則髽。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0003", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 3, "canonical_ref": "禮記·《喪服小記》 block 3", "sort_key": "0003", "text_original": "苴杖，竹也；削杖，桐也。", "text_normalized": "苴杖，竹也；削杖，桐也。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0004", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 4, "canonical_ref": "禮記·《喪服小記》 block 4", "sort_key": "0004", "text_original": "祖父卒，而後為祖母后者三年。", "text_normalized": "祖父卒，而後為祖母后者三年。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0005", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 5, "canonical_ref": "禮記·《喪服小記》 block 5", "sort_key": "0005", "text_original": "為父母，長子稽顙。大夫吊之，雖緦必稽顙。婦人為夫與長子稽顙，其餘則否。", "text_normalized": "為父母，長子稽顙。大夫吊之，雖緦必稽顙。婦人為夫與長子稽顙，其餘則否。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0006", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 6, "canonical_ref": "禮記·《喪服小記》 block 6", "sort_key": "0006", "text_original": "男主必使同姓，婦主必使異姓。", "text_normalized": "男主必使同姓，婦主必使異姓。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0007", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 7, "canonical_ref": "禮記·《喪服小記》 block 7", "sort_key": "0007", "text_original": "為父後者為出母無服。", "text_normalized": "為父後者為出母無服。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0008", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 8, "canonical_ref": "禮記·《喪服小記》 block 8", "sort_key": "0008", "text_original": "親親，以三為五，以五為九。上殺，下殺，旁殺，而親畢矣。", "text_normalized": "親親，以三為五，以五為九。上殺，下殺，旁殺，而親畢矣。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0009", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 9, "canonical_ref": "禮記·《喪服小記》 block 9", "sort_key": "0009", "text_original": "王者禘其祖之所自出，以其祖配之，而立四廟。庶子王，亦如之。", "text_normalized": "王者禘其祖之所自出，以其祖配之，而立四廟。庶子王，亦如之。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0010", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 10, "canonical_ref": "禮記·《喪服小記》 block 10", "sort_key": "0010", "text_original": "別子為祖，繼別為宗，繼禰者為小宗。有五世而遷之宗，其繼高祖者也。是故，祖遷於上，宗易於下。尊祖故敬宗，敬宗所以尊祖禰也。", "text_normalized": "別子為祖，繼別為宗，繼禰者為小宗。有五世而遷之宗，其繼高祖者也。是故，祖遷於上，宗易於下。尊祖故敬宗，敬宗所以尊祖禰也。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0011", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 11, "canonical_ref": "禮記·《喪服小記》 block 11", "sort_key": "0011", "text_original": "庶子不祭祖者，明其宗也。庶子不為長子斬，不繼祖與禰故也。庶子不祭殤與無後者，殤與無後者從祖祔食。庶子不祭禰者，明其宗也。", "text_normalized": "庶子不祭祖者，明其宗也。庶子不為長子斬，不繼祖與禰故也。庶子不祭殤與無後者，殤與無後者從祖祔食。庶子不祭禰者，明其宗也。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0012", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 12, "canonical_ref": "禮記·《喪服小記》 block 12", "sort_key": "0012", "text_original": "親親尊尊長長，男女之有別，人道之大者也。", "text_normalized": "親親尊尊長長，男女之有別，人道之大者也。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0013", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 13, "canonical_ref": "禮記·《喪服小記》 block 13", "sort_key": "0013", "text_original": "從服者，所從亡則已。屬從者，所從雖沒也服。妾從女君而出，則不為女君之子服。", "text_normalized": "從服者，所從亡則已。屬從者，所從雖沒也服。妾從女君而出，則不為女君之子服。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0014", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 14, "canonical_ref": "禮記·《喪服小記》 block 14", "sort_key": "0014", "text_original": "禮不王不禘。", "text_normalized": "禮不王不禘。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0015", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 15, "canonical_ref": "禮記·《喪服小記》 block 15", "sort_key": "0015", "text_original": "世子不降妻之父母；其為妻也，與大夫之適子同。", "text_normalized": "世子不降妻之父母；其為妻也，與大夫之適子同。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0016", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 16, "canonical_ref": "禮記·《喪服小記》 block 16", "sort_key": "0016", "text_original": "父為士，子為天子諸侯，則祭以天子諸侯，其尸服以士服。父為天子諸侯，子為士，祭以士，其尸服以士服。", "text_normalized": "父為士，子為天子諸侯，則祭以天子諸侯，其尸服以士服。父為天子諸侯，子為士，祭以士，其尸服以士服。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0017", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 17, "canonical_ref": "禮記·《喪服小記》 block 17", "sort_key": "0017", "text_original": "婦當喪而出，則除之。為父母喪，未練而出，則三年。既練而出，則已。未練而反，則期；既練而反，則遂之。", "text_normalized": "婦當喪而出，則除之。為父母喪，未練而出，則三年。既練而出，則已。未練而反，則期；既練而反，則遂之。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0018", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 18, "canonical_ref": "禮記·《喪服小記》 block 18", "sort_key": "0018", "text_original": "再期之喪，三年也；期之喪，二年也。九月七月之喪，三時也；五月之喪，二時也；三月之喪，一時也。故期而祭，禮也；期而除喪，道也。祭不為除喪也。", "text_normalized": "再期之喪，三年也；期之喪，二年也。九月七月之喪，三時也；五月之喪，二時也；三月之喪，一時也。故期而祭，禮也；期而除喪，道也。祭不為除喪也。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0019", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 19, "canonical_ref": "禮記·《喪服小記》 block 19", "sort_key": "0019", "text_original": "三年而後葬者必再祭，其祭之間不同時而除喪。", "text_normalized": "三年而後葬者必再祭，其祭之間不同時而除喪。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0020", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 20, "canonical_ref": "禮記·《喪服小記》 block 20", "sort_key": "0020", "text_original": "大功者主人之喪，有三年者，則必為之再祭。朋友，虞祔而已。", "text_normalized": "大功者主人之喪，有三年者，則必為之再祭。朋友，虞祔而已。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0021", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 21, "canonical_ref": "禮記·《喪服小記》 block 21", "sort_key": "0021", "text_original": "士妾有子，而為之緦，無子則已。", "text_normalized": "士妾有子，而為之緦，無子則已。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0022", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 22, "canonical_ref": "禮記·《喪服小記》 block 22", "sort_key": "0022", "text_original": "生不及祖父母諸父昆弟，而父稅喪，己則否。降而在緦小功者，則稅之。", "text_normalized": "生不及祖父母諸父昆弟，而父稅喪，己則否。降而在緦小功者，則稅之。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0023", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 23, "canonical_ref": "禮記·《喪服小記》 block 23", "sort_key": "0023", "text_original": "為君之父母、妻、長子，君已除喪而後聞喪，則不稅。近臣，君服斯服矣；其餘，從而服，不從而稅。君雖未知喪，臣服已。", "text_normalized": "為君之父母、妻、長子，君已除喪而後聞喪，則不稅。近臣，君服斯服矣；其餘，從而服，不從而稅。君雖未知喪，臣服已。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0024", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 24, "canonical_ref": "禮記·《喪服小記》 block 24", "sort_key": "0024", "text_original": "虞，杖不入於室；祔，杖不升於堂。", "text_normalized": "虞，杖不入於室；祔，杖不升於堂。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0025", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 25, "canonical_ref": "禮記·《喪服小記》 block 25", "sort_key": "0025", "text_original": "為君母后者，君母卒，則不為君母之黨服。", "text_normalized": "為君母后者，君母卒，則不為君母之黨服。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0026", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 26, "canonical_ref": "禮記·《喪服小記》 block 26", "sort_key": "0026", "text_original": "絰殺五分而去一，杖大如絰。", "text_normalized": "絰殺五分而去一，杖大如絰。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0027", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 27, "canonical_ref": "禮記·《喪服小記》 block 27", "sort_key": "0027", "text_original": "妾為君之長子與女君同。", "text_normalized": "妾為君之長子與女君同。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0028", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 28, "canonical_ref": "禮記·《喪服小記》 block 28", "sort_key": "0028", "text_original": "除喪者，先重者；易服者，易輕者。", "text_normalized": "除喪者，先重者；易服者，易輕者。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0029", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 29, "canonical_ref": "禮記·《喪服小記》 block 29", "sort_key": "0029", "text_original": "無事不辟廟門。哭皆於其次。", "text_normalized": "無事不辟廟門。哭皆於其次。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0030", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 30, "canonical_ref": "禮記·《喪服小記》 block 30", "sort_key": "0030", "text_original": "復與書銘，自天子達於士，其辭一也。男子稱名，婦人書姓與伯仲，如不知姓則書氏。", "text_normalized": "復與書銘，自天子達於士，其辭一也。男子稱名，婦人書姓與伯仲，如不知姓則書氏。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0031", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 31, "canonical_ref": "禮記·《喪服小記》 block 31", "sort_key": "0031", "text_original": "斬衰之葛與齊衰之麻同。齊衰之葛與大功之麻同。麻同，皆兼服之。", "text_normalized": "斬衰之葛與齊衰之麻同。齊衰之葛與大功之麻同。麻同，皆兼服之。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0032", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 32, "canonical_ref": "禮記·《喪服小記》 block 32", "sort_key": "0032", "text_original": "報葬者報虞，三月而後卒哭。", "text_normalized": "報葬者報虞，三月而後卒哭。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0033", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 33, "canonical_ref": "禮記·《喪服小記》 block 33", "sort_key": "0033", "text_original": "父母之喪偕，先葬者不虞祔，待後事。其葬，服斬衰。", "text_normalized": "父母之喪偕，先葬者不虞祔，待後事。其葬，服斬衰。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0034", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 34, "canonical_ref": "禮記·《喪服小記》 block 34", "sort_key": "0034", "text_original": "大夫降其庶子，其孫不降其父。大夫不主士之喪。", "text_normalized": "大夫降其庶子，其孫不降其父。大夫不主士之喪。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0035", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 35, "canonical_ref": "禮記·《喪服小記》 block 35", "sort_key": "0035", "text_original": "為慈母之父母無服。", "text_normalized": "為慈母之父母無服。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0036", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 36, "canonical_ref": "禮記·《喪服小記》 block 36", "sort_key": "0036", "text_original": "夫為人後者，其妻為舅姑大功。", "text_normalized": "夫為人後者，其妻為舅姑大功。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0037", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 37, "canonical_ref": "禮記·《喪服小記》 block 37", "sort_key": "0037", "text_original": "士祔於大夫則易牲。", "text_normalized": "士祔於大夫則易牲。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0038", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 38, "canonical_ref": "禮記·《喪服小記》 block 38", "sort_key": "0038", "text_original": "繼父不同居也者；必嘗同居。皆無主後。同財而祭其祖禰為同居；有主後者為異居。", "text_normalized": "繼父不同居也者；必嘗同居。皆無主後。同財而祭其祖禰為同居；有主後者為異居。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0039", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 39, "canonical_ref": "禮記·《喪服小記》 block 39", "sort_key": "0039", "text_original": "哭朋友者於門外之右南面。", "text_normalized": "哭朋友者於門外之右南面。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0040", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 40, "canonical_ref": "禮記·《喪服小記》 block 40", "sort_key": "0040", "text_original": "祔葬者不筮宅。", "text_normalized": "祔葬者不筮宅。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0041", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 41, "canonical_ref": "禮記·《喪服小記》 block 41", "sort_key": "0041", "text_original": "士大夫不得祔於諸侯，祔於諸祖父之為士大夫者，其妻祔於諸祖姑，妾祔於妾祖姑；亡則中一以上而祔。祔必以其昭穆。諸侯不得祔於天子，天子、諸侯、大夫可以祔於士。", "text_normalized": "士大夫不得祔於諸侯，祔於諸祖父之為士大夫者，其妻祔於諸祖姑，妾祔於妾祖姑；亡則中一以上而祔。祔必以其昭穆。諸侯不得祔於天子，天子、諸侯、大夫可以祔於士。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0042", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 42, "canonical_ref": "禮記·《喪服小記》 block 42", "sort_key": "0042", "text_original": "為母之君母，母卒則不服。", "text_normalized": "為母之君母，母卒則不服。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0043", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 43, "canonical_ref": "禮記·《喪服小記》 block 43", "sort_key": "0043", "text_original": "宗子，母在為妻禫。", "text_normalized": "宗子，母在為妻禫。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0044", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 44, "canonical_ref": "禮記·《喪服小記》 block 44", "sort_key": "0044", "text_original": "為慈母后者，為庶母可也，為祖庶母可也。", "text_normalized": "為慈母后者，為庶母可也，為祖庶母可也。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0045", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 45, "canonical_ref": "禮記·《喪服小記》 block 45", "sort_key": "0045", "text_original": "為父、母、妻、長子禫。", "text_normalized": "為父、母、妻、長子禫。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0046", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 46, "canonical_ref": "禮記·《喪服小記》 block 46", "sort_key": "0046", "text_original": "慈母與妾母，不世祭也。", "text_normalized": "慈母與妾母，不世祭也。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0047", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 47, "canonical_ref": "禮記·《喪服小記》 block 47", "sort_key": "0047", "text_original": "丈夫冠而不為殤，婦人笄而不為殤。為殤後者，以其服服之。", "text_normalized": "丈夫冠而不為殤，婦人笄而不為殤。為殤後者，以其服服之。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0048", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 48, "canonical_ref": "禮記·《喪服小記》 block 48", "sort_key": "0048", "text_original": "久而不葬者，唯主喪者不除；其餘以麻終月數者，除喪則已。", "text_normalized": "久而不葬者，唯主喪者不除；其餘以麻終月數者，除喪則已。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0049", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 49, "canonical_ref": "禮記·《喪服小記》 block 49", "sort_key": "0049", "text_original": "箭笄終喪三年。", "text_normalized": "箭笄終喪三年。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0050", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 50, "canonical_ref": "禮記·《喪服小記》 block 50", "sort_key": "0050", "text_original": "齊衰三月與大功同者，繩屨。", "text_normalized": "齊衰三月與大功同者，繩屨。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0051", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 51, "canonical_ref": "禮記·《喪服小記》 block 51", "sort_key": "0051", "text_original": "練，筮日筮尸，視濯，皆要絰杖繩屨。有司告具，而後去杖。筮日筮尸，有司告事畢而後杖，拜送賓。大祥，吉服而筮尸。", "text_normalized": "練，筮日筮尸，視濯，皆要絰杖繩屨。有司告具，而後去杖。筮日筮尸，有司告事畢而後杖，拜送賓。大祥，吉服而筮尸。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0052", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 52, "canonical_ref": "禮記·《喪服小記》 block 52", "sort_key": "0052", "text_original": "庶子在父之室，則為其母不禫。庶子不以杖即位。父不主庶子之喪，則孫以杖即位可也。父在，庶子為妻以杖即位可也。", "text_normalized": "庶子在父之室，則為其母不禫。庶子不以杖即位。父不主庶子之喪，則孫以杖即位可也。父在，庶子為妻以杖即位可也。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0053", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 53, "canonical_ref": "禮記·《喪服小記》 block 53", "sort_key": "0053", "text_original": "諸侯吊於異國之臣，則其君為主。", "text_normalized": "諸侯吊於異國之臣，則其君為主。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0054", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 54, "canonical_ref": "禮記·《喪服小記》 block 54", "sort_key": "0054", "text_original": "諸侯吊，必皮弁錫衰。所吊雖已葬，主人必免。主人未喪服，則君於不錫衰。", "text_normalized": "諸侯吊，必皮弁錫衰。所吊雖已葬，主人必免。主人未喪服，則君於不錫衰。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0055", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 55, "canonical_ref": "禮記·《喪服小記》 block 55", "sort_key": "0055", "text_original": "養有疾者不喪服，遂以主其喪。非養者入主人之喪，則不易己之喪服。養尊者必易服，養卑者否。", "text_normalized": "養有疾者不喪服，遂以主其喪。非養者入主人之喪，則不易己之喪服。養尊者必易服，養卑者否。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0056", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 56, "canonical_ref": "禮記·《喪服小記》 block 56", "sort_key": "0056", "text_original": "妾無妾祖姑者，易牲而祔於女君可也。", "text_normalized": "妾無妾祖姑者，易牲而祔於女君可也。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0057", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 57, "canonical_ref": "禮記·《喪服小記》 block 57", "sort_key": "0057", "text_original": "婦之喪、虞、卒哭，其夫若子主之。祔，則舅主之。", "text_normalized": "婦之喪、虞、卒哭，其夫若子主之。祔，則舅主之。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0058", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 58, "canonical_ref": "禮記·《喪服小記》 block 58", "sort_key": "0058", "text_original": "士不攝大夫。士攝大夫，唯宗子。", "text_normalized": "士不攝大夫。士攝大夫，唯宗子。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0059", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 59, "canonical_ref": "禮記·《喪服小記》 block 59", "sort_key": "0059", "text_original": "主人未除喪，有兄弟自他國至，則主人不免而為主。", "text_normalized": "主人未除喪，有兄弟自他國至，則主人不免而為主。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0060", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 60, "canonical_ref": "禮記·《喪服小記》 block 60", "sort_key": "0060", "text_original": "陳器之道，多陳之而省納之可也；省陳之而盡納之可也。", "text_normalized": "陳器之道，多陳之而省納之可也；省陳之而盡納之可也。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0061", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 61, "canonical_ref": "禮記·《喪服小記》 block 61", "sort_key": "0061", "text_original": "奔兄弟之喪，先之墓而後之家，為位而哭。所知之喪，則哭於宮而後之墓。", "text_normalized": "奔兄弟之喪，先之墓而後之家，為位而哭。所知之喪，則哭於宮而後之墓。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0062", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 62, "canonical_ref": "禮記·《喪服小記》 block 62", "sort_key": "0062", "text_original": "父不為眾子次於外。", "text_normalized": "父不為眾子次於外。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0063", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 63, "canonical_ref": "禮記·《喪服小記》 block 63", "sort_key": "0063", "text_original": "與諸侯為兄弟者服斬。", "text_normalized": "與諸侯為兄弟者服斬。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0064", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 64, "canonical_ref": "禮記·《喪服小記》 block 64", "sort_key": "0064", "text_original": "下殤小功，帶，澡麻不絕本，詘而反以報之。", "text_normalized": "下殤小功，帶，澡麻不絕本，詘而反以報之。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0065", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 65, "canonical_ref": "禮記·《喪服小記》 block 65", "sort_key": "0065", "text_original": "婦祔於祖姑，祖姑有三人，則祔於親者。", "text_normalized": "婦祔於祖姑，祖姑有三人，則祔於親者。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0066", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 66, "canonical_ref": "禮記·《喪服小記》 block 66", "sort_key": "0066", "text_original": "其妻為大夫而卒，而後其夫不為大夫，而祔於其妻則不易牲。", "text_normalized": "其妻為大夫而卒，而後其夫不為大夫，而祔於其妻則不易牲。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0067", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 67, "canonical_ref": "禮記·《喪服小記》 block 67", "sort_key": "0067", "text_original": "為父後者，為出母無服。無服也者，喪者不祭故也。", "text_normalized": "為父後者，為出母無服。無服也者，喪者不祭故也。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0068", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 68, "canonical_ref": "禮記·《喪服小記》 block 68", "sort_key": "0068", "text_original": "婦人不為主而杖者：姑在為夫杖，母為長子削杖。女子子在室為父母，其主喪者不杖，則子一人杖。", "text_normalized": "婦人不為主而杖者：姑在為夫杖，母為長子削杖。女子子在室為父母，其主喪者不杖，則子一人杖。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0069", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 69, "canonical_ref": "禮記·《喪服小記》 block 69", "sort_key": "0069", "text_original": "緦小功，虞卒哭則免。既葬而不報虞，則雖主人皆冠，及虞則皆免。為兄弟既除喪已。及其葬也，反服其服。報虞卒哭則免。如不報虞則除之。遠葬者比反哭者皆冠，及郊而後免反哭。", "text_normalized": "緦小功，虞卒哭則免。既葬而不報虞，則雖主人皆冠，及虞則皆免。為兄弟既除喪已。及其葬也，反服其服。報虞卒哭則免。如不報虞則除之。遠葬者比反哭者皆冠，及郊而後免反哭。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0070", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 70, "canonical_ref": "禮記·《喪服小記》 block 70", "sort_key": "0070", "text_original": "君吊，雖不當免時也，主人必免，不散麻。雖異國之君，免也。親者皆免。", "text_normalized": "君吊，雖不當免時也，主人必免，不散麻。雖異國之君，免也。親者皆免。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0071", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 71, "canonical_ref": "禮記·《喪服小記》 block 71", "sort_key": "0071", "text_original": "除殤之喪者，其祭也必玄。除成喪者，其祭也朝服縞冠。", "text_normalized": "除殤之喪者，其祭也必玄。除成喪者，其祭也朝服縞冠。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0072", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 72, "canonical_ref": "禮記·《喪服小記》 block 72", "sort_key": "0072", "text_original": "奔父之喪，括髮於堂上，袒降踴，襲絰于東方。奔母之喪，不括髮，袒於堂上，降踴，襲免于東方。絰即位成踴，出門哭止。三日而五哭三袒。", "text_normalized": "奔父之喪，括髮於堂上，袒降踴，襲絰于東方。奔母之喪，不括髮，袒於堂上，降踴，襲免于東方。絰即位成踴，出門哭止。三日而五哭三袒。", "notes": ""}
{"segment_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3__seg-0073", "work_id": "liji", "section_id": "liji-015-record-of-small-matters-in-the-dress-of", "source_id": "liji-015-record-of-small-matters-in-the-dress-of__cn-zh-1f6b1d3", "language": "zh-Hant", "segment_type": "block", "segment_order": 73, "canonical_ref": "禮記·《喪服小記》 block 73", "sort_key": "0073", "text_original": "適婦不為舅後者，則姑為之小功。", "text_normalized": "適婦不為舅後者，則姑為之小功。", "notes": ""}
