{"segment_id": "laozi-chapter-022__legge-chinesenotes-1891__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-022", "source_id": "laozi-chapter-022__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 22.1", "sort_key": "022.001", "text_original": "The partial becomes complete;", "text_normalized": "The partial becomes complete;", "notes": ""}
{"segment_id": "laozi-chapter-022__legge-chinesenotes-1891__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-022", "source_id": "laozi-chapter-022__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 22.2", "sort_key": "022.002", "text_original": "the crooked, straight;", "text_normalized": "the crooked, straight;", "notes": ""}
{"segment_id": "laozi-chapter-022__legge-chinesenotes-1891__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-022", "source_id": "laozi-chapter-022__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 22.3", "sort_key": "022.003", "text_original": "the empty, full;", "text_normalized": "the empty, full;", "notes": ""}
{"segment_id": "laozi-chapter-022__legge-chinesenotes-1891__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-022", "source_id": "laozi-chapter-022__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 22.4", "sort_key": "022.004", "text_original": "the worn out, new.", "text_normalized": "the worn out, new.", "notes": ""}
{"segment_id": "laozi-chapter-022__legge-chinesenotes-1891__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-022", "source_id": "laozi-chapter-022__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 22.5", "sort_key": "022.005", "text_original": "He whose (desires) are few gets them;", "text_normalized": "He whose (desires) are few gets them;", "notes": ""}
{"segment_id": "laozi-chapter-022__legge-chinesenotes-1891__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-022", "source_id": "laozi-chapter-022__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 22.6", "sort_key": "022.006", "text_original": "he whose (desires) are many goes astray.", "text_normalized": "he whose (desires) are many goes astray.", "notes": ""}
{"segment_id": "laozi-chapter-022__legge-chinesenotes-1891__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-022", "source_id": "laozi-chapter-022__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 22.7", "sort_key": "022.007", "text_original": "Therefore the sage holds in his embrace the one thing (of humility), and manifests it to all the world.", "text_normalized": "Therefore the sage holds in his embrace the one thing (of humility), and manifests it to all the world.", "notes": ""}
{"segment_id": "laozi-chapter-022__legge-chinesenotes-1891__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-022", "source_id": "laozi-chapter-022__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 22.8", "sort_key": "022.008", "text_original": "He is free from self- display, and therefore he shines;", "text_normalized": "He is free from self- display, and therefore he shines;", "notes": ""}
{"segment_id": "laozi-chapter-022__legge-chinesenotes-1891__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-022", "source_id": "laozi-chapter-022__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 22.9", "sort_key": "022.009", "text_original": "from self-assertion, and therefore he is distinguished;", "text_normalized": "from self-assertion, and therefore he is distinguished;", "notes": ""}
{"segment_id": "laozi-chapter-022__legge-chinesenotes-1891__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-022", "source_id": "laozi-chapter-022__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 22.10", "sort_key": "022.010", "text_original": "from self-boasting, and therefore his merit is acknowledged;", "text_normalized": "from self-boasting, and therefore his merit is acknowledged;", "notes": ""}
{"segment_id": "laozi-chapter-022__legge-chinesenotes-1891__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-022", "source_id": "laozi-chapter-022__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 22.11", "sort_key": "022.011", "text_original": "from self-complacency, and therefore he acquires superiority.", "text_normalized": "from self-complacency, and therefore he acquires superiority.", "notes": ""}
{"segment_id": "laozi-chapter-022__legge-chinesenotes-1891__seg-012", "work_id": "laozi", "section_id": "laozi-chapter-022", "source_id": "laozi-chapter-022__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 12, "canonical_ref": "老子 22.12", "sort_key": "022.012", "text_original": "It is because he is thus free from striving that therefore no one in the world is able to strive with him.", "text_normalized": "It is because he is thus free from striving that therefore no one in the world is able to strive with him.", "notes": ""}
{"segment_id": "laozi-chapter-022__legge-chinesenotes-1891__seg-013", "work_id": "laozi", "section_id": "laozi-chapter-022", "source_id": "laozi-chapter-022__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 13, "canonical_ref": "老子 22.13", "sort_key": "022.013", "text_original": "That saying of the ancients that 'the partial becomes complete' was not vainly spoken:", "text_normalized": "That saying of the ancients that 'the partial becomes complete' was not vainly spoken:", "notes": ""}
{"segment_id": "laozi-chapter-022__legge-chinesenotes-1891__seg-014", "work_id": "laozi", "section_id": "laozi-chapter-022", "source_id": "laozi-chapter-022__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 14, "canonical_ref": "老子 22.14", "sort_key": "022.014", "text_original": "- all real completion is comprehended under it.", "text_normalized": "- all real completion is comprehended under it.", "notes": ""}
