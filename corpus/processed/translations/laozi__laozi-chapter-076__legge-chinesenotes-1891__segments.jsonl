{"segment_id": "laozi-chapter-076__legge-chinesenotes-1891__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-076", "source_id": "laozi-chapter-076__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 76.1", "sort_key": "076.001", "text_original": "Man at his birth is supple and weak;", "text_normalized": "Man at his birth is supple and weak;", "notes": ""}
{"segment_id": "laozi-chapter-076__legge-chinesenotes-1891__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-076", "source_id": "laozi-chapter-076__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 76.2", "sort_key": "076.002", "text_original": "at his death, firm and strong.", "text_normalized": "at his death, firm and strong.", "notes": ""}
{"segment_id": "laozi-chapter-076__legge-chinesenotes-1891__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-076", "source_id": "laozi-chapter-076__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 76.3", "sort_key": "076.003", "text_original": "(So it is with) all things.", "text_normalized": "(So it is with) all things.", "notes": ""}
{"segment_id": "laozi-chapter-076__legge-chinesenotes-1891__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-076", "source_id": "laozi-chapter-076__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 76.4", "sort_key": "076.004", "text_original": "Trees and plants, in their early growth, are soft and brittle;", "text_normalized": "Trees and plants, in their early growth, are soft and brittle;", "notes": ""}
{"segment_id": "laozi-chapter-076__legge-chinesenotes-1891__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-076", "source_id": "laozi-chapter-076__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 76.5", "sort_key": "076.005", "text_original": "at their death, dry and withered.", "text_normalized": "at their death, dry and withered.", "notes": ""}
{"segment_id": "laozi-chapter-076__legge-chinesenotes-1891__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-076", "source_id": "laozi-chapter-076__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 76.6", "sort_key": "076.006", "text_original": "Thus it is that firmness and strength are the concomitants of death;", "text_normalized": "Thus it is that firmness and strength are the concomitants of death;", "notes": ""}
{"segment_id": "laozi-chapter-076__legge-chinesenotes-1891__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-076", "source_id": "laozi-chapter-076__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 76.7", "sort_key": "076.007", "text_original": "softness and weakness, the concomitants of life.", "text_normalized": "softness and weakness, the concomitants of life.", "notes": ""}
{"segment_id": "laozi-chapter-076__legge-chinesenotes-1891__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-076", "source_id": "laozi-chapter-076__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 76.8", "sort_key": "076.008", "text_original": "Hence he who (relies on) the strength of his forces does not conquer;", "text_normalized": "Hence he who (relies on) the strength of his forces does not conquer;", "notes": ""}
{"segment_id": "laozi-chapter-076__legge-chinesenotes-1891__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-076", "source_id": "laozi-chapter-076__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 76.9", "sort_key": "076.009", "text_original": "and a tree which is strong will fill the out-stretched arms, (and thereby invites the feller.)", "text_normalized": "and a tree which is strong will fill the out-stretched arms, (and thereby invites the feller.)", "notes": ""}
{"segment_id": "laozi-chapter-076__legge-chinesenotes-1891__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-076", "source_id": "laozi-chapter-076__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 76.10", "sort_key": "076.010", "text_original": "Therefore the place of what is firm and strong is below, and that of what is soft and weak is above.", "text_normalized": "Therefore the place of what is firm and strong is below, and that of what is soft and weak is above.", "notes": ""}
