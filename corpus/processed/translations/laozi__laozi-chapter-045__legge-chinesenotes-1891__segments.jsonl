{"segment_id": "laozi-chapter-045__legge-chinesenotes-1891__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-045", "source_id": "laozi-chapter-045__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 45.1", "sort_key": "045.001", "text_original": "Who thinks his great achievements poor", "text_normalized": "Who thinks his great achievements poor", "notes": ""}
{"segment_id": "laozi-chapter-045__legge-chinesenotes-1891__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-045", "source_id": "laozi-chapter-045__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 45.2", "sort_key": "045.002", "text_original": "Shall find his vigour long endure.", "text_normalized": "Shall find his vigour long endure.", "notes": ""}
{"segment_id": "laozi-chapter-045__legge-chinesenotes-1891__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-045", "source_id": "laozi-chapter-045__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 45.3", "sort_key": "045.003", "text_original": "Of greatest fulness, deemed a void,", "text_normalized": "Of greatest fulness, deemed a void,", "notes": ""}
{"segment_id": "laozi-chapter-045__legge-chinesenotes-1891__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-045", "source_id": "laozi-chapter-045__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 45.4", "sort_key": "045.004", "text_original": "Exhaustion never shall stem the tide.", "text_normalized": "Exhaustion never shall stem the tide.", "notes": ""}
{"segment_id": "laozi-chapter-045__legge-chinesenotes-1891__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-045", "source_id": "laozi-chapter-045__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 45.5", "sort_key": "045.005", "text_original": "Do thou what's straight still crooked deem;", "text_normalized": "Do thou what's straight still crooked deem;", "notes": ""}
{"segment_id": "laozi-chapter-045__legge-chinesenotes-1891__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-045", "source_id": "laozi-chapter-045__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 45.6", "sort_key": "045.006", "text_original": "Thy greatest art still stupid seem,", "text_normalized": "Thy greatest art still stupid seem,", "notes": ""}
{"segment_id": "laozi-chapter-045__legge-chinesenotes-1891__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-045", "source_id": "laozi-chapter-045__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 45.7", "sort_key": "045.007", "text_original": "And eloquence a stammering scream.", "text_normalized": "And eloquence a stammering scream.", "notes": ""}
{"segment_id": "laozi-chapter-045__legge-chinesenotes-1891__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-045", "source_id": "laozi-chapter-045__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 45.8", "sort_key": "045.008", "text_original": "Constant action overcomes cold;", "text_normalized": "Constant action overcomes cold;", "notes": ""}
{"segment_id": "laozi-chapter-045__legge-chinesenotes-1891__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-045", "source_id": "laozi-chapter-045__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 45.9", "sort_key": "045.009", "text_original": "being still overcomes heat.", "text_normalized": "being still overcomes heat.", "notes": ""}
{"segment_id": "laozi-chapter-045__legge-chinesenotes-1891__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-045", "source_id": "laozi-chapter-045__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 45.10", "sort_key": "045.010", "text_original": "Purity and stillness give the correct law to all under heaven.", "text_normalized": "Purity and stillness give the correct law to all under heaven.", "notes": ""}
