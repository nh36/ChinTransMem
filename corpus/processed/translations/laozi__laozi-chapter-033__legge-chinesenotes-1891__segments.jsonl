{"segment_id": "laozi-chapter-033__legge-chinesenotes-1891__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-033", "source_id": "laozi-chapter-033__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 33.1", "sort_key": "033.001", "text_original": "He who knows other men is discerning;", "text_normalized": "He who knows other men is discerning;", "notes": ""}
{"segment_id": "laozi-chapter-033__legge-chinesenotes-1891__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-033", "source_id": "laozi-chapter-033__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 33.2", "sort_key": "033.002", "text_original": "he who knows himself is intelligent.", "text_normalized": "he who knows himself is intelligent.", "notes": ""}
{"segment_id": "laozi-chapter-033__legge-chinesenotes-1891__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-033", "source_id": "laozi-chapter-033__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 33.3", "sort_key": "033.003", "text_original": "He who overcomes others is strong;", "text_normalized": "He who overcomes others is strong;", "notes": ""}
{"segment_id": "laozi-chapter-033__legge-chinesenotes-1891__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-033", "source_id": "laozi-chapter-033__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 33.4", "sort_key": "033.004", "text_original": "he who overcomes himself is mighty.", "text_normalized": "he who overcomes himself is mighty.", "notes": ""}
{"segment_id": "laozi-chapter-033__legge-chinesenotes-1891__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-033", "source_id": "laozi-chapter-033__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 33.5", "sort_key": "033.005", "text_original": "He who is satisfied with his lot is rich;", "text_normalized": "He who is satisfied with his lot is rich;", "notes": ""}
{"segment_id": "laozi-chapter-033__legge-chinesenotes-1891__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-033", "source_id": "laozi-chapter-033__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 33.6", "sort_key": "033.006", "text_original": "he who goes on acting with energy has a (firm) will.", "text_normalized": "he who goes on acting with energy has a (firm) will.", "notes": ""}
{"segment_id": "laozi-chapter-033__legge-chinesenotes-1891__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-033", "source_id": "laozi-chapter-033__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 33.7", "sort_key": "033.007", "text_original": "He who does not fail in the requirements of his position, continues long;", "text_normalized": "He who does not fail in the requirements of his position, continues long;", "notes": ""}
{"segment_id": "laozi-chapter-033__legge-chinesenotes-1891__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-033", "source_id": "laozi-chapter-033__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 33.8", "sort_key": "033.008", "text_original": "he who dies and yet does not perish, has longevity.", "text_normalized": "he who dies and yet does not perish, has longevity.", "notes": ""}
