{"segment_id": "laozi-chapter-042__legge-chinesenotes-1891__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-042", "source_id": "laozi-chapter-042__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 42.1", "sort_key": "042.001", "text_original": "The Dao produced One;", "text_normalized": "The Dao produced One;", "notes": ""}
{"segment_id": "laozi-chapter-042__legge-chinesenotes-1891__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-042", "source_id": "laozi-chapter-042__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 42.2", "sort_key": "042.002", "text_original": "One produced Two;", "text_normalized": "One produced Two;", "notes": ""}
{"segment_id": "laozi-chapter-042__legge-chinesenotes-1891__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-042", "source_id": "laozi-chapter-042__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 42.3", "sort_key": "042.003", "text_original": "Two produced Three;", "text_normalized": "Two produced Three;", "notes": ""}
{"segment_id": "laozi-chapter-042__legge-chinesenotes-1891__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-042", "source_id": "laozi-chapter-042__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 42.4", "sort_key": "042.004", "text_original": "Three produced All things.", "text_normalized": "Three produced All things.", "notes": ""}
{"segment_id": "laozi-chapter-042__legge-chinesenotes-1891__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-042", "source_id": "laozi-chapter-042__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 42.5", "sort_key": "042.005", "text_original": "All things leave behind them the Obscurity (out of which they have come), and go forward to embrace the Brightness (into which they have emerged), while they are harmonised by the Breath of Vacancy.", "text_normalized": "All things leave behind them the Obscurity (out of which they have come), and go forward to embrace the Brightness (into which they have emerged), while they are harmonised by the Breath of Vacancy.", "notes": ""}
{"segment_id": "laozi-chapter-042__legge-chinesenotes-1891__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-042", "source_id": "laozi-chapter-042__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 42.6", "sort_key": "042.006", "text_original": "What men dislike is to be orphans, to have little virtue, to be as carriages without naves;", "text_normalized": "What men dislike is to be orphans, to have little virtue, to be as carriages without naves;", "notes": ""}
{"segment_id": "laozi-chapter-042__legge-chinesenotes-1891__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-042", "source_id": "laozi-chapter-042__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 42.7", "sort_key": "042.007", "text_original": "and yet these are the designations which kings and princes use for themselves.", "text_normalized": "and yet these are the designations which kings and princes use for themselves.", "notes": ""}
{"segment_id": "laozi-chapter-042__legge-chinesenotes-1891__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-042", "source_id": "laozi-chapter-042__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 42.8", "sort_key": "042.008", "text_original": "So it is that some things are increased by being diminished, and others are diminished by being increased.", "text_normalized": "So it is that some things are increased by being diminished, and others are diminished by being increased.", "notes": ""}
{"segment_id": "laozi-chapter-042__legge-chinesenotes-1891__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-042", "source_id": "laozi-chapter-042__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 42.9", "sort_key": "042.009", "text_original": "What other men (thus) teach, I also teach.", "text_normalized": "What other men (thus) teach, I also teach.", "notes": ""}
{"segment_id": "laozi-chapter-042__legge-chinesenotes-1891__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-042", "source_id": "laozi-chapter-042__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 42.10", "sort_key": "042.010", "text_original": "The violent and strong do not die their natural death.", "text_normalized": "The violent and strong do not die their natural death.", "notes": ""}
{"segment_id": "laozi-chapter-042__legge-chinesenotes-1891__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-042", "source_id": "laozi-chapter-042__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 42.11", "sort_key": "042.011", "text_original": "I will make this the basis of my teaching.", "text_normalized": "I will make this the basis of my teaching.", "notes": ""}
