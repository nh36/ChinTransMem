{"segment_id": "laozi-chapter-028__legge-chinesenotes-1891__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-028", "source_id": "laozi-chapter-028__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 28.1", "sort_key": "028.001", "text_original": "Who knows his manhood's strength,", "text_normalized": "Who knows his manhood's strength,", "notes": ""}
{"segment_id": "laozi-chapter-028__legge-chinesenotes-1891__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-028", "source_id": "laozi-chapter-028__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 28.2", "sort_key": "028.002", "text_original": "Yet still his female feebleness maintains;", "text_normalized": "Yet still his female feebleness maintains;", "notes": ""}
{"segment_id": "laozi-chapter-028__legge-chinesenotes-1891__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-028", "source_id": "laozi-chapter-028__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 28.3", "sort_key": "028.003", "text_original": "As to one channel flow the many drains,", "text_normalized": "As to one channel flow the many drains,", "notes": ""}
{"segment_id": "laozi-chapter-028__legge-chinesenotes-1891__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-028", "source_id": "laozi-chapter-028__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 28.4", "sort_key": "028.004", "text_original": "All come to him, yea, all beneath the sky.", "text_normalized": "All come to him, yea, all beneath the sky.", "notes": ""}
{"segment_id": "laozi-chapter-028__legge-chinesenotes-1891__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-028", "source_id": "laozi-chapter-028__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 28.5", "sort_key": "028.005", "text_original": "Thus he the constant excellence retains;", "text_normalized": "Thus he the constant excellence retains;", "notes": ""}
{"segment_id": "laozi-chapter-028__legge-chinesenotes-1891__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-028", "source_id": "laozi-chapter-028__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 28.6", "sort_key": "028.006", "text_original": "The simple child again, free from all stains.", "text_normalized": "The simple child again, free from all stains.", "notes": ""}
{"segment_id": "laozi-chapter-028__legge-chinesenotes-1891__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-028", "source_id": "laozi-chapter-028__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 28.7", "sort_key": "028.007", "text_original": "Who knows how white attracts,", "text_normalized": "Who knows how white attracts,", "notes": ""}
{"segment_id": "laozi-chapter-028__legge-chinesenotes-1891__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-028", "source_id": "laozi-chapter-028__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 28.8", "sort_key": "028.008", "text_original": "Yet always keeps himself within black's shade,", "text_normalized": "Yet always keeps himself within black's shade,", "notes": ""}
{"segment_id": "laozi-chapter-028__legge-chinesenotes-1891__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-028", "source_id": "laozi-chapter-028__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 28.9", "sort_key": "028.009", "text_original": "The pattern of humility displayed,", "text_normalized": "The pattern of humility displayed,", "notes": ""}
{"segment_id": "laozi-chapter-028__legge-chinesenotes-1891__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-028", "source_id": "laozi-chapter-028__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 28.10", "sort_key": "028.010", "text_original": "Displayed in view of all beneath the sky;", "text_normalized": "Displayed in view of all beneath the sky;", "notes": ""}
{"segment_id": "laozi-chapter-028__legge-chinesenotes-1891__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-028", "source_id": "laozi-chapter-028__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 28.11", "sort_key": "028.011", "text_original": "He in the unchanging excellence arrayed,", "text_normalized": "He in the unchanging excellence arrayed,", "notes": ""}
{"segment_id": "laozi-chapter-028__legge-chinesenotes-1891__seg-012", "work_id": "laozi", "section_id": "laozi-chapter-028", "source_id": "laozi-chapter-028__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 12, "canonical_ref": "老子 28.12", "sort_key": "028.012", "text_original": "Endless return to man's first state has made.", "text_normalized": "Endless return to man's first state has made.", "notes": ""}
{"segment_id": "laozi-chapter-028__legge-chinesenotes-1891__seg-013", "work_id": "laozi", "section_id": "laozi-chapter-028", "source_id": "laozi-chapter-028__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 13, "canonical_ref": "老子 28.13", "sort_key": "028.013", "text_original": "Who knows how glory shines,", "text_normalized": "Who knows how glory shines,", "notes": ""}
{"segment_id": "laozi-chapter-028__legge-chinesenotes-1891__seg-014", "work_id": "laozi", "section_id": "laozi-chapter-028", "source_id": "laozi-chapter-028__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 14, "canonical_ref": "老子 28.14", "sort_key": "028.014", "text_original": "Yet loves disgrace, nor ever for it is pale;", "text_normalized": "Yet loves disgrace, nor ever for it is pale;", "notes": ""}
{"segment_id": "laozi-chapter-028__legge-chinesenotes-1891__seg-015", "work_id": "laozi", "section_id": "laozi-chapter-028", "source_id": "laozi-chapter-028__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 15, "canonical_ref": "老子 28.15", "sort_key": "028.015", "text_original": "Behold his presence in a spacious vale,", "text_normalized": "Behold his presence in a spacious vale,", "notes": ""}
{"segment_id": "laozi-chapter-028__legge-chinesenotes-1891__seg-016", "work_id": "laozi", "section_id": "laozi-chapter-028", "source_id": "laozi-chapter-028__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 16, "canonical_ref": "老子 28.16", "sort_key": "028.016", "text_original": "To which men come from all beneath the sky.", "text_normalized": "To which men come from all beneath the sky.", "notes": ""}
{"segment_id": "laozi-chapter-028__legge-chinesenotes-1891__seg-017", "work_id": "laozi", "section_id": "laozi-chapter-028", "source_id": "laozi-chapter-028__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 17, "canonical_ref": "老子 28.17", "sort_key": "028.017", "text_original": "The unchanging excellence completes its tale;", "text_normalized": "The unchanging excellence completes its tale;", "notes": ""}
{"segment_id": "laozi-chapter-028__legge-chinesenotes-1891__seg-018", "work_id": "laozi", "section_id": "laozi-chapter-028", "source_id": "laozi-chapter-028__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 18, "canonical_ref": "老子 28.18", "sort_key": "028.018", "text_original": "The simple infant man in him we hail.", "text_normalized": "The simple infant man in him we hail.", "notes": ""}
{"segment_id": "laozi-chapter-028__legge-chinesenotes-1891__seg-019", "work_id": "laozi", "section_id": "laozi-chapter-028", "source_id": "laozi-chapter-028__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 19, "canonical_ref": "老子 28.19", "sort_key": "028.019", "text_original": "The unwrought material, when divided and distributed, forms vessels.", "text_normalized": "The unwrought material, when divided and distributed, forms vessels.", "notes": ""}
{"segment_id": "laozi-chapter-028__legge-chinesenotes-1891__seg-020", "work_id": "laozi", "section_id": "laozi-chapter-028", "source_id": "laozi-chapter-028__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 20, "canonical_ref": "老子 28.20", "sort_key": "028.020", "text_original": "The sage, when employed, becomes the Head of all the Officers (of government);", "text_normalized": "The sage, when employed, becomes the Head of all the Officers (of government);", "notes": ""}
{"segment_id": "laozi-chapter-028__legge-chinesenotes-1891__seg-021", "work_id": "laozi", "section_id": "laozi-chapter-028", "source_id": "laozi-chapter-028__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 21, "canonical_ref": "老子 28.21", "sort_key": "028.021", "text_original": "and in his greatest regulations he employs no violent measures.", "text_normalized": "and in his greatest regulations he employs no violent measures.", "notes": ""}
