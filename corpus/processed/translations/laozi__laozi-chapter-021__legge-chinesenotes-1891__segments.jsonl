{"segment_id": "laozi-chapter-021__legge-chinesenotes-1891__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-021", "source_id": "laozi-chapter-021__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 21.1", "sort_key": "021.001", "text_original": "The grandest forms of active force", "text_normalized": "The grandest forms of active force", "notes": ""}
{"segment_id": "laozi-chapter-021__legge-chinesenotes-1891__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-021", "source_id": "laozi-chapter-021__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 21.2", "sort_key": "021.002", "text_original": "From Dao come, their only source.", "text_normalized": "From Dao come, their only source.", "notes": ""}
{"segment_id": "laozi-chapter-021__legge-chinesenotes-1891__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-021", "source_id": "laozi-chapter-021__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 21.3", "sort_key": "021.003", "text_original": "Who can of Dao the nature tell?", "text_normalized": "Who can of Dao the nature tell?", "notes": ""}
{"segment_id": "laozi-chapter-021__legge-chinesenotes-1891__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-021", "source_id": "laozi-chapter-021__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 21.4", "sort_key": "021.004", "text_original": "Our sight it flies, our touch as well.", "text_normalized": "Our sight it flies, our touch as well.", "notes": ""}
{"segment_id": "laozi-chapter-021__legge-chinesenotes-1891__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-021", "source_id": "laozi-chapter-021__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 21.5", "sort_key": "021.005", "text_original": "Eluding sight, eluding touch,", "text_normalized": "Eluding sight, eluding touch,", "notes": ""}
{"segment_id": "laozi-chapter-021__legge-chinesenotes-1891__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-021", "source_id": "laozi-chapter-021__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 21.6", "sort_key": "021.006", "text_original": "The forms of things all in it crouch;", "text_normalized": "The forms of things all in it crouch;", "notes": ""}
{"segment_id": "laozi-chapter-021__legge-chinesenotes-1891__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-021", "source_id": "laozi-chapter-021__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 21.7", "sort_key": "021.007", "text_original": "Eluding touch, eluding sight,", "text_normalized": "Eluding touch, eluding sight,", "notes": ""}
{"segment_id": "laozi-chapter-021__legge-chinesenotes-1891__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-021", "source_id": "laozi-chapter-021__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 21.8", "sort_key": "021.008", "text_original": "There are their semblances, all right.", "text_normalized": "There are their semblances, all right.", "notes": ""}
{"segment_id": "laozi-chapter-021__legge-chinesenotes-1891__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-021", "source_id": "laozi-chapter-021__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 21.9", "sort_key": "021.009", "text_original": "Profound it is, dark and obscure;", "text_normalized": "Profound it is, dark and obscure;", "notes": ""}
{"segment_id": "laozi-chapter-021__legge-chinesenotes-1891__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-021", "source_id": "laozi-chapter-021__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 21.10", "sort_key": "021.010", "text_original": "Things' essences all there endure.", "text_normalized": "Things' essences all there endure.", "notes": ""}
{"segment_id": "laozi-chapter-021__legge-chinesenotes-1891__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-021", "source_id": "laozi-chapter-021__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 21.11", "sort_key": "021.011", "text_original": "Those essences the truth enfold", "text_normalized": "Those essences the truth enfold", "notes": ""}
{"segment_id": "laozi-chapter-021__legge-chinesenotes-1891__seg-012", "work_id": "laozi", "section_id": "laozi-chapter-021", "source_id": "laozi-chapter-021__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 12, "canonical_ref": "老子 21.12", "sort_key": "021.012", "text_original": "Of what, when seen, shall then be told.", "text_normalized": "Of what, when seen, shall then be told.", "notes": ""}
{"segment_id": "laozi-chapter-021__legge-chinesenotes-1891__seg-013", "work_id": "laozi", "section_id": "laozi-chapter-021", "source_id": "laozi-chapter-021__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 13, "canonical_ref": "老子 21.13", "sort_key": "021.013", "text_original": "Now it is so;", "text_normalized": "Now it is so;", "notes": ""}
{"segment_id": "laozi-chapter-021__legge-chinesenotes-1891__seg-014", "work_id": "laozi", "section_id": "laozi-chapter-021", "source_id": "laozi-chapter-021__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 14, "canonical_ref": "老子 21.14", "sort_key": "021.014", "text_original": "'twas so of old.", "text_normalized": "'twas so of old.", "notes": ""}
{"segment_id": "laozi-chapter-021__legge-chinesenotes-1891__seg-015", "work_id": "laozi", "section_id": "laozi-chapter-021", "source_id": "laozi-chapter-021__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 15, "canonical_ref": "老子 21.15", "sort_key": "021.015", "text_original": "Its name - what passes not away;", "text_normalized": "Its name - what passes not away;", "notes": ""}
{"segment_id": "laozi-chapter-021__legge-chinesenotes-1891__seg-016", "work_id": "laozi", "section_id": "laozi-chapter-021", "source_id": "laozi-chapter-021__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 16, "canonical_ref": "老子 21.16", "sort_key": "021.016", "text_original": "So, in their beautiful array,", "text_normalized": "So, in their beautiful array,", "notes": ""}
{"segment_id": "laozi-chapter-021__legge-chinesenotes-1891__seg-017", "work_id": "laozi", "section_id": "laozi-chapter-021", "source_id": "laozi-chapter-021__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 17, "canonical_ref": "老子 21.17", "sort_key": "021.017", "text_original": "Things form and never know decay.", "text_normalized": "Things form and never know decay.", "notes": ""}
{"segment_id": "laozi-chapter-021__legge-chinesenotes-1891__seg-018", "work_id": "laozi", "section_id": "laozi-chapter-021", "source_id": "laozi-chapter-021__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 18, "canonical_ref": "老子 21.18", "sort_key": "021.018", "text_original": "How know I that it is so with all the beauties of existing things?", "text_normalized": "How know I that it is so with all the beauties of existing things?", "notes": ""}
{"segment_id": "laozi-chapter-021__legge-chinesenotes-1891__seg-019", "work_id": "laozi", "section_id": "laozi-chapter-021", "source_id": "laozi-chapter-021__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 19, "canonical_ref": "老子 21.19", "sort_key": "021.019", "text_original": "By this (nature of the Dao).", "text_normalized": "By this (nature of the Dao).", "notes": ""}
