{"segment_id": "laozi-chapter-054__legge-chinesenotes-1891__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-054", "source_id": "laozi-chapter-054__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 54.9", "sort_key": "054.009", "text_original": "And where the family it rules", "text_normalized": "And where the family it rules", "notes": ""}
{"segment_id": "laozi-chapter-054__legge-chinesenotes-1891__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-054", "source_id": "laozi-chapter-054__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 54.10", "sort_key": "054.010", "text_original": "What riches will accrue!", "text_normalized": "What riches will accrue!", "notes": ""}
{"segment_id": "laozi-chapter-054__legge-chinesenotes-1891__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-054", "source_id": "laozi-chapter-054__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 54.11", "sort_key": "054.011", "text_original": "The neighbourhood where it prevails", "text_normalized": "The neighbourhood where it prevails", "notes": ""}
{"segment_id": "laozi-chapter-054__legge-chinesenotes-1891__seg-012", "work_id": "laozi", "section_id": "laozi-chapter-054", "source_id": "laozi-chapter-054__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 12, "canonical_ref": "老子 54.12", "sort_key": "054.012", "text_original": "In thriving will abound;", "text_normalized": "In thriving will abound;", "notes": ""}
{"segment_id": "laozi-chapter-054__legge-chinesenotes-1891__seg-013", "work_id": "laozi", "section_id": "laozi-chapter-054", "source_id": "laozi-chapter-054__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 13, "canonical_ref": "老子 54.13", "sort_key": "054.013", "text_original": "And when 'tis seen throughout the state,", "text_normalized": "And when 'tis seen throughout the state,", "notes": ""}
{"segment_id": "laozi-chapter-054__legge-chinesenotes-1891__seg-014", "work_id": "laozi", "section_id": "laozi-chapter-054", "source_id": "laozi-chapter-054__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 14, "canonical_ref": "老子 54.14", "sort_key": "054.014", "text_original": "Good fortune will be found.", "text_normalized": "Good fortune will be found.", "notes": ""}
{"segment_id": "laozi-chapter-054__legge-chinesenotes-1891__seg-015", "work_id": "laozi", "section_id": "laozi-chapter-054", "source_id": "laozi-chapter-054__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 15, "canonical_ref": "老子 54.15", "sort_key": "054.015", "text_original": "Employ it the kingdom o'er,", "text_normalized": "Employ it the kingdom o'er,", "notes": ""}
{"segment_id": "laozi-chapter-054__legge-chinesenotes-1891__seg-016", "work_id": "laozi", "section_id": "laozi-chapter-054", "source_id": "laozi-chapter-054__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 16, "canonical_ref": "老子 54.16", "sort_key": "054.016", "text_original": "And men thrive all around.", "text_normalized": "And men thrive all around.", "notes": ""}
{"segment_id": "laozi-chapter-054__legge-chinesenotes-1891__seg-017", "work_id": "laozi", "section_id": "laozi-chapter-054", "source_id": "laozi-chapter-054__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 17, "canonical_ref": "老子 54.17", "sort_key": "054.017", "text_original": "In this way the effect will be seen in the person, by the observation of different cases;", "text_normalized": "In this way the effect will be seen in the person, by the observation of different cases;", "notes": ""}
{"segment_id": "laozi-chapter-054__legge-chinesenotes-1891__seg-018", "work_id": "laozi", "section_id": "laozi-chapter-054", "source_id": "laozi-chapter-054__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 18, "canonical_ref": "老子 54.18", "sort_key": "054.018", "text_original": "in the family;", "text_normalized": "in the family;", "notes": ""}
{"segment_id": "laozi-chapter-054__legge-chinesenotes-1891__seg-019", "work_id": "laozi", "section_id": "laozi-chapter-054", "source_id": "laozi-chapter-054__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 19, "canonical_ref": "老子 54.19", "sort_key": "054.019", "text_original": "in the neighbourhood;", "text_normalized": "in the neighbourhood;", "notes": ""}
{"segment_id": "laozi-chapter-054__legge-chinesenotes-1891__seg-020", "work_id": "laozi", "section_id": "laozi-chapter-054", "source_id": "laozi-chapter-054__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 20, "canonical_ref": "老子 54.20", "sort_key": "054.020", "text_original": "in the state; and in the kingdom.", "text_normalized": "in the state; and in the kingdom.", "notes": ""}
{"segment_id": "laozi-chapter-054__legge-chinesenotes-1891__seg-021", "work_id": "laozi", "section_id": "laozi-chapter-054", "source_id": "laozi-chapter-054__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 21, "canonical_ref": "老子 54.21", "sort_key": "054.021", "text_original": "How do I know that this effect is sure to hold thus all under the sky?", "text_normalized": "How do I know that this effect is sure to hold thus all under the sky?", "notes": ""}
