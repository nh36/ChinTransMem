{"segment_id": "laozi-chapter-054__legge-chinesenotes-1891__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-054", "source_id": "laozi-chapter-054__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 54.6", "sort_key": "054.006", "text_original": "Sacrifices to his shrine.", "text_normalized": "Sacrifices to his shrine.", "notes": ""}
{"segment_id": "laozi-chapter-054__legge-chinesenotes-1891__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-054", "source_id": "laozi-chapter-054__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 54.7", "sort_key": "054.007", "text_original": "Dao when nursed within one's self,", "text_normalized": "Dao when nursed within one's self,", "notes": ""}
