{"segment_id": "laozi-chapter-054__legge-chinesenotes-1891__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-054", "source_id": "laozi-chapter-054__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 54.3", "sort_key": "054.003", "text_original": "What his skilful arms enfold,", "text_normalized": "What his skilful arms enfold,", "notes": ""}
{"segment_id": "laozi-chapter-054__legge-chinesenotes-1891__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-054", "source_id": "laozi-chapter-054__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 54.4", "sort_key": "054.004", "text_original": "From him can never be borne.", "text_normalized": "From him can never be borne.", "notes": ""}
