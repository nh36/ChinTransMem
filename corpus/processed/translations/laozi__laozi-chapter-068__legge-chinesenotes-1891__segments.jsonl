{"segment_id": "laozi-chapter-068__legge-chinesenotes-1891__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-068", "source_id": "laozi-chapter-068__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 68.1", "sort_key": "068.001", "text_original": "He who in (Dao's) wars has skill", "text_normalized": "He who in (Dao's) wars has skill", "notes": ""}
{"segment_id": "laozi-chapter-068__legge-chinesenotes-1891__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-068", "source_id": "laozi-chapter-068__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 68.2", "sort_key": "068.002", "text_original": "Assumes no martial port;", "text_normalized": "Assumes no martial port;", "notes": ""}
{"segment_id": "laozi-chapter-068__legge-chinesenotes-1891__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-068", "source_id": "laozi-chapter-068__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 68.3", "sort_key": "068.003", "text_original": "He who fights with most good will", "text_normalized": "He who fights with most good will", "notes": ""}
{"segment_id": "laozi-chapter-068__legge-chinesenotes-1891__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-068", "source_id": "laozi-chapter-068__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 68.4", "sort_key": "068.004", "text_original": "To rage makes no resort.", "text_normalized": "To rage makes no resort.", "notes": ""}
{"segment_id": "laozi-chapter-068__legge-chinesenotes-1891__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-068", "source_id": "laozi-chapter-068__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 68.5", "sort_key": "068.005", "text_original": "He who vanquishes yet still", "text_normalized": "He who vanquishes yet still", "notes": ""}
{"segment_id": "laozi-chapter-068__legge-chinesenotes-1891__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-068", "source_id": "laozi-chapter-068__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 68.6", "sort_key": "068.006", "text_original": "Keeps from his foes apart;", "text_normalized": "Keeps from his foes apart;", "notes": ""}
{"segment_id": "laozi-chapter-068__legge-chinesenotes-1891__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-068", "source_id": "laozi-chapter-068__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 68.7", "sort_key": "068.007", "text_original": "He whose hests men most fulfil", "text_normalized": "He whose hests men most fulfil", "notes": ""}
{"segment_id": "laozi-chapter-068__legge-chinesenotes-1891__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-068", "source_id": "laozi-chapter-068__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 68.8", "sort_key": "068.008", "text_original": "Yet humbly plies his art.", "text_normalized": "Yet humbly plies his art.", "notes": ""}
{"segment_id": "laozi-chapter-068__legge-chinesenotes-1891__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-068", "source_id": "laozi-chapter-068__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 68.9", "sort_key": "068.009", "text_original": "Thus we say, 'He never contends,", "text_normalized": "Thus we say, 'He never contends,", "notes": ""}
{"segment_id": "laozi-chapter-068__legge-chinesenotes-1891__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-068", "source_id": "laozi-chapter-068__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 68.10", "sort_key": "068.010", "text_original": "And therein is his might.'", "text_normalized": "And therein is his might.'", "notes": ""}
{"segment_id": "laozi-chapter-068__legge-chinesenotes-1891__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-068", "source_id": "laozi-chapter-068__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 68.11", "sort_key": "068.011", "text_original": "Thus we say, 'Men's wills he bends,", "text_normalized": "Thus we say, 'Men's wills he bends,", "notes": ""}
{"segment_id": "laozi-chapter-068__legge-chinesenotes-1891__seg-012", "work_id": "laozi", "section_id": "laozi-chapter-068", "source_id": "laozi-chapter-068__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 12, "canonical_ref": "老子 68.12", "sort_key": "068.012", "text_original": "That they with him unite.'", "text_normalized": "That they with him unite.'", "notes": ""}
{"segment_id": "laozi-chapter-068__legge-chinesenotes-1891__seg-013", "work_id": "laozi", "section_id": "laozi-chapter-068", "source_id": "laozi-chapter-068__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 13, "canonical_ref": "老子 68.13", "sort_key": "068.013", "text_original": "Thus we say, 'Like Heaven's his ends,", "text_normalized": "Thus we say, 'Like Heaven's his ends,", "notes": ""}
{"segment_id": "laozi-chapter-068__legge-chinesenotes-1891__seg-014", "work_id": "laozi", "section_id": "laozi-chapter-068", "source_id": "laozi-chapter-068__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 14, "canonical_ref": "老子 68.14", "sort_key": "068.014", "text_original": "No sage of old more bright.'", "text_normalized": "No sage of old more bright.'", "notes": ""}
