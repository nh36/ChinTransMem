{"segment_id": "laozi-chapter-081__legge-chinesenotes-1891__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-081", "source_id": "laozi-chapter-081__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 81.1", "sort_key": "081.001", "text_original": "Sincere words are not fine;", "text_normalized": "Sincere words are not fine;", "notes": ""}
{"segment_id": "laozi-chapter-081__legge-chinesenotes-1891__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-081", "source_id": "laozi-chapter-081__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 81.2", "sort_key": "081.002", "text_original": "fine words are not sincere.", "text_normalized": "fine words are not sincere.", "notes": ""}
{"segment_id": "laozi-chapter-081__legge-chinesenotes-1891__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-081", "source_id": "laozi-chapter-081__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 81.3", "sort_key": "081.003", "text_original": "Those who are skilled (in the Dao) do not dispute (about it);", "text_normalized": "Those who are skilled (in the Dao) do not dispute (about it);", "notes": ""}
{"segment_id": "laozi-chapter-081__legge-chinesenotes-1891__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-081", "source_id": "laozi-chapter-081__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 81.4", "sort_key": "081.004", "text_original": "the disputatious are not skilled in it.", "text_normalized": "the disputatious are not skilled in it.", "notes": ""}
{"segment_id": "laozi-chapter-081__legge-chinesenotes-1891__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-081", "source_id": "laozi-chapter-081__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 81.5", "sort_key": "081.005", "text_original": "Those who know (the Dao) are not extensively learned;", "text_normalized": "Those who know (the Dao) are not extensively learned;", "notes": ""}
{"segment_id": "laozi-chapter-081__legge-chinesenotes-1891__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-081", "source_id": "laozi-chapter-081__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 81.6", "sort_key": "081.006", "text_original": "the extensively learned do not know it.", "text_normalized": "the extensively learned do not know it.", "notes": ""}
{"segment_id": "laozi-chapter-081__legge-chinesenotes-1891__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-081", "source_id": "laozi-chapter-081__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 81.7", "sort_key": "081.007", "text_original": "The sage does not accumulate (for himself).", "text_normalized": "The sage does not accumulate (for himself).", "notes": ""}
{"segment_id": "laozi-chapter-081__legge-chinesenotes-1891__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-081", "source_id": "laozi-chapter-081__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 81.8", "sort_key": "081.008", "text_original": "The more that he expends for others, the more does he possess of his own;", "text_normalized": "The more that he expends for others, the more does he possess of his own;", "notes": ""}
{"segment_id": "laozi-chapter-081__legge-chinesenotes-1891__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-081", "source_id": "laozi-chapter-081__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 81.9", "sort_key": "081.009", "text_original": "the more that he gives to others, the more does he have himself.", "text_normalized": "the more that he gives to others, the more does he have himself.", "notes": ""}
{"segment_id": "laozi-chapter-081__legge-chinesenotes-1891__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-081", "source_id": "laozi-chapter-081__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 81.10", "sort_key": "081.010", "text_original": "With all the sharpness of the Way of Heaven, it injures not;", "text_normalized": "With all the sharpness of the Way of Heaven, it injures not;", "notes": ""}
{"segment_id": "laozi-chapter-081__legge-chinesenotes-1891__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-081", "source_id": "laozi-chapter-081__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 81.11", "sort_key": "081.011", "text_original": "with all the doing in the way of the sage he does not strive.", "text_normalized": "with all the doing in the way of the sage he does not strive.", "notes": ""}
