{"segment_id": "laozi-chapter-055__legge-chinesenotes-1891__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-055", "source_id": "laozi-chapter-055__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 55.1", "sort_key": "055.001", "text_original": "He who has in himself abundantly the attributes (of the Dao) is like an infant.", "text_normalized": "He who has in himself abundantly the attributes (of the Dao) is like an infant.", "notes": ""}
{"segment_id": "laozi-chapter-055__legge-chinesenotes-1891__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-055", "source_id": "laozi-chapter-055__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 55.2", "sort_key": "055.002", "text_original": "Poisonous insects will not sting him;", "text_normalized": "Poisonous insects will not sting him;", "notes": ""}
{"segment_id": "laozi-chapter-055__legge-chinesenotes-1891__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-055", "source_id": "laozi-chapter-055__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 55.3", "sort_key": "055.003", "text_original": "fierce beasts will not seize him;", "text_normalized": "fierce beasts will not seize him;", "notes": ""}
{"segment_id": "laozi-chapter-055__legge-chinesenotes-1891__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-055", "source_id": "laozi-chapter-055__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 55.4", "sort_key": "055.004", "text_original": "birds of prey will not strike him.", "text_normalized": "birds of prey will not strike him.", "notes": ""}
{"segment_id": "laozi-chapter-055__legge-chinesenotes-1891__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-055", "source_id": "laozi-chapter-055__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 55.5", "sort_key": "055.005", "text_original": "(The infant's) bones are weak and its sinews soft, but yet its grasp is firm.", "text_normalized": "(The infant's) bones are weak and its sinews soft, but yet its grasp is firm.", "notes": ""}
{"segment_id": "laozi-chapter-055__legge-chinesenotes-1891__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-055", "source_id": "laozi-chapter-055__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 55.6", "sort_key": "055.006", "text_original": "It knows not yet the union of male and female, and yet its virile member may be excited;", "text_normalized": "It knows not yet the union of male and female, and yet its virile member may be excited;", "notes": ""}
{"segment_id": "laozi-chapter-055__legge-chinesenotes-1891__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-055", "source_id": "laozi-chapter-055__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 55.7", "sort_key": "055.007", "text_original": "- showing the perfection of its physical essence.", "text_normalized": "- showing the perfection of its physical essence.", "notes": ""}
{"segment_id": "laozi-chapter-055__legge-chinesenotes-1891__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-055", "source_id": "laozi-chapter-055__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 55.8", "sort_key": "055.008", "text_original": "All day long it will cry without its throat becoming hoarse;", "text_normalized": "All day long it will cry without its throat becoming hoarse;", "notes": ""}
{"segment_id": "laozi-chapter-055__legge-chinesenotes-1891__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-055", "source_id": "laozi-chapter-055__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 55.9", "sort_key": "055.009", "text_original": "- showing the harmony (in its constitution).", "text_normalized": "- showing the harmony (in its constitution).", "notes": ""}
{"segment_id": "laozi-chapter-055__legge-chinesenotes-1891__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-055", "source_id": "laozi-chapter-055__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 55.10", "sort_key": "055.010", "text_original": "To him by whom this harmony is known,", "text_normalized": "To him by whom this harmony is known,", "notes": ""}
{"segment_id": "laozi-chapter-055__legge-chinesenotes-1891__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-055", "source_id": "laozi-chapter-055__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 55.11", "sort_key": "055.011", "text_original": "(The secret of) the unchanging (Dao) is shown,", "text_normalized": "(The secret of) the unchanging (Dao) is shown,", "notes": ""}
{"segment_id": "laozi-chapter-055__legge-chinesenotes-1891__seg-012", "work_id": "laozi", "section_id": "laozi-chapter-055", "source_id": "laozi-chapter-055__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 12, "canonical_ref": "老子 55.12", "sort_key": "055.012", "text_original": "And in the knowledge wisdom finds its throne.", "text_normalized": "And in the knowledge wisdom finds its throne.", "notes": ""}
{"segment_id": "laozi-chapter-055__legge-chinesenotes-1891__seg-013", "work_id": "laozi", "section_id": "laozi-chapter-055", "source_id": "laozi-chapter-055__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 13, "canonical_ref": "老子 55.13", "sort_key": "055.013", "text_original": "All life-increasing arts to evil turn;", "text_normalized": "All life-increasing arts to evil turn;", "notes": ""}
{"segment_id": "laozi-chapter-055__legge-chinesenotes-1891__seg-014", "work_id": "laozi", "section_id": "laozi-chapter-055", "source_id": "laozi-chapter-055__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 14, "canonical_ref": "老子 55.14", "sort_key": "055.014", "text_original": "Where the mind makes the vital breath to burn,", "text_normalized": "Where the mind makes the vital breath to burn,", "notes": ""}
{"segment_id": "laozi-chapter-055__legge-chinesenotes-1891__seg-015", "work_id": "laozi", "section_id": "laozi-chapter-055", "source_id": "laozi-chapter-055__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 15, "canonical_ref": "老子 55.15", "sort_key": "055.015", "text_original": "When things have become strong, they (then) become old, which may be said to be contrary to the Dao.", "text_normalized": "When things have become strong, they (then) become old, which may be said to be contrary to the Dao.", "notes": ""}
{"segment_id": "laozi-chapter-055__legge-chinesenotes-1891__seg-016", "work_id": "laozi", "section_id": "laozi-chapter-055", "source_id": "laozi-chapter-055__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 16, "canonical_ref": "老子 55.16", "sort_key": "055.016", "text_original": "Whatever is contrary to the Dao soon ends.", "text_normalized": "Whatever is contrary to the Dao soon ends.", "notes": ""}
