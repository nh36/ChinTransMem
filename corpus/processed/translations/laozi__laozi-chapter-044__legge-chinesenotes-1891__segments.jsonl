{"segment_id": "laozi-chapter-044__legge-chinesenotes-1891__seg-018", "work_id": "laozi", "section_id": "laozi-chapter-044", "source_id": "laozi-chapter-044__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 18, "canonical_ref": "老子 44.18", "sort_key": "044.018", "text_original": "From danger free", "text_normalized": "From danger free", "notes": ""}
