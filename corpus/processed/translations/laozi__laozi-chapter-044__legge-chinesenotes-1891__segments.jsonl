{"segment_id": "laozi-chapter-044__legge-chinesenotes-1891__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-044", "source_id": "laozi-chapter-044__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 44.7", "sort_key": "044.007", "text_original": "- which brings", "text_normalized": "- which brings", "notes": ""}
