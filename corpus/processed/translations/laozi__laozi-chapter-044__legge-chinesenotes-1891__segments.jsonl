{"segment_id": "laozi-chapter-044__legge-chinesenotes-1891__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-044", "source_id": "laozi-chapter-044__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 44.9", "sort_key": "044.009", "text_original": "Thus we may see,", "text_normalized": "Thus we may see,", "notes": ""}
{"segment_id": "laozi-chapter-044__legge-chinesenotes-1891__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-044", "source_id": "laozi-chapter-044__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 44.10", "sort_key": "044.010", "text_original": "Who cleaves to fame", "text_normalized": "Who cleaves to fame", "notes": ""}
