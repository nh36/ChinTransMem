{"segment_id": "laozi-chapter-044__legge-chinesenotes-1891__seg-012", "work_id": "laozi", "section_id": "laozi-chapter-044", "source_id": "laozi-chapter-044__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 12, "canonical_ref": "老子 44.12", "sort_key": "044.012", "text_original": "Who loves large stores", "text_normalized": "Who loves large stores", "notes": ""}
{"segment_id": "laozi-chapter-044__legge-chinesenotes-1891__seg-013", "work_id": "laozi", "section_id": "laozi-chapter-044", "source_id": "laozi-chapter-044__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 13, "canonical_ref": "老子 44.13", "sort_key": "044.013", "text_original": "Gives up the richer state.", "text_normalized": "Gives up the richer state.", "notes": ""}
{"segment_id": "laozi-chapter-044__legge-chinesenotes-1891__seg-014", "work_id": "laozi", "section_id": "laozi-chapter-044", "source_id": "laozi-chapter-044__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 14, "canonical_ref": "老子 44.14", "sort_key": "044.014", "text_original": "Who is content", "text_normalized": "Who is content", "notes": ""}
{"segment_id": "laozi-chapter-044__legge-chinesenotes-1891__seg-015", "work_id": "laozi", "section_id": "laozi-chapter-044", "source_id": "laozi-chapter-044__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 15, "canonical_ref": "老子 44.15", "sort_key": "044.015", "text_original": "Needs fear no shame.", "text_normalized": "Needs fear no shame.", "notes": ""}
{"segment_id": "laozi-chapter-044__legge-chinesenotes-1891__seg-016", "work_id": "laozi", "section_id": "laozi-chapter-044", "source_id": "laozi-chapter-044__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 16, "canonical_ref": "老子 44.16", "sort_key": "044.016", "text_original": "Who knows to stop", "text_normalized": "Who knows to stop", "notes": ""}
