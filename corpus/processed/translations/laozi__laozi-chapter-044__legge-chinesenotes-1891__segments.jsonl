{"segment_id": "laozi-chapter-044__legge-chinesenotes-1891__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-044", "source_id": "laozi-chapter-044__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 44.1", "sort_key": "044.001", "text_original": "Or fame or life,", "text_normalized": "Or fame or life,", "notes": ""}
{"segment_id": "laozi-chapter-044__legge-chinesenotes-1891__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-044", "source_id": "laozi-chapter-044__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 44.2", "sort_key": "044.002", "text_original": "Which do you hold more dear?", "text_normalized": "Which do you hold more dear?", "notes": ""}
{"segment_id": "laozi-chapter-044__legge-chinesenotes-1891__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-044", "source_id": "laozi-chapter-044__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 44.3", "sort_key": "044.003", "text_original": "Or life or wealth,", "text_normalized": "Or life or wealth,", "notes": ""}
{"segment_id": "laozi-chapter-044__legge-chinesenotes-1891__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-044", "source_id": "laozi-chapter-044__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 44.4", "sort_key": "044.004", "text_original": "To which would you adhere?", "text_normalized": "To which would you adhere?", "notes": ""}
{"segment_id": "laozi-chapter-044__legge-chinesenotes-1891__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-044", "source_id": "laozi-chapter-044__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 44.5", "sort_key": "044.005", "text_original": "Keep life and lose those other things;", "text_normalized": "Keep life and lose those other things;", "notes": ""}
