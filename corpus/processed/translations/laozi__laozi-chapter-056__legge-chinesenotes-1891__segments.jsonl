{"segment_id": "laozi-chapter-056__legge-chinesenotes-1891__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-056", "source_id": "laozi-chapter-056__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 56.1", "sort_key": "056.001", "text_original": "He who knows (the Dao) does not (care to) speak (about it);", "text_normalized": "He who knows (the Dao) does not (care to) speak (about it);", "notes": ""}
{"segment_id": "laozi-chapter-056__legge-chinesenotes-1891__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-056", "source_id": "laozi-chapter-056__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 56.2", "sort_key": "056.002", "text_original": "he who is (ever ready to) speak about it does not know it.", "text_normalized": "he who is (ever ready to) speak about it does not know it.", "notes": ""}
{"segment_id": "laozi-chapter-056__legge-chinesenotes-1891__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-056", "source_id": "laozi-chapter-056__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 56.3", "sort_key": "056.003", "text_original": "He (who knows it) will keep his mouth shut and close the portals (of his nostrils).", "text_normalized": "He (who knows it) will keep his mouth shut and close the portals (of his nostrils).", "notes": ""}
{"segment_id": "laozi-chapter-056__legge-chinesenotes-1891__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-056", "source_id": "laozi-chapter-056__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 56.4", "sort_key": "056.004", "text_original": "He will blunt his sharp points and unravel the complications of things;", "text_normalized": "He will blunt his sharp points and unravel the complications of things;", "notes": ""}
{"segment_id": "laozi-chapter-056__legge-chinesenotes-1891__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-056", "source_id": "laozi-chapter-056__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 56.5", "sort_key": "056.005", "text_original": "he will attemper his brightness, and bring himself into agreement with the obscurity (of others).", "text_normalized": "he will attemper his brightness, and bring himself into agreement with the obscurity (of others).", "notes": ""}
{"segment_id": "laozi-chapter-056__legge-chinesenotes-1891__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-056", "source_id": "laozi-chapter-056__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 56.6", "sort_key": "056.006", "text_original": "This is called 'the Mysterious Agreement.'", "text_normalized": "This is called 'the Mysterious Agreement.'", "notes": ""}
{"segment_id": "laozi-chapter-056__legge-chinesenotes-1891__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-056", "source_id": "laozi-chapter-056__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 56.7", "sort_key": "056.007", "text_original": "(Such an one) cannot be treated familiarly or distantly;", "text_normalized": "(Such an one) cannot be treated familiarly or distantly;", "notes": ""}
{"segment_id": "laozi-chapter-056__legge-chinesenotes-1891__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-056", "source_id": "laozi-chapter-056__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 56.8", "sort_key": "056.008", "text_original": "he is beyond all consideration of profit or injury;", "text_normalized": "he is beyond all consideration of profit or injury;", "notes": ""}
{"segment_id": "laozi-chapter-056__legge-chinesenotes-1891__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-056", "source_id": "laozi-chapter-056__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 56.9", "sort_key": "056.009", "text_original": "beyond all consideration of nobility or meanness:", "text_normalized": "beyond all consideration of nobility or meanness:", "notes": ""}
{"segment_id": "laozi-chapter-056__legge-chinesenotes-1891__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-056", "source_id": "laozi-chapter-056__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 56.10", "sort_key": "056.010", "text_original": "- he is the noblest man under heaven.", "text_normalized": "- he is the noblest man under heaven.", "notes": ""}
