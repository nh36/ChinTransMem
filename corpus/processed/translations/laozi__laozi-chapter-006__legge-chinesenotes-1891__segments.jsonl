{"segment_id": "laozi-chapter-006__legge-chinesenotes-1891__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-006", "source_id": "laozi-chapter-006__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 6.1", "sort_key": "006.001", "text_original": "The valley spirit dies not, aye the same;", "text_normalized": "The valley spirit dies not, aye the same;", "notes": ""}
{"segment_id": "laozi-chapter-006__legge-chinesenotes-1891__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-006", "source_id": "laozi-chapter-006__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 6.2", "sort_key": "006.002", "text_original": "The female mystery thus do we name.", "text_normalized": "The female mystery thus do we name.", "notes": ""}
{"segment_id": "laozi-chapter-006__legge-chinesenotes-1891__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-006", "source_id": "laozi-chapter-006__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 6.3", "sort_key": "006.003", "text_original": "Its gate, from which at first they issued forth,", "text_normalized": "Its gate, from which at first they issued forth,", "notes": ""}
{"segment_id": "laozi-chapter-006__legge-chinesenotes-1891__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-006", "source_id": "laozi-chapter-006__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 6.4", "sort_key": "006.004", "text_original": "Is called the root from which grew heaven and earth.", "text_normalized": "Is called the root from which grew heaven and earth.", "notes": ""}
{"segment_id": "laozi-chapter-006__legge-chinesenotes-1891__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-006", "source_id": "laozi-chapter-006__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 6.5", "sort_key": "006.005", "text_original": "Long and unbroken does its power remain,", "text_normalized": "Long and unbroken does its power remain,", "notes": ""}
{"segment_id": "laozi-chapter-006__legge-chinesenotes-1891__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-006", "source_id": "laozi-chapter-006__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 6.6", "sort_key": "006.006", "text_original": "Used gently, and without the touch of pain.", "text_normalized": "Used gently, and without the touch of pain.", "notes": ""}
