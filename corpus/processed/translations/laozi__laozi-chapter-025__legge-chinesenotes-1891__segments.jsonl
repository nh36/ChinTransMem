{"segment_id": "laozi-chapter-025__legge-chinesenotes-1891__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-025", "source_id": "laozi-chapter-025__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 25.1", "sort_key": "025.001", "text_original": "There was something undefined and complete, coming into existence before Heaven and Earth.", "text_normalized": "There was something undefined and complete, coming into existence before Heaven and Earth.", "notes": ""}
{"segment_id": "laozi-chapter-025__legge-chinesenotes-1891__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-025", "source_id": "laozi-chapter-025__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 25.2", "sort_key": "025.002", "text_original": "How still it was and formless, standing alone, and undergoing no change, reaching everywhere and in no danger (of being exhausted)!", "text_normalized": "How still it was and formless, standing alone, and undergoing no change, reaching everywhere and in no danger (of being exhausted)!", "notes": ""}
{"segment_id": "laozi-chapter-025__legge-chinesenotes-1891__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-025", "source_id": "laozi-chapter-025__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 25.3", "sort_key": "025.003", "text_original": "It may be regarded as the Mother of all things.", "text_normalized": "It may be regarded as the Mother of all things.", "notes": ""}
{"segment_id": "laozi-chapter-025__legge-chinesenotes-1891__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-025", "source_id": "laozi-chapter-025__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 25.4", "sort_key": "025.004", "text_original": "I do not know its name, and I give it the designation of the Dao (the Way or Course).", "text_normalized": "I do not know its name, and I give it the designation of the Dao (the Way or Course).", "notes": ""}
{"segment_id": "laozi-chapter-025__legge-chinesenotes-1891__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-025", "source_id": "laozi-chapter-025__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 25.5", "sort_key": "025.005", "text_original": "Making an effort (further) to give it a name I call it The Great.", "text_normalized": "Making an effort (further) to give it a name I call it The Great.", "notes": ""}
{"segment_id": "laozi-chapter-025__legge-chinesenotes-1891__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-025", "source_id": "laozi-chapter-025__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 25.6", "sort_key": "025.006", "text_original": "Great, it passes on (in constant flow).", "text_normalized": "Great, it passes on (in constant flow).", "notes": ""}
{"segment_id": "laozi-chapter-025__legge-chinesenotes-1891__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-025", "source_id": "laozi-chapter-025__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 25.7", "sort_key": "025.007", "text_original": "Passing on, it becomes remote.", "text_normalized": "Passing on, it becomes remote.", "notes": ""}
{"segment_id": "laozi-chapter-025__legge-chinesenotes-1891__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-025", "source_id": "laozi-chapter-025__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 25.8", "sort_key": "025.008", "text_original": "Having become remote, it returns.", "text_normalized": "Having become remote, it returns.", "notes": ""}
{"segment_id": "laozi-chapter-025__legge-chinesenotes-1891__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-025", "source_id": "laozi-chapter-025__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 25.9", "sort_key": "025.009", "text_original": "Therefore the Dao is great;", "text_normalized": "Therefore the Dao is great;", "notes": ""}
{"segment_id": "laozi-chapter-025__legge-chinesenotes-1891__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-025", "source_id": "laozi-chapter-025__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 25.10", "sort_key": "025.010", "text_original": "Heaven is great;", "text_normalized": "Heaven is great;", "notes": ""}
{"segment_id": "laozi-chapter-025__legge-chinesenotes-1891__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-025", "source_id": "laozi-chapter-025__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 25.11", "sort_key": "025.011", "text_original": "Earth is great;", "text_normalized": "Earth is great;", "notes": ""}
{"segment_id": "laozi-chapter-025__legge-chinesenotes-1891__seg-012", "work_id": "laozi", "section_id": "laozi-chapter-025", "source_id": "laozi-chapter-025__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 12, "canonical_ref": "老子 25.12", "sort_key": "025.012", "text_original": "and the (sage) king is also great.", "text_normalized": "and the (sage) king is also great.", "notes": ""}
{"segment_id": "laozi-chapter-025__legge-chinesenotes-1891__seg-013", "work_id": "laozi", "section_id": "laozi-chapter-025", "source_id": "laozi-chapter-025__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 13, "canonical_ref": "老子 25.13", "sort_key": "025.013", "text_original": "In the universe there are four that are great, and the (sage) king is one of them.", "text_normalized": "In the universe there are four that are great, and the (sage) king is one of them.", "notes": ""}
{"segment_id": "laozi-chapter-025__legge-chinesenotes-1891__seg-014", "work_id": "laozi", "section_id": "laozi-chapter-025", "source_id": "laozi-chapter-025__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 14, "canonical_ref": "老子 25.14", "sort_key": "025.014", "text_original": "Man takes his law from the Earth;", "text_normalized": "Man takes his law from the Earth;", "notes": ""}
{"segment_id": "laozi-chapter-025__legge-chinesenotes-1891__seg-015", "work_id": "laozi", "section_id": "laozi-chapter-025", "source_id": "laozi-chapter-025__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 15, "canonical_ref": "老子 25.15", "sort_key": "025.015", "text_original": "the Earth takes its law from Heaven;", "text_normalized": "the Earth takes its law from Heaven;", "notes": ""}
{"segment_id": "laozi-chapter-025__legge-chinesenotes-1891__seg-016", "work_id": "laozi", "section_id": "laozi-chapter-025", "source_id": "laozi-chapter-025__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 16, "canonical_ref": "老子 25.16", "sort_key": "025.016", "text_original": "Heaven takes its law from the Dao.", "text_normalized": "Heaven takes its law from the Dao.", "notes": ""}
{"segment_id": "laozi-chapter-025__legge-chinesenotes-1891__seg-017", "work_id": "laozi", "section_id": "laozi-chapter-025", "source_id": "laozi-chapter-025__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 17, "canonical_ref": "老子 25.17", "sort_key": "025.017", "text_original": "The law of the Dao is its being what it is.", "text_normalized": "The law of the Dao is its being what it is.", "notes": ""}
