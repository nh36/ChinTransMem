{"segment_id": "laozi-chapter-058__legge-chinesenotes-1891__seg-001", "work_id": "laozi", "section_id": "laozi-chapter-058", "source_id": "laozi-chapter-058__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 1, "canonical_ref": "老子 58.1", "sort_key": "058.001", "text_original": "The government that seems the most unwise,", "text_normalized": "The government that seems the most unwise,", "notes": ""}
{"segment_id": "laozi-chapter-058__legge-chinesenotes-1891__seg-002", "work_id": "laozi", "section_id": "laozi-chapter-058", "source_id": "laozi-chapter-058__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 2, "canonical_ref": "老子 58.2", "sort_key": "058.002", "text_original": "Oft goodness to the people best supplies;", "text_normalized": "Oft goodness to the people best supplies;", "notes": ""}
{"segment_id": "laozi-chapter-058__legge-chinesenotes-1891__seg-003", "work_id": "laozi", "section_id": "laozi-chapter-058", "source_id": "laozi-chapter-058__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 3, "canonical_ref": "老子 58.3", "sort_key": "058.003", "text_original": "That which is meddling, touching everything,", "text_normalized": "That which is meddling, touching everything,", "notes": ""}
{"segment_id": "laozi-chapter-058__legge-chinesenotes-1891__seg-004", "work_id": "laozi", "section_id": "laozi-chapter-058", "source_id": "laozi-chapter-058__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 4, "canonical_ref": "老子 58.4", "sort_key": "058.004", "text_original": "Will work but ill, and disappointment bring.", "text_normalized": "Will work but ill, and disappointment bring.", "notes": ""}
{"segment_id": "laozi-chapter-058__legge-chinesenotes-1891__seg-005", "work_id": "laozi", "section_id": "laozi-chapter-058", "source_id": "laozi-chapter-058__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 5, "canonical_ref": "老子 58.5", "sort_key": "058.005", "text_original": "Misery!", "text_normalized": "Misery!", "notes": ""}
{"segment_id": "laozi-chapter-058__legge-chinesenotes-1891__seg-006", "work_id": "laozi", "section_id": "laozi-chapter-058", "source_id": "laozi-chapter-058__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 6, "canonical_ref": "老子 58.6", "sort_key": "058.006", "text_original": "- happiness is to be found by its side!", "text_normalized": "- happiness is to be found by its side!", "notes": ""}
{"segment_id": "laozi-chapter-058__legge-chinesenotes-1891__seg-007", "work_id": "laozi", "section_id": "laozi-chapter-058", "source_id": "laozi-chapter-058__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 7, "canonical_ref": "老子 58.7", "sort_key": "058.007", "text_original": "Happiness!", "text_normalized": "Happiness!", "notes": ""}
{"segment_id": "laozi-chapter-058__legge-chinesenotes-1891__seg-008", "work_id": "laozi", "section_id": "laozi-chapter-058", "source_id": "laozi-chapter-058__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 8, "canonical_ref": "老子 58.8", "sort_key": "058.008", "text_original": "- misery lurks beneath it!", "text_normalized": "- misery lurks beneath it!", "notes": ""}
{"segment_id": "laozi-chapter-058__legge-chinesenotes-1891__seg-009", "work_id": "laozi", "section_id": "laozi-chapter-058", "source_id": "laozi-chapter-058__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 9, "canonical_ref": "老子 58.9", "sort_key": "058.009", "text_original": "Who knows what either will come to in the end?", "text_normalized": "Who knows what either will come to in the end?", "notes": ""}
{"segment_id": "laozi-chapter-058__legge-chinesenotes-1891__seg-010", "work_id": "laozi", "section_id": "laozi-chapter-058", "source_id": "laozi-chapter-058__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 10, "canonical_ref": "老子 58.10", "sort_key": "058.010", "text_original": "Shall we then dispense with correction?", "text_normalized": "Shall we then dispense with correction?", "notes": ""}
{"segment_id": "laozi-chapter-058__legge-chinesenotes-1891__seg-011", "work_id": "laozi", "section_id": "laozi-chapter-058", "source_id": "laozi-chapter-058__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 11, "canonical_ref": "老子 58.11", "sort_key": "058.011", "text_original": "The (method of) correction shall by a turn become distortion, and the good in it shall by a turn become evil.", "text_normalized": "The (method of) correction shall by a turn become distortion, and the good in it shall by a turn become evil.", "notes": ""}
{"segment_id": "laozi-chapter-058__legge-chinesenotes-1891__seg-012", "work_id": "laozi", "section_id": "laozi-chapter-058", "source_id": "laozi-chapter-058__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 12, "canonical_ref": "老子 58.12", "sort_key": "058.012", "text_original": "The delusion of the people (on this point) has indeed subsisted for a long time.", "text_normalized": "The delusion of the people (on this point) has indeed subsisted for a long time.", "notes": ""}
{"segment_id": "laozi-chapter-058__legge-chinesenotes-1891__seg-013", "work_id": "laozi", "section_id": "laozi-chapter-058", "source_id": "laozi-chapter-058__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 13, "canonical_ref": "老子 58.13", "sort_key": "058.013", "text_original": "Therefore the sage is (like) a square which cuts no one (with its angles);", "text_normalized": "Therefore the sage is (like) a square which cuts no one (with its angles);", "notes": ""}
{"segment_id": "laozi-chapter-058__legge-chinesenotes-1891__seg-014", "work_id": "laozi", "section_id": "laozi-chapter-058", "source_id": "laozi-chapter-058__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 14, "canonical_ref": "老子 58.14", "sort_key": "058.014", "text_original": "(like) a corner which injures no one (with its sharpness).", "text_normalized": "(like) a corner which injures no one (with its sharpness).", "notes": ""}
{"segment_id": "laozi-chapter-058__legge-chinesenotes-1891__seg-015", "work_id": "laozi", "section_id": "laozi-chapter-058", "source_id": "laozi-chapter-058__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 15, "canonical_ref": "老子 58.15", "sort_key": "058.015", "text_original": "He is straightforward, but allows himself no license;", "text_normalized": "He is straightforward, but allows himself no license;", "notes": ""}
{"segment_id": "laozi-chapter-058__legge-chinesenotes-1891__seg-016", "work_id": "laozi", "section_id": "laozi-chapter-058", "source_id": "laozi-chapter-058__legge-chinesenotes-1891", "language": "en", "segment_type": "sentence", "segment_order": 16, "canonical_ref": "老子 58.16", "sort_key": "058.016", "text_original": "he is bright, but does not dazzle.", "text_normalized": "he is bright, but does not dazzle.", "notes": ""}
