{"alignment_id": "laozi-chapter-063__align-002", "work_id": "laozi", "section_id": "laozi-chapter-063", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 3, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 2, "target_segment_count": 2, "chinese_ref": "老子 63.3 - 老子 63.4", "chinese_text": "味無味。大小多少，", "translation_ref": "老子 63.2 - 老子 63.3", "translation_text": "to conduct affairs without (feeling the) trouble of them; to taste without discerning any flavour;"}
{"alignment_id": "laozi-chapter-063__align-003", "work_id": "laozi", "section_id": "laozi-chapter-063", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 5, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 2, "target_segment_count": 1, "chinese_ref": "老子 63.5 - 老子 63.6", "chinese_text": "報怨以德。圖難於其易，", "translation_ref": "老子 63.4", "translation_text": "to consider what is small as great, and a few as many; and to recompense injury with kindness."}
{"alignment_id": "laozi-chapter-063__align-004", "work_id": "laozi", "section_id": "laozi-chapter-063", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 7, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 2, "target_segment_count": 1, "chinese_ref": "老子 63.7 - 老子 63.8", "chinese_text": "為大於其細；天下難事必作於易，", "translation_ref": "老子 63.5", "translation_text": "(The master of it) anticipates things that are difficult while they are easy, and does things that would become great while they are small."}
{"alignment_id": "laozi-chapter-063__align-005", "work_id": "laozi", "section_id": "laozi-chapter-063", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 9, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 2, "target_segment_count": 1, "chinese_ref": "老子 63.9 - 老子 63.10", "chinese_text": "天下大事必作於細。是以聖人終不為大，", "translation_ref": "老子 63.6", "translation_text": "All difficult things in the world are sure to arise from a previous state in which they were easy, and all great things from one in which they were small."}
{"alignment_id": "laozi-chapter-063__align-006", "work_id": "laozi", "section_id": "laozi-chapter-063", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 11, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 2, "target_segment_count": 1, "chinese_ref": "老子 63.11 - 老子 63.12", "chinese_text": "故能成其大。夫輕諾必寡信，", "translation_ref": "老子 63.7", "translation_text": "Therefore the sage, while he never does what is great, is able on that account to accomplish the greatest things."}
{"alignment_id": "laozi-chapter-063__align-007", "work_id": "laozi", "section_id": "laozi-chapter-063", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 13, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 63.13", "chinese_text": "多易必多難。", "translation_ref": "老子 63.8", "translation_text": "He who lightly promises is sure to keep but little faith;"}
{"alignment_id": "laozi-chapter-063__align-008", "work_id": "laozi", "section_id": "laozi-chapter-063", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 14, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 63.14", "chinese_text": "是以聖人猶難之，", "translation_ref": "老子 63.9", "translation_text": "he who is continually thinking things easy is sure to find them difficult."}
{"alignment_id": "laozi-chapter-063__align-009", "work_id": "laozi", "section_id": "laozi-chapter-063", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 15, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 63.15", "chinese_text": "故終無難矣", "translation_ref": "老子 63.10", "translation_text": "Therefore the sage sees difficulty even in what seems easy, and so never has any difficulties."}
