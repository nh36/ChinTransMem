{"alignment_id": "laozi-chapter-068__align-001", "work_id": "laozi", "section_id": "laozi-chapter-068", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 1, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 2, "chinese_ref": "老子 68.1", "chinese_text": "善為士者不武，", "translation_ref": "老子 68.1 - 老子 68.2", "translation_text": "He who in (Dao's) wars has skill Assumes no martial port;"}
{"alignment_id": "laozi-chapter-068__align-002", "work_id": "laozi", "section_id": "laozi-chapter-068", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 2, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 2, "chinese_ref": "老子 68.2", "chinese_text": "善戰者不怒，", "translation_ref": "老子 68.3 - 老子 68.4", "translation_text": "He who fights with most good will To rage makes no resort."}
{"alignment_id": "laozi-chapter-068__align-003", "work_id": "laozi", "section_id": "laozi-chapter-068", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 3, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 2, "chinese_ref": "老子 68.3", "chinese_text": "善勝敵者不與，", "translation_ref": "老子 68.5 - 老子 68.6", "translation_text": "He who vanquishes yet still Keeps from his foes apart;"}
{"alignment_id": "laozi-chapter-068__align-004", "work_id": "laozi", "section_id": "laozi-chapter-068", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 4, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 2, "chinese_ref": "老子 68.4", "chinese_text": "善用人者為之下，", "translation_ref": "老子 68.7 - 老子 68.8", "translation_text": "He whose hests men most fulfil Yet humbly plies his art."}
{"alignment_id": "laozi-chapter-068__align-005", "work_id": "laozi", "section_id": "laozi-chapter-068", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 5, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 2, "chinese_ref": "老子 68.5", "chinese_text": "是謂不爭之德，", "translation_ref": "老子 68.9 - 老子 68.10", "translation_text": "Thus we say, 'He never contends, And therein is his might.'"}
{"alignment_id": "laozi-chapter-068__align-006", "work_id": "laozi", "section_id": "laozi-chapter-068", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 6, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 2, "chinese_ref": "老子 68.6", "chinese_text": "是謂用人之力，", "translation_ref": "老子 68.11 - 老子 68.12", "translation_text": "Thus we say, 'Men's wills he bends, That they with him unite.'"}
{"alignment_id": "laozi-chapter-068__align-007", "work_id": "laozi", "section_id": "laozi-chapter-068", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 7, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 2, "chinese_ref": "老子 68.7", "chinese_text": "是謂配天古之極。", "translation_ref": "老子 68.13 - 老子 68.14", "translation_text": "Thus we say, 'Like Heaven's his ends, No sage of old more bright.'"}
