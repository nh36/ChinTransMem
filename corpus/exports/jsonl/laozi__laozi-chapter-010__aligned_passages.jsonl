{"alignment_id": "laozi-chapter-010__align-002", "work_id": "laozi", "section_id": "laozi-chapter-010", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 2, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 2, "target_segment_count": 1, "chinese_ref": "老子 10.2 - 老子 10.3", "chinese_text": "能無離乎？專氣致柔，", "translation_ref": "老子 10.2", "translation_text": "When one gives undivided attention to the (vital) breath, and brings it to the utmost degree of pliancy, he can become as a (tender) babe."}
