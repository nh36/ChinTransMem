{"alignment_id": "laozi-chapter-010__align-008", "work_id": "laozi", "section_id": "laozi-chapter-010", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 15, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 10.15", "chinese_text": "生而不有，", "translation_ref": "老子 10.8", "translation_text": "it produces them and does not claim them as its own;"}
