{"alignment_id": "laozi-chapter-015__align-001", "work_id": "laozi", "section_id": "laozi-chapter-015", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 1, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 3, "target_segment_count": 1, "chinese_ref": "老子 15.1 - 老子 15.3", "chinese_text": "古之善為士者，微妙玄通，深不可識。", "translation_ref": "老子 15.1", "translation_text": "The skilful masters (of the Dao) in old times, with a subtle and exquisite penetration, comprehended its mysteries, and were deep (also) so as to elude men's knowledge."}
{"alignment_id": "laozi-chapter-015__align-002", "work_id": "laozi", "section_id": "laozi-chapter-015", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 4, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 2, "target_segment_count": 1, "chinese_ref": "老子 15.4 - 老子 15.5", "chinese_text": "夫唯不可識，故強為之容。", "translation_ref": "老子 15.2", "translation_text": "As they were thus beyond men's knowledge, I will make an effort to describe of what sort they appeared to be."}
{"alignment_id": "laozi-chapter-015__align-003", "work_id": "laozi", "section_id": "laozi-chapter-015", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 6, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 15.6", "chinese_text": "豫焉若冬涉川，", "translation_ref": "老子 15.3", "translation_text": "Shrinking looked they like those who wade through a stream in winter;"}
{"alignment_id": "laozi-chapter-015__align-004", "work_id": "laozi", "section_id": "laozi-chapter-015", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 7, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 15.7", "chinese_text": "猶兮若畏四鄰，", "translation_ref": "老子 15.4", "translation_text": "irresolute like those who are afraid of all around them;"}
{"alignment_id": "laozi-chapter-015__align-005", "work_id": "laozi", "section_id": "laozi-chapter-015", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 8, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 15.8", "chinese_text": "儼兮其若容，", "translation_ref": "老子 15.5", "translation_text": "grave like a guest (in awe of his host);"}
{"alignment_id": "laozi-chapter-015__align-006", "work_id": "laozi", "section_id": "laozi-chapter-015", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 9, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 15.9", "chinese_text": "渙兮若冰之將釋，", "translation_ref": "老子 15.6", "translation_text": "evanescent like ice that is melting away;"}
{"alignment_id": "laozi-chapter-015__align-007", "work_id": "laozi", "section_id": "laozi-chapter-015", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 10, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 15.10", "chinese_text": "敦兮其若樸，", "translation_ref": "老子 15.7", "translation_text": "unpretentious like wood that has not been fashioned into anything;"}
{"alignment_id": "laozi-chapter-015__align-008", "work_id": "laozi", "section_id": "laozi-chapter-015", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 11, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 15.11", "chinese_text": "曠兮其若谷，", "translation_ref": "老子 15.8", "translation_text": "vacant like a valley, and dull like muddy water."}
{"alignment_id": "laozi-chapter-015__align-009", "work_id": "laozi", "section_id": "laozi-chapter-015", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 12, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 2, "target_segment_count": 3, "chinese_ref": "老子 15.12 - 老子 15.13", "chinese_text": "混兮其若濁。孰能濁以靜之徐清？", "translation_ref": "老子 15.9 - 老子 15.11", "translation_text": "Who can (make) the muddy water (clear)? Let it be still, and it will gradually become clear. Who can secure the condition of rest?"}
{"alignment_id": "laozi-chapter-015__align-010", "work_id": "laozi", "section_id": "laozi-chapter-015", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 14, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 2, "target_segment_count": 2, "chinese_ref": "老子 15.14 - 老子 15.15", "chinese_text": "孰能安以久動之徐生？保此道者不欲盈，", "translation_ref": "老子 15.12 - 老子 15.13", "translation_text": "Let movement go on, and the condition of rest will gradually arise. They who preserve this method of the Dao do not wish to be full (of themselves)."}
{"alignment_id": "laozi-chapter-015__align-011", "work_id": "laozi", "section_id": "laozi-chapter-015", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 16, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 2, "target_segment_count": 1, "chinese_ref": "老子 15.16 - 老子 15.17", "chinese_text": "夫唯不盈，故能蔽不新成。", "translation_ref": "老子 15.14", "translation_text": "It is through their not being full of themselves that they can afford to seem worn and not appear new and complete."}
