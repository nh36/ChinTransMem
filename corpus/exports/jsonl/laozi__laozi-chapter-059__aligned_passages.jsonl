{"alignment_id": "laozi-chapter-059__align-002", "work_id": "laozi", "section_id": "laozi-chapter-059", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 3, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 2, "target_segment_count": 1, "chinese_ref": "老子 59.3 - 老子 59.4", "chinese_text": "夫唯嗇，是謂早服；", "translation_ref": "老子 59.2", "translation_text": "It is only by this moderation that there is effected an early return (to man's normal state)."}
{"alignment_id": "laozi-chapter-059__align-003", "work_id": "laozi", "section_id": "laozi-chapter-059", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 5, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 59.5", "chinese_text": "早服謂之重積德；", "translation_ref": "老子 59.3", "translation_text": "That early return is what I call the repeated accumulation of the attributes (of the Dao)."}
{"alignment_id": "laozi-chapter-059__align-004", "work_id": "laozi", "section_id": "laozi-chapter-059", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 6, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 59.6", "chinese_text": "重積德則無不克，", "translation_ref": "老子 59.4", "translation_text": "With that repeated accumulation of those attributes, there comes the subjugation (of every obstacle to such return)."}
{"alignment_id": "laozi-chapter-059__align-005", "work_id": "laozi", "section_id": "laozi-chapter-059", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 7, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 59.7", "chinese_text": "無不克則莫知其極；", "translation_ref": "老子 59.5", "translation_text": "Of this subjugation we know not what shall be the limit;"}
{"alignment_id": "laozi-chapter-059__align-006", "work_id": "laozi", "section_id": "laozi-chapter-059", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 8, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 2, "target_segment_count": 1, "chinese_ref": "老子 59.8 - 老子 59.9", "chinese_text": "莫知其極，可以有國；", "translation_ref": "老子 59.6", "translation_text": "and when one knows not what the limit shall be, he may be the ruler of a state."}
{"alignment_id": "laozi-chapter-059__align-007", "work_id": "laozi", "section_id": "laozi-chapter-059", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 10, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 59.10", "chinese_text": "有國之母，", "translation_ref": "老子 59.7", "translation_text": "He who possesses the mother of the state may continue long."}
{"alignment_id": "laozi-chapter-059__align-008", "work_id": "laozi", "section_id": "laozi-chapter-059", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 11, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 2, "target_segment_count": 1, "chinese_ref": "老子 59.11 - 老子 59.12", "chinese_text": "可以長久；是謂深根固柢，", "translation_ref": "老子 59.8", "translation_text": "His case is like that (of the plant) of which we say that its roots are deep and its flower stalks firm:"}
{"alignment_id": "laozi-chapter-059__align-009", "work_id": "laozi", "section_id": "laozi-chapter-059", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 13, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 59.13", "chinese_text": "長生久視之道。", "translation_ref": "老子 59.9", "translation_text": "- this is the way to secure that its enduring life shall long be seen."}
