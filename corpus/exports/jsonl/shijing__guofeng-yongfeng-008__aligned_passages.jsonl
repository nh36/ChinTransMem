{"alignment_id": "shijing__guofeng-yongfeng-008__001__zhwikisource-20260530__legge-sbe-v3-1879-fulltext", "work_id": "shijing", "section_id": "guofeng-yongfeng-008", "alignment_type": "exact_or_near_exact", "confidence": 0.99, "order": 1, "section_unit": "poem", "segment_type": "stanza", "alignment_granularity": "stanza", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "詩經·國風·鄘風·008.1", "chinese_text": "相鼠有皮，人而無儀，人而無儀，不死何為。", "translation_ref": "相鼠.1", "translation_text": "Look at a rat, - it has its skin;\nBut a man should be without dignity of demeanour.\nIf a man have no dignity of demeanour,\nWhat should he but die?"}
{"alignment_id": "shijing__guofeng-yongfeng-008__002__zhwikisource-20260530__legge-sbe-v3-1879-fulltext", "work_id": "shijing", "section_id": "guofeng-yongfeng-008", "alignment_type": "exact_or_near_exact", "confidence": 0.99, "order": 2, "section_unit": "poem", "segment_type": "stanza", "alignment_granularity": "stanza", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "詩經·國風·鄘風·008.2", "chinese_text": "相鼠有齒，人而無止，人而無止，不死何俟。", "translation_ref": "相鼠.2", "translation_text": "Look at a rat, - it has its teeth;\nBut a man shall be without any right deportment.\nIf a man have not right deportment,\nWhat should he wait for but death?"}
{"alignment_id": "shijing__guofeng-yongfeng-008__003__zhwikisource-20260530__legge-sbe-v3-1879-fulltext", "work_id": "shijing", "section_id": "guofeng-yongfeng-008", "alignment_type": "exact_or_near_exact", "confidence": 0.99, "order": 3, "section_unit": "poem", "segment_type": "stanza", "alignment_granularity": "stanza", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "詩經·國風·鄘風·008.3", "chinese_text": "相鼠有體，人而無禮，人而無禮，胡不遄死。", "translation_ref": "相鼠.3", "translation_text": "Look at a rat, - it has its limbs;\nBut a man shall be without any rules of propriety.\nIf a man observe no rules of propriety,\nWhy does he not quickly die?"}
