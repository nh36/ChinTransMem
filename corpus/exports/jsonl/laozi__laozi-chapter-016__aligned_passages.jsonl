{"alignment_id": "laozi-chapter-016__align-002", "work_id": "laozi", "section_id": "laozi-chapter-016", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 3, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 3, "target_segment_count": 2, "chinese_ref": "老子 16.3 - 老子 16.5", "chinese_text": "萬物並作，吾以觀復。夫物芸芸，", "translation_ref": "老子 16.2 - 老子 16.3", "translation_text": "All things alike go through their processes of activity, and (then) we see them return (to their original state). When things (in the vegetable world) have displayed their luxuriant growth, we see each of them return to its root."}
