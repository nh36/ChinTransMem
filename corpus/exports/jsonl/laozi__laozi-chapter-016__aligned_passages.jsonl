{"alignment_id": "laozi-chapter-016__align-005", "work_id": "laozi", "section_id": "laozi-chapter-016", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 8, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 16.8", "chinese_text": "是謂復命。", "translation_ref": "老子 16.6", "translation_text": "The report of that fulfilment is the regular, unchanging rule."}
