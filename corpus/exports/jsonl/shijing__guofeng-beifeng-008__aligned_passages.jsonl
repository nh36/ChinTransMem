{"alignment_id": "shijing__guofeng-beifeng-008__002__zhwikisource-20260530__legge-sheking-1871-ocr", "work_id": "shijing", "section_id": "guofeng-beifeng-008", "alignment_type": "exact_or_near_exact", "confidence": 0.99, "order": 2, "section_unit": "poem", "segment_type": "stanza", "alignment_granularity": "stanza", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "詩經·國風·邶風·008.2", "chinese_text": "雄雉于飛，下上其音，展矣君子，實勞我心。", "translation_ref": "雄雉.2", "translation_text": "The pheasant has flown away,\nBut from below, from above, comes his voice.\nAh! the princely man! —\nHe afflicts my heart."}
{"alignment_id": "shijing__guofeng-beifeng-008__003__zhwikisource-20260530__legge-sheking-1871-ocr", "work_id": "shijing", "section_id": "guofeng-beifeng-008", "alignment_type": "exact_or_near_exact", "confidence": 0.99, "order": 3, "section_unit": "poem", "segment_type": "stanza", "alignment_granularity": "stanza", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "詩經·國風·邶風·008.3", "chinese_text": "瞻彼日月，悠悠我思，道之云遠，曷云能來。", "translation_ref": "雄雉.3", "translation_text": "Look at that sun and moon!\nLong, long do I think.\nThe way is distant;\nHow can he come to me?"}
{"alignment_id": "shijing__guofeng-beifeng-008__004__zhwikisource-20260530__legge-sheking-1871-ocr", "work_id": "shijing", "section_id": "guofeng-beifeng-008", "alignment_type": "exact_or_near_exact", "confidence": 0.99, "order": 4, "section_unit": "poem", "segment_type": "stanza", "alignment_granularity": "stanza", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "詩經·國風·邶風·008.4", "chinese_text": "百爾君子，不知德行，不忮不求，何用不臧。", "translation_ref": "雄雉.4", "translation_text": "All ye princely men,\nKnow ye not his virtuous conduct?\nHe hates none; he covets nothing; —\nWhat does he which is not good?"}
