{"alignment_id": "laozi-chapter-067__align-009", "work_id": "laozi", "section_id": "laozi-chapter-067", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 14, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 3, "target_segment_count": 2, "chinese_ref": "老子 67.14 - 老子 67.16", "chinese_text": "不敢為天下先，故能成器長。今舍慈且勇，", "translation_ref": "老子 67.10 - 老子 67.11", "translation_text": "shrinking from taking precedence of others, I can become a vessel of the highest honour. Now-a-days they give up gentleness and are all for being bold;"}
{"alignment_id": "laozi-chapter-067__align-010", "work_id": "laozi", "section_id": "laozi-chapter-067", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 17, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 67.17", "chinese_text": "舍儉且廣，", "translation_ref": "老子 67.12", "translation_text": "economy, and are all for being liberal;"}
{"alignment_id": "laozi-chapter-067__align-011", "work_id": "laozi", "section_id": "laozi-chapter-067", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 18, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 67.18", "chinese_text": "舍後且先，", "translation_ref": "老子 67.13", "translation_text": "the hindmost place, and seek only to be foremost;"}
{"alignment_id": "laozi-chapter-067__align-012", "work_id": "laozi", "section_id": "laozi-chapter-067", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 19, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 3, "target_segment_count": 2, "chinese_ref": "老子 67.19 - 老子 67.21", "chinese_text": "死矣！夫慈以戰則勝，以守則固。", "translation_ref": "老子 67.14 - 老子 67.15", "translation_text": "- (of all which the end is) death. Gentleness is sure to be victorious even in battle, and firmly to maintain its ground."}
{"alignment_id": "laozi-chapter-067__align-013", "work_id": "laozi", "section_id": "laozi-chapter-067", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 22, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 2, "target_segment_count": 1, "chinese_ref": "老子 67.22 - 老子 67.23", "chinese_text": "天將救之，以慈衛之。", "translation_ref": "老子 67.16", "translation_text": "Heaven will save its possessor, by his (very) gentleness protecting him."}
