{"alignment_id": "laozi-chapter-067__align-001", "work_id": "laozi", "section_id": "laozi-chapter-067", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 1, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 3, "target_segment_count": 1, "chinese_ref": "老子 67.1 - 老子 67.3", "chinese_text": "天下皆謂我道大，似不肖。夫唯大，", "translation_ref": "老子 67.1", "translation_text": "All the world says that, while my Dao is great, it yet appears to be inferior (to other systems of teaching)."}
{"alignment_id": "laozi-chapter-067__align-002", "work_id": "laozi", "section_id": "laozi-chapter-067", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 4, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 2, "target_segment_count": 1, "chinese_ref": "老子 67.4 - 老子 67.5", "chinese_text": "故似不肖。若肖，", "translation_ref": "老子 67.2", "translation_text": "Now it is just its greatness that makes it seem to be inferior."}
{"alignment_id": "laozi-chapter-067__align-003", "work_id": "laozi", "section_id": "laozi-chapter-067", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 6, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 2, "target_segment_count": 1, "chinese_ref": "老子 67.6 - 老子 67.7", "chinese_text": "久矣其細也夫！我有三寶，", "translation_ref": "老子 67.3", "translation_text": "If it were like any other (system), for long would its smallness have been known!"}
{"alignment_id": "laozi-chapter-067__align-004", "work_id": "laozi", "section_id": "laozi-chapter-067", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 8, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 2, "target_segment_count": 1, "chinese_ref": "老子 67.8 - 老子 67.9", "chinese_text": "持而保之。一曰慈，", "translation_ref": "老子 67.4", "translation_text": "But I have three precious things which I prize and hold fast."}
{"alignment_id": "laozi-chapter-067__align-005", "work_id": "laozi", "section_id": "laozi-chapter-067", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 10, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 67.10", "chinese_text": "二曰儉，", "translation_ref": "老子 67.5", "translation_text": "The first is gentleness;"}
{"alignment_id": "laozi-chapter-067__align-006", "work_id": "laozi", "section_id": "laozi-chapter-067", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 11, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 2, "chinese_ref": "老子 67.11", "chinese_text": "三曰不敢為天下先。", "translation_ref": "老子 67.6 - 老子 67.7", "translation_text": "the second is economy; and the third is shrinking from taking precedence of others."}
{"alignment_id": "laozi-chapter-067__align-007", "work_id": "laozi", "section_id": "laozi-chapter-067", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 12, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 67.12", "chinese_text": "慈故能勇，", "translation_ref": "老子 67.8", "translation_text": "With that gentleness I can be bold;"}
