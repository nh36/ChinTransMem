{"alignment_id": "laozi-chapter-064__align-002", "work_id": "laozi", "section_id": "laozi-chapter-064", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 2, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 2, "target_segment_count": 1, "chinese_ref": "老子 64.2 - 老子 64.3", "chinese_text": "其未兆易謀。其脆易泮，", "translation_ref": "老子 64.2", "translation_text": "before a thing has given indications of its presence, it is easy to take measures against it;"}
{"alignment_id": "laozi-chapter-064__align-003", "work_id": "laozi", "section_id": "laozi-chapter-064", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 4, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 64.4", "chinese_text": "其微易散。", "translation_ref": "老子 64.3", "translation_text": "that which is brittle is easily broken;"}
{"alignment_id": "laozi-chapter-064__align-004", "work_id": "laozi", "section_id": "laozi-chapter-064", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 5, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 64.5", "chinese_text": "為之於未有，", "translation_ref": "老子 64.4", "translation_text": "that which is very small is easily dispersed."}
{"alignment_id": "laozi-chapter-064__align-005", "work_id": "laozi", "section_id": "laozi-chapter-064", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 6, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 64.6", "chinese_text": "治之於未亂。", "translation_ref": "老子 64.5", "translation_text": "Action should be taken before a thing has made its appearance;"}
{"alignment_id": "laozi-chapter-064__align-006", "work_id": "laozi", "section_id": "laozi-chapter-064", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 7, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 64.7", "chinese_text": "合抱之木，", "translation_ref": "老子 64.6", "translation_text": "order should be secured before disorder has begun."}
{"alignment_id": "laozi-chapter-064__align-007", "work_id": "laozi", "section_id": "laozi-chapter-064", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 8, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 64.8", "chinese_text": "生於毫末；", "translation_ref": "老子 64.7", "translation_text": "The tree which fills the arms grew from the tiniest sprout;"}
{"alignment_id": "laozi-chapter-064__align-008", "work_id": "laozi", "section_id": "laozi-chapter-064", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 9, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 3, "target_segment_count": 2, "chinese_ref": "老子 64.9 - 老子 64.11", "chinese_text": "九層之臺，起於累土；千里之行，", "translation_ref": "老子 64.8 - 老子 64.9", "translation_text": "the tower of nine storeys rose from a (small) heap of earth; the journey of a thousand li commenced with a single step."}
{"alignment_id": "laozi-chapter-064__align-009", "work_id": "laozi", "section_id": "laozi-chapter-064", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 12, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 64.12", "chinese_text": "始於足下。", "translation_ref": "老子 64.10", "translation_text": "He who acts (with an ulterior purpose) does harm;"}
{"alignment_id": "laozi-chapter-064__align-010", "work_id": "laozi", "section_id": "laozi-chapter-064", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 13, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 2, "target_segment_count": 1, "chinese_ref": "老子 64.13 - 老子 64.14", "chinese_text": "為者敗之，執者失之。", "translation_ref": "老子 64.11", "translation_text": "he who takes hold of a thing (in the same way) loses his hold."}
{"alignment_id": "laozi-chapter-064__align-011", "work_id": "laozi", "section_id": "laozi-chapter-064", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 15, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 2, "target_segment_count": 2, "chinese_ref": "老子 64.15 - 老子 64.16", "chinese_text": "是以聖人無為故無敗，無執故無失。", "translation_ref": "老子 64.12 - 老子 64.13", "translation_text": "The sage does not act (so), and therefore does no harm; he does not lay hold (so), and therefore does not lose his bold."}
{"alignment_id": "laozi-chapter-064__align-012", "work_id": "laozi", "section_id": "laozi-chapter-064", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 17, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 2, "target_segment_count": 1, "chinese_ref": "老子 64.17 - 老子 64.18", "chinese_text": "民之從事，常於幾成而敗之。", "translation_ref": "老子 64.14", "translation_text": "(But) people in their conduct of affairs are constantly ruining them when they are on the eve of success."}
{"alignment_id": "laozi-chapter-064__align-013", "work_id": "laozi", "section_id": "laozi-chapter-064", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 19, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 4, "target_segment_count": 2, "chinese_ref": "老子 64.19 - 老子 64.22", "chinese_text": "慎終如始，則無敗事。是以聖人欲不欲，不貴難得之貨；", "translation_ref": "老子 64.15 - 老子 64.16", "translation_text": "If they were careful at the end, as (they should be) at the beginning, they would not so ruin them. Therefore the sage desires what (other men) do not desire, and does not prize things difficult to get;"}
{"alignment_id": "laozi-chapter-064__align-014", "work_id": "laozi", "section_id": "laozi-chapter-064", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 23, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 2, "target_segment_count": 1, "chinese_ref": "老子 64.23 - 老子 64.24", "chinese_text": "學不學，復眾人之所過。", "translation_ref": "老子 64.17", "translation_text": "he learns what (other men) do not learn, and turns back to what the multitude of men have passed by."}
{"alignment_id": "laozi-chapter-064__align-015", "work_id": "laozi", "section_id": "laozi-chapter-064", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 25, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 2, "target_segment_count": 1, "chinese_ref": "老子 64.25 - 老子 64.26", "chinese_text": "以輔萬物之自然，而不敢為。", "translation_ref": "老子 64.18", "translation_text": "Thus he helps the natural development of all things, and does not dare to act (with an ulterior purpose of his own)."}
