{"alignment_id": "yijing-033-dun__alignment-005", "work_id": "yijing", "section_id": "yijing-033-dun", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 5, "section_unit": "section", "segment_type": "block", "alignment_granularity": "block", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "易經 33 九四", "chinese_text": "九四：好遯君子吉，小人否。", "translation_ref": "易經 33 九四", "translation_text": "The fourth NINE, undivided, shows its subject retiring notwithstanding his likings. In a superior man this will lead to good fortune; a small man cannot attain to this."}
{"alignment_id": "yijing-033-dun__alignment-006", "work_id": "yijing", "section_id": "yijing-033-dun", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 6, "section_unit": "section", "segment_type": "block", "alignment_granularity": "block", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "易經 33 九五", "chinese_text": "九五：嘉遯，貞吉。", "translation_ref": "易經 33 九五", "translation_text": "The fifth NINE, undivided, shows its subject retiring in an admirable way. With firm correctness there will be good fortune."}
