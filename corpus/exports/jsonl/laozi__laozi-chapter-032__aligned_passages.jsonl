{"alignment_id": "laozi-chapter-032__align-003", "work_id": "laozi", "section_id": "laozi-chapter-032", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 4, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 2, "target_segment_count": 1, "chinese_ref": "老子 32.4 - 老子 32.5", "chinese_text": "侯王若能守之，萬物將自賓。", "translation_ref": "老子 32.3", "translation_text": "If a feudal prince or the king could guard and hold it, all would spontaneously submit themselves to him."}
