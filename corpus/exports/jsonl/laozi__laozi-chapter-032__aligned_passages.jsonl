{"alignment_id": "laozi-chapter-032__align-005", "work_id": "laozi", "section_id": "laozi-chapter-032", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 9, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 32.9", "chinese_text": "始制有名，", "translation_ref": "老子 32.5", "translation_text": "As soon as it proceeds to action, it has a name."}
{"alignment_id": "laozi-chapter-032__align-006", "work_id": "laozi", "section_id": "laozi-chapter-032", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 10, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 3, "target_segment_count": 2, "chinese_ref": "老子 32.10 - 老子 32.12", "chinese_text": "名亦既有，夫亦將知止，知止所以不殆。", "translation_ref": "老子 32.6 - 老子 32.7", "translation_text": "When it once has that name, (men) can know to rest in it. When they know to rest in it, they can be free from all risk of failure and error."}
{"alignment_id": "laozi-chapter-032__align-007", "work_id": "laozi", "section_id": "laozi-chapter-032", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 13, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 2, "target_segment_count": 1, "chinese_ref": "老子 32.13 - 老子 32.14", "chinese_text": "譬道之在天下，猶川谷之於江海。", "translation_ref": "老子 32.8", "translation_text": "The relation of the Dao to all the world is like that of the great rivers and seas to the streams from the valleys."}
