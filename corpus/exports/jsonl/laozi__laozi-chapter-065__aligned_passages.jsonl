{"alignment_id": "laozi-chapter-065__align-003", "work_id": "laozi", "section_id": "laozi-chapter-065", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 3, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "sentence", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 65.3", "chinese_text": "故以智治國，國之賊，", "translation_ref": "老子 65.3", "translation_text": "He who (tries to) govern a state by his wisdom is a scourge to it; while he who does not (try to) do so is a blessing."}
