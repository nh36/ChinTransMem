{"alignment_id": "laozi-chapter-051__align-004", "work_id": "laozi", "section_id": "laozi-chapter-051", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 9, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 4, "target_segment_count": 1, "chinese_ref": "老子 51.9 - 老子 51.12", "chinese_text": "故道生之，德畜之。長之育之，亭之毒之，", "translation_ref": "老子 51.5", "translation_text": "Thus it is that the Dao produces (all things), nourishes them, brings them to their full growth, nurses them, completes them, matures them, maintains them, and overspreads them."}
{"alignment_id": "laozi-chapter-051__align-005", "work_id": "laozi", "section_id": "laozi-chapter-051", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 13, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 51.13", "chinese_text": "蓋之覆之。", "translation_ref": "老子 51.6", "translation_text": "It produces them and makes no claim to the possession of them;"}
{"alignment_id": "laozi-chapter-051__align-006", "work_id": "laozi", "section_id": "laozi-chapter-051", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 14, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 2, "target_segment_count": 1, "chinese_ref": "老子 51.14 - 老子 51.15", "chinese_text": "生而不有，為而不恃，", "translation_ref": "老子 51.7", "translation_text": "it carries them through their processes and does not vaunt its ability in doing so;"}
{"alignment_id": "laozi-chapter-051__align-007", "work_id": "laozi", "section_id": "laozi-chapter-051", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 16, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 2, "target_segment_count": 2, "chinese_ref": "老子 51.16 - 老子 51.17", "chinese_text": "長而不宰。是謂玄德。", "translation_ref": "老子 51.8 - 老子 51.9", "translation_text": "it brings them to maturity and exercises no control over them; - this is called its mysterious operation."}
