{"alignment_id": "laozi-chapter-026__align-002", "work_id": "laozi", "section_id": "laozi-chapter-026", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 2, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "sentence", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 26.2", "chinese_text": "是以聖人終日行不離輜重。", "translation_ref": "老子 26.2", "translation_text": "Therefore a wise prince, marching the whole day, does not go far from his baggage waggons."}
{"alignment_id": "laozi-chapter-026__align-003", "work_id": "laozi", "section_id": "laozi-chapter-026", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 3, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "sentence", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 26.3", "chinese_text": "雖有榮觀，燕處超然。", "translation_ref": "老子 26.3", "translation_text": "Although he may have brilliant prospects to look at, he quietly remains (in his proper place), indifferent to them."}
{"alignment_id": "laozi-chapter-026__align-004", "work_id": "laozi", "section_id": "laozi-chapter-026", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 4, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "sentence", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 26.4", "chinese_text": "奈何萬乘之主，而以身輕天下？", "translation_ref": "老子 26.4", "translation_text": "How should the lord of a myriad chariots carry himself lightly before the kingdom?"}
{"alignment_id": "laozi-chapter-026__align-005", "work_id": "laozi", "section_id": "laozi-chapter-026", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 5, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "sentence", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 26.5", "chinese_text": "輕則失本，躁則失君。", "translation_ref": "老子 26.5", "translation_text": "If he do act lightly, he has lost his root (of gravity); if he proceed to active movement, he will lose his throne."}
