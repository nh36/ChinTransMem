{"alignment_id": "laozi-chapter-008__align-004", "work_id": "laozi", "section_id": "laozi-chapter-008", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 4, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "sentence", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 8.4", "chinese_text": "居善地，心善淵，與善仁，言善信，正善治，事善能，動善時。", "translation_ref": "老子 8.4", "translation_text": "The excellence of a residence is in (the suitability of) the place; that of the mind is in abysmal stillness; that of associations is in their being with the virtuous; that of words is in their trustworthiness; that of government is in its securing good order; that of (the conduct of) affairs is in its ability; and that of (the initiation of) any movement is in its timeliness."}
{"alignment_id": "laozi-chapter-008__align-005", "work_id": "laozi", "section_id": "laozi-chapter-008", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 5, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "sentence", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 8.5", "chinese_text": "夫唯不爭，故無尤。", "translation_ref": "老子 8.5", "translation_text": "And when (one with the highest excellence) does not wrangle (about his low position), no one finds fault with him."}
