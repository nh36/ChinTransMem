{"alignment_id": "laozi-chapter-008__align-002", "work_id": "laozi", "section_id": "laozi-chapter-008", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 2, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "sentence", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 8.2", "chinese_text": "水善利萬物而不爭，處眾人之所惡，", "translation_ref": "老子 8.2", "translation_text": "The excellence of water appears in its benefiting all things, and in its occupying, without striving (to the contrary), the low place which all men dislike."}
