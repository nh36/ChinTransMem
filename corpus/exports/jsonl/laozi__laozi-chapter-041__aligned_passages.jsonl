{"alignment_id": "laozi-chapter-041__align-001", "work_id": "laozi", "section_id": "laozi-chapter-041", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 1, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 2, "target_segment_count": 1, "chinese_ref": "老子 41.1 - 老子 41.2", "chinese_text": "上士聞道，勤而行之；", "translation_ref": "老子 41.1", "translation_text": "Scholars of the highest class, when they hear about the Dao, earnestly carry it into practice."}
{"alignment_id": "laozi-chapter-041__align-002", "work_id": "laozi", "section_id": "laozi-chapter-041", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 3, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 2, "target_segment_count": 1, "chinese_ref": "老子 41.3 - 老子 41.4", "chinese_text": "中士聞道，若存若亡；", "translation_ref": "老子 41.2", "translation_text": "Scholars of the middle class, when they have heard about it, seem now to keep it and now to lose it."}
{"alignment_id": "laozi-chapter-041__align-003", "work_id": "laozi", "section_id": "laozi-chapter-041", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 5, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 2, "target_segment_count": 1, "chinese_ref": "老子 41.5 - 老子 41.6", "chinese_text": "下士聞道，大笑之。", "translation_ref": "老子 41.3", "translation_text": "Scholars of the lowest class, when they have heard about it, laugh greatly at it."}
{"alignment_id": "laozi-chapter-041__align-004", "work_id": "laozi", "section_id": "laozi-chapter-041", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 7, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 41.7", "chinese_text": "不笑不足以為道。", "translation_ref": "老子 41.4", "translation_text": "If it were not (thus) laughed at, it would not be fit to be the Dao."}
