{"alignment_id": "laozi-chapter-041__align-004", "work_id": "laozi", "section_id": "laozi-chapter-041", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 4, "section_unit": "chapter", "segment_type": "block", "alignment_granularity": "block", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 41.4", "chinese_text": "進道若退，", "translation_ref": "老子 41.4", "translation_text": "Who progress in it makes, seems drawing back;"}
{"alignment_id": "laozi-chapter-041__align-005", "work_id": "laozi", "section_id": "laozi-chapter-041", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 5, "section_unit": "chapter", "segment_type": "block", "alignment_granularity": "block", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 41.5", "chinese_text": "夷道若纇，", "translation_ref": "老子 41.5", "translation_text": "Its even way is like a rugged track."}
