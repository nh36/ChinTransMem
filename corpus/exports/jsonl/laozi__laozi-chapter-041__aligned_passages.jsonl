{"alignment_id": "laozi-chapter-041__align-008", "work_id": "laozi", "section_id": "laozi-chapter-041", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 8, "section_unit": "chapter", "segment_type": "block", "alignment_granularity": "block", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 41.8", "chinese_text": "廣德若不足，", "translation_ref": "老子 41.8", "translation_text": "And he has most whose lot the least supplies."}
{"alignment_id": "laozi-chapter-041__align-009", "work_id": "laozi", "section_id": "laozi-chapter-041", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 9, "section_unit": "chapter", "segment_type": "block", "alignment_granularity": "block", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 41.9", "chinese_text": "建德若偷，", "translation_ref": "老子 41.9", "translation_text": "Its firmest virtue seems but poor and low;"}
{"alignment_id": "laozi-chapter-041__align-010", "work_id": "laozi", "section_id": "laozi-chapter-041", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 10, "section_unit": "chapter", "segment_type": "block", "alignment_granularity": "block", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 41.10", "chinese_text": "質真若渝，", "translation_ref": "老子 41.10", "translation_text": "Its solid truth seems change to undergo;"}
