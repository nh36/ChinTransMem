{"alignment_id": "laozi-chapter-041__align-012", "work_id": "laozi", "section_id": "laozi-chapter-041", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 12, "section_unit": "chapter", "segment_type": "block", "alignment_granularity": "block", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 41.12", "chinese_text": "大器晚成，", "translation_ref": "老子 41.12", "translation_text": "A vessel great, it is the slowest made;"}
{"alignment_id": "laozi-chapter-041__align-013", "work_id": "laozi", "section_id": "laozi-chapter-041", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 13, "section_unit": "chapter", "segment_type": "block", "alignment_granularity": "block", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 41.13", "chinese_text": "大音希聲，", "translation_ref": "老子 41.13", "translation_text": "Loud is its sound, but never word it said;"}
{"alignment_id": "laozi-chapter-041__align-014", "work_id": "laozi", "section_id": "laozi-chapter-041", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 14, "section_unit": "chapter", "segment_type": "block", "alignment_granularity": "block", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 41.14", "chinese_text": "大象無形，", "translation_ref": "老子 41.14", "translation_text": "A semblance great, the shadow of a shade.'"}
{"alignment_id": "laozi-chapter-041__align-015", "work_id": "laozi", "section_id": "laozi-chapter-041", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 15, "section_unit": "chapter", "segment_type": "block", "alignment_granularity": "block", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 41.15", "chinese_text": "道隱無名。夫唯道，善貸且成。", "translation_ref": "老子 41.15", "translation_text": "The Dao is hidden, and has no name; but it is the Dao which is skilful at imparting (to all things what they need) and making them complete."}
