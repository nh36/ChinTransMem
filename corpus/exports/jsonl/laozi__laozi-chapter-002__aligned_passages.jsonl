{"alignment_id": "laozi-chapter-002__align-002", "work_id": "laozi", "section_id": "laozi-chapter-002", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 2, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 2, "target_segment_count": 1, "chinese_ref": "老子 2.2 - 老子 2.3", "chinese_text": "斯惡已。皆知善之為善，", "translation_ref": "老子 2.2", "translation_text": "they all know the skill of the skilful, and in doing this they have (the idea of) what the want of skill is."}
