{"alignment_id": "laozi-chapter-002__align-005", "work_id": "laozi", "section_id": "laozi-chapter-002", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 7, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 2.7", "chinese_text": "長短相較，", "translation_ref": "老子 2.5", "translation_text": "that length and shortness fashion out the one the figure of the other;"}
{"alignment_id": "laozi-chapter-002__align-006", "work_id": "laozi", "section_id": "laozi-chapter-002", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 8, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 2, "target_segment_count": 1, "chinese_ref": "老子 2.8 - 老子 2.9", "chinese_text": "高下相傾，音聲相和，", "translation_ref": "老子 2.6", "translation_text": "that (the ideas of) height and lowness arise from the contrast of the one with the other;"}
{"alignment_id": "laozi-chapter-002__align-007", "work_id": "laozi", "section_id": "laozi-chapter-002", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 10, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 2, "target_segment_count": 2, "chinese_ref": "老子 2.10 - 老子 2.11", "chinese_text": "前後相隨。是以聖人處無為之事，", "translation_ref": "老子 2.7 - 老子 2.8", "translation_text": "that the musical notes and tones become harmonious through the relation of one with another; and that being before and behind give the idea of one following another."}
{"alignment_id": "laozi-chapter-002__align-008", "work_id": "laozi", "section_id": "laozi-chapter-002", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 12, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 2, "target_segment_count": 2, "chinese_ref": "老子 2.12 - 老子 2.13", "chinese_text": "行不言之教；萬物作焉而不辭，", "translation_ref": "老子 2.9 - 老子 2.10", "translation_text": "Therefore the sage manages affairs without doing anything, and conveys his instructions without the use of speech. All things spring up, and there is not one which declines to show itself;"}
{"alignment_id": "laozi-chapter-002__align-009", "work_id": "laozi", "section_id": "laozi-chapter-002", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 14, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 2.14", "chinese_text": "生而不有，", "translation_ref": "老子 2.11", "translation_text": "they grow, and there is no claim made for their ownership;"}
{"alignment_id": "laozi-chapter-002__align-010", "work_id": "laozi", "section_id": "laozi-chapter-002", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 15, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 2.15", "chinese_text": "為而不恃，", "translation_ref": "老子 2.12", "translation_text": "they go through their processes, and there is no expectation (of a reward for the results)."}
{"alignment_id": "laozi-chapter-002__align-011", "work_id": "laozi", "section_id": "laozi-chapter-002", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 16, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 2.16", "chinese_text": "功成而弗居。", "translation_ref": "老子 2.13", "translation_text": "The work is accomplished, and there is no resting in it (as an achievement)."}
{"alignment_id": "laozi-chapter-002__align-012", "work_id": "laozi", "section_id": "laozi-chapter-002", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 17, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 2.17", "chinese_text": "夫唯弗居，", "translation_ref": "老子 2.14", "translation_text": "The work is done, but how no one can see;"}
{"alignment_id": "laozi-chapter-002__align-013", "work_id": "laozi", "section_id": "laozi-chapter-002", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 18, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 2.18", "chinese_text": "是以不去。", "translation_ref": "老子 2.15", "translation_text": "'Tis this that makes the power not cease to be."}
