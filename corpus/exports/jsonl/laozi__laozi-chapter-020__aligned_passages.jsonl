{"alignment_id": "laozi-chapter-020__align-002", "work_id": "laozi", "section_id": "laozi-chapter-020", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 2, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 20.2", "chinese_text": "唯之與阿，", "translation_ref": "老子 20.2", "translation_text": "The (ready) 'yes,' and (flattering) 'yea;'"}
{"alignment_id": "laozi-chapter-020__align-003", "work_id": "laozi", "section_id": "laozi-chapter-020", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 3, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 2, "target_segment_count": 2, "chinese_ref": "老子 20.3 - 老子 20.4", "chinese_text": "相去幾何？善之與惡，", "translation_ref": "老子 20.3 - 老子 20.4", "translation_text": "Small is the difference they display. But mark their issues, good and ill;"}
{"alignment_id": "laozi-chapter-020__align-004", "work_id": "laozi", "section_id": "laozi-chapter-020", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 5, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 20.5", "chinese_text": "相去若何？", "translation_ref": "老子 20.5", "translation_text": "What space the gulf between shall fill?"}
{"alignment_id": "laozi-chapter-020__align-005", "work_id": "laozi", "section_id": "laozi-chapter-020", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 6, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 20.6", "chinese_text": "人之所畏，", "translation_ref": "老子 20.6", "translation_text": "What all men fear is indeed to be feared;"}
{"alignment_id": "laozi-chapter-020__align-006", "work_id": "laozi", "section_id": "laozi-chapter-020", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 7, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 2, "target_segment_count": 1, "chinese_ref": "老子 20.7 - 老子 20.8", "chinese_text": "不可不畏。荒兮其未央哉﹗", "translation_ref": "老子 20.7", "translation_text": "but how wide and without end is the range of questions (asking to be discussed)!"}
{"alignment_id": "laozi-chapter-020__align-007", "work_id": "laozi", "section_id": "laozi-chapter-020", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 9, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 20.9", "chinese_text": "眾人熙熙，", "translation_ref": "老子 20.8", "translation_text": "The multitude of men look satisfied and pleased;"}
{"alignment_id": "laozi-chapter-020__align-008", "work_id": "laozi", "section_id": "laozi-chapter-020", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 10, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 2, "target_segment_count": 1, "chinese_ref": "老子 20.10 - 老子 20.11", "chinese_text": "如享太牢，如春登臺。", "translation_ref": "老子 20.9", "translation_text": "as if enjoying a full banquet, as if mounted on a tower in spring."}
{"alignment_id": "laozi-chapter-020__align-009", "work_id": "laozi", "section_id": "laozi-chapter-020", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 12, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 20.12", "chinese_text": "我獨泊兮其未兆，", "translation_ref": "老子 20.10", "translation_text": "I alone seem listless and still, my desires having as yet given no indication of their presence."}
{"alignment_id": "laozi-chapter-020__align-010", "work_id": "laozi", "section_id": "laozi-chapter-020", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 13, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 20.13", "chinese_text": "如嬰兒之未孩；", "translation_ref": "老子 20.11", "translation_text": "I am like an infant which has not yet smiled."}
{"alignment_id": "laozi-chapter-020__align-011", "work_id": "laozi", "section_id": "laozi-chapter-020", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 14, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 20.14", "chinese_text": "儽儽兮若無所歸。", "translation_ref": "老子 20.12", "translation_text": "I look dejected and forlorn, as if I had no home to go to."}
{"alignment_id": "laozi-chapter-020__align-012", "work_id": "laozi", "section_id": "laozi-chapter-020", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 15, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 20.15", "chinese_text": "眾人皆有餘，", "translation_ref": "老子 20.13", "translation_text": "The multitude of men all have enough and to spare."}
{"alignment_id": "laozi-chapter-020__align-013", "work_id": "laozi", "section_id": "laozi-chapter-020", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 16, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 1, "target_segment_count": 1, "chinese_ref": "老子 20.16", "chinese_text": "而我獨若遺。", "translation_ref": "老子 20.14", "translation_text": "I alone seem to have lost everything."}
{"alignment_id": "laozi-chapter-020__align-014", "work_id": "laozi", "section_id": "laozi-chapter-020", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 17, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 2, "target_segment_count": 2, "chinese_ref": "老子 20.17 - 老子 20.18", "chinese_text": "我愚人之心也哉﹗沌沌兮，", "translation_ref": "老子 20.15 - 老子 20.16", "translation_text": "My mind is that of a stupid man; I am in a state of chaos."}
{"alignment_id": "laozi-chapter-020__align-015", "work_id": "laozi", "section_id": "laozi-chapter-020", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 19, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 2, "target_segment_count": 1, "chinese_ref": "老子 20.19 - 老子 20.20", "chinese_text": "俗人昭昭，我獨昏昏。", "translation_ref": "老子 20.17", "translation_text": "Ordinary men look bright and intelligent, while I alone seem to be benighted."}
{"alignment_id": "laozi-chapter-020__align-016", "work_id": "laozi", "section_id": "laozi-chapter-020", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 21, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 2, "target_segment_count": 1, "chinese_ref": "老子 20.21 - 老子 20.22", "chinese_text": "俗人察察，我獨悶悶。", "translation_ref": "老子 20.18", "translation_text": "They look full of discrimination, while I alone am dull and confused."}
{"alignment_id": "laozi-chapter-020__align-017", "work_id": "laozi", "section_id": "laozi-chapter-020", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 23, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 2, "target_segment_count": 1, "chinese_ref": "老子 20.23 - 老子 20.24", "chinese_text": "澹兮其若海，飂兮若無止。", "translation_ref": "老子 20.19", "translation_text": "I seem to be carried about as on the sea, drifting as if I had nowhere to rest."}
{"alignment_id": "laozi-chapter-020__align-018", "work_id": "laozi", "section_id": "laozi-chapter-020", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 25, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 2, "target_segment_count": 1, "chinese_ref": "老子 20.25 - 老子 20.26", "chinese_text": "眾人皆有以，而我獨頑似鄙。", "translation_ref": "老子 20.20", "translation_text": "All men have their spheres of action, while I alone seem dull and incapable, like a rude borderer."}
{"alignment_id": "laozi-chapter-020__align-019", "work_id": "laozi", "section_id": "laozi-chapter-020", "alignment_type": "exact_or_near_exact", "confidence": 1.0, "order": 27, "section_unit": "chapter", "segment_type": "sentence", "alignment_granularity": "grouped", "is_coarse_alignment": false, "coarse_alignment_reason": null, "source_segment_count": 2, "target_segment_count": 1, "chinese_ref": "老子 20.27 - 老子 20.28", "chinese_text": "我獨異於人，而貴食母。", "translation_ref": "老子 20.21", "translation_text": "(Thus) I alone am different from other men, but I value the nursing-mother (the Dao)."}
