      <prop type="x-chinese-ref">詩經·國風·邶風·007.2</prop>
      <prop type="x-translation-ref">凱風.2</prop>
      <tuv xml:lang="zh-Hant">
        <seg>凱風自南，吹彼棘薪；
母氏聖善，我無令人。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>The genial wind from the south
Blows on the branches of that jujube tree,
Our mother is wise and good;
But among us there is none good.</seg>
      </tuv>
    </tu>
