      <prop type="x-chinese-ref">詩經·國風·邶風·007.3</prop>
      <prop type="x-translation-ref">凱風.3</prop>
      <tuv xml:lang="zh-Hant">
        <seg>爰有寒泉，在浚之下；
有子七人，母氏勞苦。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>There is the cool spring
Below the city of Tseun.
We are seven sons,
And our mother is full of pain and suffering.</seg>
      </tuv>
    </tu>
