      <prop type="x-translation-ref">老子 15.7</prop>
      <tuv xml:lang="zh-Hant">
        <seg>敦兮其若樸，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>unpretentious like wood that has not been fashioned into anything;</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-015__align-008">
