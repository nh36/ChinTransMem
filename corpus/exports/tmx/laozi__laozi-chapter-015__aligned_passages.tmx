      <prop type="x-translation-ref">老子 15.5</prop>
      <tuv xml:lang="zh-Hant">
        <seg>儼兮其若容，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>grave like a guest (in awe of his host);</seg>
      </tuv>
    </tu>
