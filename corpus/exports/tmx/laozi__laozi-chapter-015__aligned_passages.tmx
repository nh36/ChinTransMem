      <prop type="x-chinese-ref">老子 15.11</prop>
      <prop type="x-translation-ref">老子 15.8</prop>
      <tuv xml:lang="zh-Hant">
        <seg>曠兮其若谷，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>vacant like a valley, and dull like muddy water.</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-015__align-009">
      <prop type="x-work-id">laozi</prop>
