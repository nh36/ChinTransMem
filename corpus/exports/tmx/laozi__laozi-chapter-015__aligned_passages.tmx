      <prop type="x-translation-ref">老子 15.6</prop>
      <tuv xml:lang="zh-Hant">
        <seg>渙兮若冰之將釋，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>evanescent like ice that is melting away;</seg>
      </tuv>
    </tu>
