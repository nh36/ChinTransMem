      <prop type="x-chinese-ref">老子 15.6</prop>
      <prop type="x-translation-ref">老子 15.3</prop>
      <tuv xml:lang="zh-Hant">
        <seg>豫焉若冬涉川，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Shrinking looked they like those who wade through a stream in winter;</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-015__align-004">
      <prop type="x-work-id">laozi</prop>
