      <prop type="x-translation-ref">老子 15.4</prop>
      <tuv xml:lang="zh-Hant">
        <seg>猶兮若畏四鄰，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>irresolute like those who are afraid of all around them;</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-015__align-005">
