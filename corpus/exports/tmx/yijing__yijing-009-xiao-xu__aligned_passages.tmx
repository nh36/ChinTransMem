      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">易經 9 judgment</prop>
      <prop type="x-translation-ref">易經 9 judgment</prop>
      <tuv xml:lang="zh-Hant">
        <seg>小畜，亨。密雲不雨，自我西郊。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Xiao Xu indicates that (under its conditions) there will be progress and success. (We see) dense clouds, but no rain coming from our borders in the west.</seg>
      </tuv>
    </tu>
    <tu tuid="yijing-009-xiao-xu__alignment-002">
      <prop type="x-work-id">yijing</prop>
