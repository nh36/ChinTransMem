      <prop type="x-source-segment-count">1</prop>
      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 79.5</prop>
      <prop type="x-translation-ref">老子 79.5</prop>
      <tuv xml:lang="zh-Hant">
        <seg>天道無親，常與善人。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>In the Way of Heaven, there is no partiality of love; it is always on the side of the good man.</seg>
      </tuv>
    </tu>
