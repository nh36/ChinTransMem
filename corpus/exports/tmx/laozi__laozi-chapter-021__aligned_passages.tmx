      <prop type="x-translation-ref">老子 21.12</prop>
      <tuv xml:lang="zh-Hant">
        <seg>其精甚真，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Of what, when seen, shall then be told.</seg>
      </tuv>
    </tu>
