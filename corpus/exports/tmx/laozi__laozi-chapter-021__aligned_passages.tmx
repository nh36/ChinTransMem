      <prop type="x-translation-ref">老子 21.15</prop>
      <tuv xml:lang="zh-Hant">
        <seg>自今及古，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Its name - what passes not away;</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-021__align-012">
