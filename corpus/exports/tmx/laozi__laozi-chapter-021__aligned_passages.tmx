      <prop type="x-translation-ref">老子 21.17</prop>
      <tuv xml:lang="zh-Hant">
        <seg>以閱眾甫。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Things form and never know decay.</seg>
      </tuv>
    </tu>
