      <prop type="x-chinese-ref">老子 21.5 - 老子 21.6</prop>
      <prop type="x-translation-ref">老子 21.5 - 老子 21.7</prop>
      <tuv xml:lang="zh-Hant">
        <seg>惚兮恍兮，其中有象；</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Eluding sight, eluding touch, The forms of things all in it crouch; Eluding touch, eluding sight,</seg>
      </tuv>
    </tu>
