      <prop type="x-translation-ref">老子 21.13 - 老子 21.14</prop>
      <tuv xml:lang="zh-Hant">
        <seg>其中有信。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Now it is so; 'twas so of old.</seg>
      </tuv>
    </tu>
