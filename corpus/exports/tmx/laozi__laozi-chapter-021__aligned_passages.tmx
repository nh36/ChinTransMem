      <prop type="x-translation-ref">老子 21.11</prop>
      <tuv xml:lang="zh-Hant">
        <seg>其中有精；</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Those essences the truth enfold</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-021__align-009">
