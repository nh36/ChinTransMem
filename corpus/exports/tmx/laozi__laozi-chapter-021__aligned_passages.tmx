      <prop type="x-translation-ref">老子 21.16</prop>
      <tuv xml:lang="zh-Hant">
        <seg>其名不去，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>So, in their beautiful array,</seg>
      </tuv>
    </tu>
