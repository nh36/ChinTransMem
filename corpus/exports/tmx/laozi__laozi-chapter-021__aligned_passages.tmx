      <prop type="x-translation-ref">老子 21.2</prop>
      <tuv xml:lang="zh-Hant">
        <seg>惟道是從。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>From Dao come, their only source.</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-021__align-003">
