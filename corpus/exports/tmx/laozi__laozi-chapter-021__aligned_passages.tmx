      <prop type="x-translation-ref">老子 21.8</prop>
      <tuv xml:lang="zh-Hant">
        <seg>恍兮惚兮，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>There are their semblances, all right.</seg>
      </tuv>
    </tu>
