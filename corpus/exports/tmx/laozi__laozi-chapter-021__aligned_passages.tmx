      <prop type="x-translation-ref">老子 21.10</prop>
      <tuv xml:lang="zh-Hant">
        <seg>窈兮冥兮，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Things' essences all there endure.</seg>
      </tuv>
    </tu>
