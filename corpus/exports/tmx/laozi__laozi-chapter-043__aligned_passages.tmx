      <prop type="x-translation-ref">老子 43.3</prop>
      <tuv xml:lang="zh-Hant">
        <seg>吾是以知無為之有益。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>I know hereby what advantage belongs to doing nothing (with a purpose).</seg>
      </tuv>
    </tu>
