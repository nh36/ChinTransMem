      <tuv xml:lang="zh-Hant">
        <seg>禍兮福之所倚，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Misery! - happiness is to be found by its side! Happiness!</seg>
      </tuv>
    </tu>
