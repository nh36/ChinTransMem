      <tuv xml:lang="zh-Hant">
        <seg>是以聖人方而不割，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Therefore the sage is (like) a square which cuts no one (with its angles);</seg>
      </tuv>
    </tu>
