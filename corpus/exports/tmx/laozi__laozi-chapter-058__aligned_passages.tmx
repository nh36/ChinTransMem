      <prop type="x-translation-ref">老子 58.11</prop>
      <tuv xml:lang="zh-Hant">
        <seg>其無正。正復為奇，善復為妖。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>The (method of) correction shall by a turn become distortion, and the good in it shall by a turn become evil.</seg>
      </tuv>
    </tu>
