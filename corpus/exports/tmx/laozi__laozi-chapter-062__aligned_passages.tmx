      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 62.10</prop>
      <prop type="x-translation-ref">老子 62.10</prop>
      <tuv xml:lang="zh-Hant">
        <seg>故為天下貴。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>This is the reason why all under heaven consider it the most valuable thing.</seg>
      </tuv>
