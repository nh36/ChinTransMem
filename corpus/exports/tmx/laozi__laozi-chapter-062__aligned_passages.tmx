      <prop type="x-chinese-ref">老子 62.1</prop>
      <prop type="x-translation-ref">老子 62.1</prop>
      <tuv xml:lang="zh-Hant">
        <seg>道者萬物之奧。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Dao has of all things the most honoured place.</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-062__align-002">
