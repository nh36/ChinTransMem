      <prop type="x-confidence">1.00</prop>
      <prop type="x-source-segment-count">1</prop>
      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 62.8</prop>
      <prop type="x-translation-ref">老子 62.8</prop>
      <tuv xml:lang="zh-Hant">
        <seg>古之所以貴此道者何？</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Why was it that the ancients prized this Dao so much?</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-062__align-009">
      <prop type="x-work-id">laozi</prop>
      <prop type="x-section-id">laozi-chapter-062</prop>
