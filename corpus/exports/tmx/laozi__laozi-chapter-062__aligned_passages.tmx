      <prop type="x-chinese-ref">老子 62.5</prop>
      <prop type="x-translation-ref">老子 62.5</prop>
      <tuv xml:lang="zh-Hant">
        <seg>人之不善，何棄之有？</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>(its) admirable deeds can raise their performer above others.</seg>
      </tuv>
    </tu>
