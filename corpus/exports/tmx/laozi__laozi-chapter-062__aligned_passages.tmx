      <prop type="x-chinese-ref">老子 62.2</prop>
      <prop type="x-translation-ref">老子 62.2</prop>
      <tuv xml:lang="zh-Hant">
        <seg>善人之寶，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>No treasures give good men so rich a grace;</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-062__align-003">
      <prop type="x-work-id">laozi</prop>
      <prop type="x-section-id">laozi-chapter-062</prop>
