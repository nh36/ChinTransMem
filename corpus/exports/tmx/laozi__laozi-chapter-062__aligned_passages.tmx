      <prop type="x-chinese-ref">老子 62.6</prop>
      <prop type="x-translation-ref">老子 62.6</prop>
      <tuv xml:lang="zh-Hant">
        <seg>故立天子，置三公，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Even men who are not good are not abandoned by it.</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-062__align-007">
      <prop type="x-work-id">laozi</prop>
