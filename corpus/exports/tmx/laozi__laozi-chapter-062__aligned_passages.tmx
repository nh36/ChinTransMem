      <prop type="x-chinese-ref">老子 62.3</prop>
      <prop type="x-translation-ref">老子 62.3</prop>
      <tuv xml:lang="zh-Hant">
        <seg>不善人之所保。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Bad men it guards, and doth their ill efface.</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-062__align-004">
      <prop type="x-work-id">laozi</prop>
      <prop type="x-section-id">laozi-chapter-062</prop>
