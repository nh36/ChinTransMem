      <prop type="x-chinese-ref">老子 62.4</prop>
      <prop type="x-translation-ref">老子 62.4</prop>
      <tuv xml:lang="zh-Hant">
        <seg>美言可以市，尊行可以加人。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>(Its) admirable words can purchase honour;</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-062__align-005">
      <prop type="x-work-id">laozi</prop>
      <prop type="x-section-id">laozi-chapter-062</prop>
