      <prop type="x-chinese-ref">老子 29.6 - 老子 29.7</prop>
      <prop type="x-translation-ref">老子 29.4 - 老子 29.5</prop>
      <tuv xml:lang="zh-Hant">
        <seg>執者失之。故物或行或隨，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>he who would hold it in his grasp loses it. The course and nature of things is such that</seg>
      </tuv>
    </tu>
