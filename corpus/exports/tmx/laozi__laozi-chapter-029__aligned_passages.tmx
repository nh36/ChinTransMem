      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 29.10</prop>
      <prop type="x-translation-ref">老子 29.8</prop>
      <tuv xml:lang="zh-Hant">
        <seg>或挫或隳。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Strength is of weakness oft the spoil;</seg>
      </tuv>
    </tu>
