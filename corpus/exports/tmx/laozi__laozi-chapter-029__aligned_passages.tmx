      <prop type="x-chinese-ref">老子 29.8</prop>
      <prop type="x-translation-ref">老子 29.6</prop>
      <tuv xml:lang="zh-Hant">
        <seg>或歔或吹。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>What was in front is now behind;</seg>
      </tuv>
    </tu>
