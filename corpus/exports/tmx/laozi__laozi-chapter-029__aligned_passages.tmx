      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 29.5</prop>
      <prop type="x-translation-ref">老子 29.3</prop>
      <tuv xml:lang="zh-Hant">
        <seg>為者敗之，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>He who would so win it destroys it;</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-029__align-004">
      <prop type="x-work-id">laozi</prop>
      <prop type="x-section-id">laozi-chapter-029</prop>
      <prop type="x-section-unit">chapter</prop>
