      <prop type="x-source-segment-count">2</prop>
      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 29.3 - 老子 29.4</prop>
      <prop type="x-translation-ref">老子 29.2</prop>
      <tuv xml:lang="zh-Hant">
        <seg>天下神器，不可為也，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>The kingdom is a spirit-like thing, and cannot be got by active doing.</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-029__align-003">
      <prop type="x-work-id">laozi</prop>
      <prop type="x-section-id">laozi-chapter-029</prop>
      <prop type="x-section-unit">chapter</prop>
      <prop type="x-segment-type">sentence</prop>
