      <prop type="x-chinese-ref">老子 29.9</prop>
      <prop type="x-translation-ref">老子 29.7</prop>
      <tuv xml:lang="zh-Hant">
        <seg>或強或羸，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>What warmed anon we freezing find.</seg>
      </tuv>
    </tu>
