      <prop type="x-source-segment-count">2</prop>
      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 29.1 - 老子 29.2</prop>
      <prop type="x-translation-ref">老子 29.1</prop>
      <tuv xml:lang="zh-Hant">
        <seg>將欲取天下而為之，吾見其不得已。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>If any one should wish to get the kingdom for himself, and to effect this by what he does, I see that he will not succeed.</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-029__align-002">
      <prop type="x-work-id">laozi</prop>
      <prop type="x-section-id">laozi-chapter-029</prop>
