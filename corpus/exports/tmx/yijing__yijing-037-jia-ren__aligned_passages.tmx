      <prop type="x-chinese-ref">易經 37 初九</prop>
      <prop type="x-translation-ref">易經 37 初九</prop>
      <tuv xml:lang="zh-Hant">
        <seg>初九：閑有家，悔亡。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>The first NINE, undivided, shows its subject establishing restrictive regulations in his household Occasion for repentance will disappear.</seg>
      </tuv>
    </tu>
