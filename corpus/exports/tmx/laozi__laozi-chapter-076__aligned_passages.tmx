      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 76.3</prop>
      <prop type="x-translation-ref">老子 76.3</prop>
      <tuv xml:lang="zh-Hant">
        <seg>強大處下，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Hence he who (relies on) the strength of his forces does not conquer; and a tree which is strong will fill the out-stretched arms, (and thereby invites the feller.)</seg>
      </tuv>
    </tu>
