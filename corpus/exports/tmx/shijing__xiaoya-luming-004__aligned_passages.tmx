      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">詩經·小雅·鹿鳴之什·004.3</prop>
      <prop type="x-translation-ref">常棣.3</prop>
      <tuv xml:lang="zh-Hant">
        <seg>脊令在原，兄弟急難。每有良朋，況也永歎。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>There is the wagtail on the level height; --
When brothers are in urgent difficulties,
Friends, though they may be good,
Will only heave long sighs.</seg>
      </tuv>
    </tu>
    <tu tuid="shijing__xiaoya-luming-004__004__zhwikisource-20260530__legge-sheking-1871-ocr">
      <prop type="x-work-id">shijing</prop>
