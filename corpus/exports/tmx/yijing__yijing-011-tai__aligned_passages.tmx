      <prop type="x-chinese-ref">易經 11 judgment</prop>
      <prop type="x-translation-ref">易經 11 judgment</prop>
      <tuv xml:lang="zh-Hant">
        <seg>泰，小往大來，吉亨。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>In Tai (we see) the little gone and the great come. (It indicates that) there will be good fortune, with progress and success.</seg>
      </tuv>
    </tu>
    <tu tuid="yijing-011-tai__alignment-002">
      <prop type="x-work-id">yijing</prop>
