      <prop type="x-translation-ref">老子 49.3</prop>
      <tuv xml:lang="zh-Hant">
        <seg>善者，吾善之；</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>To those who are good (to me), I am good;</seg>
      </tuv>
    </tu>
