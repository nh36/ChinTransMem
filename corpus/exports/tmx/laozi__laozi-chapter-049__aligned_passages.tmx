      <prop type="x-source-segment-count">1</prop>
      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 49.3</prop>
      <prop type="x-translation-ref">老子 49.3</prop>
      <tuv xml:lang="zh-Hant">
        <seg>德善。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>To those who are sincere (with me), I am sincere; and to those who are not sincere (with me), I am also sincere; - and thus (all) get to be sincere.</seg>
      </tuv>
    </tu>
