      <prop type="x-translation-ref">老子 49.4</prop>
      <tuv xml:lang="zh-Hant">
        <seg>不善者，吾亦善之，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>and to those who are not good (to me), I am also good;</seg>
      </tuv>
    </tu>
