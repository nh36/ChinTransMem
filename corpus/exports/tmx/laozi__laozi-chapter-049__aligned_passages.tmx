      <prop type="x-translation-ref">老子 49.1</prop>
      <tuv xml:lang="zh-Hant">
        <seg>聖人無常心，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>The sage has no invariable mind of his own;</seg>
      </tuv>
    </tu>
