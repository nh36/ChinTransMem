      <prop type="x-translation-ref">老子 49.2</prop>
      <tuv xml:lang="zh-Hant">
        <seg>以百姓心為心。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>he makes the mind of the people his mind.</seg>
      </tuv>
    </tu>
