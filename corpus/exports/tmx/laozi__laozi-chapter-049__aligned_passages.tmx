      <prop type="x-chinese-ref">老子 49.15</prop>
      <prop type="x-translation-ref">老子 49.10</prop>
      <tuv xml:lang="zh-Hant">
        <seg>百姓皆注其耳目,聖人皆孩之。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>The people all keep their eyes and ears directed to him, and he deals with them all as his children.</seg>
      </tuv>
