      <prop type="x-source-segment-count">1</prop>
      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">易經 30 初九</prop>
      <prop type="x-translation-ref">易經 30 初九</prop>
      <tuv xml:lang="zh-Hant">
        <seg>初九：履錯然，敬之无咎。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>The first NINE, undivided, shows one ready to move with confused steps. But he treads at the same time reverently, and there will be no mistake.</seg>
      </tuv>
    </tu>
