      <prop type="x-chinese-ref">易經 30 六二</prop>
      <prop type="x-translation-ref">易經 30 六二</prop>
      <tuv xml:lang="zh-Hant">
        <seg>六二：黃離，元吉。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>The second SIX, divided, shows its subject in his place in yellow. There will be great good fortune.</seg>
      </tuv>
    </tu>
