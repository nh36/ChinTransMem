      <prop type="x-chinese-ref">詩經·國風·邶風·002.1</prop>
      <prop type="x-translation-ref">Lull e..1</prop>
      <tuv xml:lang="zh-Hant">
        <seg>綠兮衣兮，綠衣黃裏，心之憂矣，曷維其已。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Green is the upper robe,
Green with a yellow lining!
The sorrow of my heart, —
How can it cease?</seg>
      </tuv>
    </tu>
