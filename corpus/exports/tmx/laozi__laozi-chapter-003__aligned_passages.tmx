      <prop type="x-alignment-type">exact_or_near_exact</prop>
      <prop type="x-confidence">1.00</prop>
      <prop type="x-source-segment-count">2</prop>
      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 3.14 - 老子 3.15</prop>
      <prop type="x-translation-ref">老子 3.6</prop>
      <tuv xml:lang="zh-Hant">
        <seg>為無為，則無不治。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>When there is this abstinence from action, good order is universal.</seg>
      </tuv>
    </tu>
