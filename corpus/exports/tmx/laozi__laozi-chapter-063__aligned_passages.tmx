      <prop type="x-source-segment-count">1</prop>
      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 63.14</prop>
      <prop type="x-translation-ref">老子 63.9</prop>
      <tuv xml:lang="zh-Hant">
        <seg>是以聖人猶難之，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>he who is continually thinking things easy is sure to find them difficult.</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-063__align-009">
