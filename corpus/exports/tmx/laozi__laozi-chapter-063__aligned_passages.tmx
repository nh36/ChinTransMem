      <prop type="x-confidence">1.00</prop>
      <prop type="x-source-segment-count">1</prop>
      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 63.15</prop>
      <prop type="x-translation-ref">老子 63.10</prop>
      <tuv xml:lang="zh-Hant">
        <seg>故終無難矣</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Therefore the sage sees difficulty even in what seems easy, and so never has any difficulties.</seg>
      </tuv>
    </tu>
