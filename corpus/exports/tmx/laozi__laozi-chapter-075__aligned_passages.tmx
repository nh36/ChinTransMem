      <prop type="x-chinese-ref">老子 75.4 - 老子 75.5</prop>
      <prop type="x-translation-ref">老子 75.3</prop>
      <tuv xml:lang="zh-Hant">
        <seg>民之難治，以其上之有為，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>The people are difficult to govern because of the (excessive) agency of their superiors (in governing them).</seg>
      </tuv>
    </tu>
