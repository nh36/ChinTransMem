      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">易經 42 judgment</prop>
      <prop type="x-translation-ref">易經 42 judgment</prop>
      <tuv xml:lang="zh-Hant">
        <seg>益，利有攸往，利涉大川。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Yi indicates that (in the state which it denotes) there will be advantage in every movement which shall be undertaken, that it will be advantageous (even) to cross the great stream.</seg>
      </tuv>
    </tu>
    <tu tuid="yijing-042-yi__alignment-002">
      <prop type="x-work-id">yijing</prop>
