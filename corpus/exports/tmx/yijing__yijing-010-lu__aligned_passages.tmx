      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">易經 10 初九</prop>
      <prop type="x-translation-ref">易經 10 初九</prop>
      <tuv xml:lang="zh-Hant">
        <seg>初九，素履，往无咎。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>The first NINE, undivided, shows its subject treading his accustomed path. If he go forward, there will be no error.</seg>
      </tuv>
    </tu>
