      <prop type="x-chinese-ref">老子 72.8</prop>
      <prop type="x-translation-ref">老子 72.6</prop>
      <tuv xml:lang="zh-Hant">
        <seg>自愛不自貴；</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>loves, but does not (appear to set a) value on, himself.</seg>
      </tuv>
    </tu>
