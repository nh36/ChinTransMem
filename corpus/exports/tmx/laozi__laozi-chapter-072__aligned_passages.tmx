      <prop type="x-chinese-ref">老子 72.7</prop>
      <prop type="x-translation-ref">老子 72.5</prop>
      <tuv xml:lang="zh-Hant">
        <seg>是以聖人自知不自見，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Therefore the sage knows (these things) of himself, but does not parade (his knowledge);</seg>
      </tuv>
    </tu>
