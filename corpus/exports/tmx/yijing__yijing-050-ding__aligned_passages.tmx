      <prop type="x-chinese-ref">易經 50 judgment</prop>
      <prop type="x-translation-ref">易經 50 judgment</prop>
      <tuv xml:lang="zh-Hant">
        <seg>鼎，元吉，亨。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Ding gives the intimation of great progress and success.</seg>
      </tuv>
    </tu>
    <tu tuid="yijing-050-ding__alignment-002">
