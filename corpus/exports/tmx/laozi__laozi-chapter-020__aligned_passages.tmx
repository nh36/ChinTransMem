      <prop type="x-chinese-ref">老子 20.7</prop>
      <prop type="x-translation-ref">老子 20.7</prop>
      <tuv xml:lang="zh-Hant">
        <seg>儽儽兮若無所歸。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>The multitude of men look satisfied and pleased; as if enjoying a full banquet, as if mounted on a tower in spring.</seg>
      </tuv>
    </tu>
