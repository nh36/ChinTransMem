      <prop type="x-translation-ref">老子 20.4</prop>
      <tuv xml:lang="zh-Hant">
        <seg>荒兮其未央哉﹗</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>But mark their issues, good and ill;</seg>
      </tuv>
    </tu>
