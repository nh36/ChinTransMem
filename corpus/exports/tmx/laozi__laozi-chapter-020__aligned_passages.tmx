      <tuv xml:lang="zh-Hant">
        <seg>我獨悶悶。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>I am in a state of chaos.</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-020__align-015">
