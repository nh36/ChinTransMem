      <prop type="x-translation-ref">老子 20.9</prop>
      <tuv xml:lang="zh-Hant">
        <seg>我愚人之心也哉﹗</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>I am like an infant which has not yet smiled.</seg>
      </tuv>
    </tu>
