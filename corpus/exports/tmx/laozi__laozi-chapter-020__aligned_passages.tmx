      <prop type="x-translation-ref">老子 20.3</prop>
      <tuv xml:lang="zh-Hant">
        <seg>人之所畏，不可不畏。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Small is the difference they display.</seg>
      </tuv>
    </tu>
