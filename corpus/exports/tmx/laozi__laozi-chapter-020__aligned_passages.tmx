      <prop type="x-translation-ref">老子 20.18</prop>
      <tuv xml:lang="zh-Hant">
        <seg>而我獨頑似鄙。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>All men have their spheres of action, while I alone seem dull and incapable, like a rude borderer.</seg>
      </tuv>
    </tu>
