      <prop type="x-translation-ref">老子 20.11</prop>
      <tuv xml:lang="zh-Hant">
        <seg>俗人昭昭，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>The multitude of men all have enough and to spare.</seg>
      </tuv>
    </tu>
