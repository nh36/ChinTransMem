      <prop type="x-chinese-ref">老子 20.8</prop>
      <prop type="x-translation-ref">老子 20.8</prop>
      <tuv xml:lang="zh-Hant">
        <seg>眾人皆有餘，而我獨若遺。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>I alone seem listless and still, my desires having as yet given no indication of their presence.</seg>
      </tuv>
    </tu>
