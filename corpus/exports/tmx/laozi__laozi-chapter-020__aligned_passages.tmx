      <prop type="x-translation-ref">老子 20.17</prop>
      <tuv xml:lang="zh-Hant">
        <seg>眾人皆有以，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>I seem to be carried about as on the sea, drifting as if I had nowhere to rest.</seg>
      </tuv>
    </tu>
