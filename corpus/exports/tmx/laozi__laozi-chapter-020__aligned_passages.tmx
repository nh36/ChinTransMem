      <prop type="x-translation-ref">老子 20.10</prop>
      <tuv xml:lang="zh-Hant">
        <seg>沌沌兮，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>I look dejected and forlorn, as if I had no home to go to.</seg>
      </tuv>
    </tu>
