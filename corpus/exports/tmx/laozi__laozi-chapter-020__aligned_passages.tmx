      <prop type="x-translation-ref">老子 20.15</prop>
      <tuv xml:lang="zh-Hant">
        <seg>澹兮其若海，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Ordinary men look bright and intelligent, while I alone seem to be benighted.</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-020__align-016">
