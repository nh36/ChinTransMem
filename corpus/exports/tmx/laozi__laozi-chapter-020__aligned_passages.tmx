      <prop type="x-translation-ref">老子 20.12</prop>
      <tuv xml:lang="zh-Hant">
        <seg>我獨昏昏。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>I alone seem to have lost everything.</seg>
      </tuv>
    </tu>
