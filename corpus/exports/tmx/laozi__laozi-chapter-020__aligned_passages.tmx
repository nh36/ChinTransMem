      <prop type="x-translation-ref">老子 20.2</prop>
      <tuv xml:lang="zh-Hant">
        <seg>善之與惡，相去若何？</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>The (ready) 'yes,' and (flattering) 'yea;'</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-020__align-003">
