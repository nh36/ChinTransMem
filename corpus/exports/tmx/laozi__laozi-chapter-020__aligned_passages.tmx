      <prop type="x-translation-ref">老子 20.16</prop>
      <tuv xml:lang="zh-Hant">
        <seg>飂兮若無止。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>They look full of discrimination, while I alone am dull and confused.</seg>
      </tuv>
    </tu>
