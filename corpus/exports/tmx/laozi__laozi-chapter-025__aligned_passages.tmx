      <prop type="x-chinese-ref">老子 25.1 - 老子 25.2</prop>
      <prop type="x-translation-ref">老子 25.1</prop>
      <tuv xml:lang="zh-Hant">
        <seg>有物混成，先天地生。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>There was something undefined and complete, coming into existence before Heaven and Earth.</seg>
      </tuv>
    </tu>
