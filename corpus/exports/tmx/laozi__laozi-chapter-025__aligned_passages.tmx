      <prop type="x-translation-ref">老子 25.10 - 老子 25.11</prop>
      <tuv xml:lang="zh-Hant">
        <seg>故道大，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Heaven is great; Earth is great;</seg>
      </tuv>
    </tu>
