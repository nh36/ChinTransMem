      <prop type="x-translation-ref">老子 25.12</prop>
      <tuv xml:lang="zh-Hant">
        <seg>天大，地大，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>and the (sage) king is also great.</seg>
      </tuv>
    </tu>
