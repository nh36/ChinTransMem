      <prop type="x-translation-ref">老子 25.7</prop>
      <tuv xml:lang="zh-Hant">
        <seg>大曰逝，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Passing on, it becomes remote.</seg>
      </tuv>
    </tu>
