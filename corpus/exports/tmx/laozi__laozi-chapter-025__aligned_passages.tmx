      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 25.3 - 老子 25.4</prop>
      <prop type="x-translation-ref">老子 25.2</prop>
      <tuv xml:lang="zh-Hant">
        <seg>寂兮寥兮，獨立而不改，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>How still it was and formless, standing alone, and undergoing no change, reaching everywhere and in no danger (of being exhausted)!</seg>
      </tuv>
    </tu>
