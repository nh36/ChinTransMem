      <prop type="x-chinese-ref">老子 25.5</prop>
      <prop type="x-translation-ref">老子 25.3</prop>
      <tuv xml:lang="zh-Hant">
        <seg>周行而不殆，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>It may be regarded as the Mother of all things.</seg>
      </tuv>
    </tu>
