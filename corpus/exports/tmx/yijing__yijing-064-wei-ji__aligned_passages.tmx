      <prop type="x-chinese-ref">易經 64 初六</prop>
      <prop type="x-translation-ref">易經 64 初六</prop>
      <tuv xml:lang="zh-Hant">
        <seg>初六：濡其尾，吝。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>The first SIX, divided, shows its subject (like a fox) whose tail gets immersed. There will be occasion for regret.</seg>
      </tuv>
    </tu>
