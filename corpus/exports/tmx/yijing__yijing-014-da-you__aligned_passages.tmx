      <prop type="x-chinese-ref">易經 14 judgment</prop>
      <prop type="x-translation-ref">易經 14 judgment</prop>
      <tuv xml:lang="zh-Hant">
        <seg>大有，元亨。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Da You indicates that, (under the circumstances which it implies), there will be great progress and success.</seg>
      </tuv>
    </tu>
