      <prop type="x-chinese-ref">易經 14 九二</prop>
      <prop type="x-translation-ref">易經 14 九二</prop>
      <tuv xml:lang="zh-Hant">
        <seg>九二：大車以載，有攸往，无咎。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>In the second NINE, undivided, we have a large waggon with its load. In whatever direction advance is made, there will be no error.</seg>
      </tuv>
    </tu>
