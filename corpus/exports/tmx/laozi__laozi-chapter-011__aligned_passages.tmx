      <prop type="x-translation-ref">老子 11.1</prop>
      <tuv xml:lang="zh-Hant">
        <seg>三十輻共一轂，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>The thirty spokes unite in the one nave;</seg>
      </tuv>
    </tu>
