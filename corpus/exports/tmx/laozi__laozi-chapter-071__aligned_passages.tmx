      <prop type="x-chinese-ref">老子 71.1</prop>
      <prop type="x-translation-ref">老子 71.1</prop>
      <tuv xml:lang="zh-Hant">
        <seg>知不知上，不知知病。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>To know and yet (think) we do not know is the highest (attainment); not to know (and yet think) we do know is a disease.</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-071__align-002">
