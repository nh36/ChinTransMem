      <prop type="x-source-segment-count">1</prop>
      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 65.10</prop>
      <prop type="x-translation-ref">老子 65.5</prop>
      <tuv xml:lang="zh-Hant">
        <seg>知此兩者亦稽式。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>He who knows these two things finds in them also his model and rule.</seg>
      </tuv>
    </tu>
