      <prop type="x-translation-ref">老子 50.1</prop>
      <tuv xml:lang="zh-Hant">
        <seg>出生入死。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Men come forth and live;</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-050__align-002">
      <prop type="x-work-id">laozi</prop>
      <prop type="x-section-id">laozi-chapter-050</prop>
