      <prop type="x-source-segment-count">1</prop>
      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">易經 55 九三</prop>
      <prop type="x-translation-ref">易經 55 九三</prop>
      <tuv xml:lang="zh-Hant">
        <seg>九三：豐其沛，日中見昧，折其右肱，无咎。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>The third NINE, undivided, shows its subject with an (additional) screen of a large and thick banner, through which at midday he can see (the small) Mei star. (In the darkness) he breaks his right arm; but there will be no error.</seg>
      </tuv>
    </tu>
