      <prop type="x-translation-ref">老子 46.3 - 老子 46.4</prop>
      <tuv xml:lang="zh-Hant">
        <seg>〉禍莫大於不知足；</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>There is no guilt greater than to sanction ambition; no calamity greater than to be discontented with one's lot;</seg>
      </tuv>
    </tu>
