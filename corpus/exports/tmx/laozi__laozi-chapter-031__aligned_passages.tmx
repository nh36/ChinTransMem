      <prop type="x-chinese-ref">老子 31.16</prop>
      <prop type="x-translation-ref">老子 31.11</prop>
      <tuv xml:lang="zh-Hant">
        <seg>吉事尚左，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>on occasions of mourning, the right hand.</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-031__align-011">
