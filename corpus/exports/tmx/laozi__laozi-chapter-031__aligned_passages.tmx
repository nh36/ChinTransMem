      <prop type="x-chinese-ref">老子 31.10</prop>
      <prop type="x-translation-ref">老子 31.6</prop>
      <tuv xml:lang="zh-Hant">
        <seg>恬淡為上。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Calm and repose are what he prizes;</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-031__align-007">
