      <prop type="x-chinese-ref">老子 31.7 - 老子 31.8</prop>
      <prop type="x-translation-ref">老子 31.4</prop>
      <tuv xml:lang="zh-Hant">
        <seg>兵者不祥之器，非君子之器，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Those sharp weapons are instruments of evil omen, and not the instruments of the superior man;</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-031__align-005">
      <prop type="x-work-id">laozi</prop>
