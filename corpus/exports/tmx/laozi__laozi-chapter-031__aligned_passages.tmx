      <prop type="x-chinese-ref">老子 31.12 - 老子 31.13</prop>
      <prop type="x-translation-ref">老子 31.8</prop>
      <tuv xml:lang="zh-Hant">
        <seg>而美之者，是樂殺人。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>To consider this desirable would be to delight in the slaughter of men;</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-031__align-009">
      <prop type="x-work-id">laozi</prop>
      <prop type="x-section-id">laozi-chapter-031</prop>
      <prop type="x-section-unit">chapter</prop>
      <prop type="x-segment-type">sentence</prop>
