      <prop type="x-chinese-ref">老子 31.9</prop>
      <prop type="x-translation-ref">老子 31.5</prop>
      <tuv xml:lang="zh-Hant">
        <seg>不得已而用之，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>- he uses them only on the compulsion of necessity.</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-031__align-006">
