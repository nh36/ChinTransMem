      <prop type="x-chinese-ref">老子 31.19</prop>
      <prop type="x-translation-ref">老子 31.13</prop>
      <tuv xml:lang="zh-Hant">
        <seg>上將軍居右，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>the general commanding in chief has his on the right;</seg>
      </tuv>
    </tu>
