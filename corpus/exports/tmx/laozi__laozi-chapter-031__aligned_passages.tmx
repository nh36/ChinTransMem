      <prop type="x-translation-ref">老子 31.15</prop>
      <tuv xml:lang="zh-Hant">
        <seg>殺人之眾，以哀悲泣之，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>He who has killed multitudes of men should weep for them with the bitterest grief;</seg>
      </tuv>
    </tu>
