      <prop type="x-source-segment-count">2</prop>
      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 31.5 - 老子 31.6</prop>
      <prop type="x-translation-ref">老子 31.3</prop>
      <tuv xml:lang="zh-Hant">
        <seg>君子居則貴左，用兵則貴右。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>The superior man ordinarily considers the left hand the most honourable place, but in time of war the right hand.</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-031__align-004">
      <prop type="x-work-id">laozi</prop>
