      <prop type="x-chinese-ref">老子 31.11</prop>
      <prop type="x-translation-ref">老子 31.7</prop>
      <tuv xml:lang="zh-Hant">
        <seg>勝而不美，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>victory (by force of arms) is to him undesirable.</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-031__align-008">
      <prop type="x-work-id">laozi</prop>
      <prop type="x-section-id">laozi-chapter-031</prop>
      <prop type="x-section-unit">chapter</prop>
      <prop type="x-segment-type">sentence</prop>
