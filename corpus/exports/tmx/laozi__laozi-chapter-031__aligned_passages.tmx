      <prop type="x-chinese-ref">老子 31.20</prop>
      <prop type="x-translation-ref">老子 31.14</prop>
      <tuv xml:lang="zh-Hant">
        <seg>言以喪禮處之。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>- his place, that is, is assigned to him as in the rites of mourning.</seg>
      </tuv>
    </tu>
