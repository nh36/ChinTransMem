      <prop type="x-translation-ref">老子 31.12</prop>
      <tuv xml:lang="zh-Hant">
        <seg>凶事尚右。偏將軍居左，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>The second in command of the army has his place on the left;</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-031__align-012">
      <prop type="x-work-id">laozi</prop>
