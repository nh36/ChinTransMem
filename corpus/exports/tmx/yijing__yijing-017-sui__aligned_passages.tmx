      <prop type="x-chinese-ref">易經 17 六二</prop>
      <prop type="x-translation-ref">易經 17 六二</prop>
      <tuv xml:lang="zh-Hant">
        <seg>六二：系小子，失丈夫。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>The second SIX, divided, shows us one who cleaves to the little boy, and lets go the man of age and experience.</seg>
      </tuv>
    </tu>
