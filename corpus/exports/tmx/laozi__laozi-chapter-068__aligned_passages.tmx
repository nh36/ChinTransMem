      <prop type="x-translation-ref">老子 68.7 - 老子 68.8</prop>
      <tuv xml:lang="zh-Hant">
        <seg>善用人者為之下，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>He whose hests men most fulfil Yet humbly plies his art.</seg>
      </tuv>
    </tu>
