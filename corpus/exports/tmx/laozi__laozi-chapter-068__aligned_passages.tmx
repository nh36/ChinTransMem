      <prop type="x-translation-ref">老子 68.5 - 老子 68.6</prop>
      <tuv xml:lang="zh-Hant">
        <seg>善勝敵者不與，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>He who vanquishes yet still Keeps from his foes apart;</seg>
      </tuv>
    </tu>
