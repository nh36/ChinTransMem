      <prop type="x-translation-ref">老子 68.1 - 老子 68.2</prop>
      <tuv xml:lang="zh-Hant">
        <seg>善為士者不武，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>He who in (Dao's) wars has skill Assumes no martial port;</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-068__align-002">
      <prop type="x-work-id">laozi</prop>
      <prop type="x-section-id">laozi-chapter-068</prop>
