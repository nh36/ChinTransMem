      <prop type="x-translation-ref">老子 68.9 - 老子 68.10</prop>
      <tuv xml:lang="zh-Hant">
        <seg>是謂不爭之德，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Thus we say, 'He never contends, And therein is his might.'</seg>
      </tuv>
    </tu>
