      <prop type="x-chinese-ref">老子 68.2</prop>
      <prop type="x-translation-ref">老子 68.3 - 老子 68.4</prop>
      <tuv xml:lang="zh-Hant">
        <seg>善戰者不怒，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>He who fights with most good will To rage makes no resort.</seg>
      </tuv>
    </tu>
