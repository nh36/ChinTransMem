      <prop type="x-chinese-ref">老子 23.1 - 老子 23.2</prop>
      <prop type="x-translation-ref">老子 23.1 - 老子 23.2</prop>
      <tuv xml:lang="zh-Hant">
        <seg>希言自然。故飄風不終朝，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Abstaining from speech marks him who is obeying the spontaneity of his nature. A violent wind does not last for a whole morning;</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-023__align-002">
      <prop type="x-work-id">laozi</prop>
      <prop type="x-section-id">laozi-chapter-023</prop>
