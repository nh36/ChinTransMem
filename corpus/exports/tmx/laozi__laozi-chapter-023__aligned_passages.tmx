      <prop type="x-translation-ref">老子 23.10</prop>
      <tuv xml:lang="zh-Hant">
        <seg>道亦樂得之；同於德者，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>those with whom he agrees as to its manifestation have the happiness of attaining to it;</seg>
      </tuv>
    </tu>
