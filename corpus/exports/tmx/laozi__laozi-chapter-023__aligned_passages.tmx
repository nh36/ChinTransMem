      <prop type="x-translation-ref">老子 23.4</prop>
      <tuv xml:lang="zh-Hant">
        <seg>孰為此者？</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>To whom is it that these (two) things are owing?</seg>
      </tuv>
    </tu>
