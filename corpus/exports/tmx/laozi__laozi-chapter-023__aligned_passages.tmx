      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 23.6</prop>
      <prop type="x-translation-ref">老子 23.6</prop>
      <tuv xml:lang="zh-Hant">
        <seg>天地尚不能久，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>If Heaven and Earth cannot make such (spasmodic) actings last long, how much less can man!</seg>
      </tuv>
    </tu>
