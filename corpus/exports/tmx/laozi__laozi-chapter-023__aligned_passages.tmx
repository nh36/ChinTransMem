      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 23.3</prop>
      <prop type="x-translation-ref">老子 23.3</prop>
      <tuv xml:lang="zh-Hant">
        <seg>驟雨不終日。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>a sudden rain does not last for the whole day.</seg>
      </tuv>
    </tu>
