      <prop type="x-translation-ref">老子 23.5</prop>
      <tuv xml:lang="zh-Hant">
        <seg>天地。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>To Heaven and Earth.</seg>
      </tuv>
    </tu>
