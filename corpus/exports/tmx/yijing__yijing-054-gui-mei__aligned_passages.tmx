      <prop type="x-chinese-ref">易經 54 judgment</prop>
      <prop type="x-translation-ref">易經 54 judgment</prop>
      <tuv xml:lang="zh-Hant">
        <seg>歸妹，征凶，无攸利。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Gui Mei indicates that (under the conditions which it denotes) action will be evil, and in no wise advantageous.</seg>
      </tuv>
    </tu>
