      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 16.14</prop>
      <prop type="x-translation-ref">老子 16.10</prop>
      <tuv xml:lang="zh-Hant">
        <seg>容乃公，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>From this community of feeling comes a kingliness of character;</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-016__align-010">
      <prop type="x-work-id">laozi</prop>
      <prop type="x-section-id">laozi-chapter-016</prop>
