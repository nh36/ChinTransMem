      <prop type="x-chinese-ref">老子 16.16</prop>
      <prop type="x-translation-ref">老子 16.12</prop>
      <tuv xml:lang="zh-Hant">
        <seg>王乃天，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>In that likeness to heaven he possesses the Dao.</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-016__align-012">
      <prop type="x-work-id">laozi</prop>
      <prop type="x-section-id">laozi-chapter-016</prop>
