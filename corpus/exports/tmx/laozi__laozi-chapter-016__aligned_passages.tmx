      <prop type="x-confidence">1.00</prop>
      <prop type="x-source-segment-count">1</prop>
      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 16.10</prop>
      <prop type="x-translation-ref">老子 16.8</prop>
      <tuv xml:lang="zh-Hant">
        <seg>知常曰明。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>not to know it leads to wild movements and evil issues.</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-016__align-008">
      <prop type="x-work-id">laozi</prop>
      <prop type="x-section-id">laozi-chapter-016</prop>
      <prop type="x-section-unit">chapter</prop>
      <prop type="x-segment-type">sentence</prop>
      <prop type="x-alignment-granularity">grouped</prop>
      <prop type="x-is-coarse-alignment">false</prop>
      <prop type="x-alignment-type">exact_or_near_exact</prop>
      <prop type="x-confidence">1.00</prop>
      <prop type="x-source-segment-count">3</prop>
      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 16.11 - 老子 16.13</prop>
      <prop type="x-translation-ref">老子 16.9</prop>
      <tuv xml:lang="zh-Hant">
        <seg>不知常，妄作凶。知常容，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>The knowledge of that unchanging rule produces a (grand) capacity and forbearance, and that capacity and forbearance lead to a community (of feeling with all things).</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-016__align-009">
      <prop type="x-work-id">laozi</prop>
      <prop type="x-section-id">laozi-chapter-016</prop>
