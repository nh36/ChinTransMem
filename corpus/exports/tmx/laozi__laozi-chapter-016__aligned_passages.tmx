      <prop type="x-source-segment-count">1</prop>
      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 16.15</prop>
      <prop type="x-translation-ref">老子 16.11</prop>
      <tuv xml:lang="zh-Hant">
        <seg>公乃王，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>and he who is king-like goes on to be heaven-like.</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-016__align-011">
      <prop type="x-work-id">laozi</prop>
      <prop type="x-section-id">laozi-chapter-016</prop>
