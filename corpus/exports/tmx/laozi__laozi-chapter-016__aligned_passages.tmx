      <prop type="x-translation-ref">老子 16.13</prop>
      <tuv xml:lang="zh-Hant">
        <seg>天乃道，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Possessed of the Dao, he endures long;</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-016__align-013">
      <prop type="x-work-id">laozi</prop>
