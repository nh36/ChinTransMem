      <prop type="x-chinese-ref">老子 16.18 - 老子 16.19</prop>
      <prop type="x-translation-ref">老子 16.14</prop>
      <tuv xml:lang="zh-Hant">
        <seg>道乃久，沒身不殆。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>and to the end of his bodily life, is exempt from all danger of decay.</seg>
      </tuv>
    </tu>
