      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 55.3</prop>
      <prop type="x-translation-ref">老子 55.3</prop>
      <tuv xml:lang="zh-Hant">
        <seg>骨弱筋柔而握固。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>(The infant's) bones are weak and its sinews soft, but yet its grasp is firm.</seg>
      </tuv>
    </tu>
