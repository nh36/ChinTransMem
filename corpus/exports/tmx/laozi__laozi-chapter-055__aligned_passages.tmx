      <prop type="x-translation-ref">老子 55.10</prop>
      <tuv xml:lang="zh-Hant">
        <seg>益生曰祥。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Where the mind makes the vital breath to burn,</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-055__align-011">
