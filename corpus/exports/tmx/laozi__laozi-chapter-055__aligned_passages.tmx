      <prop type="x-translation-ref">老子 55.6</prop>
      <tuv xml:lang="zh-Hant">
        <seg>終日號而不嗄，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>To him by whom this harmony is known,</seg>
      </tuv>
    </tu>
