      <prop type="x-chinese-ref">老子 55.4</prop>
      <prop type="x-translation-ref">老子 55.4</prop>
      <tuv xml:lang="zh-Hant">
        <seg>未知牝牡之合而全作，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>It knows not yet the union of male and female, and yet its virile member may be excited; - showing the perfection of its physical essence.</seg>
      </tuv>
    </tu>
