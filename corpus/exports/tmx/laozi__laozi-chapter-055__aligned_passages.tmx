      <prop type="x-translation-ref">老子 55.8</prop>
      <tuv xml:lang="zh-Hant">
        <seg>知和曰常，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>And in the knowledge wisdom finds its throne.</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-055__align-009">
