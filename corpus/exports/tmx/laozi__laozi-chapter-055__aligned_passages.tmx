      <prop type="x-chinese-ref">老子 55.5</prop>
      <prop type="x-translation-ref">老子 55.5</prop>
      <tuv xml:lang="zh-Hant">
        <seg>精之至也。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>All day long it will cry without its throat becoming hoarse; - showing the harmony (in its constitution).</seg>
      </tuv>
    </tu>
