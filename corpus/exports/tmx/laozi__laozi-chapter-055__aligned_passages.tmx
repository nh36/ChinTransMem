      <prop type="x-translation-ref">老子 55.7</prop>
      <tuv xml:lang="zh-Hant">
        <seg>和之至也。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>(The secret of) the unchanging (Dao) is shown,</seg>
      </tuv>
    </tu>
