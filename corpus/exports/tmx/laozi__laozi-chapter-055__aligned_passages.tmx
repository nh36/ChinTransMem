      <prop type="x-translation-ref">老子 55.9</prop>
      <tuv xml:lang="zh-Hant">
        <seg>知常曰明。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>All life-increasing arts to evil turn;</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-055__align-010">
      <prop type="x-work-id">laozi</prop>
