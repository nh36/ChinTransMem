      <prop type="x-translation-ref">老子 27.8</prop>
      <tuv xml:lang="zh-Hant">
        <seg>是謂襲明。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>This is called 'Hiding the light of his procedure.'</seg>
      </tuv>
    </tu>
