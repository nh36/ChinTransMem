      <prop type="x-chinese-ref">老子 27.5</prop>
      <prop type="x-translation-ref">老子 27.5</prop>
      <tuv xml:lang="zh-Hant">
        <seg>善結無繩約而不可解。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>the skilful binder uses no strings or knots, while to unloose what he has bound will be impossible.</seg>
      </tuv>
    </tu>
