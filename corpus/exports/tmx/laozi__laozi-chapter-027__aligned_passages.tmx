      <prop type="x-chinese-ref">老子 27.4</prop>
      <prop type="x-translation-ref">老子 27.4</prop>
      <tuv xml:lang="zh-Hant">
        <seg>善閉無關楗而不可開，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>the skilful closer needs no bolts or bars, while to open what he has shut will be impossible;</seg>
      </tuv>
    </tu>
