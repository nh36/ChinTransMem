      <prop type="x-chinese-ref">老子 27.11 - 老子 27.12</prop>
      <prop type="x-translation-ref">老子 27.9</prop>
      <tuv xml:lang="zh-Hant">
        <seg>故善人者，不善人之師；</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Therefore the man of skill is a master (to be looked up to) by him who has not the skill;</seg>
      </tuv>
    </tu>
