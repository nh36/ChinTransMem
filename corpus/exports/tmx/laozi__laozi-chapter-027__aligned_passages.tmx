      <prop type="x-chinese-ref">老子 27.1</prop>
      <prop type="x-translation-ref">老子 27.1</prop>
      <tuv xml:lang="zh-Hant">
        <seg>善行無轍迹，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>The skilful traveller leaves no traces of his wheels or footsteps;</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-027__align-002">
      <prop type="x-work-id">laozi</prop>
      <prop type="x-section-id">laozi-chapter-027</prop>
