      <prop type="x-translation-ref">老子 27.7</prop>
      <tuv xml:lang="zh-Hant">
        <seg>常善救物，故無棄物，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>he is always skilful at saving things, and so he does not cast away anything.</seg>
      </tuv>
    </tu>
