      <prop type="x-target-segment-count">2</prop>
      <prop type="x-chinese-ref">老子 27.2 - 老子 27.3</prop>
      <prop type="x-translation-ref">老子 27.2 - 老子 27.3</prop>
      <tuv xml:lang="zh-Hant">
        <seg>善言無瑕讁；善數不用籌策；</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>the skilful speaker says nothing that can be found fault with or blamed; the skilful reckoner uses no tallies;</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-027__align-003">
      <prop type="x-work-id">laozi</prop>
      <prop type="x-section-id">laozi-chapter-027</prop>
      <prop type="x-section-unit">chapter</prop>
