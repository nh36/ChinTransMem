      <prop type="x-translation-ref">老子 27.12</prop>
      <tuv xml:lang="zh-Hant">
        <seg>是謂要妙。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>This is called 'The utmost degree of mystery.'</seg>
