      <prop type="x-chinese-ref">老子 27.13 - 老子 27.14</prop>
      <prop type="x-translation-ref">老子 27.10</prop>
      <tuv xml:lang="zh-Hant">
        <seg>不善人者，善人之資。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>and he who has not the skill is the helper of (the reputation of) him who has the skill.</seg>
      </tuv>
    </tu>
