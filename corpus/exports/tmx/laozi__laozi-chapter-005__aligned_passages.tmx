      <prop type="x-translation-ref">老子 5.2</prop>
      <tuv xml:lang="zh-Hant">
        <seg>聖人不仁，以百姓為芻狗。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>'Tis emptied, yet it loses not its power;</seg>
      </tuv>
    </tu>
