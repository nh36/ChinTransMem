      <prop type="x-is-coarse-alignment">false</prop>
      <prop type="x-alignment-type">exact_or_near_exact</prop>
      <prop type="x-confidence">1.00</prop>
      <prop type="x-source-segment-count">1</prop>
      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">易經 25 初九</prop>
      <prop type="x-translation-ref">易經 25 初九</prop>
      <tuv xml:lang="zh-Hant">
        <seg>初九：无妄，往吉。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>The first NINE, undivided, shows its subject free from all insincerity. His advance will be accompanied with good fortune.</seg>
      </tuv>
    </tu>
    <tu tuid="yijing-025-wu-wang__alignment-003">
      <prop type="x-work-id">yijing</prop>
      <prop type="x-section-id">yijing-025-wu-wang</prop>
      <prop type="x-section-unit">section</prop>
