      <prop type="x-chinese-ref">詩經·小雅·節南山之什·009.5</prop>
      <prop type="x-translation-ref">何人斯.5</prop>
      <tuv xml:lang="zh-Hant">
        <seg>爾之安行，亦不遑舍。爾之亟行，遑脂爾車？壹者之來，云何其盱。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>You go along slowly,
And yet you have not leisure to stop!
You go along rapidly,
And yet you have leisure to grease your wheels!
If you would come to me but once! --
Why am I kept in a state of expectation?</seg>
      </tuv>
    </tu>
    <tu tuid="shijing__xiaoya-jienanshan-009__006__zhwikisource-20260530__legge-sheking-1871-ocr">
      <prop type="x-work-id">shijing</prop>
      <prop type="x-section-id">xiaoya-jienanshan-009</prop>
