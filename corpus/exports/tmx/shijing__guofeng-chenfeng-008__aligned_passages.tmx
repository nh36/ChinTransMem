      <prop type="x-chinese-ref">詩經·國風·陳風·008.1</prop>
      <prop type="x-translation-ref">月出.1</prop>
      <tuv xml:lang="zh-Hant">
        <seg>月出皎兮，佼人僚兮，舒窈糾兮，勞心悄兮。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>The moon comes forth in her brightness;
How lovely is that beautiful lady!
O to have my deep longings for her relieved!
How anxious is my toiled heart!</seg>
      </tuv>
    </tu>
