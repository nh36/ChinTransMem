      <prop type="x-translation-ref">易經 12 六三</prop>
      <tuv xml:lang="zh-Hant">
        <seg>六三，包羞。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>The third SIX, divided, shows its subject ashamed of the purpose folded (in his breast).</seg>
      </tuv>
    </tu>
