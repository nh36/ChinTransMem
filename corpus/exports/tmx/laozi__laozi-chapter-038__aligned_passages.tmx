      <prop type="x-translation-ref">老子 38.11</prop>
      <tuv xml:lang="zh-Hant">
        <seg>而亂之首。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>and when righteousness was lost, the proprieties appeared.</seg>
      </tuv>
    </tu>
