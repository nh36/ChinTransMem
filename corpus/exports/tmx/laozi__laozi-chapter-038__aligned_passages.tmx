      <prop type="x-translation-ref">老子 38.10</prop>
      <tuv xml:lang="zh-Hant">
        <seg>忠信之薄，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>when benevolence was lost, righteousness appeared;</seg>
      </tuv>
    </tu>
