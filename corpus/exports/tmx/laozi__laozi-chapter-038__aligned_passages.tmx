      <prop type="x-chinese-ref">老子 38.7</prop>
      <prop type="x-translation-ref">老子 38.4</prop>
      <tuv xml:lang="zh-Hant">
        <seg>上仁為之而無以為，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>(Those who) possessed them in a lower degree were (always) doing, and had need to be so doing.</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-038__align-005">
      <prop type="x-work-id">laozi</prop>
      <prop type="x-section-id">laozi-chapter-038</prop>
      <prop type="x-section-unit">chapter</prop>
      <prop type="x-segment-type">sentence</prop>
