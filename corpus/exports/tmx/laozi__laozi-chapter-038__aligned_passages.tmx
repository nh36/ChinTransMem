      <prop type="x-translation-ref">老子 38.9</prop>
      <tuv xml:lang="zh-Hant">
        <seg>夫禮者，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>when its attributes were lost, benevolence appeared;</seg>
      </tuv>
    </tu>
