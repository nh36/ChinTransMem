      <prop type="x-translation-ref">老子 38.15</prop>
      <tuv xml:lang="zh-Hant">
        <seg>不居其華。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>dwells with the fruit and not with the flower.</seg>
      </tuv>
    </tu>
