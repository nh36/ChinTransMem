      <prop type="x-source-segment-count">1</prop>
      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 38.6</prop>
      <prop type="x-translation-ref">老子 38.3</prop>
      <tuv xml:lang="zh-Hant">
        <seg>下德為之而有以為。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>(Those who) possessed in the highest degree those attributes did nothing (with a purpose), and had no need to do anything.</seg>
      </tuv>
    </tu>
