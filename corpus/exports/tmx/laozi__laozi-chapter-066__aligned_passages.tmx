      <prop type="x-source-segment-count">1</prop>
      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 66.4</prop>
      <prop type="x-translation-ref">老子 66.4</prop>
      <tuv xml:lang="zh-Hant">
        <seg>是以聖人處上而民不重，處前而民不害。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Therefore all in the world delight to exalt him and do not weary of him.</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-066__align-005">
      <prop type="x-work-id">laozi</prop>
