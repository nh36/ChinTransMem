      <prop type="x-confidence">1.00</prop>
      <prop type="x-source-segment-count">1</prop>
      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 66.5</prop>
      <prop type="x-translation-ref">老子 66.5</prop>
      <tuv xml:lang="zh-Hant">
        <seg>是以天下樂推而不厭，以其不爭，故天下莫能與之爭。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Because he does not strive, no one finds it possible to strive with him.</seg>
      </tuv>
    </tu>
