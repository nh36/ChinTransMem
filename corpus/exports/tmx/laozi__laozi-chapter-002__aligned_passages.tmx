      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 2.16</prop>
      <prop type="x-translation-ref">老子 2.13</prop>
      <tuv xml:lang="zh-Hant">
        <seg>功成而弗居。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>The work is accomplished, and there is no resting in it (as an achievement).</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-002__align-012">
