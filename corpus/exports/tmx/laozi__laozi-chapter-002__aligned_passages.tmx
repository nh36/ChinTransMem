      <prop type="x-chinese-ref">老子 2.18</prop>
      <prop type="x-translation-ref">老子 2.15</prop>
      <tuv xml:lang="zh-Hant">
        <seg>是以不去。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>'Tis this that makes the power not cease to be.</seg>
      </tuv>
    </tu>
