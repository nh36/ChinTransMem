      <prop type="x-translation-ref">老子 2.14</prop>
      <tuv xml:lang="zh-Hant">
        <seg>夫唯弗居，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>The work is done, but how no one can see;</seg>
      </tuv>
    </tu>
