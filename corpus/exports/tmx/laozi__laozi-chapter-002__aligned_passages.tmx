      <prop type="x-source-segment-count">1</prop>
      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 2.1</prop>
      <prop type="x-translation-ref">老子 2.1</prop>
      <tuv xml:lang="zh-Hant">
        <seg>天下皆知美之為美，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>All in the world know the beauty of the beautiful, and in doing this they have (the idea of) what ugliness is;</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-002__align-002">
      <prop type="x-work-id">laozi</prop>
      <prop type="x-section-id">laozi-chapter-002</prop>
      <prop type="x-section-unit">chapter</prop>
      <prop type="x-segment-type">sentence</prop>
      <prop type="x-alignment-granularity">grouped</prop>
      <prop type="x-is-coarse-alignment">false</prop>
      <prop type="x-alignment-type">exact_or_near_exact</prop>
      <prop type="x-confidence">1.00</prop>
      <prop type="x-source-segment-count">2</prop>
      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 2.2 - 老子 2.3</prop>
      <prop type="x-translation-ref">老子 2.2</prop>
      <tuv xml:lang="zh-Hant">
        <seg>斯惡已。皆知善之為善，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>they all know the skill of the skilful, and in doing this they have (the idea of) what the want of skill is.</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-002__align-003">
      <prop type="x-work-id">laozi</prop>
      <prop type="x-section-id">laozi-chapter-002</prop>
      <prop type="x-section-unit">chapter</prop>
      <prop type="x-segment-type">sentence</prop>
      <prop type="x-alignment-granularity">grouped</prop>
      <prop type="x-is-coarse-alignment">false</prop>
      <prop type="x-alignment-type">exact_or_near_exact</prop>
      <prop type="x-confidence">1.00</prop>
      <prop type="x-source-segment-count">2</prop>
      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 2.4 - 老子 2.5</prop>
      <prop type="x-translation-ref">老子 2.3</prop>
      <tuv xml:lang="zh-Hant">
        <seg>斯不善已。故有無相生，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>So it is that existence and non-existence give birth the one to (the idea of) the other;</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-002__align-004">
      <prop type="x-work-id">laozi</prop>
      <prop type="x-section-id">laozi-chapter-002</prop>
      <prop type="x-section-unit">chapter</prop>
      <prop type="x-segment-type">sentence</prop>
