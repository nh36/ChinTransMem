      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 2.7</prop>
      <prop type="x-translation-ref">老子 2.5</prop>
      <tuv xml:lang="zh-Hant">
        <seg>長短相較，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>that length and shortness fashion out the one the figure of the other;</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-002__align-006">
      <prop type="x-work-id">laozi</prop>
