      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 2.6</prop>
      <prop type="x-translation-ref">老子 2.4</prop>
      <tuv xml:lang="zh-Hant">
        <seg>難易相成，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>that difficulty and ease produce the one (the idea of) the other;</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-002__align-005">
      <prop type="x-work-id">laozi</prop>
