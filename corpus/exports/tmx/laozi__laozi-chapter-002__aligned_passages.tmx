      <prop type="x-confidence">1.00</prop>
      <prop type="x-source-segment-count">1</prop>
      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 2.14</prop>
      <prop type="x-translation-ref">老子 2.11</prop>
      <tuv xml:lang="zh-Hant">
        <seg>生而不有，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>they grow, and there is no claim made for their ownership;</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-002__align-010">
      <prop type="x-work-id">laozi</prop>
      <prop type="x-section-id">laozi-chapter-002</prop>
      <prop type="x-section-unit">chapter</prop>
      <prop type="x-segment-type">sentence</prop>
      <prop type="x-alignment-granularity">grouped</prop>
      <prop type="x-is-coarse-alignment">false</prop>
      <prop type="x-alignment-type">exact_or_near_exact</prop>
      <prop type="x-confidence">1.00</prop>
      <prop type="x-source-segment-count">1</prop>
      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 2.15</prop>
      <prop type="x-translation-ref">老子 2.12</prop>
      <tuv xml:lang="zh-Hant">
        <seg>為而不恃，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>they go through their processes, and there is no expectation (of a reward for the results).</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-002__align-011">
      <prop type="x-work-id">laozi</prop>
