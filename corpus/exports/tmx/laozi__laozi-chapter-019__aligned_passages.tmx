      <prop type="x-chinese-ref">老子 19.1 - 老子 19.2</prop>
      <prop type="x-translation-ref">老子 19.1</prop>
      <tuv xml:lang="zh-Hant">
        <seg>絕聖棄智，民利百倍；</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>If we could renounce our sageness and discard our wisdom, it would be better for the people a hundredfold.</seg>
      </tuv>
    </tu>
