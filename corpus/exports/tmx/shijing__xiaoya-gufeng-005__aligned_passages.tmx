      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">詩經·小雅·谷風之什·005.5</prop>
      <prop type="x-translation-ref">北山.5</prop>
      <tuv xml:lang="zh-Hant">
        <seg>或不知叫號，或慘慘劬勞；或棲遲偃仰，或王事鞅掌。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Some never hear a sound,
And some are cruelly toiled;
Some lazily roost, on their backs looking up,
And some are all-bustled in the service of the king.</seg>
      </tuv>
    </tu>
    <tu tuid="shijing__xiaoya-gufeng-005__006__zhwikisource-20260530__legge-sheking-1871-ocr">
