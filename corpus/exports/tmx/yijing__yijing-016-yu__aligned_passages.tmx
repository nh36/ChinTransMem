      <prop type="x-chinese-ref">易經 16 初六</prop>
      <prop type="x-translation-ref">易經 16 初六</prop>
      <tuv xml:lang="zh-Hant">
        <seg>初六：鳴豫，凶。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>The first SIX, divided, shows its subject proclaiming his pleasure and satisfaction. There will be evil.</seg>
      </tuv>
    </tu>
