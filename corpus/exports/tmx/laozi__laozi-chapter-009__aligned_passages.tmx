      <prop type="x-chinese-ref">老子 9.2</prop>
      <prop type="x-translation-ref">老子 9.2</prop>
      <tuv xml:lang="zh-Hant">
        <seg>揣而梲之，不可長保。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>If you keep feeling a point that has been sharpened, the point cannot long preserve its sharpness.</seg>
      </tuv>
    </tu>
