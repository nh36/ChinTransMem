      <prop type="x-chinese-ref">老子 9.1</prop>
      <prop type="x-translation-ref">老子 9.1</prop>
      <tuv xml:lang="zh-Hant">
        <seg>持而盈之，不如其已；</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>It is better to leave a vessel unfilled, than to attempt to carry it when it is full.</seg>
      </tuv>
    </tu>
