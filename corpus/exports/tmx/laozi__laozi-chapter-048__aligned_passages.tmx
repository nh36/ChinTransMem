      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 48.6</prop>
      <prop type="x-translation-ref">老子 48.5</prop>
      <tuv xml:lang="zh-Hant">
        <seg>取天下常以無事，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>He who gets as his own all under heaven does so by giving himself no trouble (with that end).</seg>
      </tuv>
    </tu>
