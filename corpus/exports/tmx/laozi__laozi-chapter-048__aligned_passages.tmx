      <prop type="x-source-segment-count">3</prop>
      <prop type="x-target-segment-count">2</prop>
      <prop type="x-chinese-ref">老子 48.1 - 老子 48.3</prop>
      <prop type="x-translation-ref">老子 48.1 - 老子 48.2</prop>
      <tuv xml:lang="zh-Hant">
        <seg>為學日益，為道日損。損之又損，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>He who devotes himself to learning (seeks) from day to day to increase (his knowledge); he who devotes himself to the Dao (seeks) from day to day to diminish (his doing).</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-048__align-002">
      <prop type="x-work-id">laozi</prop>
      <prop type="x-section-id">laozi-chapter-048</prop>
      <prop type="x-section-unit">chapter</prop>
      <prop type="x-segment-type">sentence</prop>
      <prop type="x-alignment-granularity">grouped</prop>
      <prop type="x-is-coarse-alignment">false</prop>
      <prop type="x-alignment-type">exact_or_near_exact</prop>
      <prop type="x-confidence">1.00</prop>
      <prop type="x-source-segment-count">1</prop>
      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 48.4</prop>
      <prop type="x-translation-ref">老子 48.3</prop>
      <tuv xml:lang="zh-Hant">
        <seg>以至於無為。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>He diminishes it and again diminishes it, till he arrives at doing nothing (on purpose).</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-048__align-003">
      <prop type="x-work-id">laozi</prop>
      <prop type="x-section-id">laozi-chapter-048</prop>
      <prop type="x-section-unit">chapter</prop>
      <prop type="x-segment-type">sentence</prop>
