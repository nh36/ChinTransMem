      <prop type="x-chinese-ref">老子 48.7 - 老子 48.8</prop>
      <prop type="x-translation-ref">老子 48.6</prop>
      <tuv xml:lang="zh-Hant">
        <seg>及其有事，不足以取天下。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>If one take trouble (with that end), he is not equal to getting as his own all under heaven.</seg>
      </tuv>
