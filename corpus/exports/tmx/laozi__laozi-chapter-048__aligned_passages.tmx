      <prop type="x-source-segment-count">1</prop>
      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 48.5</prop>
      <prop type="x-translation-ref">老子 48.4</prop>
      <tuv xml:lang="zh-Hant">
        <seg>無為而無不為。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Having arrived at this point of non-action, there is nothing which he does not do.</seg>
      </tuv>
    </tu>
