      <prop type="x-chinese-ref">易經 33 judgment</prop>
      <prop type="x-translation-ref">易經 33 judgment</prop>
      <tuv xml:lang="zh-Hant">
        <seg>遯，亨，小利貞。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Dun indicates successful progress (in its circumstances). To a small extent it will (still) be advantageous to be firm and correct.</seg>
      </tuv>
    </tu>
