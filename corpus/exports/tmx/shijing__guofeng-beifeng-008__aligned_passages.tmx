      <prop type="x-alignment-type">exact_or_near_exact</prop>
      <prop type="x-confidence">0.99</prop>
      <prop type="x-source-segment-count">1</prop>
      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">詩經·國風·邶風·008.3</prop>
      <prop type="x-translation-ref">雄雉.3</prop>
      <tuv xml:lang="zh-Hant">
        <seg>瞻彼日月，悠悠我思，道之云遠，曷云能來。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Look at that sun and moon!
Long, long do I think.
The way is distant;
How can he come to me?</seg>
      </tuv>
    </tu>
    <tu tuid="shijing__guofeng-beifeng-008__004__zhwikisource-20260530__legge-sheking-1871-ocr">
