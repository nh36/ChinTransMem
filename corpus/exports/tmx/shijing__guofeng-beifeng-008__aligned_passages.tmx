      <prop type="x-chinese-ref">詩經·國風·邶風·008.1</prop>
      <prop type="x-translation-ref">雄雉.1</prop>
      <tuv xml:lang="zh-Hant">
        <seg>雄雉于飛，泄泄其羽，我之懷矣，自詒伊阻。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>The male pheasant flies away,
Lazily moving his wings.
The man of my heart! —
He has brought on us this separation.</seg>
      </tuv>
    </tu>
    <tu tuid="shijing__guofeng-beifeng-008__002__zhwikisource-20260530__legge-sheking-1871-ocr">
      <prop type="x-work-id">shijing</prop>
