      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">詩經·國風·邶風·008.4</prop>
      <prop type="x-translation-ref">雄雉.4</prop>
      <tuv xml:lang="zh-Hant">
        <seg>百爾君子，不知德行，不忮不求，何用不臧。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>All ye princely men,
Know ye not his virtuous conduct?
He hates none; he covets nothing; —
What does he which is not good?</seg>
      </tuv>
    </tu>
