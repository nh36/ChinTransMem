      <prop type="x-alignment-granularity">stanza</prop>
      <prop type="x-is-coarse-alignment">false</prop>
      <prop type="x-alignment-type">exact_or_near_exact</prop>
      <prop type="x-confidence">0.99</prop>
      <prop type="x-source-segment-count">1</prop>
      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">詩經·國風·邶風·008.2</prop>
      <prop type="x-translation-ref">雄雉.2</prop>
      <tuv xml:lang="zh-Hant">
        <seg>雄雉于飛，下上其音，展矣君子，實勞我心。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>The pheasant has flown away,
But from below, from above, comes his voice.
Ah! the princely man! —
He afflicts my heart.</seg>
      </tuv>
    </tu>
    <tu tuid="shijing__guofeng-beifeng-008__003__zhwikisource-20260530__legge-sheking-1871-ocr">
