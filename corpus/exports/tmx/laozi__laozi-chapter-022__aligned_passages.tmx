      <prop type="x-chinese-ref">老子 22.10</prop>
      <prop type="x-translation-ref">老子 22.10</prop>
      <tuv xml:lang="zh-Hant">
        <seg>不自伐故有功，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>from self-boasting, and therefore his merit is acknowledged;</seg>
      </tuv>
    </tu>
