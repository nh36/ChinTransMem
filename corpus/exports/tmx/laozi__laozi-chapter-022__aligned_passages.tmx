      <prop type="x-translation-ref">老子 22.8</prop>
      <tuv xml:lang="zh-Hant">
        <seg>不自見故明，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>He is free from self- display, and therefore he shines;</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-022__align-007">
