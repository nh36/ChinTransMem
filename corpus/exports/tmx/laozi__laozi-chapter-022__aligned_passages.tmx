      <prop type="x-chinese-ref">老子 22.11</prop>
      <prop type="x-translation-ref">老子 22.11</prop>
      <tuv xml:lang="zh-Hant">
        <seg>不自矜故長。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>from self-complacency, and therefore he acquires superiority.</seg>
      </tuv>
    </tu>
