      <prop type="x-chinese-ref">老子 22.4 - 老子 22.6</prop>
      <prop type="x-translation-ref">老子 22.5 - 老子 22.6</prop>
      <tuv xml:lang="zh-Hant">
        <seg>敝則新，少則得，多則惑。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>He whose (desires) are few gets them; he whose (desires) are many goes astray.</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-022__align-005">
