      <prop type="x-translation-ref">老子 22.2 - 老子 22.3</prop>
      <tuv xml:lang="zh-Hant">
        <seg>枉則直，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>the crooked, straight; the empty, full;</seg>
      </tuv>
    </tu>
