      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 22.16</prop>
      <prop type="x-translation-ref">老子 22.14</prop>
      <tuv xml:lang="zh-Hant">
        <seg>誠全而歸之。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>- all real completion is comprehended under it.</seg>
      </tuv>
