      <prop type="x-chinese-ref">老子 22.7</prop>
      <prop type="x-translation-ref">老子 22.7</prop>
      <tuv xml:lang="zh-Hant">
        <seg>是以聖人抱一為天下式。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Therefore the sage holds in his embrace the one thing (of humility), and manifests it to all the world.</seg>
      </tuv>
    </tu>
