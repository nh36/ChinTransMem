      <prop type="x-translation-ref">老子 22.4</prop>
      <tuv xml:lang="zh-Hant">
        <seg>窪則盈，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>the worn out, new.</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-022__align-004">
      <prop type="x-work-id">laozi</prop>
