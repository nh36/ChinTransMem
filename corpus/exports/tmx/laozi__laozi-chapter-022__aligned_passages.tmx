      <prop type="x-translation-ref">老子 22.9</prop>
      <tuv xml:lang="zh-Hant">
        <seg>不自是故彰，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>from self-assertion, and therefore he is distinguished;</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-022__align-008">
      <prop type="x-work-id">laozi</prop>
