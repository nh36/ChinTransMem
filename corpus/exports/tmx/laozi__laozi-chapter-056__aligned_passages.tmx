      <prop type="x-chinese-ref">老子 56.1 - 老子 56.2</prop>
      <prop type="x-translation-ref">老子 56.1</prop>
      <tuv xml:lang="zh-Hant">
        <seg>知者不言，言者不知。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>He who knows (the Dao) does not (care to) speak (about it);</seg>
      </tuv>
    </tu>
