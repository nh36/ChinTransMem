      <prop type="x-chinese-ref">老子 56.3 - 老子 56.4</prop>
      <prop type="x-translation-ref">老子 56.2</prop>
      <tuv xml:lang="zh-Hant">
        <seg>塞其兌，閉其門，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>he who is (ever ready to) speak about it does not know it.</seg>
      </tuv>
    </tu>
