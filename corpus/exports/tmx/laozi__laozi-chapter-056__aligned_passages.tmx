      <prop type="x-chinese-ref">老子 56.5 - 老子 56.7</prop>
      <prop type="x-translation-ref">老子 56.3</prop>
      <tuv xml:lang="zh-Hant">
        <seg>挫其銳，解其分，和其光，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>He (who knows it) will keep his mouth shut and close the portals (of his nostrils).</seg>
      </tuv>
    </tu>
