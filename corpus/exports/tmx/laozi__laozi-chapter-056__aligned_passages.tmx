      <prop type="x-translation-ref">老子 56.7</prop>
      <tuv xml:lang="zh-Hant">
        <seg>不可得而害；</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>(Such an one) cannot be treated familiarly or distantly;</seg>
      </tuv>
    </tu>
