      <prop type="x-translation-ref">老子 56.5</prop>
      <tuv xml:lang="zh-Hant">
        <seg>故不可得而親，不可得而疏；</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>he will attemper his brightness, and bring himself into agreement with the obscurity (of others).</seg>
      </tuv>
    </tu>
