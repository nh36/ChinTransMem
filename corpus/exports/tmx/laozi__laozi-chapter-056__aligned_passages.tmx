      <prop type="x-translation-ref">老子 56.4</prop>
      <tuv xml:lang="zh-Hant">
        <seg>同其塵，是謂玄同。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>He will blunt his sharp points and unravel the complications of things;</seg>
      </tuv>
    </tu>
