      <prop type="x-source-segment-count">1</prop>
      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">易經 40 初六</prop>
      <prop type="x-translation-ref">易經 40 初六</prop>
      <tuv xml:lang="zh-Hant">
        <seg>初六：无咎。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>The first SIX, divided, shows that its subject will commit no error.</seg>
      </tuv>
    </tu>
