      <prop type="x-chinese-ref">易經 44 judgment</prop>
      <prop type="x-translation-ref">易經 44 judgment</prop>
      <tuv xml:lang="zh-Hant">
        <seg>姤，女壯，勿用取女。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Gou shows a female who is bold and strong. It will not be good to marry (such) a female.</seg>
      </tuv>
    </tu>
