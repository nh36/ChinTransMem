      <prop type="x-source-segment-count">1</prop>
      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">詩經·國風·邶風·005.2</prop>
      <prop type="x-translation-ref">Chung fung..2</prop>
      <tuv xml:lang="zh-Hant">
        <seg>終風且霾，惠然肯來，莫往莫來，悠悠我思。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>The wind blows, with clouds of dust.
Kindly he seems to be willing to come to me;
[But] he neither goes nor comes.
Long, long, do I think of him.</seg>
      </tuv>
    </tu>
