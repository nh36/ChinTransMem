      <prop type="x-chinese-ref">詩經·小雅·鹿鳴之什·006.2</prop>
      <prop type="x-translation-ref">天保.2</prop>
      <tuv xml:lang="zh-Hant">
        <seg>天保定爾，俾爾戩穀。罄無不宜，受天百祿。降爾遐福，維日不足。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Heaven protects and establishes thee.
It grants thee all excellence,
So that thine every matter is right,
And thou receivest every Heavenly favour.
It sends down to thee long-during happiness,
Which the days are not sufficient to enjoy.</seg>
      </tuv>
    </tu>
    <tu tuid="shijing__xiaoya-luming-006__003__zhwikisource-20260530__legge-sbe-v3-1879">
      <prop type="x-work-id">shijing</prop>
      <prop type="x-section-id">xiaoya-luming-006</prop>
