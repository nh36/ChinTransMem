      <prop type="x-alignment-granularity">stanza</prop>
      <prop type="x-is-coarse-alignment">false</prop>
      <prop type="x-alignment-type">exact_or_near_exact</prop>
      <prop type="x-confidence">0.99</prop>
      <prop type="x-source-segment-count">1</prop>
      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">詩經·國風·邶風·009.3</prop>
      <prop type="x-translation-ref">aou-y ew-koo-y eh •.3</prop>
      <tuv xml:lang="zh-Hant">
        <seg>雝雝鳴鴈，旭日始旦，士如歸妻，迨冰未泮。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>The wild goose, with its harmonious notes,
At sunrise, with the earliest dawn,
By the gentleman, who wishes to bring home his bride,
[Is presented] before the ice is melted.</seg>
      </tuv>
    </tu>
    <tu tuid="shijing__guofeng-beifeng-009__004__zhwikisource-20260530__legge-sheking-1871-ocr">
