      <prop type="x-confidence">1.00</prop>
      <prop type="x-source-segment-count">1</prop>
      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">易經 1 用九</prop>
      <prop type="x-translation-ref">易經 1 用九</prop>
      <tuv xml:lang="zh-Hant">
        <seg>用九，見羣龍无首，吉。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>(The lines of this hexagram are all strong and undivided, as appears from) the use of the number NINE. If the host of dragons (thus) appearing were to divest themselves of their heads, there would be good fortune.</seg>
      </tuv>
    </tu>
    <tu tuid="yijing-001-qian__alignment-008">
      <prop type="x-work-id">yijing</prop>
      <prop type="x-section-id">yijing-001-qian</prop>
      <prop type="x-section-unit">section</prop>
      <prop type="x-segment-type">block</prop>
