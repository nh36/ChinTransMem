      <prop type="x-chinese-ref">易經 1 judgment</prop>
      <prop type="x-translation-ref">易經 1 judgment</prop>
      <tuv xml:lang="zh-Hant">
        <seg>乾，元、亨、利、貞。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Qian (represents) what is great and originating, penetrating, advantageous, correct and firm.</seg>
      </tuv>
    </tu>
