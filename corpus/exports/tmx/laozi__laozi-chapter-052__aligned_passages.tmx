      <prop type="x-translation-ref">老子 52.11</prop>
      <tuv xml:lang="zh-Hant">
        <seg>是為習常。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>And hides the unchanging from men's sight.</seg>
