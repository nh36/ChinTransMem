      <prop type="x-source-segment-count">3</prop>
      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 52.11 - 老子 52.13</prop>
      <prop type="x-translation-ref">老子 52.5</prop>
      <tuv xml:lang="zh-Hant">
        <seg>開其兌，濟其事，終身不救。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Let him keep his mouth open, and (spend his breath) in the promotion of his affairs, and all his life there will be no safety for him.</seg>
      </tuv>
    </tu>
