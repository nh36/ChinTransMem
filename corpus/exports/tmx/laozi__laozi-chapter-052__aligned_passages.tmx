      <prop type="x-translation-ref">老子 52.8 - 老子 52.9</prop>
      <tuv xml:lang="zh-Hant">
        <seg>復歸其明，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Who uses well his light, Reverting to its (source so) bright,</seg>
      </tuv>
    </tu>
