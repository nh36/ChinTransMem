      <prop type="x-chinese-ref">老子 52.18</prop>
      <prop type="x-translation-ref">老子 52.10</prop>
      <tuv xml:lang="zh-Hant">
        <seg>無遺身殃，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Will from his body ward all blight,</seg>
      </tuv>
    </tu>
