      <prop type="x-chinese-ref">老子 47.4 - 老子 47.5</prop>
      <prop type="x-translation-ref">老子 47.2</prop>
      <tuv xml:lang="zh-Hant">
        <seg>見天道。其出彌遠，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>without looking out from his window, one sees the Dao of Heaven.</seg>
      </tuv>
    </tu>
