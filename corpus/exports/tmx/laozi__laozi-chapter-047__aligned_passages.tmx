      <prop type="x-chinese-ref">老子 47.1 - 老子 47.3</prop>
      <prop type="x-translation-ref">老子 47.1</prop>
      <tuv xml:lang="zh-Hant">
        <seg>不出戶，知天下；不闚牖，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Without going outside his door, one understands (all that takes place) under the sky;</seg>
      </tuv>
    </tu>
