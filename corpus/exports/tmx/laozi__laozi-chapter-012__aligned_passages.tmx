      <prop type="x-translation-ref">老子 12.2</prop>
      <tuv xml:lang="zh-Hant">
        <seg>五音令人耳聾，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Music's five notes the ears as deaf can make;</seg>
      </tuv>
