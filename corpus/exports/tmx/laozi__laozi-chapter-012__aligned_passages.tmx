      <prop type="x-translation-ref">老子 12.1</prop>
      <tuv xml:lang="zh-Hant">
        <seg>五色令人目盲，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Colour's five hues from the eyes their sight will take;</seg>
      </tuv>
    </tu>
