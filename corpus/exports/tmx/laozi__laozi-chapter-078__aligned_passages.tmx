      <prop type="x-translation-ref">老子 78.2</prop>
      <tuv xml:lang="zh-Hant">
        <seg>弱之勝強，柔之勝剛，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>- for there is nothing (so effectual) for which it can be changed.</seg>
      </tuv>
    </tu>
