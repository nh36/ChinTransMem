      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 53.2</prop>
      <prop type="x-translation-ref">老子 53.2</prop>
      <tuv xml:lang="zh-Hant">
        <seg>大道甚夷，而民好徑。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>The great Dao (or way) is very level and easy; but people love the by-ways.</seg>
      </tuv>
    </tu>
