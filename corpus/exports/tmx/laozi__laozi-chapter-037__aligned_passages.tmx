      <prop type="x-translation-ref">老子 37.4 - 老子 37.5</prop>
      <tuv xml:lang="zh-Hant">
        <seg>夫亦將無欲。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Simplicity without a name Is free from all external aim.</seg>
      </tuv>
    </tu>
