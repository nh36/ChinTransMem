      <prop type="x-chinese-ref">老子 37.6 - 老子 37.7</prop>
      <prop type="x-translation-ref">老子 37.3</prop>
      <tuv xml:lang="zh-Hant">
        <seg>吾將鎮之以無名之樸。無名之樸，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>If this transformation became to me an object of desire, I would express the desire by the nameless simplicity.</seg>
      </tuv>
    </tu>
