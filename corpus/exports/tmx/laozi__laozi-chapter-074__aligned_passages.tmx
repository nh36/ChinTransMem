      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 74.7</prop>
      <prop type="x-translation-ref">老子 74.4</prop>
      <tuv xml:lang="zh-Hant">
        <seg>常有司殺者殺，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>There is always One who presides over the infliction death.</seg>
      </tuv>
    </tu>
