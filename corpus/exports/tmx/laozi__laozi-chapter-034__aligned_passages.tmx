      <prop type="x-translation-ref">老子 34.8</prop>
      <tuv xml:lang="zh-Hant">
        <seg>可名為大。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>- it may be named in the greatest things.</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-034__align-008">
