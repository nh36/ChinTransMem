      <prop type="x-chinese-ref">老子 34.11</prop>
      <prop type="x-translation-ref">老子 34.10</prop>
      <tuv xml:lang="zh-Hant">
        <seg>故能成其大。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>It is through his not making himself great that he can accomplish them.</seg>
      </tuv>
