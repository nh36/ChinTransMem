      <prop type="x-chinese-ref">老子 34.5</prop>
      <prop type="x-translation-ref">老子 34.5</prop>
      <tuv xml:lang="zh-Hant">
        <seg>衣養萬物而不為主，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>It clothes all things as with a garment, and makes no assumption of being their lord;</seg>
      </tuv>
    </tu>
