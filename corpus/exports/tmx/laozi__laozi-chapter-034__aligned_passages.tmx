      <prop type="x-chinese-ref">老子 34.4</prop>
      <prop type="x-translation-ref">老子 34.4</prop>
      <tuv xml:lang="zh-Hant">
        <seg>功成不名有。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>When its work is accomplished, it does not claim the name of having done it.</seg>
      </tuv>
    </tu>
