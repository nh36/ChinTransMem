      <prop type="x-translation-ref">老子 34.6</prop>
      <tuv xml:lang="zh-Hant">
        <seg>常無欲，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>- it may be named in the smallest things.</seg>
      </tuv>
    </tu>
