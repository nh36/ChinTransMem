      <prop type="x-chinese-ref">老子 34.10</prop>
      <prop type="x-translation-ref">老子 34.9</prop>
      <tuv xml:lang="zh-Hant">
        <seg>以其終不自為大，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Hence the sage is able (in the same way) to accomplish his great achievements.</seg>
      </tuv>
    </tu>
