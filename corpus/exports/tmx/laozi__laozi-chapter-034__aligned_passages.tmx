      <prop type="x-chinese-ref">老子 34.1 - 老子 34.2</prop>
      <prop type="x-translation-ref">老子 34.1 - 老子 34.2</prop>
      <tuv xml:lang="zh-Hant">
        <seg>大道氾兮，其可左右。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>All-pervading is the Great Dao! It may be found on the left hand and on the right.</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-034__align-002">
      <prop type="x-work-id">laozi</prop>
