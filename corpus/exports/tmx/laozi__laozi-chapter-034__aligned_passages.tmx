      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 34.3</prop>
      <prop type="x-translation-ref">老子 34.3</prop>
      <tuv xml:lang="zh-Hant">
        <seg>萬物恃之而生而不辭，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>All things depend on it for their production, which it gives to them, not one refusing obedience to it.</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-034__align-003">
      <prop type="x-work-id">laozi</prop>
