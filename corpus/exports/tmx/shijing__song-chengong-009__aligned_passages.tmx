      <prop type="x-alignment-granularity">stanza</prop>
      <prop type="x-is-coarse-alignment">false</prop>
      <prop type="x-alignment-type">exact_or_near_exact</prop>
      <prop type="x-confidence">0.99</prop>
      <prop type="x-source-segment-count">1</prop>
      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">詩經·頌·臣工之什·009.2</prop>
      <prop type="x-translation-ref">有客.2</prop>
      <tuv xml:lang="zh-Hant">
        <seg>有客宿宿，有客信信。言授之縶，以縶其馬。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>The noble guest will stay (but) a night or two!
The noble guest will stay (but) two nights or four!
Give him ropes,
To bind his horses.</seg>
      </tuv>
    </tu>
    <tu tuid="shijing__song-chengong-009__003__zhwikisource-20260530__legge-sbe-v3-1879">
