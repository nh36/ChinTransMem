      <prop type="x-alignment-granularity">stanza</prop>
      <prop type="x-is-coarse-alignment">false</prop>
      <prop type="x-alignment-type">exact_or_near_exact</prop>
      <prop type="x-confidence">0.99</prop>
      <prop type="x-source-segment-count">1</prop>
      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">詩經·頌·臣工之什·009.3</prop>
      <prop type="x-translation-ref">有客.3</prop>
      <tuv xml:lang="zh-Hant">
        <seg>薄言追之，左右綏之。既有淫威，降福孔夷。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>I will convoy him (with a parting feast);
I will comfort him in every possible way.
Adorned with such great dignity,
It is very natural that he should be blessed.</seg>
      </tuv>
    </tu>
