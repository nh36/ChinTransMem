      <prop type="x-translation-ref">老子 80.6</prop>
      <tuv xml:lang="zh-Hant">
        <seg>甘其食，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>They should think their (coarse) food sweet;</seg>
      </tuv>
    </tu>
