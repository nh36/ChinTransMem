      <prop type="x-chinese-ref">老子 80.6 - 老子 80.7</prop>
      <prop type="x-translation-ref">老子 80.4</prop>
      <tuv xml:lang="zh-Hant">
        <seg>雖有甲兵，無所陳之。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>though they had buff coats and sharp weapons, they should have no occasion to don or use them.</seg>
      </tuv>
    </tu>
