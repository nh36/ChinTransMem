      <prop type="x-chinese-ref">老子 80.8</prop>
      <prop type="x-translation-ref">老子 80.5</prop>
      <tuv xml:lang="zh-Hant">
        <seg>使人復結繩而用之，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>I would make the people return to the use of knotted cords (instead of the written characters).</seg>
      </tuv>
    </tu>
