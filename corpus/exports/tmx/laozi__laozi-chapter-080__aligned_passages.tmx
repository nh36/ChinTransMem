      <prop type="x-chinese-ref">老子 80.4 - 老子 80.5</prop>
      <prop type="x-translation-ref">老子 80.3</prop>
      <tuv xml:lang="zh-Hant">
        <seg>雖有舟輿，無所乘之；</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Though they had boats and carriages, they should have no occasion to ride in them;</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-080__align-004">
