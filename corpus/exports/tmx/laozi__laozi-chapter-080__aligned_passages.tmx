      <prop type="x-translation-ref">老子 80.7</prop>
      <tuv xml:lang="zh-Hant">
        <seg>美其服，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>their (plain) clothes beautiful;</seg>
      </tuv>
    </tu>
