      <prop type="x-translation-ref">老子 80.8</prop>
      <tuv xml:lang="zh-Hant">
        <seg>安其居，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>their (poor) dwellings places of rest;</seg>
      </tuv>
    </tu>
