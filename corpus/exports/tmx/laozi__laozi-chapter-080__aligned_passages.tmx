      <prop type="x-translation-ref">老子 80.9</prop>
      <tuv xml:lang="zh-Hant">
        <seg>樂其俗。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>and their common (simple) ways sources of enjoyment.</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-080__align-010">
