      <prop type="x-source-segment-count">1</prop>
      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">詩經·國風·邶風·006.1</prop>
      <prop type="x-translation-ref">Keih koo..1</prop>
      <tuv xml:lang="zh-Hant">
        <seg>擊鼓其鏜，踴躍用兵，土國城漕，我獨南行。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Hear the roll of our drums!
See how we leap about, using our weapons!
Those do the fieldwork in the State, or fortify Tsou,
While we alone march to the south.</seg>
      </tuv>
    </tu>
    <tu tuid="shijing__guofeng-beifeng-006__002__zhwikisource-20260530__legge-sheking-1871-ocr">
