      <prop type="x-is-coarse-alignment">false</prop>
      <prop type="x-alignment-type">exact_or_near_exact</prop>
      <prop type="x-confidence">0.99</prop>
      <prop type="x-source-segment-count">1</prop>
      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">詩經·國風·邶風·006.3</prop>
      <prop type="x-translation-ref">Keih koo..3</prop>
      <tuv xml:lang="zh-Hant">
        <seg>爰居爰處，爰喪其馬，于以求之，于林之下。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Here we stay; here we stop;
Here we lose our horses;
And we seek for them,
Among the trees of the forest.</seg>
      </tuv>
    </tu>
