      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">易經 7 judgment</prop>
      <prop type="x-translation-ref">易經 7 judgment</prop>
      <tuv xml:lang="zh-Hant">
        <seg>師，貞丈人吉，无咎。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Shi indicates how, in the case which it supposes, with firmness and correctness, and (a leader of) age and experience, there will be good fortune and no error.</seg>
      </tuv>
    </tu>
