      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 30.1 - 老子 30.2</prop>
      <prop type="x-translation-ref">老子 30.1</prop>
      <tuv xml:lang="zh-Hant">
        <seg>以道佐人主者，不以兵強天下。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>He who would assist a lord of men in harmony with the Dao will not assert his mastery in the kingdom by force of arms.</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-030__align-002">
      <prop type="x-work-id">laozi</prop>
      <prop type="x-section-id">laozi-chapter-030</prop>
      <prop type="x-section-unit">chapter</prop>
      <prop type="x-segment-type">sentence</prop>
      <prop type="x-alignment-granularity">grouped</prop>
      <prop type="x-is-coarse-alignment">false</prop>
      <prop type="x-alignment-type">exact_or_near_exact</prop>
      <prop type="x-confidence">1.00</prop>
      <prop type="x-source-segment-count">1</prop>
      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 30.3</prop>
      <prop type="x-translation-ref">老子 30.2</prop>
      <tuv xml:lang="zh-Hant">
        <seg>其事好還。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Such a course is sure to meet with its proper return.</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-030__align-003">
      <prop type="x-work-id">laozi</prop>
      <prop type="x-section-id">laozi-chapter-030</prop>
