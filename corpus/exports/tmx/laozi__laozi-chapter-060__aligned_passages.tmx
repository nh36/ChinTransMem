      <prop type="x-confidence">1.00</prop>
      <prop type="x-source-segment-count">1</prop>
      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 60.4</prop>
      <prop type="x-translation-ref">老子 60.4</prop>
      <tuv xml:lang="zh-Hant">
        <seg>非其神不傷人，聖人亦不傷人。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>It is not that it could not hurt men, but neither does the ruling sage hurt them.</seg>
      </tuv>
    </tu>
