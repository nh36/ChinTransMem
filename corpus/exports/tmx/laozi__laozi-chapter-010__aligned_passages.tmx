      <prop type="x-chinese-ref">老子 10.1</prop>
      <prop type="x-translation-ref">老子 10.1</prop>
      <tuv xml:lang="zh-Hant">
        <seg>載營魄抱一，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>When the intelligent and animal souls are held together in one embrace, they can be kept from separating.</seg>
      </tuv>
    </tu>
