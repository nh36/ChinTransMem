      <prop type="x-chinese-ref">老子 77.8</prop>
      <prop type="x-translation-ref">老子 77.8</prop>
      <tuv xml:lang="zh-Hant">
        <seg>唯有道者。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Only he who is in possession of the Dao!</seg>
      </tuv>
    </tu>
