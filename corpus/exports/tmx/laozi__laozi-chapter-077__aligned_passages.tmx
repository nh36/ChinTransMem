      <prop type="x-chinese-ref">老子 77.5</prop>
      <prop type="x-translation-ref">老子 77.5</prop>
      <tuv xml:lang="zh-Hant">
        <seg>人之道則不然，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>It is not so with the way of man.</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-077__align-006">
      <prop type="x-work-id">laozi</prop>
      <prop type="x-section-id">laozi-chapter-077</prop>
