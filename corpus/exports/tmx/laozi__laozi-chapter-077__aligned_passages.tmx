      <prop type="x-chinese-ref">老子 77.6</prop>
      <prop type="x-translation-ref">老子 77.6</prop>
      <tuv xml:lang="zh-Hant">
        <seg>損不足以奉有餘。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>He takes away from those who have not enough to add to his own superabundance.</seg>
      </tuv>
    </tu>
