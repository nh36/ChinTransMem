      <prop type="x-source-segment-count">1</prop>
      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 77.2</prop>
      <prop type="x-translation-ref">老子 77.2</prop>
      <tuv xml:lang="zh-Hant">
        <seg>高者抑之，下者舉之；</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>The (part of the bow) which was high is brought low, and what was low is raised up.</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-077__align-003">
      <prop type="x-work-id">laozi</prop>
      <prop type="x-section-id">laozi-chapter-077</prop>
