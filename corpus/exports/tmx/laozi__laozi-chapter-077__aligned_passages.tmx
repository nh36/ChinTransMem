      <prop type="x-chinese-ref">老子 77.7</prop>
      <prop type="x-translation-ref">老子 77.7</prop>
      <tuv xml:lang="zh-Hant">
        <seg>孰能有餘以奉天下？</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Who can take his own superabundance and therewith serve all under heaven?</seg>
      </tuv>
    </tu>
