      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 77.3</prop>
      <prop type="x-translation-ref">老子 77.3</prop>
      <tuv xml:lang="zh-Hant">
        <seg>有餘者損之，不足者補之。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>(So Heaven) diminishes where there is superabundance, and supplements where there is deficiency.</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-077__align-004">
      <prop type="x-work-id">laozi</prop>
