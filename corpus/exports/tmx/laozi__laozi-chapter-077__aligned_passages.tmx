      <prop type="x-chinese-ref">老子 77.1</prop>
      <prop type="x-translation-ref">老子 77.1</prop>
      <tuv xml:lang="zh-Hant">
        <seg>天之道，其猶張弓與？</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>May not the Way (or Dao) of Heaven be compared to the (method of) bending a bow?</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-077__align-002">
      <prop type="x-work-id">laozi</prop>
      <prop type="x-section-id">laozi-chapter-077</prop>
      <prop type="x-section-unit">chapter</prop>
