      <prop type="x-chinese-ref">老子 8.1</prop>
      <prop type="x-translation-ref">老子 8.1</prop>
      <tuv xml:lang="zh-Hant">
        <seg>上善若水。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>The highest excellence is like (that of) water.</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-008__align-002">
      <prop type="x-work-id">laozi</prop>
