      <prop type="x-translation-ref">老子 8.4</prop>
      <tuv xml:lang="zh-Hant">
        <seg>故幾於道。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>The excellence of a residence is in (the suitability of) the place;</seg>
      </tuv>
    </tu>
