      <prop type="x-chinese-ref">詩經·小雅·節南山之什·001.7</prop>
      <prop type="x-translation-ref">節南山.7</prop>
      <tuv xml:lang="zh-Hant">
        <seg>駕彼四牡，四牡項領。我瞻四方，蹙蹙靡所騁。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>I yoke my four steeds,
My four steeds, long-necked.
I look to the four quarters (of the kingdom);
Distress is everywhere; there is no place I can drive to.</seg>
      </tuv>
    </tu>
    <tu tuid="shijing__xiaoya-jienanshan-001__008__zhwikisource-20260530__legge-sbe-v3-1879">
      <prop type="x-work-id">shijing</prop>
