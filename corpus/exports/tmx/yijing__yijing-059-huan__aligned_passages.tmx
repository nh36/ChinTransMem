      <prop type="x-chinese-ref">易經 59 六三</prop>
      <prop type="x-translation-ref">易經 59 六三</prop>
      <tuv xml:lang="zh-Hant">
        <seg>六三：渙其躬，无悔。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>The third SIX, divided, shows its subject discarding any regard to his own person. There will be no occasion for repentance.</seg>
      </tuv>
    </tu>
