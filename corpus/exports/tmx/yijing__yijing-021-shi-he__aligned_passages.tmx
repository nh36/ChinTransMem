      <prop type="x-translation-ref">易經 21 judgment</prop>
      <tuv xml:lang="zh-Hant">
        <seg>噬嗑，亨。利用獄。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Shi He indicates successful progress (in the condition of things which it supposes). It will be advantageous to use legal constraints.</seg>
      </tuv>
    </tu>
