      <prop type="x-chinese-ref">易經 21 初九</prop>
      <prop type="x-translation-ref">易經 21 初九</prop>
      <tuv xml:lang="zh-Hant">
        <seg>初九：屨校滅趾，无咎。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>The first NINE, undivided, shows one with his feet in the stocks and deprived of his toes. There will be no error.</seg>
      </tuv>
