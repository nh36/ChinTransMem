      <prop type="x-chinese-ref">老子 67.11</prop>
      <prop type="x-translation-ref">老子 67.6 - 老子 67.7</prop>
      <tuv xml:lang="zh-Hant">
        <seg>三曰不敢為天下先。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>the second is economy; and the third is shrinking from taking precedence of others.</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-067__align-007">
