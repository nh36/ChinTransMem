      <prop type="x-translation-ref">老子 67.9</prop>
      <tuv xml:lang="zh-Hant">
        <seg>儉故能廣，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>with that economy I can be liberal;</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-067__align-009">
      <prop type="x-work-id">laozi</prop>
      <prop type="x-section-id">laozi-chapter-067</prop>
      <prop type="x-section-unit">chapter</prop>
