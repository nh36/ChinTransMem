      <prop type="x-chinese-ref">老子 67.8 - 老子 67.9</prop>
      <prop type="x-translation-ref">老子 67.4</prop>
      <tuv xml:lang="zh-Hant">
        <seg>持而保之。一曰慈，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>But I have three precious things which I prize and hold fast.</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-067__align-005">
      <prop type="x-work-id">laozi</prop>
      <prop type="x-section-id">laozi-chapter-067</prop>
