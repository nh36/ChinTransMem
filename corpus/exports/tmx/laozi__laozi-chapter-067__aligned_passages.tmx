      <prop type="x-chinese-ref">老子 67.22 - 老子 67.23</prop>
      <prop type="x-translation-ref">老子 67.16</prop>
      <tuv xml:lang="zh-Hant">
        <seg>天將救之，以慈衛之。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Heaven will save its possessor, by his (very) gentleness protecting him.</seg>
      </tuv>
