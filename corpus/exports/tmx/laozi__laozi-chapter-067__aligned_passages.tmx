      <prop type="x-translation-ref">老子 67.13</prop>
      <tuv xml:lang="zh-Hant">
        <seg>舍後且先，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>the hindmost place, and seek only to be foremost;</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-067__align-012">
