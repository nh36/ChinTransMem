      <prop type="x-chinese-ref">老子 67.6 - 老子 67.7</prop>
      <prop type="x-translation-ref">老子 67.3</prop>
      <tuv xml:lang="zh-Hant">
        <seg>久矣其細也夫！我有三寶，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>If it were like any other (system), for long would its smallness have been known!</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-067__align-004">
      <prop type="x-work-id">laozi</prop>
