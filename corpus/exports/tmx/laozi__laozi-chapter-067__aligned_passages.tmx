      <prop type="x-chinese-ref">老子 67.12</prop>
      <prop type="x-translation-ref">老子 67.8</prop>
      <tuv xml:lang="zh-Hant">
        <seg>慈故能勇，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>With that gentleness I can be bold;</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-067__align-008">
