      <prop type="x-chinese-ref">老子 67.10</prop>
      <prop type="x-translation-ref">老子 67.5</prop>
      <tuv xml:lang="zh-Hant">
        <seg>二曰儉，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>The first is gentleness;</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-067__align-006">
      <prop type="x-work-id">laozi</prop>
      <prop type="x-section-id">laozi-chapter-067</prop>
