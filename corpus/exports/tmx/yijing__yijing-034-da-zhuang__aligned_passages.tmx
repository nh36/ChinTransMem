      <prop type="x-source-segment-count">1</prop>
      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">易經 34 九二</prop>
      <prop type="x-translation-ref">易經 34 九二</prop>
      <tuv xml:lang="zh-Hant">
        <seg>九二：貞吉。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>The second NINE, undivided, shows that with firm correctness there will be good fortune.</seg>
      </tuv>
    </tu>
    <tu tuid="yijing-034-da-zhuang__alignment-004">
      <prop type="x-work-id">yijing</prop>
      <prop type="x-section-id">yijing-034-da-zhuang</prop>
