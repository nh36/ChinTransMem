      <prop type="x-chinese-ref">易經 34 judgment</prop>
      <prop type="x-translation-ref">易經 34 judgment</prop>
      <tuv xml:lang="zh-Hant">
        <seg>大壯，利貞。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Da Zhuang indicates that (under the conditions which it symbolises) it will be advantageous to be firm and correct.</seg>
      </tuv>
    </tu>
