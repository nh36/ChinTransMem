      <prop type="x-chinese-ref">老子 26.2</prop>
      <prop type="x-translation-ref">老子 26.2</prop>
      <tuv xml:lang="zh-Hant">
        <seg>靜為躁君。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>stillness, the ruler of movement.</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-026__align-003">
      <prop type="x-work-id">laozi</prop>
