      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 26.4</prop>
      <prop type="x-translation-ref">老子 26.4</prop>
      <tuv xml:lang="zh-Hant">
        <seg>奈何萬乘之主，而以身輕天下？</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>How should the lord of a myriad chariots carry himself lightly before the kingdom?</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-026__align-005">
      <prop type="x-work-id">laozi</prop>
