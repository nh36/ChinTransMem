      <prop type="x-chinese-ref">老子 26.1</prop>
      <prop type="x-translation-ref">老子 26.1</prop>
      <tuv xml:lang="zh-Hant">
        <seg>重為輕根，靜為躁君。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Gravity is the root of lightness; stillness, the ruler of movement.</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-026__align-002">
      <prop type="x-work-id">laozi</prop>
      <prop type="x-section-id">laozi-chapter-026</prop>
      <prop type="x-section-unit">chapter</prop>
      <prop type="x-segment-type">sentence</prop>
