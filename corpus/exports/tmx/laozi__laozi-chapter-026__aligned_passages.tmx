      <prop type="x-translation-ref">老子 26.1</prop>
      <tuv xml:lang="zh-Hant">
        <seg>重為輕根，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Gravity is the root of lightness;</seg>
      </tuv>
    </tu>
