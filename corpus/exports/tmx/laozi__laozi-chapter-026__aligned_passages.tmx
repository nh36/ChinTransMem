      <prop type="x-source-segment-count">1</prop>
      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 26.2</prop>
      <prop type="x-translation-ref">老子 26.2</prop>
      <tuv xml:lang="zh-Hant">
        <seg>是以聖人終日行不離輜重。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Therefore a wise prince, marching the whole day, does not go far from his baggage waggons.</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-026__align-003">
      <prop type="x-work-id">laozi</prop>
      <prop type="x-section-id">laozi-chapter-026</prop>
      <prop type="x-section-unit">chapter</prop>
      <prop type="x-segment-type">sentence</prop>
      <prop type="x-alignment-granularity">sentence</prop>
      <prop type="x-is-coarse-alignment">false</prop>
