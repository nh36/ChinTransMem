      <prop type="x-translation-ref">老子 42.10</prop>
      <tuv xml:lang="zh-Hant">
        <seg>強梁者不得其死，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>The violent and strong do not die their natural death.</seg>
