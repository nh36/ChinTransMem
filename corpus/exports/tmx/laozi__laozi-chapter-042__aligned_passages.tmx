      <tuv xml:lang="zh-Hant">
        <seg>二生三，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Three produced All things.</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-042__align-004">
      <prop type="x-work-id">laozi</prop>
      <prop type="x-section-id">laozi-chapter-042</prop>
      <prop type="x-section-unit">chapter</prop>
