      <prop type="x-translation-ref">老子 42.9</prop>
      <tuv xml:lang="zh-Hant">
        <seg>我亦教之。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>What other men (thus) teach, I also teach.</seg>
      </tuv>
    </tu>
