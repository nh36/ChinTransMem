      <prop type="x-chinese-ref">老子 42.10</prop>
      <prop type="x-translation-ref">老子 42.7</prop>
      <tuv xml:lang="zh-Hant">
        <seg>故物或損之而益，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>and yet these are the designations which kings and princes use for themselves.</seg>
      </tuv>
    </tu>
