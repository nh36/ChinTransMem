      <prop type="x-translation-ref">老子 42.11</prop>
      <tuv xml:lang="zh-Hant">
        <seg>吾將以為教父。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>I will make this the basis of my teaching.</seg>
