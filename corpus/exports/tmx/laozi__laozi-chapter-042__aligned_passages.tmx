      <prop type="x-chinese-ref">老子 42.11 - 老子 42.12</prop>
      <prop type="x-translation-ref">老子 42.8</prop>
      <tuv xml:lang="zh-Hant">
        <seg>或益之而損。人之所教，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>So it is that some things are increased by being diminished, and others are diminished by being increased.</seg>
      </tuv>
    </tu>
