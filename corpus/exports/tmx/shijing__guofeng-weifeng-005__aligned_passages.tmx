      <prop type="x-alignment-granularity">stanza</prop>
      <prop type="x-is-coarse-alignment">false</prop>
      <prop type="x-alignment-type">exact_or_near_exact</prop>
      <prop type="x-confidence">0.99</prop>
      <prop type="x-source-segment-count">1</prop>
      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">詩經·國風·衛風·005.2</prop>
      <prop type="x-translation-ref">竹竿.2</prop>
      <tuv xml:lang="zh-Hant">
        <seg>泉源在左，淇水在右，女子有行，遠兄弟父母。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>The Ts'euen-yuen is on the left,
And the waters of the K'e are on the right.
But when a young lady goes away,
She leaves her brothers and parents.</seg>
      </tuv>
    </tu>
    <tu tuid="shijing__guofeng-weifeng-005__003__zhwikisource-20260530__legge-sheking-1871-ocr">
