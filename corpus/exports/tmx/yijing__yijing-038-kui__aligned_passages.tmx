      <prop type="x-chinese-ref">易經 38 judgment</prop>
      <prop type="x-translation-ref">易經 38 judgment</prop>
      <tuv xml:lang="zh-Hant">
        <seg>睽，小事吉。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Kui indicates that, (notwithstanding the condition of things which it denotes), in small matters there will (still) be good success.</seg>
      </tuv>
    </tu>
    <tu tuid="yijing-038-kui__alignment-002">
      <prop type="x-work-id">yijing</prop>
