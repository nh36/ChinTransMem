      <prop type="x-chinese-ref">老子 69.6 - 老子 69.7</prop>
      <prop type="x-translation-ref">老子 69.7 - 老子 69.8</prop>
      <tuv xml:lang="zh-Hant">
        <seg>執無兵。禍莫大於輕敵，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>advancing against the enemy where there is no enemy. There is no calamity greater than lightly engaging in war.</seg>
      </tuv>
    </tu>
