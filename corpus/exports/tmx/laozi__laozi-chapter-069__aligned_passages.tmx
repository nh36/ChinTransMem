      <prop type="x-chinese-ref">老子 69.4</prop>
      <prop type="x-translation-ref">老子 69.5</prop>
      <tuv xml:lang="zh-Hant">
        <seg>〉攘無臂，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>baring the arms (to fight) where there are no arms to bare;</seg>
      </tuv>
    </tu>
