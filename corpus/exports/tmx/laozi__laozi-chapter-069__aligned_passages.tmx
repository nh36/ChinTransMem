      <prop type="x-translation-ref">老子 69.6</prop>
      <tuv xml:lang="zh-Hant">
        <seg>扔無敵，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>grasping the weapon where there is no weapon to grasp;</seg>
      </tuv>
    </tu>
