      <prop type="x-chinese-ref">老子 69.8</prop>
      <prop type="x-translation-ref">老子 69.9</prop>
      <tuv xml:lang="zh-Hant">
        <seg>輕敵幾喪吾寶。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>To do that is near losing (the gentleness) which is so precious.</seg>
      </tuv>
    </tu>
