      <prop type="x-chinese-ref">易經 22 初九</prop>
      <prop type="x-translation-ref">易經 22 初九</prop>
      <tuv xml:lang="zh-Hant">
        <seg>初九：賁其趾，舍車而徒。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>The first NINE, undivided, shows one adorning (the way of) his feet. He can discard a carriage and walk on foot.</seg>
      </tuv>
    </tu>
