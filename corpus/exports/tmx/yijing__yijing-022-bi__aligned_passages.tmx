      <prop type="x-chinese-ref">易經 22 judgment</prop>
      <prop type="x-translation-ref">易經 22 judgment</prop>
      <tuv xml:lang="zh-Hant">
        <seg>賁，亨。小利有攸往。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Bi indicates that there should be free course (in what it denotes). There will be little advantage (however) if it be allowed to advance (and take the lead).</seg>
      </tuv>
    </tu>
