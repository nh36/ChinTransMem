      <prop type="x-translation-ref">老子 24.6</prop>
      <tuv xml:lang="zh-Hant">
        <seg>自矜者不長。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>he who is self- conceited has no superiority allowed to him.</seg>
      </tuv>
    </tu>
