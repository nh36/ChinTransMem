      <prop type="x-translation-ref">老子 24.4</prop>
      <tuv xml:lang="zh-Hant">
        <seg>自是者不彰，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>he who asserts his own views is not distinguished;</seg>
      </tuv>
    </tu>
