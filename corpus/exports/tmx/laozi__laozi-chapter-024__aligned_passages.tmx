      <prop type="x-translation-ref">老子 24.3</prop>
      <tuv xml:lang="zh-Hant">
        <seg>自見者不明，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>(So), he who displays himself does not shine;</seg>
      </tuv>
    </tu>
