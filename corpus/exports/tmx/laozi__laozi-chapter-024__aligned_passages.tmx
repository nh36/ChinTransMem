      <prop type="x-translation-ref">老子 24.2</prop>
      <tuv xml:lang="zh-Hant">
        <seg>跨者不行，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>he who stretches his legs does not walk (easily).</seg>
      </tuv>
    </tu>
