      <prop type="x-chinese-ref">老子 24.1</prop>
      <prop type="x-translation-ref">老子 24.1</prop>
      <tuv xml:lang="zh-Hant">
        <seg>企者不立，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>He who stands on his tiptoes does not stand firm;</seg>
      </tuv>
    </tu>
