      <prop type="x-translation-ref">老子 24.5</prop>
      <tuv xml:lang="zh-Hant">
        <seg>自伐者無功，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>he who vaunts himself does not find his merit acknowledged;</seg>
      </tuv>
    </tu>
