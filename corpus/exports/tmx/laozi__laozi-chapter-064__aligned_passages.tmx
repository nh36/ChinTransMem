      <prop type="x-chinese-ref">老子 64.12</prop>
      <prop type="x-translation-ref">老子 64.10</prop>
      <tuv xml:lang="zh-Hant">
        <seg>始於足下。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>He who acts (with an ulterior purpose) does harm;</seg>
      </tuv>
    </tu>
