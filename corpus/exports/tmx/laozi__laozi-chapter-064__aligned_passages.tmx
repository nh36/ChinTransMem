      <prop type="x-translation-ref">老子 64.6</prop>
      <tuv xml:lang="zh-Hant">
        <seg>合抱之木，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>order should be secured before disorder has begun.</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-064__align-007">
      <prop type="x-work-id">laozi</prop>
      <prop type="x-section-id">laozi-chapter-064</prop>
