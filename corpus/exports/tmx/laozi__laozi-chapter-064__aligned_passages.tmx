      <prop type="x-confidence">1.00</prop>
      <prop type="x-source-segment-count">2</prop>
      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 64.13 - 老子 64.14</prop>
      <prop type="x-translation-ref">老子 64.11</prop>
      <tuv xml:lang="zh-Hant">
        <seg>為者敗之，執者失之。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>he who takes hold of a thing (in the same way) loses his hold.</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-064__align-011">
      <prop type="x-work-id">laozi</prop>
      <prop type="x-section-id">laozi-chapter-064</prop>
      <prop type="x-section-unit">chapter</prop>
      <prop type="x-segment-type">sentence</prop>
      <prop type="x-alignment-granularity">grouped</prop>
      <prop type="x-is-coarse-alignment">false</prop>
      <prop type="x-alignment-type">exact_or_near_exact</prop>
      <prop type="x-confidence">1.00</prop>
      <prop type="x-source-segment-count">2</prop>
      <prop type="x-target-segment-count">2</prop>
      <prop type="x-chinese-ref">老子 64.15 - 老子 64.16</prop>
      <prop type="x-translation-ref">老子 64.12 - 老子 64.13</prop>
      <tuv xml:lang="zh-Hant">
        <seg>是以聖人無為故無敗，無執故無失。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>The sage does not act (so), and therefore does no harm; he does not lay hold (so), and therefore does not lose his bold.</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-064__align-012">
      <prop type="x-work-id">laozi</prop>
