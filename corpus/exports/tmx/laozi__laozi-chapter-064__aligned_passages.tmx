      <prop type="x-translation-ref">老子 64.7</prop>
      <tuv xml:lang="zh-Hant">
        <seg>生於毫末；</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>The tree which fills the arms grew from the tiniest sprout;</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-064__align-008">
