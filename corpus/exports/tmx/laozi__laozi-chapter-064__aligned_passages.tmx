      <prop type="x-chinese-ref">老子 64.4</prop>
      <prop type="x-translation-ref">老子 64.3</prop>
      <tuv xml:lang="zh-Hant">
        <seg>其微易散。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>that which is brittle is easily broken;</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-064__align-004">
      <prop type="x-work-id">laozi</prop>
