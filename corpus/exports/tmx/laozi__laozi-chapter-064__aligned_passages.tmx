      <prop type="x-chinese-ref">老子 64.6</prop>
      <prop type="x-translation-ref">老子 64.5</prop>
      <tuv xml:lang="zh-Hant">
        <seg>治之於未亂。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Action should be taken before a thing has made its appearance;</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-064__align-006">
      <prop type="x-work-id">laozi</prop>
      <prop type="x-section-id">laozi-chapter-064</prop>
