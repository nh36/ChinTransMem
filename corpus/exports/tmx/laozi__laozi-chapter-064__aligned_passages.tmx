      <prop type="x-chinese-ref">老子 64.1</prop>
      <prop type="x-translation-ref">老子 64.1</prop>
      <tuv xml:lang="zh-Hant">
        <seg>其安易持，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>That which is at rest is easily kept hold of;</seg>
      </tuv>
    </tu>
