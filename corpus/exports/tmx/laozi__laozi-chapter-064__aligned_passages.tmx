      <prop type="x-translation-ref">老子 64.4</prop>
      <tuv xml:lang="zh-Hant">
        <seg>為之於未有，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>that which is very small is easily dispersed.</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-064__align-005">
      <prop type="x-work-id">laozi</prop>
      <prop type="x-section-id">laozi-chapter-064</prop>
