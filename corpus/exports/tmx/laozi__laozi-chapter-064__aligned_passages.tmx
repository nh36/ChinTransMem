      <prop type="x-chinese-ref">老子 64.2 - 老子 64.3</prop>
      <prop type="x-translation-ref">老子 64.2</prop>
      <tuv xml:lang="zh-Hant">
        <seg>其未兆易謀。其脆易泮，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>before a thing has given indications of its presence, it is easy to take measures against it;</seg>
      </tuv>
    </tu>
