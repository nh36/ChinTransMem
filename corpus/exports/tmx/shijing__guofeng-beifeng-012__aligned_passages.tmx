      <prop type="x-source-segment-count">1</prop>
      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">詩經·國風·邶風·012.1</prop>
      <prop type="x-translation-ref">Maou-Vewt.1</prop>
      <tuv xml:lang="zh-Hant">
        <seg>旄丘之葛兮，何誕之節兮，叔兮伯兮，何多日也。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>The dolichos on that high and sloping mound; —
How wide apart are [now] its joints!
O ye uncles,
Why have ye delayed these many days?</seg>
      </tuv>
    </tu>
    <tu tuid="shijing__guofeng-beifeng-012__002__zhwikisource-20260530__legge-sheking-1871-ocr">
      <prop type="x-work-id">shijing</prop>
      <prop type="x-section-id">guofeng-beifeng-012</prop>
