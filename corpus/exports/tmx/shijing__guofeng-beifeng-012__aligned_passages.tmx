      <prop type="x-segment-type">stanza</prop>
      <prop type="x-alignment-granularity">stanza</prop>
      <prop type="x-is-coarse-alignment">false</prop>
      <prop type="x-alignment-type">exact_or_near_exact</prop>
      <prop type="x-confidence">0.99</prop>
      <prop type="x-source-segment-count">1</prop>
      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">詩經·國風·邶風·012.3</prop>
      <prop type="x-translation-ref">Maou-Vewt.3</prop>
      <tuv xml:lang="zh-Hant">
        <seg>狐裘蒙戎，匪車不東，叔兮伯兮，靡所與同。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Our fox-furs are frayed and worn.
Came our carriages not eastwards?
O ye uncles,
You do not sympathize with us.</seg>
      </tuv>
    </tu>
    <tu tuid="shijing__guofeng-beifeng-012__004__zhwikisource-20260530__legge-sheking-1871-ocr">
      <prop type="x-work-id">shijing</prop>
