      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 14.7 - 老子 14.8</prop>
      <prop type="x-translation-ref">老子 14.3</prop>
      <tuv xml:lang="zh-Hant">
        <seg>其上不皦，其下不昧。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Its upper part is not bright, and its lower part is not obscure.</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-014__align-004">
      <prop type="x-work-id">laozi</prop>
      <prop type="x-section-id">laozi-chapter-014</prop>
      <prop type="x-section-unit">chapter</prop>
      <prop type="x-segment-type">sentence</prop>
      <prop type="x-alignment-granularity">grouped</prop>
      <prop type="x-is-coarse-alignment">false</prop>
      <prop type="x-alignment-type">exact_or_near_exact</prop>
      <prop type="x-confidence">1.00</prop>
      <prop type="x-source-segment-count">2</prop>
      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 14.9 - 老子 14.10</prop>
      <prop type="x-translation-ref">老子 14.4</prop>
      <tuv xml:lang="zh-Hant">
        <seg>繩繩不可名，復歸於無物。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Ceaseless in its action, it yet cannot be named, and then it again returns and becomes nothing.</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-014__align-005">
      <prop type="x-work-id">laozi</prop>
