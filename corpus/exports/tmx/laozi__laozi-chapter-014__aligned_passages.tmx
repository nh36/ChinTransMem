      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 14.14</prop>
      <prop type="x-translation-ref">老子 14.7</prop>
      <tuv xml:lang="zh-Hant">
        <seg>迎之不見其首，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>We meet it and do not see its Front;</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-014__align-008">
      <prop type="x-work-id">laozi</prop>
