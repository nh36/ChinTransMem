      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 14.13</prop>
      <prop type="x-translation-ref">老子 14.6</prop>
      <tuv xml:lang="zh-Hant">
        <seg>是謂惚恍。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>this is called the Fleeting and Indeterminable.</seg>
      </tuv>
    </tu>
