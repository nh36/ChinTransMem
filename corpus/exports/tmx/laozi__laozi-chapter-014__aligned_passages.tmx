      <prop type="x-source-segment-count">1</prop>
      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 14.15</prop>
      <prop type="x-translation-ref">老子 14.8</prop>
      <tuv xml:lang="zh-Hant">
        <seg>隨之不見其後。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>we follow it, and do not see its Back.</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-014__align-009">
