      <prop type="x-translation-ref">老子 73.3</prop>
      <tuv xml:lang="zh-Hant">
        <seg>此兩者，或利或害。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>But</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-073__align-004">
      <prop type="x-work-id">laozi</prop>
      <prop type="x-section-id">laozi-chapter-073</prop>
