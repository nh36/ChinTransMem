      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 73.8</prop>
      <prop type="x-translation-ref">老子 73.8</prop>
      <tuv xml:lang="zh-Hant">
        <seg>繟然而善謀。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Its demonstrations are quiet, and yet its plans are skilful and effective.</seg>
      </tuv>
    </tu>
