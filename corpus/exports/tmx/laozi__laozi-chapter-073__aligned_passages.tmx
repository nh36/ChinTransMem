      <prop type="x-chinese-ref">老子 73.9</prop>
      <prop type="x-translation-ref">老子 73.9</prop>
      <tuv xml:lang="zh-Hant">
        <seg>天網恢恢，疏而不失。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>The meshes of the net of Heaven are large; far apart, but letting nothing escape.</seg>
      </tuv>
