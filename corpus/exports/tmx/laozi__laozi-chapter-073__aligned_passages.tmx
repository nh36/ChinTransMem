      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 73.7</prop>
      <prop type="x-translation-ref">老子 73.7</prop>
      <tuv xml:lang="zh-Hant">
        <seg>不召而自來，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>It is the way of Heaven not to strive, and yet it skilfully overcomes; not to speak, and yet it is skilful in (obtaining a reply); does not call, and yet men come to it of themselves.</seg>
      </tuv>
    </tu>
