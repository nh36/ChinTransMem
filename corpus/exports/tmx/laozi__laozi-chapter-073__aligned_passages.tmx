      <prop type="x-chinese-ref">老子 73.5</prop>
      <prop type="x-translation-ref">老子 73.5</prop>
      <tuv xml:lang="zh-Hant">
        <seg>天之道，不爭而善勝，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Who the cause shall truly scan?</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-073__align-006">
      <prop type="x-work-id">laozi</prop>
      <prop type="x-section-id">laozi-chapter-073</prop>
