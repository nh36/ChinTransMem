      <prop type="x-chinese-ref">老子 73.6</prop>
      <prop type="x-translation-ref">老子 73.6</prop>
      <tuv xml:lang="zh-Hant">
        <seg>不言而善應，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>On this account the sage feels a difficulty (as to what to do in the former case).</seg>
      </tuv>
    </tu>
