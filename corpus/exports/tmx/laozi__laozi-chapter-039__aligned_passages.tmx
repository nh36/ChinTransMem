      <prop type="x-chinese-ref">老子 39.1 - 老子 39.2</prop>
      <prop type="x-translation-ref">老子 39.1</prop>
      <tuv xml:lang="zh-Hant">
        <seg>昔之得一者，天得一以清，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>The things which from of old have got the One (the Dao) are -</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-039__align-002">
      <prop type="x-work-id">laozi</prop>
      <prop type="x-section-id">laozi-chapter-039</prop>
      <prop type="x-section-unit">chapter</prop>
      <prop type="x-segment-type">sentence</prop>
