      <prop type="x-translation-ref">老子 39.7 - 老子 39.8</prop>
      <tuv xml:lang="zh-Hant">
        <seg>侯王得一以為天下貞。</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Princes and kings who from it get The model which to all they give.</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-039__align-006">
      <prop type="x-work-id">laozi</prop>
      <prop type="x-section-id">laozi-chapter-039</prop>
      <prop type="x-section-unit">chapter</prop>
      <prop type="x-segment-type">sentence</prop>
