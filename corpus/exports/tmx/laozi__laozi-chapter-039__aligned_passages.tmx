      <prop type="x-target-segment-count">1</prop>
      <prop type="x-chinese-ref">老子 39.3</prop>
      <prop type="x-translation-ref">老子 39.2</prop>
      <tuv xml:lang="zh-Hant">
        <seg>地得一以寧，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Heaven which by it is bright and pure;</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-039__align-003">
      <prop type="x-work-id">laozi</prop>
      <prop type="x-section-id">laozi-chapter-039</prop>
