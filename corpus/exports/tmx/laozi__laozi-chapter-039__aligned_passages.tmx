      <prop type="x-chinese-ref">老子 39.5 - 老子 39.6</prop>
      <prop type="x-translation-ref">老子 39.4 - 老子 39.6</prop>
      <tuv xml:lang="zh-Hant">
        <seg>谷得一以盈，萬物得一以生，</seg>
      </tuv>
      <tuv xml:lang="en">
        <seg>Spirits with powers by it supplied; Valleys kept full throughout their void All creatures which through it do live</seg>
      </tuv>
    </tu>
    <tu tuid="laozi-chapter-039__align-005">
      <prop type="x-work-id">laozi</prop>
